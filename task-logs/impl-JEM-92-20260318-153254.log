elf.detail_threads.len();\\n307:         if len > 0 && self.detail_thread_selected < len - 1 {\\n308:             self.detail_thread_selected += 1;\\n309:         }\\n310:     }\\n311: \\n312:     pub fn thread_move_up(&mut self) {\\n313:         if self.detail_thread_selected > 0 {\\n314:             self.detail_thread_selected -= 1;\\n315:         }\\n316:     }\\n317: \\n318:     pub fn selected_thread(&self) -> Option<&ThreadSummary> {\\n319:         if self.detail_section == DetailSection::Threads {\\n320:             self.detail_threads.get(self.detail_thread_selected)\\n321:         } else {\\n322:             None\\n323:         }\\n324:     }\\n325: \\n326:     pub fn focus_threads(&mut self) {\\n327:         if !self.detail_threads.is_empty() {\\n328:             self.detail_section = DetailSection::Threads;\\n329:         }\\n330:     }\\n331: \\n332:     pub fn focus_body(&mut self) {\\n333:         self.detail_section = DetailSection::Body;\\n334:     }\\n335: \\n336:     pub fn show_workspace_picker(&mut self, workspaces: Vec<String>) {\\n337:         if !workspaces.is_empty() {\\n338:             self.workspace_picker = Some(WorkspacePicker::new(workspaces));\\n339:         }\\n340:     }\\n341: \\n342:     pub fn cancel_workspace_picker(&mut self) {\\n343:         self.workspace_picker = None;\\n344:     }\\n345: \\n346:     pub async fn refresh(&mut self) {\\n347:         self.refreshing = true;\\n348:         let selected_id = self.selected_issue().map(|i| i.identifier.clone());\\n349:         match self.api.fetch_my_issues().await {\\n350:             Ok(issues) => {\\n351:                 self.issues = issues;\\n352:                 if let Some(id) = selected_id {\\n353:                     let new_index = self\\n354:                         .filtered_issues()\\n355:                         .iter()\\n356:                         .position(|i| i.identifier == id);\\n357:                     self.selected = new_index.unwrap_or(0);\\n358:                 }\\n359:             }\\n360:             Err(_) => {}\\n361:         }\\n362:         self.refreshing = false;\\n363:     }\\n364: }\\n365: \\n366: #[cfg(test)]\\n367: mod tests {\\n368:     use super::*;\\n369:     use crate::api::fake::FakeLinearApi;\\n370: \\n371:     fn app_with_issues() -> App<FakeLinearApi> {\\n372:         let mut app = App::new(FakeLinearApi::new());\\n373:         app.issues = vec![\\n374:             Issue {\\n375:                 id: \\\"1\\\".into(),\\n376:                 identifier: \\\"JEM-1\\\".into(),\\n377:                 title: \\\"Alpha task\\\".into(),\\n378:                 state: None,\\n379:                 priority: Some(2.0),\\n380:                 project: None,\\n381:                 description: None,\\n382:                 assignee: None,\\n383:                 labels: None,\\n384:                 comments: None,\\n385:             },\\n386:             Issue {\\n387:                 id: \\\"2\\\".into(),\\n388:                 identifier: \\\"JEM-2\\\".into(),\\n389:                 title: \\\"Beta task\\\".into(),\\n390:                 state: None,\\n391:                 priority: Some(3.0),\\n392:                 project: None,\\n393:                 description: None,\\n394:                 assignee: None,\\n395:                 labels: None,\\n396:                 comments: None,\\n397:             },\\n398:             Issue {\\n399:                 id: \\\"3\\\".into(),\\n400:                 identifier: \\\"JEM-3\\\".into(),\\n401:                 title: \\\"Gamma task\\\".into(),\\n402:                 state: None,\\n403:                 priority: None,\\n404:                 project: None,\\n405:                 description: None,\\n406:                 assignee: None,\\n407:                 labels: None,\\n408:                 comments: None,\\n409:             },\\n410:         ];\\n411:         app\\n412:     }\\n413: \\n414:     #[test]\\n415:     fn navigation_wraps_at_bounds() {\\n416:         let mut app = app_with_issues();\\n417:         assert_eq!(app.selected, 0);\\n418: \\n419:         app.move_down();\\n420:         assert_eq!(app.selected, 1);\\n421:         app.move_down();\\n422:         assert_eq!(app.selected, 2);\\n423:         app.move_down(); // at bottom, stays\\n424:         assert_eq!(app.selected, 2);\\n425: \\n426:         app.move_up();\\n427:         assert_eq!(app.selected, 1);\\n428:         app.top();\\n429:         assert_eq!(app.selected, 0);\\n430:         app.move_up(); // at top, stays\\n431:         assert_eq!(app.selected, 0);\\n432:     }\\n433: \\n434:     #[test]\\n435:     fn bottom_goes_to_last() {\\n436:         let mut app = app_with_issues();\\n437:         app.bottom();\\n438:         assert_eq!(app.selected, 2);\\n439:     }\\n440: \\n441:     #[test]\\n442:     fn filter_narrows_results() {\\n443:         let mut app = app_with_issues();\\n444:         app.filter = Some((SortColumn::Title, \\\"beta\\\".into()));\\n445:         let filtered = app.filtered_issues();\\n446:         assert_eq!(filtered.len(), 1);\\n447:         assert_eq!(filtered[0].identifier, \\\"JEM-2\\\");\\n448:     }\\n449: \\n450:     #[test]\\n451:     fn filter_is_case_insensitive() {\\n452:         let mut app = app_with_issues();\\n453:         app.filter = Some((SortColumn::Title, \\\"ALPHA\\\".into()));\\n454:         assert_eq!(app.filtered_issues().len(), 1);\\n455:     }\\n456: \\n457:     #[test]\\n458:     fn apply_empty_filter_clears() {\\n459:         let mut app = app_with_issues();\\n460:         app.start_filter();\\n461:         app.apply_filter();\\n462:         assert!(app.filter.is_none());\\n463:         assert!(!app.filtering);\\n464:     }\\n465: \\n466:     #[test]\\n467:     fn apply_filter_sets_and_resets_cursor() {\\n468:         let mut app = app_with_issues();\\n469:         app.selected = 2;\\n470:         app.start_filter();\\n471:         app.filter_input = \\\"gamma\\\".into();\\n472:         app.apply_filter()