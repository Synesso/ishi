:             Constraint::Min(30),\\n73:             Constraint::Length(20),\\n74:             Constraint::Length(15),\\n75:             Constraint::Length(10),\\n76:         ],\\n77:     )\\n78:     .header(header)\\n79:     .block(Block::default().borders(Borders::ALL).title(title))\\n80:     .row_highlight_style(Style::default().add_modifier(Modifier::REVERSED));\\n81: \\n82:     let mut table_state = TableState::default();\\n83:     if !issues.is_empty() {\\n84:         table_state.select(Some(app.selected));\\n85:     }\\n86: \\n87:     frame.render_stateful_widget(table, chunks[0], &mut table_state);\\n88: \\n89:     let key_style = Style::default().fg(Color::Yellow).add_modifier(Modifier::BOLD);\\n90: \\n91:     let column_hints = vec![\\n92:         Span::styled(\\\"i\\\", key_style),\\n93:         Span::raw(\\\"d  \\\"),\\n94:         Span::styled(\\\"t\\\", key_style),\\n95:         Span::raw(\\\"itle  \\\"),\\n96:         Span::styled(\\\"p\\\", key_style),\\n97:         Span::raw(\\\"roject  \\\"),\\n98:         Span::styled(\\\"s\\\", key_style),\\n99:         Span::raw(\\\"tatus  p\\\"),\\n100:         Span::styled(\\\"r\\\", key_style),\\n101:         Span::raw(\\\"iority\\\"),\\n102:     ];\\n103: \\n104:     // Status bar\\n105:     if app.refreshing {\\n106:         let line = Line::from(Span::styled(\\n107:             \\\"Refreshing...\\\",\\n108:             Style::default().fg(Color::Yellow),\\n109:         ));\\n110:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n111:     } else if app.awaiting_quit {\\n112:         let line = Line::from(vec![\\n113:             Span::raw(\\\"Press \\\"),\\n114:             Span::styled(\\\"q\\\", key_style),\\n115:             Span::raw(\\\" again to quit\\\"),\\n116:         ]);\\n117:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n118:     } else if app.awaiting_sort {\\n119:         let mut spans = vec![Span::raw(\\\"sort by: \\\")];\\n120:         spans.extend(column_hints);\\n121:         frame.render_widget(Paragraph::new(Line::from(spans)), chunks[1]);\\n122:     } else if app.awaiting_filter {\\n123:         let mut spans = vec![Span::raw(\\\"filter by: \\\")];\\n124:         spans.extend(column_hints);\\n125:         frame.render_widget(Paragraph::new(Line::from(spans)), chunks[1]);\\n126:     } else if app.filtering {\\n127:         let prefix = match app.filter_column {\\n128:             Some(ref col) => format!(\\\"[{}] /\\\", col.label()),\\n129:             None => \\\"/\\\".into(),\\n130:         };\\n131:         let line = Line::from(vec![\\n132:             Span::raw(prefix),\\n133:             Span::styled(&app.filter_input, Style::default().add_modifier(Modifier::BOLD)),\\n134:             Span::raw(\\\"▏\\\"),\\n135:         ]);\\n136:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n137:     } else if app.searching {\\n138:         let line = Line::from(vec![\\n139:             Span::raw(\\\"/\\\"),\\n140:             Span::styled(&app.search_input, Style::default().add_modifier(Modifier::BOLD)),\\n141:             Span::raw(\\\"▏\\\"),\\n142:         ]);\\n143:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n144:     } else if app.search.is_some() || app.filter.is_some() {\\n145:         let line = Line::from(vec![\\n146:             Span::raw(\\\"Active — press Esc to clear\\\"),\\n147:         ]);\\n148:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n149:     }\\n150: }\\n151: \\n152: fn highlight_match<'a>(text: &'a str, query: Option<&str>, base_style: Style) -> Vec<Span<'a>> {\\n153:     let query = match query {\\n154:         Some(q) if !q.is_empty() => q,\\n155:         _ => return vec![Span::styled(text, base_style)],\\n156:     };\\n157:     let lower_text = text.to_lowercase();\\n158:     let lower_query = query.to_lowercase();\\n159:     let mut spans = Vec::new();\\n160:     let mut start = 0;\\n161:     while let Some(pos) = lower_text[start..].find(&lower_query) {\\n162:         let abs_pos = start + pos;\\n163:         if abs_pos > start {\\n164:             spans.push(Span::styled(&text[start..abs_pos], base_style));\\n165:         }\\n166:         spans.push(Span::styled(\\n167:             &text[abs_pos..abs_pos + query.len()],\\n168:             base_style.add_modifier(Modifier::BOLD),\\n169:         ));\\n170:         start = abs_pos + query.len();\\n171:     }\\n172:     if start < text.len() {\\n173:         spans.push(Span::styled(&text[start..], base_style));\\n174:     }\\n175:     if spans.is_empty() {\\n176:         spans.push(Span::styled(text, base_style));\\n177:     }\\n178:     spans\\n179: }\\n180: \\n181: fn status_style(status: &str) -> Style {\\n182:     match status {\\n183:         \\\"In Progress\\\" => Style::default().fg(Color::Yellow),\\n184:         \\\"Todo\\\" => Style::default().fg(Color::Cyan),\\n185:         \\\"Done\\\" => Style::default().fg(Color::Green),\\n186:         \\\"Canceled\\\" | \\\"Cancelled\\\" => Style::default().fg(Color::DarkGray),\\n187:         \\\"In Review\\\" => Style::default().fg(Color::Magenta),\\n188:         \\\"Backlog\\\" | \\\"Triage\\\" => Style::default().fg(Color::DarkGray),\\n189:         _ => Style::default(),\\n190:     }\\n191: }\\n192: \\n193: fn priority_style(priority: &str) -> Style {\\n194:     match priority {\\n195:         \\\"Urgent\\\" => Style::default().fg(Color::Red).add_modifier(Modifier::BOLD),\\n196:         \\\"High\\\" => Style::default().fg(Color::Red),\\n197:         \\\"Medium\\\" => Style::default().fg(Color::Yellow),\\n198:         \\\"Low\\\" => Style::default().fg(Color::DarkGray),\\n199:         _ => Style::default(),\\n200:     }\\n201: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01RczTSBD3yUHHf3GHLpQCSH","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/app.rs\",\"content\":\"[... omitted lines 1 to 249 ...]\\n250:         self.filtering = false;\\n251:        