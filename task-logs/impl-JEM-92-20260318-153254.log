\":\"1: use std::cmp::Ordering;\\n2: \\n3: use crate::amp::thread::ThreadSummary;\\n4: use crate::api::client::LinearApi;\\n5: use crate::api::types::Issue;\\n6: \\n7: #[derive(Debug, Clone, Copy, PartialEq, Eq)]\\n8: pub enum DetailSection {\\n9:     Body,\\n10:     Threads,\\n11: }\\n12: \\n13: #[allow(dead_code)]\\n14: pub enum View {\\n15:     MyIssues,\\n16:     Project,\\n17:     Detail,\\n18: }\\n19: \\n20: /// State for the workspace picker modal shown when starting a new Amp thread.\\n21: #[derive(Debug, Clone)]\\n22: pub struct WorkspacePicker {\\n23:     pub options: Vec<String>,\\n24:     pub selected: usize,\\n25: }\\n26: \\n27: #[allow(dead_code)]\\n28: impl WorkspacePicker {\\n29:     pub fn new(options: Vec<String>) -> Self {\\n30:         Self {\\n31:             options,\\n32:             selected: 0,\\n33:         }\\n34:     }\\n35: \\n36:     pub fn move_down(&mut self) {\\n37:         if !self.options.is_empty() && self.selected < self.options.len() - 1 {\\n38:             self.selected += 1;\\n39:         }\\n40:     }\\n41: \\n42:     pub fn move_up(&mut self) {\\n43:         if self.selected > 0 {\\n44:             self.selected -= 1;\\n45:         }\\n46:     }\\n47: \\n48:     pub fn selected_workspace(&self) -> Option<&str> {\\n49:         self.options.get(self.selected).map(|s| s.as_str())\\n50:     }\\n51: }\\n52: \\n53: #[derive(Debug, Clone, Copy, PartialEq, Eq)]\\n54: pub enum SortColumn {\\n55:     Identifier,\\n56:     Title,\\n57:     Project,\\n58:     Status,\\n59:     Priority,\\n60: }\\n61: \\n62: impl SortColumn {\\n63:     pub fn label(&self) -> &'static str {\\n64:         match self {\\n65:             SortColumn::Identifier => \\\"ID\\\",\\n66:             SortColumn::Title => \\\"Title\\\",\\n67:             SortColumn::Project => \\\"Project\\\",\\n68:             SortColumn::Status => \\\"Status\\\",\\n69:             SortColumn::Priority => \\\"Priority\\\",\\n70:         }\\n71:     }\\n72: }\\n73: \\n74: #[derive(Debug, Clone, Copy, PartialEq, Eq)]\\n75: pub enum SortDirection {\\n76:     Asc,\\n77:     Desc,\\n78: }\\n79: \\n80: impl SortDirection {\\n81:     pub fn toggle(self) -> Self {\\n82:         match self {\\n83:             SortDirection::Asc => SortDirection::Desc,\\n84:             SortDirection::Desc => SortDirection::Asc,\\n85:         }\\n86:     }\\n87: }\\n88: \\n89: pub struct App<A: LinearApi> {\\n90:     pub running: bool,\\n91:     pub view: View,\\n92:     pub api: A,\\n93:     pub issues: Vec<Issue>,\\n94:     pub selected: usize,\\n95:     pub filter: Option<(SortColumn, String)>,\\n96:     pub filter_input: String,\\n97:     pub filter_column: Option<SortColumn>,\\n98:     pub filtering: bool,\\n99:     pub awaiting_quit: bool,\\n100:     pub awaiting_filter: bool,\\n101:     pub awaiting_sort: bool,\\n102:     pub sort: Option<(SortColumn, SortDirection)>,\\n103:     pub search: Option<String>,\\n104:     pub search_input: String,\\n105:     pub searching: bool,\\n106:     pub detail_scroll: u16,\\n107:     pub detail_scroll_max: u16,\\n108:     pub refreshing: bool,\\n109:     pub detail_section: DetailSection,\\n110:     pub detail_threads: Vec<ThreadSummary>,\\n111:     pub detail_thread_selected: usize,\\n112:     pub workspace_picker: Option<WorkspacePicker>,\\n113: }\\n114: \\n115: impl<A: LinearApi> App<A> {\\n116:     pub fn new(api: A) -> Self {\\n117:         Self {\\n118:             running: true,\\n119:             view: View::MyIssues,\\n120:             api,\\n121:             issues: Vec::new(),\\n122:             selected: 0,\\n123:             filter: None,\\n124:             filter_input: String::new(),\\n125:             filter_column: None,\\n126:             filtering: false,\\n127:             awaiting_quit: false,\\n128:             awaiting_filter: false,\\n129:             awaiting_sort: false,\\n130:             sort: None,\\n131:             search: None,\\n132:             search_input: String::new(),\\n133:             searching: false,\\n134:             detail_scroll: 0,\\n135:             detail_scroll_max: 0,\\n136:             refreshing: false,\\n137:             detail_section: DetailSection::Body,\\n138:             detail_threads: Vec::new(),\\n139:             detail_thread_selected: 0,\\n140:             workspace_picker: None,\\n141:         }\\n142:     }\\n143: \\n144:     pub fn filtered_issues(&self) -> Vec<&Issue> {\\n145:         let mut issues: Vec<&Issue> = self.issues.iter().collect();\\n146:         if let Some((col, f)) = &self.filter {\\n147:             let lower = f.to_lowercase();\\n148:             issues.retain(|i| {\\n149:                 let value = match col {\\n150:                     SortColumn::Identifier => i.identifier.as_str(),\\n151:                     SortColumn::Title => i.title.as_str(),\\n152:                     SortColumn::Project => i.project_str(),\\n153:                     SortColumn::Status => i.status_str(),\\n154:                     SortColumn::Priority => i.priority_str(),\\n155:                 };\\n156:                 value.to_lowercase().contains(&lower)\\n157:             });\\n158:         }\\n159:         if let Some(q) = &self.search {\\n160:             let lower = q.to_lowercase();\\n161:             issues.retain(|i| i.matches_search(&lower));\\n162:         }\\n163:         if let Some((col, dir)) = &self.sort {\\n164:             issues.sort_by(|a, b| {\\n165:                 let ord = match col {\\n166:                     SortColumn::Identifier => a.identifier.cmp(&b.identifier),\\n167:                     SortColumn::Title => a.title.to_lowercase().cmp(&b.title.to_lowercase()),\\n168:                     SortColumn::Project => a.project_str().cmp(b.project_str()),\\n169:                     SortColumn::Status => a.status_str().cmp(b.status_str()),\\n170:                     SortColumn::Priority => a.priority.partial_cmp(&b.priority).unwrap_or(Ordering::Equal),\\n171:                 };\\n172:                 match dir {\\n173:                     SortDirection::Asc => ord,\\n174:                     SortDirection::Desc => ord.reverse(),\\n175:                 }\\n176:             });\\n177:         }\\n178:         issues\\n179:     }\\n180: \\n181:     pub fn set_sort(&mut self, col: SortColumn) {\\n182:         self.sort = Some(match self.sort {\\n183:             Some((c, dir)) if c == col => (col, dir.toggle()),\\n184:             _ => (col, SortDirection::Asc),\\n185:         });\\n186:         self.selected = 0;\\n187:     }\\n188: \\n189:     pub fn move_down(&mut self) {\\n190:         let len = self.filtered_issues().len();\\n191:         if len > 0 && self.selected < len - 1 {\\n192:             self.selected += 1;\\n193:         }\\n194:     }\\n195: \\n196:     pub fn move_up(&mut self) {\\n197:         if self.selected > 0 {\\n198:             self.selected -= 1;\\n199:         }\\n200:     }\\n201: \\n202:     pub fn top(&mut self) {\\n203:         self.selected = 0;\\n204:     }\\n205: \\n206:     pub fn bottom(&mut self) {\\n207:         let len = self.filtered_issues().len();\\n208:         if len > 0 {\\n209:             self.selected = len - 1;\\n210:         }\\n211:     }\\n212: \\n213:     pub fn start_search(&mut self) {\\n214:         self.searching = true;\\n215:         self.search_input.clear();\\n216:     }\\n217: \\n218:     pub fn apply_search(&mut self) {\\n219:         self.searching = false;\\n220:         if self.search_input.is_empty() {\\n221:             self.search = None;\\n222:         } else {\\n223:             self.search = Some(self.search_input.clone());\\n224:         }\\n225:         self.selected = 0;\\n226:     }\\n227: \\n228:     pub fn cancel_search(&mut self) {\\n229:         self.searching = false;\\n230:         self.search_input.clear();\\n231:     }\\n232: \\n233:     pub fn clear_search(&mut self) {\\n234:         self.search = None;\\n235:         self.search_input.clear();\\n236:         self.selected = 0;\\n237:     }\\n238: \\n239:     pub fn start_filter(&mut self) {\\n240:         self.start_column_filter(SortColumn::Title);\\n241:     }\\n242: \\n243:     pub fn start_column_filter(&mut self, col: SortColumn) {\\n244:         self.filter_column = Some(col);\\n245:         self.filtering = true;\\n246:         self.filter_input.clear();\\n247:     }\\n248: \\n249:     pub fn apply_filter(&mut self) {\\n250:         self.filtering = false;\\n[... omitted lines 251 to 642 ...]\\n643:     }\\n644: \\n645:     #[tokio::test]\\n646:     async fn refresh_preserves_selection_when_issue_exists() {\\n647:         let fake = FakeLinearApi::new();\\n648:         fake.push_response(serde_json::json!({\\n649:             \\\"data\\\": { \\\"issues\\\": { \\\"nodes\\\": [\\n650:                 { \\\"id\\\": \\\"1\\\", \\\"identifier\\\": \\\"JEM-1\\\", \\\"title\\\": \\\"Alpha\\\" },\\n651:                 { \\\"id\\\": \\\"2\\\", \\\"identifier\\\": \\\"JEM-2\\\", \\\"title\\\": \\\"Beta\\\" },\\n652:                 { \\\"id\\\": \\\"3\\\", \\\"identifier\\\": \\\"JEM-3\\\", \\\"title\\\": \\\"Gamma\\\" }\\n653:             ]}}\\n654:         }));\\n655:         let mut app = App::new(fake);\\n656:         app.issues = vec![\\n657:             Issue { id: \\\"1\\\".into(), identifier: \\\"JEM-1\\\".into(), title: \\\"Alpha\\\".into(), state: None, priority: None, project: None, description: None, assignee: None, labels: None, comments: None },\\n658:             Issue { id: \\\"2\\\".into(), identifier: \\\"JEM-2\\\".into(), title: \\\"Beta\\\".into(), state: None, priority: None, project: None, description: None, assignee: None, labels: None, comments: None },\\n659:         ];\\n660:         app.selected = 1; // JEM-2 selected\\n661: \\n662:         app.refresh().await;\\n663: \\n664:         assert_eq!(app.selected, 1); // JEM-2 is still at index 1\\n665:         assert_eq!(app.issues[app.selected].identifier, \\\"JEM-2\\\");\\n666:     }\\n667: \\n668:     #[tokio::test]\\n669: