{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"toolu_vrtx_01UfvV2K51M6mVfhwS2GRCze","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/amp/state.rs\",\"content\":\"1: use anyhow::Result;\\n2: use serde::{Deserialize, Serialize};\\n3: use std::collections::HashMap;\\n4: use std::path::{Path, PathBuf};\\n5: \\n6: /// A thread's link to a Linear issue and the workspace it was started in.\\n7: #[derive(Debug, Serialize, Deserialize, Clone, PartialEq)]\\n8: pub struct ThreadLink {\\n9:     pub issue: String,\\n10:     pub workspace: String,\\n11: }\\n12: \\n13: /// Persistent state for ishi, stored at `~/.config/ishi/state.toml`.\\n14: ///\\n15: /// Two data structures:\\n16: /// * **Thread links** — maps thread ID → issue identifier + workspace path.\\n17: ///   One issue can have many threads, but each thread belongs to exactly one issue.\\n18: /// * **Workspace history** — ordered list of previously used directory paths,\\n19: ///   most recent first.\\n20: #[derive(Debug, Serialize, Deserialize, Default, Clone, PartialEq)]\\n21: pub struct State {\\n22:     /// thread ID → link (issue identifier + workspace path)\\n23:     #[serde(default)]\\n24:     pub thread_links: HashMap<String, ThreadLink>,\\n25: \\n26:     /// Ordered list of workspace directory paths, most recent first.\\n27:     #[serde(default)]\\n28:     pub workspace_history: Vec<String>,\\n29: }\\n30: \\n31: #[allow(dead_code)]\\n32: impl State {\\n33:     /// Load state from a TOML file, returning default if the file does not exist.\\n34:     pub fn load(path: &Path) -> Result<Self> {\\n35:         if !path.exists() {\\n36:             return Ok(Self::default());\\n37:         }\\n38:         let contents = std::fs::read_to_string(path)?;\\n39:         let state: State = toml::from_str(&contents)?;\\n40:         Ok(state)\\n41:     }\\n42: \\n43:     /// Save state to a TOML file, creating parent directories as needed.\\n44:     pub fn save(&self, path: &Path) -> Result<()> {\\n45:         if let Some(parent) = path.parent() {\\n46:             std::fs::create_dir_all(parent)?;\\n47:         }\\n48:         let contents = toml::to_string_pretty(self)?;\\n49:         std::fs::write(path, contents)?;\\n50:         Ok(())\\n51:     }\\n52: \\n53:     /// Record a thread link: thread ID → issue identifier + workspace path.\\n54:     /// If the thread already exists, it is updated.\\n55:     pub fn add_thread_link(&mut self, thread_id: &str, issue: &str, workspace: &str) {\\n56:         self.thread_links.insert(\\n57:             thread_id.to_string(),\\n58:             ThreadLink {\\n59:                 issue: issue.to_string(),\\n60:                 workspace: workspace.to_string(),\\n61:             },\\n62:         );\\n63:     }\\n64: \\n65:     /// Return all thread IDs linked to the given issue identifier.\\n66:     pub fn threads_for_issue(&self, issue_identifier: &str) -> Vec<&str> {\\n67:         let mut ids: Vec<&str> = self\\n68:             .thread_links\\n69:             .iter()\\n70:             .filter(|(_, link)| link.issue == issue_identifier)\\n71:             .map(|(id, _)| id.as_str())\\n72:             .collect();\\n73:         ids.sort();\\n74:         ids\\n75:     }\\n76: \\n77:     /// Look up the workspace directory for a given thread ID.\\n78:     pub fn workspace_for(&self, thread_id: &str) -> Option<&str> {\\n79:         self.thread_links\\n80:             .get(thread_id)\\n81:             .map(|link| link.workspace.as_str())\\n82:     }\\n83: \\n84:     /// Add a workspace directory to the front of the history.\\n85:     /// If it already appears, it is moved to the front.\\n86:     pub fn add_workspace(&mut self, workspace: &str) {\\n87:         self.workspace_history\\n88:             .retain(|w| w != workspace);\\n89:         self.workspace_history.insert(0, workspace.to_string());\\n90:     }\\n91: \\n92:     /// Return the ordered workspace history (most recent first).\\n93:     pub fn workspaces(&self) -> &[String] {\\n94:         &self.workspace_history\\n95:     }\\n96: }\\n97: \\n98: /// Return the default state file path: `~/.config/ishi/state.toml`.\\n99: pub fn state_path() -> Result<PathBuf> {\\n100:     let dir = dirs::config_dir()\\n101:         .ok_or_else(|| anyhow::anyhow!(\\\"could not determine config directory\\\"))?\\n102:         .join(\\\"ishi\\\");\\n103:     std::fs::create_dir_all(&dir)?;\\n104:     Ok(dir.join(\\\"state.toml\\\"))\\n105: }\\n106: \\n107: #[cfg(test)]\\n108: mod tests {\\n109:     use super::*;\\n110: \\n111:     #[test]\\n112:     fn load_missing_file_returns_default() {\\n113:         let dir = tempfile::tempdir().unwrap();\\n114:         let path = dir.path().join(\\\"nonexistent.toml\\\");\\n115:         let state = State::load(&path).unwrap();\\n116:         assert!(state.thread_links.is_empty());\\n117:         assert!(state.workspace_history.is_empty());\\n118:     }\\n119: \\n120:     #[test]\\n121:     fn save_and_load_round_trip() {\\n122:         let dir = tempfile::tempdir().unwrap();\\n123:         let path = dir.path().join(\\\"state.toml\\\");\\n124: \\n125:         let mut state = State::default();\\n126:         state.add_thread_link(\\\"T-abc-123\\\", \\\"JEM-1\\\", \\\"/home/user/project-a\\\");\\n127:         state.add_thread_link(\\\"T-def-456\\\", \\\"JEM-1\\\", \\\"/home/user/project-a\\\");\\n128:         state.add_thread_link(\\\"T-ghi-789\\\", \\\"JEM-2\\\", \\\"/home/user/project-b\\\");\\n129:         state.add_workspace(\\\"/home/user/project-a\\\");\\n130:         state.add_workspace(\\\"/home/user/project-b\\\");\\n131: \\n132:         state.save(&path).unwrap();\\n133: \\n134:         let loaded = State::load(&path).unwrap();\\n135:         assert_eq!(loaded, state);\\n136:     }\\n137: \\n138:     #[test]\\n139:     fn threads_for_issue_unknown_returns_empty() {\\n140:         let state = State::default();\\n141:         assert!(state.threads_for_issue(\\\"JEM-999\\\").is_empty());\\n142:     }\\n143: \\n144:     #[test]\\n145:     fn threads_for_issue_returns_matching_threads() {\\n146:         let mut state = State::default();\\n147:         state.add_thread_link(\\\"T-abc\\\", \\\"JEM-1\\\", \\\"/ws\\\");\\n148:         state.add_thread_link(\\\"T-def\\\", \\\"JEM-1\\\", \\\"/ws\\\");\\n149:         state.add_thread_link(\\\"T-ghi\\\", \\\"JEM-2\\\", \\\"/ws\\\");\\n150: \\n151:         let threads = state.threads_for_issue(\\\"JEM-1\\\");\\n152:         assert_eq!(threads.len(), 2);\\n153:         assert!(threads.contains(&\\\"T-abc\\\"));\\n154:         assert!(threads.contains(&\\\"T-def\\\"));\\n155:     }\\n156: \\n157:     #[test]\\n158:     fn add_thread_link_overwrites_existing() {\\n159:         let mut state = State::default();\\n160:         state.add_thread_link(\\\"T-abc\\\", \\\"JEM-1\\\", \\\"/old/path\\\");\\n161:         state.add_thread_link(\\\"T-abc\\\", \\\"JEM-1\\\", \\\"/new/path\\\");\\n162: \\n163:         assert_eq!(state.thread_links.len(), 1);\\n164:         assert_eq!(state.workspace_for(\\\"T-abc\\\"), Some(\\\"/new/path\\\"));\\n165:     }\\n166: \\n167:     #[test]\\n168:     fn workspace_for_unknown_thread_returns_none() {\\n169:         let state = State::default();\\n170:         assert!(state.workspace_for(\\\"T-unknown\\\").is_none());\\n171:     }\\n172: \\n173:     #[test]\\n174:     fn workspace_for_known_thread() {\\n175:         let mut state = State::default();\\n176:         state.add_thread_link(\\\"T-abc\\\", \\\"JEM-1\\\", \\\"/home/user/project\\\");\\n177:         assert_eq!(state.workspace_for(\\\"T-abc\\\"), Some(\\\"/home/user/project\\\"));\\n178:     }\\n179: \\n180:     #[test]\\n181:     fn add_workspace_inserts_at_front() {\\n182:         let mut state = State::default();\\n183:         state.add_workspace(\\\"/first\\\");\\n184:         state.add_workspace(\\\"/second\\\");\\n185:         assert_eq!(state.workspaces(), &[\\\"/second\\\", \\\"/first\\\"]);\\n186:     }\\n187: \\n188:     #[test]\\n189:     fn add_workspace_deduplicates_and_moves_to_front() {\\n190:         let mut state = State::default();\\n191:         state.add_workspace(\\\"/a\\\");\\n192:         state.add_workspace(\\\"/b\\\");\\n193:         state.add_workspace(\\\"/a\\\");\\n194:         assert_eq!(state.workspaces(), &[\\\"/a\\\", \\\"/b\\\"]);\\n195:     }\\n196: \\n197:     #[test]\\n198:     fn workspaces_empty_by_default() {\\n199:         let state = State::default();\\n200:         assert!(state.workspaces().is_empty());\\n201:     }\\n202: \\n203:     #[test]\\n204:     fn save_creates_parent_directories() {\\n205:         let dir = tempfile::tempdir().unwrap();\\n206:         let path = dir.path().join(\\\"nested\\\").join(\\\"dir\\\").join(\\\"state.toml\\\");\\n207: \\n208:         let state = State::default();\\n209:         state.save(&path).unwrap();\\n210:         assert!(path.exists());\\n211:     }\\n212: \\n213:     #[test]\\n214:     fn workspace_history_round_trips_through_save_load() {\\n215:         let dir = tempfile::tempdir().unwrap();\\n216:         let path = dir.path().join(\\\"state.toml\\\");\\n217: \\n218:         let mut state = State::default();\\n219:         state.add_workspace(\\\"/project-a\\\");\\n220:         state.add_workspace(\\\"/project-b\\\");\\n221:         state.add_workspace(\\\"/project-c\\\");\\n222:         state.save(&path).unwrap();\\n223: \\n224:         let loaded = State::load(&path).unwrap();\\n225:         assert_eq!(loaded.workspaces(), &[\\\"/project-c\\\", \\\"/project-b\\\", \\\"/project-a\\\"]);\\n226:     }\\n227: \\n228:     #[test]\\n229:     fn thread_link_round_trips_through_save_load() {\\n230:         let dir = tempfile::tempdir().unwrap();\\n231:         let path = dir.path().join(\\\"state.toml\\\");\\n232: \\n233:         let mut state = State::default();\\n234:         state.add_thread_link(\\\"T-abc\\\", \\\"JEM-1\\\", \\\"/workspace/dir\\\");\\n235:         state.save(&path).unwrap();\\n236: \\n237:         let loaded = State::load(&path).unwrap();\\n238:         assert_eq!(loaded.workspace_for(\\\"T-abc\\\"), Some(\\\"/workspace/dir\\\"));\\n239:         let threads = loaded.threads_for_issue(\\\"JEM-1\\\");\\n240:         assert_eq!(threads, vec![\\\"T-abc\\\"]);\\n241:     }\\n242: \\n243:     #[test]\\n244:     fn load_empty_toml_returns_default() {\\n245:         let dir = tempfile::tempdir().unwrap();\\n246:         let path = dir.path().join(\\\"state.toml\\\");\\n247:         std::fs::write(&path, \\\"\\\").unwrap();\\n248: \\n249:         let state = State::load(&path).unwrap();\\n250:         assert!(state.thread_links.is_empty());\\n251:         assert!(state.workspace_history.is_empty());\\n252:     }\\n253: \\n254:     #[test]\\n255:     fn load_toml_without_workspace_history() {\\n256:         let dir = tempfile::tempdir().unwrap();\\n257:         let path = dir.path().join(\\\"state.toml\\\");\\n258:         let toml = r#\\\"\\n259: [thread_links.T-abc]\\n260: issue = \\\"JEM-1\\\"\\n261: workspace = \\\"/ws\\\"\\n262: \\\"#;\\n263:         std::fs::write(&path, toml).unwrap();\\n264: \\n265:         let state = State::load(&path).unwrap();\\n266:         assert_eq!(state.threads_for_issue(\\\"JEM-1\\\"), vec![\\\"T-abc\\\"]);\\n267:         assert!(state.workspace_history.is_empty());\\n268:     }\\n269: \\n270:     #[test]\\n271:     fn load_toml_without_thread_links() {\\n272:         let dir = tempfile::tempdir().unwrap();\\n273:         let path = dir.path().join(\\\"state.toml\\\");\\n274:         let toml = r#\\\"workspace_history = [\\\"/a\\\", \\\"/b\\\"]\\\"#;\\n275:         std::fs::write(&path, toml).unwrap();\\n276: \\n277:         let state = State::load(&path).unwrap();\\n278:         assert!(state.thread_links.is_empty());\\n279:         assert_eq!(state.workspaces(), &[\\\"/a\\\", \\\"/b\\\"]);\\n280:     }\\n281: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_012pbbPPB4Q5eZBuErLXy3x9","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/amp/thread.rs\",\"content\":\"1: use anyhow::Result;\\n2: use serde::Deserialize;\\n3: use std::path::{Path, PathBuf};\\n4: \\n5: #[derive(Debug, Deserialize)]\\n6: struct RawThread {\\n7:     id: String,\\n8:     created: u64,\\n9:     title: Option<String>,\\n10:     #[serde(default)]\\n11:     messages: Vec<serde_json::Value>,\\n12:     #[serde(rename = \\\"usageLedger\\\")]\\n13:     usage_ledger: Option<UsageLedger>,\\n14: }\\n15: \\n16: #[derive(Debug, Deserialize)]\\n17: struct UsageLedger {\\n18:     #[serde(default)]\\n19:     events: Vec<LedgerEvent>,\\n20: }\\n21: \\n22: #[derive(Debug, Deserialize)]\\n23: struct LedgerEvent {\\n24:     timestamp: String,\\n25: }\\n26: \\n27: /// Summary of an Amp thread for display in the TUI.\\n28: #[derive(Debug, Clone, PartialEq)]\\n29: pub struct ThreadSummary {\\n30:     pub id: String,\\n31:     pub title: String,\\n32:     pub message_count: usize,\\n33:     /// Milliseconds since Unix epoch of last activity (or creation time).\\n34:     pub last_activity_ms: u64,\\n35: }\\n36: \\n37: impl ThreadSummary {\\n38:     pub fn relative_time(&self) -> String {\\n39:         let now_ms = std::time::SystemTime::now()\\n40:             .duration_since(std::time::UNIX_EPOCH)\\n41:             .map(|d| d.as_millis() as u64)\\n42:             .unwrap_or(0);\\n43:         format_relative_time(now_ms, self.last_activity_ms)\\n44:     }\\n45: }\\n46: \\n47: pub fn format_relative_time(now_ms: u64, then_ms: u64) -> String {\\n48:     let diff_secs = now_ms.saturating_sub(then_ms) / 1000;\\n49: \\n50:     if diff_secs < 60 {\\n51:         format!(\\\"{}s ago\\\", diff_secs)\\n52:     } else if diff_secs < 3600 {\\n53:         format!(\\\"{}m ago\\\", diff_secs / 60)\\n54:     } else if diff_secs < 86400 {\\n55:         format!(\\\"{}h ago\\\", diff_secs / 3600)\\n56:     } else {\\n57:         format!(\\\"{}d ago\\\", diff_secs / 86400)\\n58:     }\\n59: }\\n60: \\n61: /// Returns the default directory where Amp stores thread files.\\n62: pub fn amp_threads_dir() -> Option<PathBuf> {\\n63:     dirs::data_dir().map(|d| d.join(\\\"amp\\\").join(\\\"threads\\\"))\\n64: }\\n65: \\n66: /// Read a thread file and produce a summary.\\n67: pub fn read_thread_summary(path: &Path) -> Result<ThreadSummary> {\\n68:     let contents = std::fs::read_to_string(path)?;\\n69:     parse_thread_summary(&contents)\\n70: }\\n71: \\n72: /// Parse a thread JSON string into a summary.\\n73: pub fn parse_thread_summary(json: &str) -> Result<ThreadSummary> {\\n74:     let raw: RawThread = serde_json::from_str(json)?;\\n75: \\n76:     let title = raw\\n77:         .title\\n78:         .unwrap_or_else(|| \\\"Untitled thread\\\".to_string());\\n79: \\n80:     let message_count = raw.messages.len();\\n81: \\n82:     // Last activity: latest usage ledger event timestamp, or creation time.\\n83:     let last_activity_ms = raw\\n84:         .usage_ledger\\n85:         .and_then(|ledger| {\\n86:             ledger.events.last().and_then(|e| {\\n87:                 chrono_parse_to_ms(&e.timestamp)\\n88:             })\\n89:         })\\n90:         .unwrap_or(raw.created);\\n91: \\n92:     Ok(ThreadSummary {\\n93:         id: raw.id,\\n94:         title,\\n95:         message_count,\\n96:         last_activity_ms,\\n97:     })\\n98: }\\n99: \\n100: /// Parse an ISO-8601 timestamp string to milliseconds since epoch.\\n101: /// Uses manual parsing to avoid adding a chrono dependency.\\n102: fn chrono_parse_to_ms(s: &str) -> Option<u64> {\\n103:     // Expected format: \\\"2025-12-28T21:21:59.052Z\\\"\\n104:     // We'll use a simple parse approach\\n105:     let s = s.trim_end_matches('Z');\\n106:     let (date_part, time_part) = s.split_once('T')?;\\n107: \\n108:     let mut date_iter = date_part.split('-');\\n109:     let year: i64 = date_iter.next()?.parse().ok()?;\\n110:     let month: u32 = date_iter.next()?.parse().ok()?;\\n111:     let day: u32 = date_iter.next()?.parse().ok()?;\\n112: \\n113:     let (time_main, millis) = if let Some((t, ms)) = time_part.split_once('.') {\\n114:         let ms_val: u64 = ms.parse().ok()?;\\n115:         (t, ms_val)\\n116:     } else {\\n117:         (time_part, 0u64)\\n118:     };\\n119: \\n120:     let mut time_iter = time_main.split(':');\\n121:     let hour: u32 = time_iter.next()?.parse().ok()?;\\n122:     let min: u32 = time_iter.next()?.parse().ok()?;\\n123:     let sec: u32 = time_iter.next()?.parse().ok()?;\\n124: \\n125:     // Days from epoch (1970-01-01) using a simplified calculation\\n126:     let days = days_from_epoch(year, month, day)?;\\n127:     let total_secs = (days as u64) * 86400 + (hour as u64) * 3600 + (min as u64) * 60 + (sec as u64);\\n128:     Some(total_secs * 1000 + millis)\\n129: }\\n130: \\n131: fn days_from_epoch(year: i64, month: u32, day: u32) -> Option<i64> {\\n132:     // Adjust for months <= 2 (treat Jan/Feb as months 13/14 of previous year)\\n133:     let (y, m) = if month <= 2 {\\n134:         (year - 1, month + 12)\\n135:     } else {\\n136:         (year, month)\\n137:     };\\n138: \\n139:     let era = if y >= 0 { y } else { y - 399 } / 400;\\n140:     let yoe = (y - era * 400) as u32;\\n141:     let doy = (153 * (m - 3) + 2) / 5 + day - 1;\\n142:     let doe = yoe * 365 + yoe / 4 - yoe / 100 + doy;\\n143:     let days = era * 146097 + doe as i64 - 719468;\\n144:     Some(days)\\n145: }\\n146: \\n147: /// Load thread summaries for a list of thread IDs from the given threads directory.\\n148: pub fn load_thread_summaries(\\n149:     threads_dir: &Path,\\n150:     thread_ids: &[String],\\n151: ) -> Vec<ThreadSummary> {\\n152:     thread_ids\\n153:         .iter()\\n154:         .filter_map(|id| {\\n155:             let path = threads_dir.join(format!(\\\"{}.json\\\", id));\\n156:             read_thread_summary(&path).ok()\\n157:         })\\n158:         .collect()\\n159: }\\n160: \\n161: /// Read a single thread by ID from the default Amp threads directory.\\n162: pub fn read_thread(id: &str) -> Result<ThreadSummary> {\\n163:     let threads_dir =\\n164:         amp_threads_dir().ok_or_else(|| anyhow::anyhow!(\\\"could not determine Amp threads directory\\\"))?;\\n165:     let path = threads_dir.join(format!(\\\"{}.json\\\", id));\\n166:     read_thread_summary(&path)\\n167: }\\n168: \\n169: /// Snapshot all thread IDs from a given directory by listing `*.json` filenames.\\n170: ///\\n171: /// Returns a set of thread IDs (filenames without `.json` extension).\\n172: pub fn snapshot_thread_ids(dir: &Path) -> std::collections::HashSet<String> {\\n173:     let mut ids = std::collections::HashSet::new();\\n174:     if let Ok(entries) = std::fs::read_dir(dir) {\\n175:         for entry in entries.flatten() {\\n176:             let path = entry.path();\\n177:             if path.extension().is_some_and(|ext| ext == \\\"json\\\")\\n178:                 && let Some(stem) = path.file_stem().and_then(|s| s.to_str())\\n179:             {\\n180:                 ids.insert(stem.to_string());\\n181:             }\\n182:         }\\n183:     }\\n184:     ids\\n185: }\\n186: \\n187: /// List all thread summaries from the default Amp threads directory.\\n188: ///\\n189: /// Scans `~/.local/share/amp/threads/*.json` and parses metadata from each file.\\n190: /// Threads that fail to parse are silently skipped.\\n191: pub fn list_threads() -> Result<Vec<ThreadSummary>> {\\n192:     let threads_dir =\\n193:         amp_threads_dir().ok_or_else(|| anyhow::anyhow!(\\\"could not determine Amp threads directory\\\"))?;\\n194:     list_threads_in(&threads_dir)\\n195: }\\n196: \\n197: /// List all thread summaries from a given directory.\\n198: ///\\n199: /// Scans `dir/*.json` and parses metadata from each file.\\n200: /// Files that fail to parse are silently skipped.\\n201: pub fn list_threads_in(dir: &Path) -> Result<Vec<ThreadSummary>> {\\n202:     let mut threads = Vec::new();\\n203:     for entry in std::fs::read_dir(dir)? {\\n204:         let entry = entry?;\\n205:         let path = entry.path();\\n206:         if path.extension().is_some_and(|ext| ext == \\\"json\\\")\\n207:             && let Ok(summary) = read_thread_summary(&path)\\n208:         {\\n209:             threads.push(summary);\\n210:         }\\n211:     }\\n212:     threads.sort_by(|a, b| b.last_activity_ms.cmp(&a.last_activity_ms));\\n213:     Ok(threads)\\n214: }\\n215: \\n216: #[cfg(test)]\\n217: mod tests {\\n218:     use super::*;\\n219: \\n220:     #[test]\\n221:     fn parse_minimal_thread() {\\n222:         let json = r#\\\"{\\n223:             \\\"v\\\": 0,\\n224:             \\\"id\\\": \\\"T-abc-123\\\",\\n225:             \\\"created\\\": 1700000000000,\\n226:             \\\"messages\\\": []\\n227:         }\\\"#;\\n228:         let summary = parse_thread_summary(json).unwrap();\\n229:         assert_eq!(summary.id, \\\"T-abc-123\\\");\\n230:         assert_eq!(summary.title, \\\"Untitled thread\\\");\\n231:         assert_eq!(summary.message_count, 0);\\n232:         assert_eq!(summary.last_activity_ms, 1700000000000);\\n233:     }\\n234: \\n235:     #[test]\\n236:     fn parse_thread_with_title_and_messages() {\\n237:         let json = r#\\\"{\\n238:             \\\"v\\\": 0,\\n239:             \\\"id\\\": \\\"T-def-456\\\",\\n240:             \\\"created\\\": 1700000000000,\\n241:             \\\"title\\\": \\\"Fix the bug\\\",\\n242:             \\\"messages\\\": [{\\\"role\\\": \\\"user\\\"}, {\\\"role\\\": \\\"assistant\\\"}, {\\\"role\\\": \\\"user\\\"}]\\n243:         }\\\"#;\\n244:         let summary = parse_thread_summary(json).unwrap();\\n245:         assert_eq!(summary.title, \\\"Fix the bug\\\");\\n246:         assert_eq!(summary.message_count, 3);\\n247:     }\\n248: \\n249:     #[test]\\n250:     fn parse_thread_with_usage_ledger() {\\n[... omitted lines 251 to 264 ...]\\n265:         // 2025-12-28T21:21:59.052Z\\n266:         assert_eq!(summary.last_activity_ms, 1766956919052);\\n267:     }\\n268: \\n269:     #[test]\\n270:     fn format_relative_time_seconds() {\\n271:         assert_eq!(format_relative_time(1000_000, 1000_000), \\\"0s ago\\\");\\n272:         assert_eq!(format_relative_time(1030_000, 1000_000), \\\"30s ago\\\");\\n273:     }\\n274: \\n275:     #[test]\\n276:     fn format_relative_time_minutes() {\\n277:         assert_eq!(format_relative_time(1000_000 + 120_000, 1000_000), \\\"2m ago\\\");\\n278:         assert_eq!(format_relative_time(1000_000 + 420_000, 1000_000), \\\"7m ago\\\");\\n279:     }\\n280: \\n281:     #[test]\\n282:     fn format_relative_time_hours() {\\n283:         let two_hours = 2 * 3600 * 1000;\\n284:         assert_eq!(format_relative_time(1000_000 + two_hours, 1000_000), \\\"2h ago\\\");\\n285:     }\\n286: \\n287:     #[test]\\n288:     fn format_relative_time_days() {\\n289:         let three_days = 3 * 86400 * 1000;\\n290:         assert_eq!(format_relative_time(1000_000 + three_days, 1000_000), \\\"3d ago\\\");\\n291:     }\\n292: \\n293:     #[test]\\n294:     fn chrono_parse_known_timestamp() {\\n295:         let ms = chrono_parse_to_ms(\\\"2025-12-28T21:21:59.052Z\\\").unwrap();\\n296:         assert_eq!(ms, 1766956919052);\\n297:     }\\n298: \\n299:     #[test]\\n300:     fn chrono_parse_no_millis() {\\n301:         let ms = chrono_parse_to_ms(\\\"2025-01-01T00:00:00Z\\\").unwrap();\\n302:         // 2025-01-01 = day 20089 from epoch\\n303:         assert_eq!(ms, 1735689600000);\\n304:     }\\n305: \\n306:     #[test]\\n307:     fn load_thread_summaries_from_dir() {\\n308:         let dir = tempfile::tempdir().unwrap();\\n309:         let thread_json = r#\\\"{\\n310:             \\\"v\\\": 0,\\n311:             \\\"id\\\": \\\"T-test-1\\\",\\n312:             \\\"created\\\": 1700000000000,\\n313:             \\\"title\\\": \\\"Test thread\\\",\\n314:             \\\"messages\\\": [{\\\"role\\\": \\\"user\\\"}]\\n315:         }\\\"#;\\n316:         std::fs::write(dir.path().join(\\\"T-test-1.json\\\"), thread_json).unwrap();\\n317: \\n318:         let summaries = load_thread_summaries(dir.path(), &[\\\"T-test-1\\\".to_string()]);\\n319:         assert_eq!(summaries.len(), 1);\\n320:         assert_eq!(summaries[0].title, \\\"Test thread\\\");\\n321:     }\\n322: \\n323:     #[test]\\n324:     fn load_thread_summaries_skips_missing_files() {\\n325:         let dir = tempfile::tempdir().unwrap();\\n326:         let summaries = load_thread_summaries(\\n327:             dir.path(),\\n328:             &[\\\"T-nonexistent\\\".to_string()],\\n329:         );\\n330:         assert!(summaries.is_empty());\\n331:     }\\n332: \\n333:     #[test]\\n334:     fn list_threads_in_returns_sorted_by_last_activity_desc() {\\n335:         let dir = tempfile::tempdir().unwrap();\\n336:         let old_thread = r#\\\"{\\n337:             \\\"v\\\": 0,\\n338:             \\\"id\\\": \\\"T-old\\\",\\n339:             \\\"created\\\": 1600000000000,\\n340:             \\\"title\\\": \\\"Old thread\\\",\\n341:             \\\"messages\\\": [{\\\"role\\\": \\\"user\\\"}]\\n342:         }\\\"#;\\n343:         let new_thread = r#\\\"{\\n344:             \\\"v\\\": 0,\\n345:             \\\"id\\\": \\\"T-new\\\",\\n346:             \\\"created\\\": 1700000000000,\\n347:             \\\"title\\\": \\\"New thread\\\",\\n348:             \\\"messages\\\": [{\\\"role\\\": \\\"user\\\"}, {\\\"role\\\": \\\"assistant\\\"}]\\n349:         }\\\"#;\\n350:         let mid_thread = r#\\\"{\\n351:             \\\"v\\\": 0,\\n352:             \\\"id\\\": \\\"T-mid\\\",\\n353:             \\\"created\\\": 1650000000000,\\n354:             \\\"title\\\": \\\"Mid thread\\\",\\n355:             \\\"messages\\\": []\\n356:         }\\\"#;\\n357:         std::fs::write(dir.path().join(\\\"T-old.json\\\"), old_thread).unwrap();\\n358:         std::fs::write(dir.path().join(\\\"T-new.json\\\"), new_thread).unwrap();\\n359:         std::fs::write(dir.path().join(\\\"T-mid.json\\\"), mid_thread).unwrap();\\n360: \\n361:         let threads = list_threads_in(dir.path()).unwrap();\\n362:         assert_eq!(threads.len(), 3);\\n363:         assert_eq!(threads[0].id, \\\"T-new\\\");\\n364:         assert_eq!(threads[1].id, \\\"T-mid\\\");\\n365:         assert_eq!(threads[2].id, \\\"T-old\\\");\\n366:     }\\n367: \\n368:     #[test]\\n369:     fn list_threads_in_skips_invalid_json() {\\n370:         let dir = tempfile::tempdir().unwrap();\\n371:         let valid = r#\\\"{\\n372:             \\\"v\\\": 0,\\n373:             \\\"id\\\": \\\"T-valid\\\",\\n374:             \\\"created\\\": 1700000000000,\\n375:             \\\"messages\\\": []\\n376:         }\\\"#;\\n377:         std::fs::write(dir.path().join(\\\"T-valid.json\\\"), valid).unwrap();\\n378:         std::fs::write(dir.path().join(\\\"T-bad.json\\\"), \\\"not valid json\\\").unwrap();\\n379: \\n380:         let threads = list_threads_in(dir.path()).unwrap();\\n381:         assert_eq!(threads.len(), 1);\\n382:         assert_eq!(threads[0].id, \\\"T-valid\\\");\\n383:     }\\n384: \\n385:     #[test]\\n386:     fn list_threads_in_ignores_non_json_files() {\\n387:         let dir = tempfile::tempdir().unwrap();\\n388:         let valid = r#\\\"{\\n389:             \\\"v\\\": 0,\\n390:             \\\"id\\\": \\\"T-only\\\",\\n391:             \\\"created\\\": 1700000000000,\\n392:             \\\"messages\\\": []\\n393:         }\\\"#;\\n394:         std::fs::write(dir.path().join(\\\"T-only.json\\\"), valid).unwrap();\\n395:         std::fs::write(dir.path().join(\\\"notes.txt\\\"), \\\"some notes\\\").unwrap();\\n396: \\n397:         let threads = list_threads_in(dir.path()).unwrap();\\n398:         assert_eq!(threads.len(), 1);\\n399:         assert_eq!(threads[0].id, \\\"T-only\\\");\\n400:     }\\n401: \\n402:     #[test]\\n403:     fn list_threads_in_empty_dir() {\\n404:         let dir = tempfile::tempdir().unwrap();\\n405:         let threads = list_threads_in(dir.path()).unwrap();\\n406:         assert!(threads.is_empty());\\n407:     }\\n408: \\n409:     #[test]\\n410:     fn list_threads_in_nonexistent_dir_returns_error() {\\n411:         let result = list_threads_in(Path::new(\\\"/nonexistent/dir\\\"));\\n412:         assert!(result.is_err());\\n413:     }\\n414: \\n415:     #[test]\\n416:     fn snapshot_thread_ids_empty_dir() {\\n417:         let dir = tempfile::tempdir().unwrap();\\n418:         let ids = snapshot_thread_ids(dir.path());\\n419:         assert!(ids.is_empty());\\n420:     }\\n421: \\n422:     #[test]\\n423:     fn snapshot_thread_ids_finds_json_files() {\\n424:         let dir = tempfile::tempdir().unwrap();\\n425:         std::fs::write(dir.path().join(\\\"T-abc.json\\\"), \\\"{}\\\").unwrap();\\n426:         std::fs::write(dir.path().join(\\\"T-def.json\\\"), \\\"{}\\\").unwrap();\\n427:         std::fs::write(dir.path().join(\\\"notes.txt\\\"), \\\"not a thread\\\").unwrap();\\n428: \\n429:         let ids = snapshot_thread_ids(dir.path());\\n430:         assert_eq!(ids.len(), 2);\\n431:         assert!(ids.contains(\\\"T-abc\\\"));\\n432:         assert!(ids.contains(\\\"T-def\\\"));\\n433:     }\\n434: \\n435:     #[test]\\n436:     fn snapshot_thread_ids_nonexistent_dir() {\\n437:         let ids = snapshot_thread_ids(Path::new(\\\"/nonexistent/dir\\\"));\\n438:         assert!(ids.is_empty());\\n439:     }\\n440: \\n441:     #[test]\\n442:     fn snapshot_thread_ids_diff_detects_new_thread() {\\n443:         let dir = tempfile::tempdir().unwrap();\\n444:         std::fs::write(dir.path().join(\\\"T-existing.json\\\"), \\\"{}\\\").unwrap();\\n445: \\n446:         let before = snapshot_thread_ids(dir.path());\\n447:         assert_eq!(before.len(), 1);\\n448: \\n449:         std::fs::write(dir.path().join(\\\"T-new.json\\\"), \\\"{}\\\").unwrap();\\n450: \\n451:         let after = snapshot_thread_ids(dir.path());\\n452:         let new_ids: Vec<&String> = after.difference(&before).collect();\\n453:         assert_eq!(new_ids.len(), 1);\\n454:         assert_eq!(*new_ids[0], \\\"T-new\\\");\\n455:     }\\n456: \\n457:     #[test]\\n458:     fn snapshot_thread_ids_diff_empty_when_unchanged() {\\n459:         let dir = tempfile::tempdir().unwrap();\\n460:         std::fs::write(dir.path().join(\\\"T-existing.json\\\"), \\\"{}\\\").unwrap();\\n461: \\n462:         let before = snapshot_thread_ids(dir.path());\\n463:         let after = snapshot_thread_ids(dir.path());\\n464:         let new_ids: Vec<&String> = after.difference(&before).collect();\\n465:         assert!(new_ids.is_empty());\\n466:     }\\n467: \\n468:     #[test]\\n469:     fn list_threads_in_with_usage_ledger_sorts_by_last_event() {\\n470:         let dir = tempfile::tempdir().unwrap();\\n471:         // Thread with old creation but recent usage ledger event\\n472:         let active_thread = r#\\\"{\\n473:             \\\"v\\\": 0,\\n474:             \\\"id\\\": \\\"T-active\\\",\\n475:             \\\"created\\\": 1600000000000,\\n476:             \\\"title\\\": \\\"Active old thread\\\",\\n477:             \\\"messages\\\": [{\\\"role\\\": \\\"user\\\"}],\\n478:             \\\"usageLedger\\\": {\\n479:                 \\\"events\\\": [\\n480:                     {\\\"timestamp\\\": \\\"2025-12-28T21:21:59.052Z\\\"}\\n481:                 ]\\n482:             }\\n483:         }\\\"#;\\n484:         // Thread with recent creation but no ledger\\n485:         let recent_thread = r#\\\"{\\n486:             \\\"v\\\": 0,\\n487:             \\\"id\\\": \\\"T-recent\\\",\\n488:             \\\"created\\\": 1700000000000,\\n489:             \\\"title\\\": \\\"Recent thread\\\",\\n490:             \\\"messages\\\": []\\n491:         }\\\"#;\\n492:         std::fs::write(dir.path().join(\\\"T-active.json\\\"), active_thread).unwrap();\\n493:         std::fs::write(dir.path().join(\\\"T-recent.json\\\"), recent_thread).unwrap();\\n494: \\n495:         let threads = list_threads_in(dir.path()).unwrap();\\n496:         assert_eq!(threads.len(), 2);\\n497:         // T-active has last_activity from ledger (2025-12-28) > T-recent creation (1700000000000)\\n498:         assert_eq!(threads[0].id, \\\"T-active\\\");\\n499:         assert_eq!(threads[1].id, \\\"T-recent\\\");\\n500:     }\\n501: \\n502:     #[test]\\n503:     fn thread_summary_relative_time_is_nonempty() {\\n504:         let summary = ThreadSummary {\\n505:             id: \\\"T-test\\\".to_string(),\\n506:             title: \\\"Test\\\".to_string(),\\n507:             message_count: 1,\\n508:             last_activity_ms: 1700000000000,\\n509:         };\\n510:         let relative = summary.relative_time();\\n511:         assert!(!relative.is_empty());\\n512:         assert!(relative.ends_with(\\\" ago\\\"));\\n513:     }\\n514: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01LkJY5ZcFfJNvmn9BLzPtdq","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/amp/mod.rs\",\"content\":\"1: pub mod state;\\n2: pub mod thread;\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01AgCfcYWeJPz1Knipr66j7o","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/views/detail.rs\",\"content\":\"1: use ratatui::{\\n2:     layout::{Constraint, Layout, Rect},\\n3:     style::{Color, Modifier, Style},\\n4:     text::{Line, Span},\\n5:     widgets::{Block, Borders, Clear, Paragraph, Wrap},\\n6:     Frame,\\n7: };\\n8: \\n9: use crate::api::client::LinearApi;\\n10: use crate::app::{App, DetailSection};\\n11: \\n12: pub fn render<A: LinearApi>(frame: &mut Frame, area: Rect, app: &mut App<A>) {\\n13:     let issue = match app.selected_issue() {\\n14:         Some(i) => i,\\n15:         None => {\\n16:             frame.render_widget(Paragraph::new(\\\"No issue selected\\\"), area);\\n17:             return;\\n18:         }\\n19:     };\\n20: \\n21:     // Metadata fields\\n22:     let label_style = Style::default().fg(Color::DarkGray);\\n23: \\n24:     let