702:         // FakeLinearApi with no response returns empty vec (not an error), so issues get replaced\\n703:         // This tests that refreshing flag is cleared\\n704:         assert!(!app.refreshing);\\n705:     }\\n706: \\n707:     #[test]\\n708:     fn select_issue_resets_thread_state() {\\n709:         let mut app = app_with_issues();\\n710:         app.detail_section = DetailSection::Threads;\\n711:         app.detail_thread_selected = 2;\\n712:         app.select_issue();\\n713:         assert!(matches!(app.detail_section, DetailSection::Body));\\n714:         assert_eq!(app.detail_thread_selected, 0);\\n715:     }\\n716: \\n717:     #[test]\\n718:     fn back_to_list_clears_threads() {\\n719:         let mut app = app_with_issues();\\n720:         app.select_issue();\\n721:         app.detail_threads = vec![ThreadSummary {\\n722:             id: \\\"T-1\\\".into(),\\n723:             title: \\\"Thread\\\".into(),\\n724:             message_count: 5,\\n725:             last_activity_ms: 1700000000000,\\n726:         }];\\n727:         app.detail_section = DetailSection::Threads;\\n728:         app.back_to_list();\\n729:         assert!(matches!(app.detail_section, DetailSection::Body));\\n730:         assert!(app.detail_threads.is_empty());\\n731:         assert_eq!(app.detail_thread_selected, 0);\\n732:     }\\n733: \\n734:     #[test]\\n735:     fn thread_move_down_and_up() {\\n736:         let mut app = app_with_issues();\\n737:         app.detail_threads = vec![\\n738:             ThreadSummary { id: \\\"T-1\\\".into(), title: \\\"A\\\".into(), message_count: 1, last_activity_ms: 0 },\\n739:             ThreadSummary { id: \\\"T-2\\\".into(), title: \\\"B\\\".into(), message_count: 2, last_activity_ms: 0 },\\n740:             ThreadSummary { id: \\\"T-3\\\".into(), title: \\\"C\\\".into(), message_count: 3, last_activity_ms: 0 },\\n741:         ];\\n742:         assert_eq!(app.detail_thread_selected, 0);\\n743:         app.thread_move_down();\\n744:   