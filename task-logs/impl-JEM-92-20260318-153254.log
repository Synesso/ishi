:                 let is_selected = threads_focused && i == app.detail_thread_selected;\\n184:                 let style = if is_selected {\\n185:                     Style::default().add_modifier(Modifier::REVERSED)\\n186:                 } else {\\n187:                     Style::default()\\n188:                 };\\n189:                 let time_str = t.relative_time();\\n190:                 Line::from(vec![\\n191:                     Span::styled(\\n192:                         format!(\\\"  {} \\\", t.title),\\n193:                         style,\\n194:                     ),\\n195:                     Span::styled(\\n196:                         format!(\\\"({} msgs) \\\", t.message_count),\\n197:                         style.fg(Color::DarkGray),\\n198:                     ),\\n199:                     Span::styled(\\n200:                         time_str,\\n201:                         style.fg(Color::DarkGray),\\n202:                     ),\\n203:                 ])\\n204:             })\\n205:             .collect();\\n206: \\n207:         let threads_block = Paragraph::new(thread_lines).block(\\n208:             Block::default()\\n209:                 .borders(Borders::ALL)\\n210:                 .title(format!(\\\"Threads ({})\\\", thread_count))\\n211:                 .border_style(threads_border_style),\\n212:         );\\n213:         frame.render_widget(threads_block, chunks[2]);\\n214:     }\\n215: \\n216:     // Status bar\\n217:     let key_style = Style::default().fg(Color::Yellow).add_modifier(Modifier::BOLD);\\n218:     let bar = if app.awaiting_quit {\\n219:         Line::from(vec![\\n220:             Span::raw(\\\"Press \\\"),\\n221:             Span::styled(\\\"q\\\", key_style),\\n222:             Span::raw(\\\" again to quit\\\"),\\n223:         ])\\n224:     } else if app.detail_section == DetailSection::Threads {\\n225:         Line::from(vec![\\n226:             Span::styled(\\\"Esc\\\", key_style),\\n227:             Span::raw(\\\" back  \\\"),\\n228:             Span::styled(\\\"j\\\", key_style),\\n229:             Span::raw(\\\"/\\\"),\\n230:             Span::styled(\\\"k\\\", key_style),\\n231:             Span::raw(\\\" navigate  \\\"),\\n232:             Span::styled(\\\"Enter\\\", key_style),\\n233:             Span::raw(\\\" continue  \\\"),\\n234:             Span::styled(\\\"a\\\", key_style),\\n235:             Span::raw(\\\" new thread\\\"),\\n236:         ])\\n237:     } else {\\n238:         let mut spans = vec![\\n239:             Span::styled(\\\"Esc\\\", key_style),\\n240:             Span::raw(\\\" back  \\\"),\\n241:             Span::styled(\\\"j\\\", key_style),\\n242:             Span::raw(\\\"/\\\"),\\n243:             Span::styled(\\\"k\\\", key_style),\\n244:             Span::raw(\\\" scroll\\\"),\\n245:         ];\\n246:         if !app.detail_threads.is_empty() {\\n247:             spans.push(Span::raw(\\\"  \\\"));\\n248:             spans.push(Span::styled(\\\"Tab\\\", key_style));\\n249:             spans.push(Span::raw(\\\" threads\\\"));\\n250:         }\\n251:         spans.push(Span::raw(\\\"  \\\"));\\n252:         spans.push(Span::styled(\\\"a\\\", key_style));\\n253:         spans.push(Span::raw(\\\" new thread\\\"));\\n254:         Line::from(spans)\\n255:     };\\n256:     frame.render_widget(Paragraph::new(bar), chunks[3]);\\n257: \\n258:     // Workspace picker modal\\n259:     if let Some(ref picker) = app.workspace_picker {\\n260:         let picker_height = (picker.options.len() as u16 + 2).min(area.height.saturating_sub(4));\\n261:         let picker_width = picker\\n262:             .options\\n263:             .iter()\\n264:             .map(|s| s.len() as u16)\\n265:             .max()\\n266:             .unwrap_or(20)\\n267:             .max(20)\\n268:             + 4;\\n269:         let picker_width = picker_width.min(area.width.saturating_sub(4));\\n270: \\n271:         let x = area.x + (area.width.saturating_sub(picker_width)) / 2;\\n272:     