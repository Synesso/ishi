b fn clear_filter(&mut self) {\\n305:         self.filter = None;\\n306:         self.filter_column = None;\\n307:         self.filter_input.clear();\\n308:         self.selected = 0;\\n309:     }\\n310: \\n311:     pub fn select_issue(&mut self) {\\n312:         let issues = self.filtered_issues();\\n313:         if self.selected < issues.len() {\\n314:             self.view = View::Detail;\\n315:             self.detail_scroll = 0;\\n316:             self.detail_section = DetailSection::Body;\\n317:             self.detail_thread_selected = 0;\\n318:         }\\n319:     }\\n320: \\n321:     pub fn back_to_list(&mut self) {\\n322:         self.view = View::MyIssues;\\n323:         self.detail_scroll = 0;\\n324:         self.detail_section = DetailSection::Body;\\n325:         self.detail_threads.clear();\\n326:         self.detail_thread_selected = 0;\\n327:     }\\n328: \\n329:     pub fn selected_issue(&self) -> Option<&Issue> {\\n330:         let issues = self.filtered_issues();\\n331:         issues.get(self.selected).copied()\\n332:     }\\n333: \\n334:     pub fn scroll_detail_down(&mut self) {\\n335:         if self.detail_scroll < self.detail_scroll_max {\\n336:             self.detail_scroll = self.detail_scroll.saturating_add(1);\\n337:         }\\n338:     }\\n339: \\n340:     pub fn scroll_detail_up(&mut self) {\\n341:         self.detail_scroll = self.detail_scroll.saturating_sub(1);\\n342:     }\\n343: \\n344:     pub fn thread_move_down(&mut self) {\\n345:         let len = self.detail_threads.len();\\n346:         if len > 0 && self.detail_thread_selected < len - 1 {\\n347:             self.detail_thread_selected += 1;\\n348:         }\\n349:     }\\n350: \\n351:     pub fn thread_move_up(&mut self) {\\n352:         if self.detail_thread_selected > 0 {\\n353:             self.detail_thread_selected -= 1;\\n354:         }\\n355:     }\\n356: \\n357:     pub fn selected_thread(&self) -> Option<&ThreadSummary> {\\n358:         if self.detail_section == DetailSection::Threads {\\n359:             self.detail_threads.get(self.detail_thread_selected)\\n360:         } else {\\n361:             None\\n362:         }\\n363:     }\\n364: \\n365:     pub fn focus_threads(&mut self) {\\n366:         if !self.detail_threads.is_empty() {\\n367:             self.detail_section = DetailSection::Threads;\\n368:         }\\n369:     }\\n370: \\n371:     pub fn focus_body(&mut self) {\\n372:         self.detail_section = DetailSection::Body;\\n373:     }\\n374: \\n375:     pub fn show_workspace_picker(&mut self, workspaces: Vec<String>) {\\n376:         self.workspace_picker = Some(WorkspacePicker::new(workspaces));\\n377:     }\\n378: \\n379:     pub fn cancel_workspace_picker(&mut self) {\\n380:         self.workspace_picker = None;\\n381:     }\\n382: \\n383:     pub fn toggle_help(&mut self) {\\n384:         self.show_help = !self.show_help;\\n385:     }\\n386: \\n387:     pub fn dismiss_help(&mut self) {\\n388:         self.show_help = false;\\n389:     }\\n390: \\n391:     pub fn selected_issue_url(&self) -> Option<String> {\\n392:         self.selected_issue().and_then(|i| i.url.clone())\\n393:     }\\n394: \\n395:     /// Load issues, serving from cache if fresh, otherwise fetching from API.\\n396:     /// On cache hit, returns immediately. On miss, fetches and populates cache.\\n397:     pub async fn load_issues(&mut self) {\\n398:         if let Some(cached) = self.cache.get(CACHE_KEY_MY_ISSUES) {\\n399:             self.issues = cached.clone();\\n400:             return;\\n401:         }\\n402:         self.fetch_and_cache_issues().await;\\n403:     }\\n404: \\n405:     /// Force-refresh issues from API, bypassing cache.\\n406:     /// Updates the cache with the fresh response.\\n407:     pub async fn refresh(&mut self) {\\n408:         self.refreshing = true;\\n409:         self.cache.invalidate(CACHE_KEY_MY_ISSUES);\\n410:         self.fetch_and_cache_issues().await;\\n411:         self.refreshing = false;\\n412:     }\\n413: \\n414:     async fn fetch_and_cache_issues(&mut self) {\\n415:         let selected_id = self.selected_issue().map(|i| i.identifier.clone());\\n416:         if let Ok(issues) = self.api.fetch_my_issues().await {\\n417:             self.cache.insert(CACHE_KEY_MY_ISSUES, issues.clone());\\n418:             self.issues = issues;\\n419:             if let Some(id) = selected_id {\\n420:                 let new_index = self\\n421:                     .filtered_issues()\\n422:                     .iter()\\n423:                     .position(|i| i.identifier == id);\\n424:                 self.selected = new_index.unwrap_or(0);\\n425:             }\\n426:         }\\n427:     }\\n428: }\\n429: \\n430: #[cfg(test)]\\n431: mod tests {\\n432:     use super::*;\\n433:     use crate::api::fake::FakeLinearApi;\\n434: \\n435:     fn app_with_issues() -> App<FakeLinearApi> {\\n436:         let mut app = App::new(FakeLinearApi::new());\\n437:         app.issues = vec![\\n438:             Issue {\\n439:                 id: \\\"1\\\".into(),\\n440:                 identifier: \\\"JEM-1\\\".into(),\\n441:                 title: \\\"Alpha task\\\".into(),\\n442:                 url: Some(\\\"https://linear.app/test/issue/JEM-1\\\".into()),\\n443:                 state: None,\\n444:                 priority: Some(2.0),\\n445:                 project: None,\\n446:                 description: None,\\n447:                 assignee: None,\\n448:                 labels: None,\\n449:                 comments: None,\\n450:             },\\n451:             Issue {\\n452:                 id: \\\"2\\\".into(),\\n453:                 identifier: \\\"JEM-2\\\".into(),\\n454:                 title: \\\"Beta task\\\".into(),\\n455:                 url: Some(\\\"https://linear.app/test/issue/JEM-2\\\".into()),\\n456:                 state: None,\\n457:                 priority: Some(3.0),\\n458:                 project: None,\\n459:                 description: None,\\n460:                 assignee: None,\\n461:                 labels: None,\\n462:                 comments: None,\\n463:             },\\n464:             Issue {\\n465:                 id: \\\"3\\\".into(),\\n466:                 identifier: \\\"JEM-3\\\".into(),\\n467:                 title: \\\"Gamma task\\\".into(),\\n468:                 url: Some(\\\"https://linear.app/test/issue/JEM-3\\\".into()),\\n469:                 state: None,\\n470:                 priority: None,\\n471:                 project: None,\\n472:                 description: None,\\n473:                 assignee: None,\\n474:                 labels: None,\\n475:                 comments: None,\\n476:             },\\n477:         ];\\n478:         app\\n479:     }\\n480: \\n481:     #[test]\\n482:     fn navigation_wraps_at_bounds() {\\n483:         let mut app = app_with_issues();\\n484:         assert_eq!(app.selected, 0);\\n485: \\n486:         app.move_down();\\n487:         assert_eq!(app.selected, 1);\\n488:         app.move_down();\\n489:         assert_eq!(app.selected, 2);\\n490:         app.move_down(); // at bottom, stays\\n491:         assert_eq!(app.selected, 2);\\n492: \\n493:         app.move_up();\\n494:         assert_eq!(app.selected, 1);\\n495:         app.top();\\n496:         assert_eq!(app.selected, 0);\\n497:         app.move_up(); // at top, stays\\n498:         assert_eq!(app.selected, 0);\\n499:     }\\n500: \\n[... omitted lines 501 to 1210 ...]\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01LoGQqnzR5hTHqVfL9tFpG9","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/tests/fixtures/my_issues.json\",\"content\":\"1: {\\n2:   \\\"data\\\": {\\n3:     \\\"issues\\\": {\\n4:       \\\"nodes\\\": [\\n5:         {\\n6:           \\\"id\\\": \\\"issue-1\\\",\\n7:           \\\"identifier\\\": \\\"JEM-1\\\",\\n8:           \\\"title\\\": \\\"First issue\\\",\\n9:           \\\"url\\\": \\\"https://linear.app/test/issue/JEM-1\\\",\\n10:           