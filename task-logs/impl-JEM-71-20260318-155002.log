s.json\");\n        let value: serde_json::Value = serde_json::from_str(fixture).unwrap();\n        let nodes = &value[\"data\"][\"projects\"][\"nodes\"];\n        let projects: Vec<Project> = serde_json::from_value(nodes.clone()).unwrap();\n        assert_eq!(projects.len(), 2);\n        assert_eq!(projects[0].name, \"Alpha Project\");\n        assert_eq!(projects[1].name, \"Beta Project\");\n    }\n\n    #[test]\n    fn deserialize_issues_from_fixture() {"}}],"stop_reason":"tool_use","usage":{"input_tokens":1,"cache_creation_input_tokens":6614,"cache_read_input_tokens":101894,"output_tokens":734,"max_tokens":168000,"service_tier":"standard"}},"parent_tool_use_id":null,"session_id":"T-019cff7e-e369-77bd-9b4c-f08017c4f46c"}
