sue selected\\\"), area);\\n17:             return;\\n18:         }\\n19:     };\\n20: \\n21:     // Metadata fields\\n22:     let label_style = Style::default().fg(Color::DarkGray);\\n23: \\n24:     let mut meta_lines: Vec<Line> = Vec::new();\\n25: \\n26:     meta_lines.push(Line::from(vec![\\n27:         Span::styled(\\\"Status:   \\\", label_style),\\n28:         Span::styled(issue.status_str(), status_style(issue.status_str())),\\n29:     ]));\\n30: \\n31:     meta_lines.push(Line::from(vec![\\n32:         Span::styled(\\\"Priority: \\\", label_style),\\n33:         Span::styled(issue.priority_str(), priority_style(issue.priority_str())),\\n34:     ]));\\n35: \\n36:     meta_lines.push(Line::from(vec![\\n37:         Span::styled(\\\"Project:  \\\", label_style),\\n38:         Span::raw(issue.project_str()),\\n39:     ]));\\n40: \\n41:     let assignee = issue\\n42:         .assignee\\n43:         .as_ref()\\n44:         .map_or(\\\"—\\\", |a| a.name.as_str());\\n45:     meta_lines.push(Line::from(vec![\\n46:         Span::styled(\\\"Assignee: \\\", label_style),\\n47:         Span::raw(assignee),\\n48:     ]));\\n49: \\n50:     let labels_str = issue\\n51:         .labels\\n52:         .as_ref()\\n53:         .map(|l| {\\n54:             l.nodes\\n55:                 .iter()\\n56:                 .map(|l| l.name.as_str())\\n57:                 .collect::<Vec<_>>()\\n58:                 .join(\\\", \\\")\\n59:         })\\n60:         .unwrap_or_default();\\n61:     if !labels_str.is_empty() {\\n62:         meta_lines.push(Line::from(vec![\\n63:             Span::styled(\\\"Labels:   \\\", label_style),\\n64:             Span::raw(labels_str),\\n65:         ]));\\n66:     }\\n67: \\n68:     // +2 for the border top/bottom\\n69:     let meta_height = (meta_lines.len() as u16) + 2;\\n70: \\n71:     // Calculate thread section height\\n72:     let thread_count = app.detail_threads.len();\\n73:     let threads_height = if thread_count > 0 {\\n74:         // header border (1) + each thread line (1 each) + bottom border (1)\\n75:         (thread_count as u16) + 2\\n76:     } else {\\n77:         0\\n78:     };\\n79: \\n80:     let chunks = Layout::vertical([\\n81:         Constraint::Length(meta_height),\\n82:         Constraint::Min(0),\\n83:         Constraint::Length(threads_height),\\n84:         Constraint::Length(1),\\n85:     ])\\n86:     .split(area);\\n87: \\n88:     // Metadata box\\n89:     let title = Line::from(vec![\\n90:         Span::styled(\\n91:             issue.identifier.to_string(),\\n92:             Style::default().fg(Color::Green).add_modifier(Modifier::BOLD),\\n93:         ),\\n94:         Span::raw(format!(\\\" — {}\\\", issue.title)),\\n95:     ]);\\n96:     let meta = Paragraph::new(meta_lines)\\n97:         .block(Block::default().borders(Borders::ALL).title(title));\\n98:     frame.render_widget(meta, chunks[0]);\\n99: \\n100:     // Description / Comments\\n101:     let mut body_lines: Vec<Line> = Vec::new();\\n102: \\n103:     if let Some(desc) = &issue.description {\\n104:         for line in desc.lines() {\\n105:             body_lines.push(Line::raw(line.to_string()));\\n106:         }\\n107:     }\\n108: \\n109:     // Comments\\n110:     if let Some(comments) = &issue.comments\\n111:         && !comments.nodes.is_empty()\\n112:     {\\n113:         if !body_lines.is_empty() {\\n114:             body_lines.push(Line::raw(\\\"\\\"));\\n115:         }\\n116:         body_lines.push(Line::from(Span::styled(\\n117:             format!(\\\"Comments ({})\\\", comments.nodes.len()),\\n118:             Style::default().add_modifier(Modifier::BOLD | Modifier::UNDERLINED),\\n119:         )));\\n120:         body_lines.push(Line::raw(\\\"\\\"));\\n121: \\n122:         for comment in &comments.nodes {\\n123:             let author = comment\\n124:                 .user\\n125:                 .as_ref()\\n126:                 .map_or(\\\"Unknown\\\", |u| u.name.as_str());\\n127:             body_lines.push(Line::from(vec![\\n128:                 Span::styled(\\n129:                     author,\\n130:                     Style::default().fg(Color::Yellow).add_modifier(Modifier::BOLD),\\n131:                 ),\\n132:                 Span::styled(\\n133:                     format!(\\\"  {}\\\", &comment.created_at[..10]),\\n134:                     Style::default().fg(Color::DarkGray),\\n135:                 ),\\n136:             ]));\\n137:             for line in comment.body.lines() {\\n138:                 body_lines.push(Line::raw(format!(\\\"  {}\\\", line)));\\n139:             }\\n140:             body_lines.push(Line::raw(\\\"\\\"));\\n141:         }\\n142:     }\\n143: \\n144:     let content_lines = body_lines.len() as u16;\\n145:     let inner_height = chunks[1].height.saturating_sub(2); // borders\\n146:     let scroll = app.detail_scroll;\\n147: \\n148:     let body_focused = app.detail_section == DetailSection::Body;\\n149:     let body_border_style = if body_focused {\\n150:         Style::default().fg(Color::Cyan)\\n151:     } else {\\n152:         Style::default().fg(Color::DarkGray)\\n153:     };\\n154: \\n155:     let detail = Paragraph::new(body_lines)\\n156:         .block(\\n157:             Block::default()\\n158:                 .borders(Borders::ALL)\\n159:                 .title(\\\"Description\\\")\\n160:                 .border_style(body_border_style),\\n161:         )\\n162:         .wrap(Wrap { trim: false })\\n163:         .scroll((scroll, 0));\\n164: \\n165:     frame.render_widget(detail, chunks[1]);\\n166: \\n167:     app.detail_scroll_max = content_lines.saturating_sub(inner_height);\\n168: \\n169:     // Threads section\\n170:     if thread_count > 0 {\\n171:         let threads_focused = app.detail_section == DetailSection::Threads;\\n172:         let threads_border_style = if threads_focused {\\n173:             Style::default().fg(Color::Cyan)\\n174:         } else {\\n175:             Style::default().fg(Color::DarkGray)\\n176:         };\\n177: \\n178:         let thread_lines: Vec<Line> = app\\n179:             .detail_threads\\n180:             .iter()\\n181:             .enumerate()\\n182:             .map(|(i, t)| {\\n183:                 let is_selected = threads_focused && i == app.detail_thread_selected;\\n184:                 let style = if is_selected {\\n185:                     Style::default().add_modifier(Modifier::REVERSED)\\n186:                 } else {\\n187:                     Style::default()\\n188:                 };\\n189:                 let time_str = t.relative_time();\\n190:                 Line::from(vec![\\n191:                     Span::styled(\\n192:                         format!(\\\"  {} \\\", t.title),\\n193:                         style,\\n194:                     ),\\n195:                     Span::styled(\\n196:                         format!(\\\"({} msgs) \\\", t.message_count),\\n197:                         style.fg(Color::DarkGray),\\n198:                     ),\\n199:                     Span::styled(\\n200:                         time_str,\\n201:                         style.fg(Color::DarkGray),\\n202:                     ),\\n203:                 ])\\n204:             })\\n205:             .collect();\\n206: \\n207:         let threads_block = Paragraph::new(thread_lines).block(\\n208:             Block::default()\\n209:                 .borders(Borders::ALL)\\n210:                 .title(format!(\\\"Threads ({})\\\", thread_count))\\n211:                 .border_style(threads_border_style),\\n212:         );\\n213:         frame.render_widget(threads_block, chunks[2]);\\n214:     }\\n215: \\n216:     // Status bar\\n217:     let key_style = Style::default().fg(Color::Yellow).add_modifier(Modifier::BOLD);\\n218:     let bar = if app.awaiting_quit {\\n219:         Line::from(vec![\\n220:             Span::raw(\\\"Press \\\"),\\n221:             Span::styled(\\\"q\\\", key_style),\\n222:             Span::raw(\\\" again to quit\\\"),\\n223:         ])\\n224:     } else if app.awaiting_open {\\n225:         Line::from(vec![\\n226:             Span::raw(\\\"open in: \\\"),\\n227:             Span::styled(\\\"l\\\", key_style),\\n228:             Span::raw(\\\"inear  \\\"),\\n229:             Span::styled(\\\"g\\\", key_style),\\n230:             Span::raw(\\\"ithub PR\\\"),\\n231:         ])\\n232:     } else if app.detail_section == DetailSection::Threads {\\n233:         Line::from(vec![\\n234:             Span::styled(\\\"Esc\\\", key_style),\\n235:             Span::raw(\\\" back  \\\"),\\n236:             Span::styled(\\\"j\\\", key_style),\\n237:             Span::raw(\\\"/\\\"),\\n238:             Span::styled(\\\"k\\\", key_style),\\n239:             Span::raw(\\\" navigate  \\\"),\\n240:             Span::styled(\\\"Enter\\\", key_style),\\n241:             Span::raw(\\\" continue  \\\"),\\n242:             Span::styled(\\\"a\\\", key_style),\\n243:             Span::raw(\\\" new thread\\\"),\\n244:         ])\\n245:     } else {\\n246:         let mut spans = vec![\\n247:             Span::styled(\\\"Esc\\\", key_style),\\n248:             Span::raw(\\\" back  \\\"),\\n249:             Span::styled(\\\"j\\\", key_style),\\n250:             Span::raw(\\\"/\\\"),\\n251:             Span::styled(\\\"k\\\", key_style),\\n252:             Span::raw(\\\" scroll\\\"),\\n253:         ];\\n254:         if !app.detail_threads.is_empty() {\\n255:             spans.push(Span::raw(\\\"  \\\"));\\n256:             spans.push(Span::styled(\\\"Tab\\\", key_style));\\n257:             spans.push(Span::raw(\\\" threads\\\"));\\n258:         }\\n259:         spans.push(Span::raw(\\\"  \\\"));\\n260:         spans.push(Span::styled(\\\"a\\\", key_style));\\n261:         spans.push(Span::raw(\\\" new thread\\\"));\\n262:         Line::from(spans)\\n263:     };\\n264:     frame.render_widget(Paragraph::new(bar), chunks[3]);\\n265: \\n266:     // Workspace picker modal\\n267:     if let Some(ref picker) = app.workspace_picker {\\n268:         // Extra line for the input row when typing, or the hint row\\n269:         let extra_lines: u16 = 1;\\n270:         let content_lines = picker.options.len() as u16 + extra_lines;\\n271:         let picker_height = (content_lines + 2).min(area.height.saturating_sub(4));\\n272:         let picker_width = picker\\n273:             .options\\n274:             .iter()\\n275:             .map(|s| s.len() as u16)\\n276:             .max()\\n277:             .unwrap_or(20)\\n278:             .max(20)\\n279:             + 4;\\n280:         let picker_width = picker_width.min(area.width.saturating_sub(4));\\n281: \\n282:         let x = area.x + (area.width.saturating_sub(picker_width)) / 2;\\n283:         let y = area.y + (area.height.saturating_sub(picker_height)) / 2;\\n284:         let popup_area = Rect::new(x, y, picker_width, picker_height);\\n285: \\n286:         frame.render_widget(Clear, popup_area);\\n287: \\n288:         let mut lines: Vec<Line> = picker\\n289:             .options\\n290:             .iter()\\n291:             .enumerate()\\n292:             .map(|(i, ws)| {\\n293:                 let style = if !picker.typing && i == picker.selected {\\n294:                     Style::default().add_modifier(Modifier::REVERSED)\\n295:                 } else {\\n296:                     Style::default()\\n297:                 };\\n298:                 Line::from(Span::styled(format!(\\\" {} \\\", ws), style))\\n299:             })\\n300:             .collect();\\n301: \\n302:         if picker.typing {\\n303:             lines.push(Line::from(vec![\\n304:                 Span::raw(\\\" /\\\"),\\n305:                 Span::styled(&picker.input, Style::default().add_modifier(Modifier::BOLD)),\\n306:                 Span::raw(\\\"▏\\\"),\\n307:             ]));\\n308:         } else {\\n309:             let key_style = Style::default().fg(Color::DarkGray);\\n310:             lines.push(Line::from(Span::styled(\\\" / to type a path\\\", key_style)));\\n311:         }\\n312: \\n313:         let popup = Paragraph::new(lines).block(\\n314:             Block::default()\\n315:                 .borders(Borders::ALL)\\n316:                 .title(\\\"Select workspace\\\")\\n317:                 .border_style(Style::default().fg(Color::Cyan)),\\n318:         );\\n319:         frame.render_widget(popup, popup_area);\\n320:     }\\n321: }\\n322: \\n323: fn status_style(status: &str) -> Style {\\n324:     match status {\\n325:         \\\"In Progress\\\" => Style::default().fg(Color::Yellow),\\n326:         \\\"Todo\\\" => Style::default().fg(Color::Cyan),\\n327:         \\\"Done\\\" => Style::default().fg(Color::Green),\\n328:         \\\"Canceled\\\" | \\\"Cancelled\\\" => Style::default().fg(Color::DarkGray),\\n329:         \\\"In Review\\\" => Style::default().fg(Color::Magenta),\\n330:         \\\"Backlog\\\" | \\\"Triage\\\" => Style::default().fg(Color::DarkGray),\\n331:         _ => Style::default(),\\n332:     }\\n333: }\\n334: \\n335: fn priority_style(priority: &str) -> Style {\\n336:     match priority {\\n337:         \\\"Urgent\\\" => Style::default().fg(Color::Red).add_modifier(Modifier::BOLD),\\n338:         \\\"High\\\" => Style::default().fg(Color::Red),\\n339:         \\\"Medium\\\" => Style::default().fg(Color::Yellow),\\n340:         \\\"Low\\\" => Style::default().fg(Color::DarkGray),\\n341:         _ => Style::default(),\\n342:     }\\n343: }\"}","is_error":false}]},"parent_tool_use_id":null,"session_id":"T-019cff7e-e369-77bd-9b4c-f08017c4f46c"}
