        assert_eq!(issue.priority.unwrap(), 2.0);\\n121:     }\\n122: \\n123:     #[test]\\n124:     fn deserialize_issue_without_optional_fields() {\\n125:         let json = r#\\\"{\\n126:             \\\"id\\\": \\\"abc-456\\\",\\n127:             \\\"identifier\\\": \\\"JEM-2\\\",\\n128:             \\\"title\\\": \\\"Minimal issue\\\"\\n129:         }\\\"#;\\n130:         let issue: Issue = serde_json::from_str(json).unwrap();\\n131:         assert_eq!(issue.identifier, \\\"JEM-2\\\");\\n132:         assert!(issue.state.is_none());\\n133:         assert!(issue.priority.is_none());\\n134:     }\\n135: \\n136:     #[test]\\n137:     fn deserialize_issues_from_fixture() {\\n138:         let fixture = include_str!(\\\"../../tests/fixtures/my_issues.json\\\");\\n139:         let value: serde_json::Value = serde_json::from_str(fixture).unwrap();\\n140:         let nodes = &value[\\\"data\\\"][\\\"issues\\\"][\\\"nodes\\\"];\\n141:         let issues: Vec<Issue> = serde_json::from_value(nodes.clone()).unwrap();\\n142:         assert_eq!(issues.len(), 2);\\n143:         assert_eq!(issues[0].identifier, \\\"JEM-1\\\");\\n144:         assert_eq!(issues[1].identifier, \\\"JEM-2\\\");\\n145:     }\\n146: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01JAun7x6DeUN7igfKYcssN8","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/api/client.rs\",\"content\":\"1: use anyhow::Result;\\n2: use reqwest::Client;\\n3: use serde_json::Value;\\n4: \\n5: use super::types::Issue;\\n6: \\n7: const LINEAR_API_URL: &str = \\\"https://api.linear.app/graphql\\\";\\n8: \\n9: const ISSUE_PR_QUERY: &str = r#\\\"\\n10: query($issueId: String!) {\\n11:   issue(id: $issueId) {\\n12:     attachments {\\n13:       nodes {\\n14:         url\\n15:         sourceType\\n16:       }\\n17:     }\\n18:   }\\n19: }\\n20: \\\"#;\\n21: \\n22: const MY_ISSUES_QUERY: &str = r#\\\"\\n23: query {\\n24:   viewer {\\n25:     assignedIssues(\\n26:       first: 50\\n27:       filter: { state: { type: { nin: [\\\"completed\\\", \\\"canceled\\\"] } } }\\n28:       orderBy: updatedAt\\n29:     ) {\\n30:       nodes {\\n31:         id\\n32:         identifier\\n33:         title\\n34:         url\\n35:         state { name }\\n36:         priority\\n37:         project { name }\\n38:         description\\n39:         assignee { name }\\n40:         labels { nodes { name } }\\n41:         comments { nodes { body user { name } createdAt } }\\n42:       }\\n43:     }\\n44:   }\\n45: }\\n46: \\\"#;\\n47: \\n48: pub trait LinearApi: Send + Sync {\\n49:     fn query(\\n50:         &self,\\n51:         query: &str,\\n52:         variables: Option<Value>,\\n53:     ) -> impl std::future::Future<Output = Result<Value>> + Send;\\n54: \\n55:     fn fetch_my_issues(\\n56:         &self,\\n57:     ) -> impl std::future::Future<Output = Result<Vec<Issue>>> + Send;\\n58: \\n59:     fn fetch_pull_request_url(\\n60:         &self,\\n61:         issue_id: &str,\\n62:     ) -> impl std::future::Future<Output = Result<Option<String>>> + Send;\\n63: }\\n64: \\n65: pub struct LinearClient {\\n66:     client: Client,\\n67:     api_key: [REDACTED:api-key],\\n68: }\\n69: \\n70: impl LinearClient {\\n71:     pub fn new(api_key: [REDACTED:api-key]) -> Self {\\n72:         Self {\\n73:             client: Client::new(),\\n74:             api_key,\\n75:         }\\n76:     }\\n77: }\\n78: \\n79: impl LinearApi for LinearClient {\\n80:     async fn query(&self, query: &str, variables: Option<Value>) -> Result<Value> {\\n81:         let mut body = serde_json::json!({ \\\"query\\\": query });\\n82:         if let Some(vars) = variables {\\n83:             body[\\\"variables\\\"] = vars;\\n84:         }\\n85: \\n86:         let resp = self\\n87:             .client\\n88:             .post(LINEAR_API_URL)\\n89:             .header(\\\"Authorization\\\", &self.api_key)\\n90:             .json(&body)\\n91:             .send()\\n92:             .await?\\n93:             .error_for_status()?\\n94:             .json::<Value>()\\n95:             .await?;\\n96: \\n97:         Ok(resp)\\n98:     }\\n99: \\n100:     async fn fetch_my_issues(&self) -> Result<Vec<Issue>> {\\n101:         let resp = self.query(MY_ISSUES_QUERY, None).await?;\\n102:         let issues: Vec<Issue> = serde_json::from_value(\\n103:             resp[\\\"data\\\"][\\\"viewer\\\"][\\\"assignedIssues\\\"][\\\"nodes\\\"].clone(),\\n104:         )?;\\n105:         Ok(issues)\\n106:     }\\n107: \\n108:     async fn fetch_pull_request_url(&self, issue_id: &str) -> Result<Option<String>> {\\n109:         let vars = serde_json::json!({ \\\"issueId\\\": issue_id });\\n110:         let resp = self.query(ISSUE_PR_QUERY, Some(vars)).await?;\\n111:         let nodes = &resp[\\\"data\\\"][\\\"issue\\\"][\\\"attachments\\\"][\\\"nodes\\\"];\\n112:         if let Some(arr) = nodes.as_array() {\\n113:             for node in arr {\\n114:                 if let Some(url) = node[\\\"url\\\"].as_str()\\n115:                     && url.contains(\\\"github.com\\\") && url.contains(\\\"/pull/\\\")\\n116:                 {\\n117:                     return Ok(Some(url.to_string()));\\n118:                 }\\n119:             }\\n120:         }\\n121:         Ok(None)\\n122:     }\\n123: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_015YMuzmDW4yXziFsDNi7mTE","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/api/fake.rs\",\"content\":\"1: use anyhow::Result;\\n2: use serde_json::Value;\\n3: use std::collections::VecDeque;\\n4: use std::sync::Mutex;\\n5: \\n6: use super::client::LinearApi;\\n7: use super::types::Issue;\\n8: \\n9: /// A fake Linear API client for tests and offline development.\\n10: /// Enqueue responses with `push_response`, and they'll be returned in order by `query`.\\n11: /// PR URL responses are enqueued separately with `push_pr_url`.\\n12: pub struct FakeLinearApi {\\n13:     responses: Mutex<VecDeque<Value>>,\\n14:     pr_urls: Mutex<VecDeque<Option<String>>>,\\n15: }\\n16: \\n17: impl FakeLinearApi {\\n18:     pub fn new() -> Self {\\n19:         Self {\\n20:             responses: Mutex::new(VecDeque::new()),\\n21:             pr_urls: Mutex::new(VecDeque::new()),\\n22:         }\\n23:     }\\n24: \\n25:     pub fn push_response(&self, response: Value) {\\n26:         self.responses.lock().unwrap().push_back(response);\\n27:     }\\n28: \\n29:     #[allow(dead_code)]\\n30:     pub fn push_pr_url(&self, url: Option<String>) {\\n31:         self.pr_urls.lock().unwrap().push_back(url);\\n32:     }\\n33: }\\n34: \\n35: impl LinearApi for FakeLinearApi {\\n36:     async fn query(&self, _query: &str, _variables: Option<Value>) -> Result<Value> {\\n37:         let response = self\\n38:             .responses\\n39:             .lock()\\n40:             .unwrap()\\n41:             .pop_front()\\n42:             .unwrap_or_else(|| serde_json::json!({\\\"data\\\": null}));\\n43:         Ok(response)\\n44:     }\\n45: \\n46:     async fn fetch_my_issues(&self) -> Result<Vec<Issue>> {\\n47:         let resp = self.query(\\\"\\\", None).await?;\\n48:         let nodes = &resp[\\\"data\\\"][\\\"issues\\\"][\\\"nodes\\\"];\\n49:         if nodes.is_null() {\\n50:             return Ok(vec![]);\\n51:         }\\n52:         let issues: Vec<Issue> = serde_json::from_value(nodes.clone())?;\\n53:         Ok(issues)\\n54:     }\\n55: \\n56:     async fn fetch_pull_request_url(&self, _issue_id: &str) -> Result<Option<String>> {\\n57:         Ok(self.pr_urls.lock().unwrap().pop_front().flatten())\\n58:     }\\n59: }\\n60: \\n61: #[cfg(test)]\\n62: mod tests {\\n63:     use super::*;\\n64: \\n65:     #[tokio::test]\\n66:     async fn returns_enqueued_responses_in_order() {\\n67:         let fake = FakeLinearApi::new();\\n68:         fake.push_response(serde_json::json!({\\\"data\\\": {\\\"first\\\": true}}));\\n69:         fake.push_response(serde_json::json!({\\\"data\\\": {\\\"second\\\": true}}));\\n70: \\n71:         let r1 = fake.query(\\\"q1\\\", None).await.unwrap();\\n72:         let r2 = fake.query(\\\"q2\\\", None).await.unwrap();\\n73: \\n74:         assert_eq!(r1[\\\"data\\\"][\\\"first\\\"], true);\\n75:         assert_eq!(r2[\\\"data\\\"][\\\"second\\\"], true);\\n76:     }\\n77: \\n78:     #[tokio::test]\\n79:     async fn returns_null_data_when_exhausted() {\\n80:         let fake = FakeLinearApi::new();\\n81:         let r = fake.query(\\\"q\\\", None).await.unwrap();\\n82:         assert!(r[\\\"data\\\"].is_null());\\n83:     }\\n84: \\n85:     #[tokio::test]\\n86:     async fn fetch_my_issues_from_fixture() {\\n87:         let fake = FakeLinearApi::new();\\n88:         let fixture: Value =\\n89:             serde_json::from_str(include_str!(\\\"../../tests/fixtures/my_issues.json\\\")).unwrap();\\n90:         fake.push_response(fixture);\\n91: \\n92:         let issues = fake.fetch_my_issues().await.unwrap();\\n93:         assert_eq!(issues.len(), 2);\\n94:         assert_eq!(issues[0].identifier, \\\"JEM-1\\\");\\n95:         assert_eq!(issues[1].identifier, \\\"JEM-2\\\");\\n96:     }\\n97: \\n98:     #[tokio::test]\\n99:     async fn fetch_my_issues_empty_when_no_data() {\\n100:         let fake = FakeLinearApi::new();\\n101:         let issues = fake.fetch_my_issues().await.unwrap();\\n102:         assert!(issues.is_empty());\\n103:     }\\n104: \\n105:     #[tokio::test]\\n106:     async fn fetch_pull_request_url_returns_enqueued_url() {\\n107:         let fake = FakeLinearApi::new();\\n108:         fake.push_pr_url(Some(\\\"https://github.com/org/repo/pull/42\\\".into()));\\n109: \\n110:         let url = fake.fetch_pull_request_url(\\\"issue-1\\\").await.unwrap();\\n111:         assert_eq!(url, Some(\\\"https://github.com/org/repo/pull/42\\\".into()));\\n112:     }\\n113: \\n114:     #[tokio::test]\\n115:     async fn fetch_pull_request_url_returns_none_when_empty() {\\n116:         let fake = FakeLinearApi::new();\\n117:         let url = fake.fetch_pull_request_url(\\\"issue-1\\\").await.unwrap();\\n118:         assert!(url.is_none());\\n119:     }\\n120: \\n121:     #[tokio::test]\\n122:     async fn fetch_pull_request_url_returns_none_explicitly() {\\n123:         let fake = FakeLinearApi::new();\\n124:         fake.push_pr_url(None);\\n125: \\n126:         let url = fake.fetch_pull_request_url(\\\"issue-1\\\").await.unwrap();\\n127:         assert!(url.is_none());\\n128:     }\\n129: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01MavTk1gL92vh1PPv6xu7Qg","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/api/mod.rs\",\"content\":\"1: pub mod cache;\\n2: pub mod client;\\n3: #[cfg(test)]\\n4: pub mod fake;\\n5: pub mod types;\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01VZBfJPS8xW7xvXLLJi7CHF","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/views/mod.rs\",\"content\":\"1: pub mod my_issues;\\n2: pub mod project;\\n3: pub mod detail;\\n4: pub mod help;\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01W7aQQH3f6Bj4R9gTM5pXWx","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/views/my_issues.rs\",\"content\":\"1: use ratatui::{\\n2:     layout::{Constraint, Layout, Rect},\\n3:     style::{Color, Modifier, Style},\\n4:     text::{Line, Span},\\n5:     widgets::{Block, Borders, Cell, Paragraph, Row, Table, TableState},\\n6:     Frame,\\n7: };\\n8: \\n9: use crate::api::client::LinearApi;\\n10: use crate::app::{App, SortDirection};\\n11: \\n12: pub fn render<A: LinearApi>(frame: &mut Frame, area: Rect, app: &App<A>) {\\n13:     let issues = app.filtered_issues();\\n14: \\n15:     let show_bar = app.refreshing || app.awaiting_quit || app.filtering || app.filter.is_some()\\n16:         || app.awaiting_sort || app.awaiting_filter || app.awaiting_open\\n17:         || app.searching || app.search.is_some();\\n18:     let chunks = if show_bar {\\n19:         Layout::vertical([Constraint::Min(0), Constraint::Length(1)]).split(area)\\n20:     } else {\\n21:         Layout::vertical([Constraint::Min(0)]).split(area)\\n22:     };\\n23: \\n24:     let header = Row::new(vec![\\n25:         Cell::from(\\\"ID\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n26:         Cell::from(\\\"Title\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n27:         Cell::from(\\\"Project\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n28:         Cell::from(\\\"Status\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n29:         Cell::from(\\\"Priority\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n30:     ]);\\n31: \\n32:     let search_query = app.search.as_deref();\\n33: \\n34:     let rows: Vec<Row> = issues\\n35:         .iter()\\n36:         .map(|issue| {\\n37:             Row::new(vec![\\n38:                 Cell::from(Line::from(highlight_match(issue.identifier.as_str(), search_query, Style::default()))),\\n39:                 Cell::from(Line::from(highlight_match(issue.title.as_str(), search_query, Style::default()))),\\n40:                 Cell::from(Line::from(highlight_match(issue.project_str(), search_query, Style::default()))),\\n41:                 Cell::from(Line::from(highlight_match(issue.status_str(), search_query, status_style(issue.status_str())))),\\n42:                 Cell::from(Line::from(highlight_match(issue.priority_str(), search_query, priority_style(issue.priority_str())))),\\n43:             ])\\n44:         })\\n45:         .collect();\\n46: \\n47:     let sort_indicator = match &app.sort {\\n48:         Some((col, dir)) => {\\n49:             let arrow = match dir {\\n50:                 SortDirection::Asc => \\\"↑\\\",\\n51:                 SortDirection::Desc => \\\"↓\\\",\\n52:             };\\n53:             format!(\\\" [sort: {} {}]\\\", col.label(), arrow)\\n54:         }\\n55:         None => String::new(),\\n56:     };\\n57: \\n58:     let search_indicator = match &app.search {\\n59:         Some(q) => format!(\\\" [search: {}]\\\", q),\\n60:         None => String::new(),\\n61:     };\\n62: \\n63:     let title = match &app.filter {\\n64:         Some((col, f)) => format!(\\\"My Issues ({} of {}){}{} [filter: {} = {}]\\\", issues.len(), app.issues.len(), sort_indicator, search_indicator, col.label(), f),\\n65:         None => format!(\\\"My Issues ({}){}{}\\\", issues.len(), sort_indicator, search_indicator),\\n66:     };\\n67: \\n68:     let table = Table::new(\\n69:         rows,\\n70:         [\\n71:             Constraint::Length(10),\\n72:             Constraint::Min(30),\\n73:             Constraint::Length(20),\\n74:             Constraint::Length(15),\\n75:             Constraint::Length(10),\\n76:         ],\\n77:     )\\n78:     .header(header)\\n79:     .block(Block::default().borders(Borders::ALL).title(title))\\n80:     .row_highlight_style(Style::default().add_modifier(Modifier::REVERSED));\\n81: \\n82:     let mut table_state = TableState::default();\\n83:     if !issues.is_empty() {\\n84:         table_state.select(Some(app.selected));\\n85:     }\\n86: \\n87:     frame.render_stateful_widget(table, chunks[0], &mut table_state);\\n88: \\n89:     let key_style = Style::default().fg(Color::Yellow).add_modifier(Modifier::BOLD);\\n90: \\n91:     let column_hints = vec![\\n92:         Span::styled(\\\"i\\\", key_style),\\n93:         Span::raw(\\\"d  \\\"),\\n94:         Span::styled(\\\"t\\\", key_style),\\n95:         Span::raw(\\\"itle  \\\"),\\n96:         Span::styled(\\\"p\\\", key_style),\\n97:         Span::raw(\\\"roject  \\\"),\\n98:         Span::styled(\\\"s\\\", key_style),\\n99:         Span::raw(\\\"tatus  p\\\"),\\n100:         Span::styled(\\\"r\\\", key_style),\\n101:         Span::raw(\\\"iority\\\"),\\n102:     ];\\n103: \\n104:     // Status bar\\n105:     if app.refreshing {\\n106:         let line = Line::from(Span::styled(\\n107:             \\\"Refreshing...\\\",\\n108:             Style::default().fg(Color::Yellow),\\n109:         ));\\n110:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n111:     } else if app.awaiting_quit {\\n112:         let line = Line::from(vec![\\n113:             Span::raw(\\\"Press \\\"),\\n114:             Span::styled(\\\"q\\\", key_style),\\n115:             Span::raw(\\\" again to quit\\\"),\\n116:         ]);\\n117:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n118:     } else if app.awaiting_open {\\n119:         let line = Line::from(vec![\\n120:             Span::raw(\\\"open in: \\\"),\\n121:             Span::styled(\\\"l\\\", key_style),\\n122:             Span::raw(\\\"inear  \\\"),\\n123:             Span::styled(\\\"g\\\", key_style),\\n124:             Span::raw(\\\"ithub PR\\\"),\\n125:         ]);\\n126:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n127:     } else if app.awaiting_sort {\\n128:         let mut spans = vec![Span::raw(\\\"sort by: \\\")];\\n129:         spans.extend(column_hints);\\n130:         frame.render_widget(Paragraph::new(Line::from(spans)), chunks[1]);\\n131:     } else if app.awaiting_filter {\\n132:         let mut spans = vec![Span::raw(\\\"filter by: \\\")];\\n133:         spans.extend(column_hints);\\n134:         frame.render_widget(Paragraph::new(Line::from(spans)), chunks[1]);\\n135:     } else if app.filtering {\\n136:         let prefix = match app.filter_column {\\n137:             Some(ref col) => format!(\\\"[{}] /\\\", col.label()),\\n138:             None => \\\"/\\\".into(),\\n139:         };\\n140:         let line = Line::from(vec![\\n141:             Span::raw(prefix),\\n142:             Span::styled(&app.filter_input, Style::default().add_modifier(Modifier::BOLD)),\\n143:             Span::raw(\\\"▏\\\"),\\n144:         ]);\\n145:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n146:     } else if app.searching {\\n147:         let line = Line::from(vec![\\n148:             Span::raw(\\\"/\\\"),\\n149:             Span::styled(&app.search_input, Style::default().add_modifier(Modifier::BOLD)),\\n150:             Span::raw(\\\"▏\\\"),\\n151:         ]);\\n152:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n153:     } else if app.search.is_some() || app.filter.is_some() {\\n154:         let line = Line::from(vec![\\n155:             Span::raw(\\\"Active — press Esc to clear\\\"),\\n156:         ]);\\n157:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n158:     }\\n159: }\\n160: \\n161: fn highlight_match<'a>(text: &'a str, query: Option<&str>, base_style: Style) -> Vec<Span<'a>> {\\n162:     let query = match query {\\n163:         Some(q) if !q.is_empty() => q,\\n164:         _ => return vec![Span::styled(text, base_style)],\\n165:     };\\n166:     let lower_text = text.to_lowercase();\\n167:     let lower_query = query.to_lowercase();\\n168:     let mut spans = Vec::new();\\n169:     let mut start = 0;\\n170:     while let Some(pos) = lower_text[start..].find(&lower_query) {\\n171:         let abs_pos = start + pos;\\n172:         if abs_pos > start {\\n173:             spans.push(Span::styled(&text[start..abs_pos], base_style));\\n174:         }\\n175:         spans.push(Span::styled(\\n176:             &text[abs_pos..abs_pos + query.len()],\\n177:             base_style.add_modifier(Modifier::BOLD),\\n178:         ));\\n179:         start = abs_pos + query.len();\\n180:     }\\n181:     if start < text.len() {\\n182:         spans.push(Span::styled(&text[start..], base_style));\\n183:     }\\n184:     if spans.is_empty() {\\n185:         spans.push(Span::styled(text, base_style));\\n186:     }\\n187:     spans\\n188: }\\n189: \\n190: fn status_style(status: &str) -> Style {\\n191:     match status {\\n192:         \\\"In Progress\\\" => Style::default().fg(Color::Yellow),\\n193:         \\\"Todo\\\" => Style::default().fg(Color::Cyan),\\n194:         \\\"Done\\\" => Style::default().fg(Color::Green),\\n195:         \\\"Canceled\\\" | \\\"Cancelled\\\" => Style::default().fg(Color::DarkGray),\\n196:         \\\"In Review\\\" => Style::default().fg(Color::Magenta),\\n197:         \\\"Backlog\\\" | \\\"Triage\\\" => Style::default().fg(Color::DarkGray),\\n198:         _ => Style::default(),\\n199:     }\\n200: }\\n201: \\n202: fn priority_style(priority: &str) -> Style {\\n203:     match priority {\\n204:         \\\"Urgent\\\" => Style::default().fg(Color::Red).add_modifier(Modifier::BOLD),\\n205:         \\\"High\\\" => Style::default().fg(Color::Red),\\n206:         \\\"Medium\\\" => Style::default().fg(Color::Yellow),\\n207:         \\\"Low\\\" => Style::default().fg(Color::DarkGray),\\n208:         _ => Style::default(),\\n209:     }\\n210: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01W6UvxfBVig2YS2f4BZvLok","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/views/project.rs\",\"content\":\"1: // Project view — lists issues in a selected project\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_013ufBZGABkTMLJy3xiaj1gq","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/api/cache.rs\",\"content\":\"1: use std::collections::HashMap;\\n2: use std::time::{Duration, Instant};\\n3: \\n4: /// A generic in-memory cache with TTL-based expiry.\\n5: ///\\n6: /// Each entry is stored with a timestamp and expires after the configured TTL.\\n7: /// Expired entries are treated as missing (returning `None` from `get`), but the\\n8: /// stale value can still be retrieved via `get_stale` for background-refresh\\n9: /// patterns.\\n10: #[derive(Debug)]\\n11: pub struct ResponseCache<V> {\\n12:     entries: HashMap<String, CacheEntry<V>>,\\n13:     ttl: Duration,\\n14: }\\n15: \\n16: #[derive(Debug, Clone)]\\n17: struct CacheEntry<V> {\\n18:     value: V,\\n19:     inserted_at: Instant,\\n20: }\\n21: \\n22: #[allow(dead_code)]\\n23: impl<V: Clone> ResponseCache<V> {\\n24:     /// Create a new cache with the given time-to-live for entries.\\n25:     pub fn new(ttl: Duration) -> Self {\\n26:         Self {\\n27:             entries: HashMap::new(),\\n28:             ttl,\\n29:         }\\n30:     }\\n31: \\n32:     /// Insert a value into the cache, replacing any existing entry for the key.\\n33:     pub fn insert(&mut self, key: impl Into<String>, value: V) {\\n34:         self.entries.insert(\\n35:             key.into(),\\n36:             CacheEntry {\\n37:                 value,\\n38:                 inserted_at: Instant::now(),\\n39:             },\\n40:         );\\n41:     }\\n42: \\n43:     /// Get a cached value if it exists and has not expired.\\n44:     pub fn get(&self, key: &str) -> Option<&V> {\\n45:         self.entries.get(key).and_then(|entry| {\\n46:             if entry.inserted_at.elapsed() < self.ttl {\\n47:                 Some(&entry.value)\\n48:             } else {\\n49:                 None\\n50:             }\\n51:         })\\n52:     }\\n53: \\n54:     /// Get a cached value regardless of expiry. Returns `None` only if the key\\n55:     /// was never inserted.\\n56:     pub fn get_stale(&self, key: &str) -> Option<&V> {\\n57:         self.entries.get(key).map(|entry| &entry.value)\\n58:     }\\n59: \\n60:     /// Returns `true` if the key exists and has not expired.\\n61:     pub fn is_fresh(&self, key: &str) -> bool {\\n62:         self.entries\\n63:             .get(key)\\n64:             .is_some_and(|entry| entry.inserted_at.elapsed() < self.ttl)\\n65:     }\\n66: \\n67:     /// Remove a specific entry from the cache.\\n68:     pub fn invalidate(&mut self, key: &str) {\\n69:         self.entries.remove(key);\\n70:     }\\n71: \\n72:     /// Remove all entries from the cache.\\n73:     pub fn clear(&mut self) {\\n74:         self.entries.clear();\\n75:     }\\n76: }\\n77: \\n78: #[cfg(test)]\\n79: mod tests {\\n80:     use super::*;\\n81:     use std::thread;\\n82: \\n83:     #[test]\\n84:     fn insert_and_get_returns_value() {\\n85:         let mut cache = ResponseCache::new(Duration::from_secs(60));\\n86:         cache.insert(\\\"key1\\\", vec![1, 2, 3]);\\n87:         assert_eq!(cache.get(\\\"key1\\\"), Some(&vec![1, 2, 3]));\\n88:     }\\n89: \\n90:     #[test]\\n91:     fn get_returns_none_for_missing_key() {\\n92:         let cache: ResponseCache<String> = ResponseCache::new(Duration::from_secs(60));\\n93:         assert!(cache.get(\\\"missing\\\").is_none());\\n94:     }\\n95: \\n96:     #[test]\\n97:     fn expired_entry_returns_none() {\\n98:         let mut cache = ResponseCache::new(Duration::from_millis(10));\\n99:         cache.insert(\\\"key\\\", \\\"value\\\".to_string());\\n100:         thread::sleep(Duration::from_millis(20));\\n101:         assert!(cache.get(\\\"key\\\").is_none());\\n102:     }\\n103: \\n104:     #[test]\\n105:     fn get_stale_returns_expired_entry() {\\n106:         let mut cache = ResponseCache::new(Duration::from_millis(10));\\n107:         cache.insert(\\\"key\\\", \\\"value\\\".to_string());\\n108:         thread::sleep(Duration::from_millis(20));\\n109:         assert!(cache.get(\\\"key\\\").is_none());\\n110:         assert_eq!(cache.get_stale(\\\"key\\\"), Some(&\\\"value\\\".to_string()));\\n111:     }\\n112: \\n113:     #[test]\\n114:     fn get_stale_returns_none_for_missing_key() {\\n115:         let cache: ResponseCache<String> = ResponseCache::new(Duration::from_secs(60));\\n116:         assert!(cache.get_stale(\\\"missing\\\").is_none());\\n117:     }\\n118: \\n119:     #[test]\\n120:     fn is_fresh_returns_true_for_valid_entry() {\\n121:         let mut cache = ResponseCache::new(Duration::from_secs(60));\\n122:         cache.insert(\\\"key\\\", 42);\\n123:         assert!(cache.is_fresh(\\\"key\\\"));\\n124:     }\\n125: \\n126:     #[test]\\n127:     fn is_fresh_returns_false_for_expired_entry() {\\n128:         let mut cache = ResponseCache::new(Duration::from_millis(10));\\n129:         cache.insert(\\\"key\\\", 42);\\n130:         thread::sleep(Duration::from_millis(20));\\n131:         assert!(!cache.is_fresh(\\\"key\\\"));\\n132:     }\\n133: \\n134:     #[test]\\n135:     fn is_fresh_returns_false_for_missing_key() {\\n136:         let cache: ResponseCache<i32> = ResponseCache::new(Duration::from_secs(60));\\n137:         assert!(!cache.is_fresh(\\\"missing\\\"));\\n138:     }\\n139: \\n140:     #[test]\\n141:     fn insert_replaces_existing_entry() {\\n142:         let mut cache = ResponseCache::new(Duration::from_secs(60));\\n143:         cache.insert(\\\"key\\\", \\\"old\\\".to_string());\\n144:         cache.insert(\\\"key\\\", \\\"new\\\".to_string());\\n145:         assert_eq!(cache.get(\\\"key\\\"), Some(&\\\"new\\\".to_string()));\\n146:     }\\n147: \\n148:     #[test]\\n149:     fn invalidate_removes_entry() {\\n150:         let mut cache = ResponseCache::new(Duration::from_secs(60));\\n151:         cache.insert(\\\"key\\\", 1);\\n152:         cache.invalidate(\\\"key\\\");\\n153:         assert!(cache.get(\\\"key\\\").is_none());\\n154:         assert!(cache.get_stale(\\\"key\\\").is_none());\\n155:     }\\n156: \\n157:     #[test]\\n158:     fn invalidate_nonexistent_key_is_no_op() {\\n159:         let mut cache: ResponseCache<i32> = ResponseCache::new(Duration::from_secs(60));\\n160:         cache.invalidate(\\\"missing\\\"); // should not panic\\n161:     }\\n162: \\n163:     #[test]\\n164:     fn clear_removes_all_entries() {\\n165:         let mut cache = ResponseCache::new(Duration::from_secs(60));\\n166:         cache.insert(\\\"a\\\", 1);\\n167:         cache.insert(\\\"b\\\", 2);\\n168:         cache.clear();\\n169:         assert!(cache.get(\\\"a\\\").is_none());\\n170:         assert!(cache.get(\\\"b\\\").is_none());\\n171:     }\\n172: \\n173:     #[test]\\n174:     fn multiple_keys_independent() {\\n175:         let mut cache = ResponseCache::new(Duration::from_secs(60));\\n176:         cache.insert(\\\"a\\\", 1);\\n177:         cache.insert(\\\"b\\\", 2);\\n178:         assert_eq!(cache.get(\\\"a\\\"), Some(&1));\\n179:         assert_eq!(cache.get(\\\"b\\\"), Some(&2));\\n180:         cache.invalidate(\\\"a\\\");\\n181:         assert!(cache.get(\\\"a\\\").is_none());\\n182:         assert_eq!(cache.get(\\\"b\\\"), Some(&2));\\n183:     }\\n184: \\n185:     #[test]\\n186:     fn insert_refreshes_ttl() {\\n187:         let mut cache = ResponseCache::new(Duration::from_millis(50));\\n188:         cache.insert(\\\"key\\\", \\\"v1\\\".to_string());\\n189:         thread::sleep(Duration::from_millis(30));\\n190:         // Re-insert before expiry to refresh TTL\\n191:         cache.insert(\\\"key\\\", \\\"v2\\\".to_string());\\n192:         thread::sleep(Duration::from_millis(30));\\n193:         // Should still be fresh because we re-inserted\\n194:         assert_eq!(cache.get(\\\"key\\\"), Some(&\\\"v2\\\".to_string()));\\n195:     }\\n196: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01D7WtMRau67bM6vFyokpPyZ","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/tests/fixtures\",\"content\":\"issue_detail.json\\nmy_issues.json\",\"isDirectory\":true,\"directoryEntries\":[\"issue_detail.json\",\"my_issues.json\"]}","is_error":false}]},"parent_tool_use_id":null,"session_id":"T-019cff7e-e369-77bd-9b4c-f08017c4f46c"}
