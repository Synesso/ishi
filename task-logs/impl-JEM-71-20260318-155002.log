{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"toolu_vrtx_01AsLphLYcReRTBEGRGQw5Gt","content":"[{\"type\":\"text\",\"text\":\"{\\\"id\\\":\\\"JEM-71\\\",\\\"title\\\":\\\"Project list view\\\",\\\"description\\\":\\\"Fetch and display projects. Show project name, status, lead, progress. Vim nav to select. Enter to drill into project issues.\\\",\\\"projectMilestone\\\":{\\\"id\\\":\\\"016fb7fc-45da-4a8f-b46e-ffde607cfea9\\\",\\\"name\\\":\\\"Phase 3: Project View\\\"},\\\"url\\\":\\\"https://linear.app/squareup/issue/JEM-71\\\",\\\"gitBranchName\\\":\\\"jmawson/jem-71-project-list-view\\\",\\\"createdAt\\\":\\\"2026-03-18T01:37:25.147Z\\\",\\\"updatedAt\\\":\\\"2026-03-18T05:50:44.836Z\\\",\\\"archivedAt\\\":null,\\\"completedAt\\\":null,\\\"dueDate\\\":null,\\\"slaStartedAt\\\":null,\\\"slaMediumRiskAt\\\":null,\\\"slaHighRiskAt\\\":null,\\\"slaBreachesAt\\\":null,\\\"slaType\\\":\\\"all\\\",\\\"status\\\":\\\"In Progress\\\",\\\"labels\\\":[],\\\"attachments\\\":[],\\\"documents\\\":[],\\\"createdBy\\\":\\\"Jeremy Mawson\\\",\\\"createdById\\\":\\\"f265a57f-26ba-4ba6-a014-a1414e9067c4\\\",\\\"assignee\\\":\\\"Jeremy Mawson\\\",\\\"assigneeId\\\":\\\"f265a57f-26ba-4ba6-a014-a1414e9067c4\\\",\\\"project\\\":\\\"ishi\\\",\\\"projectId\\\":\\\"032af957-d258-43a4-9cac-246a45582daa\\\",\\\"team\\\":\\\"Jem\\\",\\\"teamId\\\":\\\"3dddde93-b00c-4573-a596-2475a0f69d3a\\\"}\"}]","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01LHdqhJmkkbatMPNrwsdTzk","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/app.rs\",\"content\":\"1: use std::cmp::Ordering;\\n2: use std::time::Duration;\\n3: \\n4: use crate::amp::thread::ThreadSummary;\\n5: use crate::api::cache::ResponseCache;\\n6: use crate::api::client::LinearApi;\\n7: use crate::api::types::Issue;\\n8: \\n9: const CACHE_TTL_SECS: u64 = 300; // 5 minutes\\n10: const CACHE_KEY_MY_ISSUES: &str = \\\"my_issues\\\";\\n11: \\n12: #[derive(Debug, Clone, Copy, PartialEq, Eq)]\\n13: pub enum DetailSection {\\n14:     Body,\\n15:     Threads,\\n16: }\\n17: \\n18: #[allow(dead_code)]\\n19: pub enum View {\\n20:     MyIssues,\\n21:     Project,\\n22:     Detail,\\n23: }\\n24: \\n25: /// State for the workspace picker modal shown when starting a new Amp thread.\\n26: #[derive(Debug, Clone)]\\n27: pub struct WorkspacePicker {\\n28:     pub options: Vec<String>,\\n29:     pub selected: usize,\\n30:     /// When true, the user is typing a new workspace path via `/`.\\n31:     pub typing: bool,\\n32:     /// Buffer for the path being typed.\\n33:     pub input: String,\\n34: }\\n35: \\n36: #[allow(dead_code)]\\n37: impl WorkspacePicker {\\n38:     pub fn new(options: Vec<String>) -> Self {\\n39:         Self {\\n40:             options,\\n41:             selected: 0,\\n42:             typing: false,\\n43:             input: String::new(),\\n44:         }\\n45:     }\\n46: \\n47:     pub fn move_down(&mut self) {\\n48:         if !self.options.is_empty() && self.selected < self.options.len() - 1 {\\n49:             self.selected += 1;\\n50:         }\\n51:     }\\n52: \\n53:     pub fn move_up(&mut self) {\\n54:         if self.selected > 0 {\\n55:             self.selected -= 1;\\n56:         }\\n57:     }\\n58: \\n59:     pub fn selected_workspace(&self) -> Option<&str> {\\n60:         self.options.get(self.selected).map(|s| s.as_str())\\n61:     }\\n62: \\n63:     pub fn start_typing(&mut self) {\\n64:         self.typing = true;\\n65:         self.input.clear();\\n66:     }\\n67: \\n68:     pub fn cancel_typing(&mut self) {\\n69:         self.typing = false;\\n70:         self.input.clear();\\n71:     }\\n72: \\n73:     /// Confirm the typed path. Returns the entered path if non-empty.\\n74:     pub fn confirm_typed_path(&mut self) -> Option<String> {\\n75:         self.typing = false;\\n76:         let path = self.input.trim().to_string();\\n77:         self.input.clear();\\n78:         if path.is_empty() {\\n79:             None\\n80:         } else {\\n81:             Some(path)\\n82:         }\\n83:     }\\n84: }\\n85: \\n86: #[derive(Debug, Clone, Copy, PartialEq, Eq)]\\n87: pub enum SortColumn {\\n88:     Identifier,\\n89:     Title,\\n90:     Project,\\n91:     Status,\\n92:     Priority,\\n93: }\\n94: \\n95: impl SortColumn {\\n96:     pub fn label(&self) -> &'static str {\\n97:         match self {\\n98:             SortColumn::Identifier => \\\"ID\\\",\\n99:             SortColumn::Title => \\\"Title\\\",\\n100:             SortColumn::Project => \\\"Project\\\",\\n101:             SortColumn::Status => \\\"Status\\\",\\n102:             SortColumn::Priority => \\\"Priority\\\",\\n103:         }\\n104:     }\\n105: }\\n106: \\n107: #[derive(Debug, Clone, Copy, PartialEq, Eq)]\\n108: pub enum SortDirection {\\n109:     Asc,\\n110:     Desc,\\n111: }\\n112: \\n113: impl SortDirection {\\n114:     pub fn toggle(self) -> Self {\\n115:         match self {\\n116:             SortDirection::Asc => SortDirection::Desc,\\n117:             SortDirection::Desc => SortDirection::Asc,\\n118:         }\\n119:     }\\n120: }\\n121: \\n122: pub struct App<A: LinearApi> {\\n123:     pub running: bool,\\n124:     pub view: View,\\n125:     pub api: A,\\n126:     pub issues: Vec<Issue>,\\n127:     pub selected: usize,\\n128:     pub filter: Option<(SortColumn, String)>,\\n129:     pub filter_input: String,\\n130:     pub filter_column: Option<SortColumn>,\\n131:     pub filtering: bool,\\n132:     pub awaiting_quit: bool,\\n133:     pub awaiting_filter: bool,\\n134:     pub awaiting_sort: bool,\\n135:     pub awaiting_open: bool,\\n136:     pub sort: Option<(SortColumn, SortDirection)>,\\n137:     pub search: Option<String>,\\n138:     pub search_input: String,\\n139:     pub searching: bool,\\n140:     pub detail_scroll: u16,\\n141:     pub detail_scroll_max: u16,\\n142:     pub refreshing: bool,\\n143:     pub detail_section: DetailSection,\\n144:     pub detail_threads: Vec<ThreadSummary>,\\n145:     pub detail_thread_selected: usize,\\n146:     pub workspace_picker: Option<WorkspacePicker>,\\n147:     pub show_help: bool,\\n148:     pub cache: ResponseCache<Vec<Issue>>,\\n149: }\\n150: \\n151: impl<A: LinearApi> App<A> {\\n152:     pub fn new(api: A) -> Self {\\n153:         Self {\\n154:             running: true,\\n155:             view: View::MyIssues,\\n156:             api,\\n157:             issues: Vec::new(),\\n158:             selected: 0,\\n159:             filter: None,\\n160:             filter_input: String::new(),\\n161:             filter_column: None,\\n162:             filtering: false,\\n163:             awaiting_quit: false,\\n164:             awaiting_filter: false,\\n165:             awaiting_sort: false,\\n166:             awaiting_open: false,\\n167:             sort: None,\\n168:             search: None,\\n169:             search_input: String::new(),\\n170:             searching: false,\\n171:             detail_scroll: 0,\\n172:             detail_scroll_max: 0,\\n173:             refreshing: false,\\n174:             detail_section: DetailSection::Body,\\n175:             detail_threads: Vec::new(),\\n176:             detail_thread_selected: 0,\\n177:             workspace_picker: None,\\n178:             show_help: false,\\n179:             cache: ResponseCache::new(Duration::from_secs(CACHE_TTL_SECS)),\\n180:         }\\n181:     }\\n182: \\n183:     pub fn filtered_issues(&self) -> Vec<&Issue> {\\n184:         let mut issues: Vec<&Issue> = self.issues.iter().collect();\\n185:         if let Some((col, f)) = &self.filter {\\n186:             let lower = f.to_lowercase();\\n187:             issues.retain(|i| {\\n188:                 let value = match col {\\n189:                     SortColumn::Identifier => i.identifier.as_str(),\\n190:                     SortColumn::Title => i.title.as_str(),\\n191:                     SortColumn::Project => i.project_str(),\\n192:                     SortColumn::Status => i.status_str(),\\n193:                     SortColumn::Priority => i.priority_str(),\\n194:                 };\\n195:                 value.to_lowercase().contains(&lower)\\n196:             });\\n197:         }\\n198:         if let Some(q) = &self.search {\\n199:             let lower = q.to_lowercase();\\n200:             issues.retain(|i| i.matches_search(&lower));\\n201:         }\\n202:         if let Some((col, dir)) = &self.sort {\\n203:             issues.sort_by(|a, b| {\\n204:                 let ord = match col {\\n205:                     SortColumn::Identifier => a.identifier.cmp(&b.identifier),\\n206:                     SortColumn::Title => a.title.to_lowercase().cmp(&b.title.to_lowercase()),\\n207:                     SortColumn::Project => a.project_str().cmp(b.project_str()),\\n208:                     SortColumn::Status => a.status_str().cmp(b.status_str()),\\n209:                     SortColumn::Priority => a.priority.partial_cmp(&b.priority).unwrap_or(Ordering::Equal),\\n210:                 };\\n211:                 match dir {\\n212:                     SortDirection::Asc => ord,\\n213:                     SortDirection::Desc => ord.reverse(),\\n214:                 }\\n215:             });\\n216:         }\\n217:         issues\\n218:     }\\n219: \\n220:     pub fn set_sort(&mut self, col: SortColumn) {\\n221:         self.sort = Some(match self.sort {\\n222:             Some((c, dir)) if c == col => (col, dir.toggle()),\\n223:             _ => (col, SortDirection::Asc),\\n224:         });\\n225:         self.selected = 0;\\n226:     }\\n227: \\n228:     pub fn move_down(&mut self) {\\n229:         let len = self.filtered_issues().len();\\n230:         if len > 0 && self.selected < len - 1 {\\n231:             self.selected += 1;\\n232:         }\\n233:     }\\n234: \\n235:     pub fn move_up(&mut self) {\\n236:         if self.selected > 0 {\\n237:             self.selected -= 1;\\n238:         }\\n239:     }\\n240: \\n241:     pub fn top(&mut self) {\\n242:         self.selected = 0;\\n243:     }\\n244: \\n245:     pub fn bottom(&mut self) {\\n246:         let len = self.filtered_issues().len();\\n247:         if len > 0 {\\n248:             self.selected = len - 1;\\n249:         }\\n250:     }\\n[... omitted lines 251 to 960 ...]\\n961:     }\\n962: \\n963:     #[test]\\n964:     fn workspace_picker_start_typing() {\\n965:         let mut picker = WorkspacePicker::new(vec![\\\"/a\\\".into()]);\\n966:         assert!(!picker.typing);\\n967: \\n968:         picker.start_typing();\\n969:         assert!(picker.typing);\\n970:         assert!(picker.input.is_empty());\\n971:     }\\n972: \\n973:     #[test]\\n974:     fn workspace_picker_cancel_typing() {\\n975:         let mut picker = WorkspacePicker::new(vec![\\\"/a\\\".into()]);\\n976:         picker.start_typing();\\n977:         picker.input.push_str(\\\"/some/path\\\");\\n978:         picker.cancel_typing();\\n979: \\n980:         assert!(!picker.typing);\\n981:         assert!(picker.input.is_empty());\\n982:     }\\n983: \\n984:     #[test]\\n985:     fn workspace_picker_confirm_typed_path_returns_path() {\\n986:         let mut picker = WorkspacePicker::new(vec![]);\\n987:         picker.start_typing();\\n988:         picker.input.push_str(\\\"/my/workspace\\\");\\n989: \\n990:         let result = picker.confirm_typed_path();\\n991:         assert_eq!(result, Some(\\\"/my/workspace\\\".to_string()));\\n992:         assert!(!picker.typing);\\n993:         assert!(picker.input.is_empty());\\n994:     }\\n995: \\n996:     #[test]\\n997:     fn workspace_picker_confirm_typed_path_trims_whitespace() {\\n998:         let mut picker = WorkspacePicker::new(vec![]);\\n999:         picker.start_typing();\\n1000:         picker.input.push_str(\\\"  /my/workspace  \\\");\\n1001: \\n1002:         let result = picker.confirm_typed_path();\\n1003:         assert_eq!(result, Some(\\\"/my/workspace\\\".to_string()));\\n1004:     }\\n1005: \\n1006:     #[test]\\n1007:     fn workspace_picker_confirm_empty_path_returns_none() {\\n1008:         let mut picker = WorkspacePicker::new(vec![]);\\n1009:         picker.start_typing();\\n1010: \\n1011:         let result = picker.confirm_typed_path();\\n1012:         assert!(result.is_none());\\n1013:         assert!(!picker.typing);\\n1014:     }\\n1015: \\n1016:     #[test]\\n1017:     fn workspace_picker_confirm_whitespace_only_returns_none() {\\n1018:         let mut picker = WorkspacePicker::new(vec![]);\\n1019:         picker.start_typing();\\n1020:         picker.input.push_str(\\\"   \\\");\\n1021: \\n1022:         let result = picker.confirm_typed_path();\\n1023:         assert!(result.is_none());\\n1024:     }\\n1025: \\n1026:     #[test]\\n1027:     fn workspace_picker_typing_does_not_highlight_list() {\\n1028:         let mut picker = WorkspacePicker::new(vec![\\\"/a\\\".into(), \\\"/b\\\".into()]);\\n1029:         assert!(!picker.typing);\\n1030:         // When not typing, selected item is highlighted (tested by selected_workspace)\\n1031:         assert_eq!(picker.selected_workspace(), Some(\\\"/a\\\"));\\n1032: \\n1033:         picker.start_typing();\\n1034:         // selected_workspace still returns the same, but the UI won't highlight it\\n1035:         // (the typing flag tells the renderer to suppress highlight)\\n1036:         assert!(picker.typing);\\n1037:         assert_eq!(picker.selected, 0);\\n1038:     }\\n1039: \\n1040:     #[test]\\n1041:     fn workspace_picker_typing_input_accumulates() {\\n1042:         let mut picker = WorkspacePicker::new(vec![]);\\n1043:         picker.start_typing();\\n1044:         picker.input.push('/');\\n1045:         picker.input.push('h');\\n1046:         picker.input.push('o');\\n1047:         picker.input.push('m');\\n1048:         picker.input.push('e');\\n1049:         assert_eq!(picker.input, \\\"/home\\\");\\n1050: \\n1051:         picker.input.pop();\\n1052:         assert_eq!(picker.input, \\\"/hom\\\");\\n1053:     }\\n1054: \\n1055:     #[test]\\n1056:     fn selected_issue_url_returns_url() {\\n1057:         let app = app_with_issues();\\n1058:         assert_eq!(\\n1059:             app.selected_issue_url(),\\n1060:             Some(\\\"https://linear.app/test/issue/JEM-1\\\".into())\\n1061:         );\\n1062:     }\\n1063: \\n1064:     #[test]\\n1065:     fn selected_issue_url_returns_none_when_no_issues() {\\n1066:         let app = App::new(FakeLinearApi::new());\\n1067:         assert!(app.selected_issue_url().is_none());\\n1068:     }\\n1069: \\n1070:     #[test]\\n1071:     fn selected_issue_url_returns_none_when_url_missing() {\\n1072:         let mut app = App::new(FakeLinearApi::new());\\n1073:         app.issues = vec![Issue {\\n1074:             id: \\\"1\\\".into(),\\n1075:             identifier: \\\"JEM-1\\\".into(),\\n1076:             title: \\\"No URL\\\".into(),\\n1077:             url: None,\\n1078:             state: None,\\n1079:             priority: None,\\n1080:             project: None,\\n1081:             description: None,\\n1082:             assignee: None,\\n1083:             labels: None,\\n1084:             comments: None,\\n1085:         }];\\n1086:         assert!(app.selected_issue_url().is_none());\\n1087:     }\\n1088: \\n1089:     #[test]\\n1090:     fn awaiting_open_defaults_to_false() {\\n1091:         let app = app_with_issues();\\n1092:         assert!(!app.awaiting_open);\\n1093:     }\\n1094: \\n1095:     #[test]\\n1096:     fn show_help_defaults_to_false() {\\n1097:         let app = app_with_issues();\\n1098:         assert!(!app.show_help);\\n1099:     }\\n1100: \\n1101:     #[test]\\n1102:     fn toggle_help_shows_and_hides() {\\n1103:         let mut app = app_with_issues();\\n1104:         assert!(!app.show_help);\\n1105: \\n1106:         app.toggle_help();\\n1107:         assert!(app.show_help);\\n1108: \\n1109:         app.toggle_help();\\n1110:         assert!(!app.show_help);\\n1111:     }\\n1112: \\n1113:     #[test]\\n1114:     fn dismiss_help_hides_overlay() {\\n1115:         let mut app = app_with_issues();\\n1116:         app.toggle_help();\\n1117:         assert!(app.show_help);\\n1118: \\n1119:         app.dismiss_help();\\n1120:         assert!(!app.show_help);\\n1121:     }\\n1122: \\n1123:     #[test]\\n1124:     fn dismiss_help_is_idempotent() {\\n1125:         let mut app = app_with_issues();\\n1126:         app.dismiss_help();\\n1127:         assert!(!app.show_help);\\n1128:     }\\n1129: \\n1130:     #[tokio::test]\\n1131:     async fn load_issues_fetches_on_empty_cache() {\\n1132:         let fake = FakeLinearApi::new();\\n1133:         let fixture: serde_json::Value =\\n1134:             serde_json::from_str(include_str!(\\\"../tests/fixtures/my_issues.json\\\")).unwrap();\\n1135:         fake.push_response(fixture);\\n1136:         let mut app = App::new(fake);\\n1137: \\n1138:         assert!(app.issues.is_empty());\\n1139:         app.load_issues().await;\\n1140:         assert_eq!(app.issues.len(), 2);\\n1141:         assert!(app.cache.is_fresh(CACHE_KEY_MY_ISSUES));\\n1142:     }\\n1143: \\n1144:     #[tokio::test]\\n1145:     async fn load_issues_serves_from_cache() {\\n1146:         let fake = FakeLinearApi::new();\\n1147:         // Enqueue only one response — second call should come from cache\\n1148:         let fixture: serde_json::Value =\\n1149:             serde_json::from_str(include_str!(\\\"../tests/fixtures/my_issues.json\\\")).unwrap();\\n1150:         fake.push_response(fixture);\\n1151:         let mut app = App::new(fake);\\n1152: \\n1153:         app.load_issues().await;\\n1154:         assert_eq!(app.issues.len(), 2);\\n1155: \\n1156:         // Clear issues, then load again — should restore from cache\\n1157:         app.issues.clear();\\n1158:         app.load_issues().await;\\n1159:         assert_eq!(app.issues.len(), 2);\\n1160:     }\\n1161: \\n1162:     #[tokio::test]\\n1163:     async fn refresh_bypasses_cache() {\\n1164:         let fake = FakeLinearApi::new();\\n1165:         let fixture: serde_json::Value =\\n1166:             serde_json::from_str(include_str!(\\\"../tests/fixtures/my_issues.json\\\")).unwrap();\\n1167:         fake.push_response(fixture.clone());\\n1168:         fake.push_response(fixture);\\n1169:         let mut app = App::new(fake);\\n1170: \\n1171:         app.load_issues().await;\\n1172:         assert_eq!(app.issues.len(), 2);\\n1173: \\n1174:         // Refresh should hit the API again (second enqueued response)\\n1175:         app.refresh().await;\\n1176:         assert_eq!(app.issues.len(), 2);\\n1177:         assert!(app.cache.is_fresh(CACHE_KEY_MY_ISSUES));\\n1178:     }\\n1179: \\n1180:     #[tokio::test]\\n1181:     async fn refresh_updates_cache() {\\n1182:         let fake = FakeLinearApi::new();\\n1183:         let fixture: serde_json::Value =\\n1184:             serde_json::from_str(include_str!(\\\"../tests/fixtures/my_issues.json\\\")).unwrap();\\n1185:         fake.push_response(fixture);\\n1186:         let mut app = App::new(fake);\\n1187: \\n1188:         app.load_issues().await;\\n1189:         assert_eq!(app.issues.len(), 2);\\n1190:         assert!(app.cache.is_fresh(CACHE_KEY_MY_ISSUES));\\n1191:     }\\n1192: \\n1193:     #[tokio::test]\\n1194:     async fn refresh_on_api_error_preserves_cache() {\\n1195:         let fake = FakeLinearApi::new();\\n1196:         let fixture: serde_json::Value =\\n1197:             serde_json::from_str(include_str!(\\\"../tests/fixtures/my_issues.json\\\")).unwrap();\\n1198:         fake.push_response(fixture);\\n1199:         let mut app = App::new(fake);\\n1200: \\n1201:         app.load_issues().await;\\n1202:         assert_eq!(app.issues.len(), 2);\\n1203: \\n1204:         // Refresh with no enqueued response (will get null data → empty)\\n1205:         // But since fetch returns Ok([]) for null data, issues will be replaced\\n1206:         app.refresh().await;\\n1207:         // After refresh with empty result, cache should have the empty result\\n1208:         assert!(app.cache.is_fresh(CACHE_KEY_MY_ISSUES));\\n1209:     }\\n1210: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_015C2pYaCoW7vDviubVY9Ghw","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/main.rs\",\"content\":\"1: mod amp;\\n2: mod api;\\n3: mod app;\\n4: mod config;\\n5: mod keys;\\n6: mod suspend;\\n7: mod views;\\n8: \\n9: use anyhow::Result;\\n10: use api::client::{LinearApi, LinearClient};\\n11: use app::App;\\n12: use crossterm::{\\n13:     event::{self, Event, KeyCode},\\n14:     terminal::{disable_raw_mode, enable_raw_mode, EnterAlternateScreen, LeaveAlternateScreen},\\n15:     ExecutableCommand,\\n16: };\\n17: use ratatui::{prelude::CrosstermBackend, Terminal};\\n18: use std::io::stdout;\\n19: use std::path::Path;\\n20: use std::collections::HashSet;\\n21: \\n22: /// Look up the workspace for a thread from the state file, then run\\n23: /// `amp threads continue <thread_id>` in that workspace directory,\\n24: /// suspending and restoring the TUI around the external process.\\n25: fn continue_thread(thread_id: &str) -> Result<()> {\\n26:     let state_path = amp::state::state_path()?;\\n27:     let state = amp::state::State::load(&state_path)?;\\n28:     let workspace = state\\n29:         .workspace_for(thread_id)\\n30:         .ok_or_else(|| anyhow::anyhow!(\\\"no workspace recorded for thread {}\\\", thread_id))?;\\n31:     let workspace_path = Path::new(workspace);\\n32:     suspend::run_external_command(\\\"amp\\\", &[\\\"threads\\\", \\\"continue\\\", thread_id], workspace_path)?;\\n33:     Ok(())\\n34: }\\n35: \\n36: fn load_threads_for_issue(app: &mut App<impl LinearApi>, identifier: &str) {\\n37:     let state_path = match amp::state::state_path() {\\n38:         Ok(p) => p,\\n39:         Err(_) => return,\\n40:     };\\n41:     let state = match amp::state::State::load(&state_path) {\\n42:         Ok(s) => s,\\n43:         Err(_) => return,\\n44:     };\\n45:     let thread_ids: Vec<String> = state\\n46:         .threads_for_issue(identifier)\\n47:         .into_iter()\\n48:         .map(|s| s.to_string())\\n49:         .collect();\\n50:     if thread_ids.is_empty() {\\n51:         app.detail_threads.clear();\\n52:         return;\\n53:     }\\n54:     let threads_dir = match amp::thread::amp_threads_dir() {\\n55:         Some(d) => d,\\n56:         None => return,\\n57:     };\\n58:     app.detail_threads = amp::thread::load_thread_summaries(&threads_dir, &thread_ids);\\n59:     app.detail_thread_selected = 0;\\n60: }\\n61: \\n62: /// Open the workspace picker for the current issue.\\n63: /// Loads workspace history from state and populates the picker.\\n64: fn open_workspace_picker(app: &mut App<impl LinearApi>) {\\n65:     let state_path = match amp::state::state_path() {\\n66:         Ok(p) => p,\\n67:         Err(_) => return,\\n68:     };\\n69:     let state = match amp::state::State::load(&state_path) {\\n70:         Ok(s) => s,\\n71:         Err(_) => return,\\n72:     };\\n73:     let workspaces: Vec<String> = state.workspaces().to_vec();\\n74:     app.show_workspace_picker(workspaces);\\n75: }\\n76: \\n77: /// Execute the new-thread flow:\\n78: /// 1. Snapshot thread IDs\\n79: /// 2. Suspend TUI and run `amp threads new` in the chosen workspace\\n80: /// 3. Diff thread IDs to detect the new thread\\n81: /// 4. If found, save thread link and update workspace history\\n82: fn start_new_thread(\\n83:     issue_identifier: &str,\\n84:     workspace: &str,\\n85:     before_ids: &HashSet<String>,\\n86: ) -> Result<()> {\\n87:     let workspace_path = Path::new(workspace);\\n88:     suspend::run_external_command(\\\"amp\\\", &[\\\"threads\\\", \\\"new\\\"], workspace_path)?;\\n89: \\n90:     // Diff thread IDs to find the newly created thread\\n91:     let threads_dir = match amp::thread::amp_threads_dir() {\\n92:         Some(d) => d,\\n93:         None => return Ok(()),\\n94:     };\\n95:     let after_ids = amp::thread::snapshot_thread_ids(&threads_dir);\\n96:     let new_ids: Vec<&String> = after_ids.difference(before_ids).collect();\\n97: \\n98:     if let Some(new_thread_id) = new_ids.first() {\\n99:         let state_path = amp::state::state_path()?;\\n100:         let mut state = amp::state::State::load(&state_path)?;\\n101:         state.add_thread_link(new_thread_id, issue_identifier, workspace);\\n102:         state.add_workspace(workspace);\\n103:         state.save(&state_path)?;\\n104:     }\\n105: \\n106:     Ok(())\\n107: }\\n108: \\n109: #[tokio::main]\\n110: async fn main() -> Result<()> {\\n111:     let api_key = config::resolve_api_key()?;\\n112:     let client = LinearClient::new(api_key);\\n113:     let mut app = App::new(client);\\n114: \\n115:     // Fetch issues before entering TUI (populates cache)\\n116:     app.load_issues().await;\\n117: \\n118:     // Terminal setup\\n119:     enable_raw_mode()?;\\n120:     stdout().execute(EnterAlternateScreen)?;\\n121:     let mut terminal = Terminal::new(CrosstermBackend::new(stdout()))?;\\n122: \\n123:     // Main loop\\n124:     while app.running {\\n125:         terminal.draw(|frame| {\\n126:             let area = frame.area();\\n127:             match app.view {\\n128:                 app::View::MyIssues => views::my_issues::render(frame, area, &app),\\n129:                 app::View::Detail => views::detail::render(frame, area, &mut app),\\n130:                 _ => {\\n131:                     frame.render_widget(\\n132:                         ratatui::widgets::Paragraph::new(\\\"ishi — (view not implemented)\\\"),\\n133:                         area,\\n134:                     );\\n135:                 }\\n136:             }\\n137:             if app.show_help {\\n138:                 views::help::render(frame, area);\\n139:             }\\n140:         })?;\\n141: \\n142:         if event::poll(std::time::Duration::from_millis(100))?\\n143:             && let Event::Key(key) = event::read()?\\n144:         {\\n145:             if app.show_help {\\n146:                 match key.code {\\n147:                     KeyCode::Esc | KeyCode::Char('?') => app.dismiss_help(),\\n148:                     _ => {}\\n149:                 }\\n150:             } else if app.workspace_picker.is_some() {\\n151:                 let is_typing = app.workspace_picker.as_ref().is_some_and(|p| p.typing);\\n152:                 if is_typing {\\n153:                     match key.code {\\n154:                         KeyCode::Enter => {\\n155:                             let typed_path = app\\n156:                                 .workspace_picker\\n157:                                 .as_mut()\\n158:                                 .and_then(|p| p.confirm_typed_path());\\n159:                             if let (Some(workspace), Some(issue)) =\\n160:                                 (typed_path, app.selected_issue())\\n161:                             {\\n162:                                 let issue_id = issue.identifier.clone();\\n163:                                 app.workspace_picker = None;\\n164:                                 let before_ids = amp::thread::amp_threads_dir()\\n165:                                     .map(|d| amp::thread::snapshot_thread_ids(&d))\\n166:                                     .unwrap_or_default();\\n167:                                 let _ = start_new_thread(&issue_id, &workspace, &before_ids);\\n168:                                 load_threads_for_issue(&mut app, &issue_id);\\n169:                             }\\n170:                         }\\n171:                         KeyCode::Esc => {\\n172:                             if let Some(ref mut picker) = app.workspace_picker {\\n173:                                 picker.cancel_typing();\\n174:                             }\\n175:                         }\\n176:                         KeyCode::Backspace => {\\n177:                             if let Some(ref mut picker) = app.workspace_picker {\\n178:                                 picker.input.pop();\\n179:                             }\\n180:                         }\\n181:                         KeyCode::Char(c) => {\\n182:                             if let Some(ref mut picker) = app.workspace_picker {\\n183:                                 picker.input.push(c);\\n184:                             }\\n185:                         }\\n186:                         _ => {}\\n187:                     }\\n188:                 } else {\\n189:                     match key.code {\\n190:                         KeyCode::Enter => {\\n191:                             let picker = app.workspace_picker.take();\\n192:                             if let (Some(picker), Some(issue)) = (picker, app.selected_issue())\\n193:                                 && let Some(workspace) = picker.options.get(picker.selected)\\n194:                             {\\n195:                                 let issue_id = issue.identifier.clone();\\n196:                                 let workspace = workspace.clone();\\n197:                                 let before_ids = amp::thread::amp_threads_dir()\\n198:                                     .map(|d| amp::thread::snapshot_thread_ids(&d))\\n199:                                     .unwrap_or_default();\\n200:                                 let _ = start_new_thread(&issue_id, &workspace, &before_ids);\\n201:                                 load_threads_for_issue(&mut app, &issue_id);\\n202:                             }\\n203:                         }\\n204:                         KeyCode::Esc => app.cancel_workspace_picker(),\\n205:                         KeyCode::Char('/') => {\\n206:                             if let Some(ref mut picker) = app.workspace_picker {\\n207:                                 picker.start_typing();\\n208:                             }\\n209:                         }\\n210:                         KeyCode::Char('j') | KeyCo