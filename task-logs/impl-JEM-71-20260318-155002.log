            _ => {}\\n250:                 }\\n251:             } else if app.awaiting_sort {\\n252:                 app.awaiting_sort = false;\\n253:                 match key.code {\\n254:                     KeyCode::Char('i') => app.set_sort(app::SortColumn::Identifier),\\n255:                     KeyCode::Char('t') => app.set_sort(app::SortColumn::Title),\\n256:                     KeyCode::Char('p') => app.set_sort(app::SortColumn::Project),\\n257:                     KeyCode::Char('s') => app.set_sort(app::SortColumn::Status),\\n258:                     KeyCode::Char('r') => app.set_sort(app::SortColumn::Priority),\\n259:                     _ => {}\\n260:                 }\\n261:             } else if app.awaiting_filter {\\n262:                 app.awaiting_filter = false;\\n263:                 match key.code {\\n264:                     KeyCode::Char('i') => app.start_column_filter(app::SortColumn::Identifier),\\n265:                     KeyCode::Char('t') => app.start_column_filter(app::SortColumn::Title),\\n266:                     KeyCode::Char('p') => app.start_column_filter(app::SortColumn::Project),\\n267:                     KeyCode::Char('s') => app.start_column_filter(app::SortColumn::Status),\\n268:                     KeyCode::Char('r') => app.start_column_filter(app::SortColumn::Priority),\\n269:                     _ => {}\\n270:                 }\\n271:             } else if app.searching {\\n272:                 match key.code {\\n273:                     KeyCode::Enter => app.apply_search(),\\n274:                     KeyCode::Esc => app.cancel_search(),\\n275:                     KeyCode::Backspace => {\\n276:                         app.search_input.pop();\\n277:                     }\\n278:                     KeyCode::Char(c) => {\\n279:                         app.search_input.push(c);\\n280:                     }\\n281:                     _ => {}\\n282:                 }\\n283:             } else if app.filtering {\\n284:           