{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"toolu_vrtx_01T3gVHojpg9gCYNY8kM6dJw","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/app.rs\",\"content\":\"[... omitted lines 1 to 250 ...]\\n251: \\n252:     pub async fn refresh(&mut self) {\\n253:         self.refreshing = true;\\n254:         let selected_id = self.selected_issue().map(|i| i.identifier.clone());\\n255:         match self.api.fetch_my_issues().await {\\n256:             Ok(issues) => {\\n257:                 self.issues = issues;\\n258:                 if let Some(id) = selected_id {\\n259:                     let new_index = self\\n260:                         .filtered_issues()\\n261:                         .iter()\\n262:                         .position(|i| i.identifier == id);\\n263:                     self.selected = new_index.unwrap_or(0);\\n264:                 }\\n265:             }\\n266:             Err(_) => {}\\n267:         }\\n268:         self.refreshing = false;\\n269:     }\\n270: }\\n271: \\n272: #[cfg(test)]\\n273: mod tests {\\n274:     use super::*;\\n275:     use crate::api::fake::FakeLinearApi;\\n276: \\n277:     fn app_with_issues() -> App<FakeLinearApi> {\\n278:         let mut app = App::new(FakeLinearApi::new());\\n279:         app.issues = vec![\\n280:             Issue {\\n281:                 id: \\\"1\\\".into(),\\n282:                 identifier: \\\"JEM-1\\\".into(),\\n283:                 title: \\\"Alpha task\\\".into(),\\n284:                 state: None,\\n285:                 priority: Some(2.0),\\n286:                 project: None,\\n287:                 description: None,\\n288:                 assignee: None,\\n289:                 labels: None,\\n290:                 comments: None,\\n291:             },\\n292:             Issue {\\n293:                 id: \\\"2\\\".into(),\\n294:                 identifier: \\\"JEM-2\\\".into(),\\n295:                 title: \\\"Beta task\\\".into(),\\n296:                 state: None,\\n297:                 priority: Some(3.0),\\n298:                 project: None,\\n299:                 description: None,\\n300:                 assignee: None,\\n301:                 labels: None,\\n302:                 comments: None,\\n303:             },\\n304:             Issue {\\n305:                 id: \\\"3\\\".into(),\\n306:                 identifier: \\\"JEM-3\\\".into(),\\n307:                 title: \\\"Gamma task\\\".into(),\\n308:                 state: None,\\n309:                 priority: None,\\n310:                 project: None,\\n311:                 description: None,\\n312:                 assignee: None,\\n313:                 labels: None,\\n314:                 comments: None,\\n315:             },\\n316:         ];\\n317:         app\\n318:     }\\n319: \\n320:     #[test]\\n321:     fn navigation_wraps_at_bounds() {\\n322:         let mut app = app_with_issues();\\n323:         assert_eq!(app.selected, 0);\\n324: \\n325:         app.move_down();\\n326:         assert_eq!(app.selected, 1);\\n327:         app.move_down();\\n328:         assert_eq!(app.selected, 2);\\n329:         app.move_down(); // at bottom, stays\\n330:         assert_eq!(app.selected, 2);\\n331: \\n332:         app.move_up();\\n333:         assert_eq!(app.selected, 1);\\n334:         app.top();\\n335:         assert_eq!(app.selected, 0);\\n336:         app.move_up(); // at top, stays\\n337:         assert_eq!(app.selected, 0);\\n338:     }\\n339: \\n340:     #[test]\\n341:     fn bottom_goes_to_last() {\\n342:         let mut app = app_with_issues();\\n343:         app.bottom();\\n344:         assert_eq!(app.selected, 2);\\n345:     }\\n346: \\n347:     #[test]\\n348:     fn filter_narrows_results() {\\n349:         let mut app = app_with_issues();\\n350:         app.filter = Some((SortColumn::Title, \\\"beta\\\".into()));\\n351:         let filtered = app.filtered_issues();\\n352:         assert_eq!(filtered.len(), 1);\\n353:         assert_eq!(filtered[0].identifier, \\\"JEM-2\\\");\\n354:     }\\n355: \\n356:     #[test]\\n357:     fn filter_is_case_insensitive() {\\n358:         let mut app = app_with_issues();\\n359:         app.filter = Some((SortColumn::Title, \\\"ALPHA\\\".into()));\\n360:         assert_eq!(app.filtered_issues().len(), 1);\\n361:     }\\n362: \\n[... omitted lines 363 to 612 ...]\"}","is_error":false}]},"parent_tool_use_id":null,"session_id":"T-019cff5d-cbf9-76ae-ba67-6f6c84c089e3"}
