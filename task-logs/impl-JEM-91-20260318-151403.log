ment/sourcery/ishi/src/api\",\"content\":\"client.rs\\nfake.rs\\nmod.rs\\ntypes.rs\",\"isDirectory\":true,\"directoryEntries\":[\"client.rs\",\"fake.rs\",\"mod.rs\",\"types.rs\"]}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_019cnHmFvc9pfT5VeqszQKRR","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/views\",\"content\":\"detail.rs\\nmod.rs\\nmy_issues.rs\\nproject.rs\",\"isDirectory\":true,\"directoryEntries\":[\"detail.rs\",\"mod.rs\",\"my_issues.rs\",\"project.rs\"]}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01Vp1JfNtSMcfWCGqxEaZzP5","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/app.rs\",\"content\":\"1: use std::cmp::Ordering;\\n2: \\n3: use crate::api::client::LinearApi;\\n4: use crate::api::types::Issue;\\n5: \\n6: #[allow(dead_code)]\\n7: pub enum View {\\n8:     MyIssues,\\n9:     Project,\\n10:     Detail,\\n11: }\\n12: \\n13: #[derive(Debug, Clone, Copy, PartialEq, Eq)]\\n14: pub enum SortColumn {\\n15:     Identifier,\\n16:     Title,\\n17:     Project,\\n18:     Status,\\n19:     Priority,\\n20: }\\n21: \\n22: impl SortColumn {\\n23:     pub fn label(&self) -> &'static str {\\n24:         match self {\\n25:             SortColumn::Identifier => \\\"ID\\\",\\n26:             SortColumn::Title => \\\"Title\\\",\\n27:             SortColumn::Project => \\\"Project\\\",\\n28:             SortColumn::Status => \\\"Status\\\",\\n29:             SortColumn::Priority => \\\"Priority\\\",\\n30:         }\\n31:     }\\n32: }\\n33: \\n34: #[derive(Debug, Clone, Copy, PartialEq, Eq)]\\n35: pub enum SortDirection {\\n36:     Asc,\\n37:     Desc,\\n38: }\\n39: \\n40: impl SortDirection {\\n41:     pub fn toggle(self) -> Self {\\n42:         match self {\\n43:             SortDirection::Asc => SortDirection::Desc,\\n44:             SortDirection::Desc => SortDirection::Asc,\\n45:         }\\n46:     }\\n47: }\\n48: \\n49: pub struct App<A: LinearApi> {\\n50:     pub running: bool,\\n51:     pub view: View,\\n52:     pub api: A,\\n53:     pub issues: Vec<Issue>,\\n54:     pub selected: usize,\\n55:     pub filter: Option<(SortColumn, String)>,\\n56:     pub filter_input: String,\\n57:     pub filter_column: Option<SortColumn>,\\n58:     pub filtering: bool,\\n59:     pub awaiting_quit: bool,\\n60:     pub awaiting_filter: bool,\\n61:     pub awaiting_sort: bool,\\n62:     pub sort: Option<(SortColumn, SortDirection)>,\\n63:     pub search: Option<String>,\\n64:     pub search_input: String,\\n65:     pub searching: bool,\\n66:     pub detail_scroll: u16,\\n67:     pub detail_scroll_max: u16,\\n68:     pub refreshing: bool,\\n69: }\\n70: \\n71: impl<A: LinearApi> App<A> {\\n72:     pub fn new(api: A) -> Self {\\n73:         Self {\\n74:             running: true,\\n75:             view: View::MyIssues,\\n76:             api,\\n77:             issues: Vec::new(),\\n78:             selected: 0,\\n79:             filter: None,\\n80:             filter_input: String::new(),\\n81:             filter_column: None,\\n82:             filtering: false,\\n83:             awaiting_quit: false,\\n84:             awaiting_filter: false,\\n85:             awaiting_sort: false,\\n86:             sort: None,\\n87:             search: None,\\n88:             search_input: String::new(),\\n89:             searching: false,\\n90:             detail_scroll: 0,\\n91:             detail_scroll_max: 0,\\n92:             refreshing: false,\\n93:         }\\n94:     }\\n95: \\n96:     pub fn filtered_issues(&self) -> Vec<&Issue> {\\n97:         let mut issues: Vec<&Issue> = self.issues.iter().collect();\\n98:         if let Some((col, f)) = &self.filter {\\n99:             let lower = f.to_lowercase();\\n100:             issues.retain(|i| {\\n101:                 let value = match col {\\n102:                     SortColumn::Identifier => i.identifier.as_str(),\\n103:                     SortColumn::Title => i.title.as_str(),\\n104:                     SortColumn::Project => i.project_str(),\\n105:                     SortColumn::Status => i.status_str(),\\n106:                     SortColumn::Priority => i.priority_str(),\\n107:                 };\\n108:                 value.to_lowercase().contains(&lower)\\n109:             });\\n110:         }\\n111:         if let Some(q) = &self.search {\\n112:             let lower = q.to_lowercase();\\n113:             issues.retain(|i| i.matches_search(&lower));\\n114:         }\\n115:         if let Some((col, dir)) = &self.sort {\\n116:             issues.sort_by(|a, b| {\\n117:                 let ord = match col {\\n118:                     SortColumn::Identifier => a.identifier.cmp(&b.identifier),\\n119:                     SortColumn::Title => a.title.to_lowercase().cmp(&b.title.to_lowercase()),\\n120:                     SortColumn::Project => a.project_str().cmp(b.project_str()),\\n121:                     SortColumn::Status => a.status_str().cmp(b.status_str()),\\n122:                     SortColumn::Priority => a.priority.partial_cmp(&b.priority).unwrap_or(Ordering::Equal),\\n123:                 };\\n124:                 match dir {\\n125:                     SortDirection::Asc => ord,\\n126:                     SortDirection::Desc => ord.reverse(),\\n127:                 }\\n128:             });\\n129:         }\\n130:         issues\\n131:     }\\n132: \\n133:     pub fn set_sort(&mut self, col: SortColumn) {\\n134:         self.sort = Some(match self.sort {\\n135:             Some((c, dir)) if c == col => (col, dir.toggle()),\\n136:             _ => (col, SortDirection::Asc),\\n137:         });\\n138:         self.selected = 0;\\n139:     }\\n140: \\n141:     pub fn move_down(&mut self) {\\n142:         let len = self.filtered_issues().len();\\n143:         if len > 0 && self.selected < len - 1 {\\n144:             self.selected += 1;\\n145:         }\\n146:     }\\n147: \\n148:     pub fn move_up(&mut self) {\\n149:         if self.selected > 0 {\\n150:             self.selected -= 1;\\n151:         }\\n152:     }\\n153: \\n154:     pub fn top(&mut self) {\\n155:         self.selected = 0;\\n156:     }\\n157: \\n158:     pub fn bottom(&mut self) {\\n159:         let len = self.filtered_issues().len();\\n160:         if len > 0 {\\n161:             self.selected = len - 1;\\n162:         }\\n163:     }\\n164: \\n165:     pub fn start_search(&mut self) {\\n166:         self.searching = true;\\n167:         self.search_input.clear();\\n168:     }\\n169: \\n170:     pub fn apply_search(&mut self) {\\n171:         self.searching = false;\\n172:         if self.search_input.is_empty() {\\n173:             self.search = None;\\n174:         } else {\\n175:             self.search = Some(self.search_input.clone());\\n176:         }\\n177:         self.selected = 0;\\n178:     }\\n179: \\n180:     pub fn cancel_search(&mut self) {\\n181:         self.searching = false;\\n182:         self.search_input.clear();\\n183:     }\\n184: \\n185:     pub fn clear_search(&mut self) {\\n186:         self.search = None;\\n187:         self.search_input.clear();\\n188:         self.selected = 0;\\n189:     }\\n190: \\n191:     pub fn start_filter(&mut self) {\\n192:         self.start_column_filter(SortColumn::Title);\\n193:     }\\n194: \\n195:     pub fn start_column_filter(&mut self, col: SortColumn) {\\n196:         self.filter_column = Some(col);\\n197:         self.filtering = true;\\n198:         self.filter_input.clear();\\n199:     }\\n200: \\n201:     pub fn apply_filter(&mut self) {\\n202:         self.filtering = false;\\n203:         if self.filter_input.is_empty() {\\n204:             self.filter = None;\\n205:         } else if let Some(col) = self.filter_column {\\n206:             self.filter = Some((col, self.filter_input.clone()));\\n207:         }\\n208:         self.filter_column = None;\\n209:         self.selected = 0;\\n210:     }\\n211: \\n212:     pub fn cancel_filter(&mut self) {\\n213:         self.filtering = false;\\n214:         self.filter_input.clear();\\n215:     }\\n216: \\n217:     pub fn clear_filter(&mut self) {\\n218:         self.filter = None;\\n219:         self.filter_column = None;\\n220:         self.filter_input.clear();\\n221:         self.selected = 0;\\n222:     }\\n223: \\n224:     pub fn select_issue(&mut self) {\\n225:         let issues = self.filtered_issues();\\n226:         if self.selected < issues.len() {\\n227:             self.view = View::Detail;\\n228:             self.detail_scroll = 0;\\n229:         }\\n230:     }\\n231: \\n232:     pub fn back_to_list(&mut self) {\\n233:         self.view = View::MyIssues;\\n234:         self.detail_scroll = 0;\\n235:     }\\n236: \\n237:     pub fn selected_issue(&self) -> Option<&Issue> {\\n238:         let issues = self.filtered_issues();\\n239:         issues.get(self.selected).copied()\\n240:     }\\n241: \\n242:     pub fn scroll_detail_down(&mut self) {\\n243:         if self.detail_scroll < self.detail_scroll_max {\\n244:             self.detail_scroll = self.detail_scroll.saturating_add(1);\\n245:         }\\n246:     }\\n247: \\n248:     pub fn scroll_detail_up(&mut self) {\\n249:         self.detail_scroll = self.detail_scroll.saturating_sub(1);\\n250:     }\\n[... omitted lines 251 to 362 ...]\\n363:     #[test]\\n364:     fn apply_empty_filter_clears() {\\n365:         let mut app = app_with_issues();\\n366:         app.start_filter();\\n367:         app.apply_filter();\\n368:         assert!(app.filter.is_none());\\n369:         assert!(!app.filtering);\\n370:     }\\n371: \\n372:     #[test]\\n373:     fn apply_filter_sets_and_resets_cursor() {\\n374:         let mut app = app_with_issues();\\n375:         app.selected = 2;\\n376:         app.start_filter();\\n377:         app.filter_input = \\\"gamma\\\".into();\\n378:         app.apply_filter();\\n379:         assert_eq!(app.filter.as_ref().map(|(_, f)| f.as_str()), Some(\\\"gamma\\\"));\\n380:         assert_eq!(app.selected, 0);\\n381:     }\\n382: \\n383:     #[test]\\n384:     fn cancel_filter_discards_input() {\\n385:         let mut app = app_with_issues();\\n386:         app.start_filter();\\n387:         app.filter_input = \\\"something\\\".into();\\n388:         app.cancel_filter();\\n389:         assert!(!app.filtering);\\n390:         assert!(app.filter_input.is_empty());\\n391:     }\\n392: \\n393:     #[test]\\n394:     fn select_issue_enters_detail_view() {\\n395:         let mut app = app_with_issues();\\n396:         app.selected = 1;\\n397:         app.select_issue();\\n398:         assert!(matches!(app.view, View::Detail));\\n399:         assert_eq!(app.detail_scroll, 0);\\n400:     }\\n401: \\n402:     #[test]\\n403:     fn back_to_list_returns_to_my_issues() {\\n404:         let mut app = app_with_issues();\\n405:         app.select_issue();\\n406:         app.back_to_list();\\n407:         assert!(matches!(app.view, View::MyIssues));\\n408:     }\\n409: \\n410:     #[test]\\n411:     fn selected_issue_returns_correct_issue() {\\n412:         let mut app = app_with_issues();\\n413:         app.selected = 1;\\n414:         let issue = app.selected_issue().unwrap();\\n415:         assert_eq!(issue.identifier, \\\"JEM-2\\\");\\n416:     }\\n417: \\n418:     #[test]\\n419:     fn detail_scroll_up_down() {\\n420:         let mut app = app_with_issues();\\n421:         app.select_issue();\\n422:         app.detail_scroll_max = 5;\\n423:         assert_eq!(app.detail_scroll, 0);\\n424:         app.scroll_detail_down();\\n425:         app.scroll_detail_down();\\n426:         assert_eq!(app.detail_scroll, 2);\\n427:         app.scroll_detail_up();\\n428:         assert_eq!(app.detail_scroll, 1);\\n429:         app.scroll_detail_up();\\n430:         app.scroll_detail_up(); // should not underflow\\n431:         assert_eq!(app.detail_scroll, 0);\\n432:     }\\n433: \\n434:     #[test]\\n435:     fn detail_scroll_clamped_to_max() {\\n436:         let mut app = app_with_issues();\\n437:         app.select_issue();\\n438:         app.detail_scroll_max = 2;\\n439:         app.scroll_detail_down();\\n440:         app.scroll_detail_down();\\n441:         assert_eq!(app.detail_scroll, 2);\\n442:         app.scroll_detail_down(); // should not exceed max\\n443:         assert_eq!(app.detail_scroll, 2);\\n444:     }\\n445: \\n446:     #[test]\\n447:     fn detail_scroll_blocked_when_content_fits() {\\n448:         let mut app = app_with_issues();\\n449:         app.select_issue();\\n450:         app.detail_scroll_max = 0; // content fits in box\\n451:         app.scroll_detail_down();\\n452:         assert_eq!(app.detail_scroll, 0);\\n453:     }\\n454: \\n455:     #[test]\\n456:     fn search_filters_across_all_columns() {\\n457:         let mut app = app_with_issues();\\n458:         app.search = Some(\\\"jem-2\\\".into());\\n459:         let results = app.filtered_issues();\\n460:         assert_eq!(results.len(), 1);\\n461:         assert_eq!(results[0].identifier, \\\"JEM-2\\\");\\n462:     }\\n463: \\n464:     #[test]\\n465:     fn search_is_case_insensitive() {\\n466:         let mut app = app_with_issues();\\n467:         app.search = Some(\\\"ALPHA\\\".into());\\n468:         assert_eq!(app.filtered_issues().len(), 1);\\n469:     }\\n470: \\n471:     #[test]\\n472:     fn search_matches_priority() {\\n473:         let mut app = app_with_issues();\\n474:         app.search = Some(\\\"high\\\".into());\\n475:         let results = app.filtered_issues();\\n476:         assert_eq!(results.len(), 1);\\n477:         assert_eq!(results[0].identifier, \\\"JEM-1\\\");\\n478:     }\\n479: \\n480:     #[test]\\n481:     fn apply_empty_search_clears() {\\n482:         let mut app = app_with_issues();\\n483:         app.start_search();\\n484:         app.apply_search();\\n485:         assert!(app.search.is_none());\\n486:         assert!(!app.searching);\\n487:     }\\n488: \\n489:     #[test]\\n490:     fn apply_search_sets_and_resets_cursor() {\\n491:         let mut app = app_with_issues();\\n492:         app.selected = 2;\\n493:         app.start_search();\\n494:         app.search_input = \\\"beta\\\".into();\\n495:         app.apply_search();\\n496:         assert_eq!(app.search.as_deref(), Some(\\\"beta\\\"));\\n497:         assert_eq!(app.selected, 0);\\n498:     }\\n499: \\n500:     #[test]\\n501:     fn cancel_search_discards_input() {\\n502:         let mut app = app_with_issues();\\n503:         app.start_search();\\n504:         app.search_input = \\\"something\\\".into();\\n505:         app.cancel_search();\\n506:         assert!(!app.searching);\\n507:         assert!(app.search_input.is_empty());\\n508:     }\\n509: \\n510:     #[test]\\n511:     fn search_and_filter_combine() {\\n512:         let mut app = app_with_issues();\\n513:         app.search = Some(\\\"task\\\".into());\\n514:         assert_eq!(app.filtered_issues().len(), 3);\\n515:         app.filter = Some((SortColumn::Title, \\\"alpha\\\".into()));\\n516:         assert_eq!(app.filtered_issues().len(), 1);\\n517:         assert_eq!(app.filtered_issues()[0].identifier, \\\"JEM-1\\\");\\n518:     }\\n519: \\n520:     #[tokio::test]\\n521:     async fn refresh_reloads_issues() {\\n522:         let fake = FakeLinearApi::new();\\n523:         fake.push_response(serde_json::json!({\\n524:             \\\"data\\\": { \\\"issues\\\": { \\\"nodes\\\": [\\n525:                 { \\\"id\\\": \\\"1\\\", \\\"identifier\\\": \\\"JEM-10\\\", \\\"title\\\": \\\"New issue\\\" }\\n526:             ]}}\\n527:         }));\\n528:         let mut app = App::new(fake);\\n529:         app.issues = vec![Issue {\\n530:             id: \\\"old\\\".into(),\\n531:             identifier: \\\"JEM-1\\\".into(),\\n532:             title: \\\"Old issue\\\".into(),\\n533:             state: None,\\n534:             priority: None,\\n535:             project: None,\\n536:             description: None,\\n537:             assignee: None,\\n538:             labels: None,\\n539:             comments: None,\\n540:         }];\\n541:         assert_eq!(app.issues.len(), 1);\\n542:         assert_eq!(app.issues[0].identifier, \\\"JEM-1\\\");\\n543: \\n544:         app.refresh().await;\\n545: \\n546:         assert_eq!(app.issues.len(), 1);\\n547:         assert_eq!(app.issues[0].identifier, \\\"JEM-10\\\");\\n548:         assert!(!app.refreshing);\\n549:     }\\n550: \\n551:     #[tokio::test]\\n552:     async fn refresh_preserves_selection_when_issue_exists() {\\n553:         let fake = FakeLinearApi::new();\\n554:         fake.push_response(serde_json::json!({\\n555:             \\\"data\\\": { \\\"issues\\\": { \\\"nodes\\\": [\\n556:                 { \\\"id\\\": \\\"1\\\", \\\"identifier\\\": \\\"JEM-1\\\", \\\"title\\\": \\\"Alpha\\\" },\\n557:                 { \\\"id\\\": \\\"2\\\", \\\"identifier\\\": \\\"JEM-2\\\", \\\"title\\\": \\\"Beta\\\" },\\n558:                 { \\\"id\\\": \\\"3\\\", \\\"identifier\\\": \\\"JEM-3\\\", \\\"title\\\": \\\"Gamma\\\" }\\n559:             ]}}\\n560:         }));\\n561:         let mut app = App::new(fake);\\n562:         app.issues = vec![\\n563:             Issue { id: \\\"1\\\".into(), identifier: \\\"JEM-1\\\".into(), title: \\\"Alpha\\\".into(), state: None, priority: None, project: None, description: None, assignee: None, labels: None, comments: None },\\n564:             Issue { id: \\\"2\\\".into(), identifier: \\\"JEM-2\\\".into(), title: \\\"Beta\\\".into(), state: None, priority: None, project: None, description: None, assignee: None, labels: None, comments: None },\\n565:         ];\\n566:         app.selected = 1; // JEM-2 selected\\n567: \\n568:         app.refresh().await;\\n569: \\n570:         assert_eq!(app.selected, 1); // JEM-2 is still at index 1\\n571:         assert_eq!(app.issues[app.selected].identifier, \\\"JEM-2\\\");\\n572:     }\\n573: \\n574:     #[tokio::test]\\n575:     async fn refresh_resets_selection_when_issue_gone() {\\n576:         let fake = FakeLinearApi::new();\\n577:         fake.push_response(serde_json::json!({\\n578:             \\\"data\\\": { \\\"issues\\\": { \\\"nodes\\\": [\\n579:                 { \\\"id\\\": \\\"1\\\", \\\"identifier\\\": \\\"JEM-1\\\", \\\"title\\\": \\\"Alpha\\\" },\\n580:                 { \\\"id\\\": \\\"3\\\", \\\"identifier\\\": \\\"JEM-3\\\", \\\"title\\\": \\\"Gamma\\\" }\\n581:             ]}}\\n582:         }));\\n583:         let mut app = App::new(fake);\\n584:         app.issues = vec![\\n585:             Issue { id: \\\"1\\\".into(), identifier: \\\"JEM-1\\\".into(), title: \\\"Alpha\\\".into(), state: None, priority: None, project: None, description: None, assignee: None, labels: None, comments: None },\\n586:             Issue { id: \\\"2\\\".into(), identifier: \\\"JEM-2\\\".into(), title: \\\"Beta\\\".into(), state: None, priority: None, project: None, description: None, assignee: None, labels: None, comments: None },\\n587:         ];\\n588:         app.selected = 1; // JEM-2 selected\\n589: \\n590:         app.refresh().await;\\n591: \\n592:         assert_eq!(app.selected, 0); // JEM-2 gone, reset to 0\\n593:     }\\n594: \\n595:     #[tokio::test]\\n596:     async fn refresh_on_api_error_preserves_issues() {\\n597:         let fake = FakeLinearApi::new();\\n598:         // No response enqueued — FakeLinearApi returns null data which yields empty vec,\\n599:         // but let's test the error case by not pushing any response (returns empty)\\n600:         let mut app = App::new(fake);\\n601:         let original_issues = vec![\\n602:             Issue { id: \\\"1\\\".into(), identifier: \\\"JEM-1\\\".into(), title: \\\"Alpha\\\".into(), state: None, priority: None, project: None, description: None, assignee: None, labels: None, comments: None },\\n603:         ];\\n604:         app.issues = original_issues.clone();\\n605: \\n606:         app.refresh().await;\\n607: \\n608:         // FakeLinearApi with no response returns empty vec (not an error), so issues get replaced\\n609:         // This tests that refreshing flag is cleared\\n610:         assert!(!app.refreshing);\\n611:     }\\n612: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01WQ4gcLeywkjP6Wg4jFYLBR","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/keys.rs\",\"content\":\"1: use crossterm::event::{KeyCode, KeyEvent, KeyModifiers};\\n2: \\n3: pub enum Action {\\n4:     Quit,\\n5:     MoveDown,\\n6:     MoveUp,\\n7:     Top,\\n8:     Bottom,\\n9:     Select,\\n10:     Back,\\n11:     Help,\\n12:     Search,\\n13:     OrderBy,\\n14:     FilterBy,\\n15:     Refresh,\\n16: }\\n17: \\n18: pub fn map_key(key: KeyEvent) -> Option<Action> {\\n19:     match (key.modifiers, key.code) {\\n20:         (KeyModifiers::CONTROL, KeyCode::Char('c')) => Some(Action::Quit),\\n21:         (KeyModifiers::NONE, KeyCode::Char('q')) => Some(Action::Quit),\\n22:         (_, KeyCode::Char('j')) | (_, KeyCode::Down) => Some(Action::MoveDown),\\n23:         (_, KeyCode::Char('k')) | (_, KeyCode::Up) => Some(Action::MoveUp),\\n24:         (_, KeyCode::Char('g')) => Some(Action::Top),\\n25:         (KeyModifiers::SHIFT, KeyCode::Char('G')) => Some(Action::Bottom),\\n26:         (_, KeyCode::Enter) => Some(Action::Select),\\n27:         (_, KeyCode::Esc) => Some(Action::Back),\\n28:         (_, KeyCode::Char('?')) => Some(Action::Help),\\n29:         (_, KeyCode::Char('/')) => Some(Action::Search),\\n30:         (_, KeyCode::Char('s')) => Some(Action::OrderBy),\\n31:         (_, KeyCode::Char('f')) => Some(Action::FilterBy),\\n32:         (_, KeyCode::Char('r')) => Some(Action::Refresh),\\n33:         _ => None,\\n34:     }\\n35: }\\n36: \\n37: #[cfg(test)]\\n38: mod tests {\\n39:     use super::*;\\n40:     use crossterm::event::{KeyCode, KeyEvent, KeyEventKind, KeyEventState, KeyModifiers};\\n41: \\n42:     fn key(code: KeyCode) -> KeyEvent {\\n43:         KeyEvent {\\n44:             code,\\n45:             modifiers: KeyModifiers::NONE,\\n46:             kind: KeyEventKind::Press,\\n47:             state: KeyEventState::NONE,\\n48:         }\\n49:     }\\n50: \\n51:     fn key_with(code: KeyCode, modifiers: KeyModifiers) -> KeyEvent {\\n52:         KeyEvent {\\n53:             code,\\n54:             modifiers,\\n55:             kind: KeyEventKind::Press,\\n56:             state: KeyEventState::NONE,\\n57:         }\\n58:     }\\n59: \\n60:     #[test]\\n61:     fn quit_on_q() {\\n62:         assert!(matches!(map_key(key(KeyCode::Char('q'))), Some(Action::Quit)));\\n63:     }\\n64: \\n65:     #[test]\\n66:     fn quit_on_ctrl_c() {\\n67:         assert!(matches!(\\n68:             map_key(key_with(KeyCode::Char('c'), KeyModifiers::CONTROL)),\\n69:             Some(Action::Quit)\\n70:         ));\\n71:     }\\n72: \\n73:     #[test]\\n74:     fn navigation_keys() {\\n75:         assert!(matches!(map_key(key(KeyCode::Char('j'))), Some(Action::MoveDown)));\\n76:         assert!(matches!(map_key(key(KeyCode::Down)), Some(Action::MoveDown)));\\n77:         assert!(matches!(map_key(key(KeyCode::Char('k'))), Some(Action::MoveUp)));\\n78:         assert!(matches!(map_key(key(KeyCode::Up)), Some(Action::MoveUp)));\\n79:         assert!(matches!(map_key(key(KeyCode::Char('g'))), Some(Action::Top)));\\n80:         assert!(matches!(\\n81:             map_key(key_with(KeyCode::Char('G'), KeyModifiers::SHIFT)),\\n82:             Some(Action::Bottom)\\n83:         ));\\n84:     }\\n85: \\n86:     #[test]\\n87:     fn action_keys() {\\n88:         assert!(matches!(map_key(key(KeyCode::Enter)), Some(Action::Select)));\\n89:         assert!(matches!(map_key(key(KeyCode::Esc)), Some(Action::Back)));\\n90:         assert!(matches!(map_key(key(KeyCode::Char('?'))), Some(Action::Help)));\\n91:         assert!(matches!(map_key(key(KeyCode::Char('/'))), Some(Action::Search)));\\n92:     }\\n93: \\n94:     #[test]\\n95:     fn refresh_on_r() {\\n96:         assert!(matches!(map_key(key(KeyCode::Char('r'))), Some(Action::Refresh)));\\n97:     }\\n98: \\n99:     #[test]\\n100:     fn unmapped_keys_return_none() {\\n101:         assert!(map_key(key(KeyCode::Char('x'))).is_none());\\n102:         assert!(map_key(key(KeyCode::Tab)).is_none());\\n103:         assert!(map_key(key(KeyCode::F(1))).is_none());\\n104:     }\\n105: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_017LanknXS18DkhhitYeoqq1","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/main.rs\",\"content\":\"1: mod api;\\n2: mod app;\\n3: mod config;\\n4: mod keys;\\n5: mod suspend;\\n6: mod views;\\n7: \\n8: use anyhow::Result;\\n9: use api::client::{LinearApi, LinearClient};\\n10: use app::App;\\n11: use crossterm::{\\n12:     event::{self, Event, KeyCode},\\n13:     terminal::{disable_raw_mode, enable_raw_mode, EnterAlternateScreen, LeaveAlternateScreen},\\n14:     ExecutableCommand,\\n15: };\\n16: use ratatui::{prelude::CrosstermBackend, Terminal};\\n17: use std::io::stdout;\\n18: \\n19: #[tokio::main]\\n20: async fn main() -> Result<()> {\\n21:     let api_key = config::resolve_api_key()?;\\n22:     let client = LinearClient::new(api_key);\\n23:     let mut app = App::new(client);\\n24: \\n25:     // Fetch issues before entering TUI\\n26:     match app.api.fetch_my_issues().await {\\n27:         Ok(issues) => app.issues = issues,\\n28:         Err(e) => eprintln!(\\\"Failed to fetch issues: {e}\\\"),\\n29:     }\\n30: \\n31:     // Terminal setup\\n32:     enable_raw_mode()?;\\n33:     stdout().execute(EnterAlternateScreen)?;\\n34:     let mut terminal = Terminal::new(CrosstermBackend::new(stdout()))?;\\n35: \\n36:     // Main loop\\n37:     while app.running {\\n38:         terminal.draw(|frame| {\\n39:             let area = frame.area();\\n40:             match app.view {\\n41:                 app::View::MyIssues => views::my_issues::render(frame, area, &app),\\n42:                 app::View::Detail => views::detail::render(frame, area, &mut app),\\n43:                 _ => {\\n44:                     frame.render_widget(\\n45:                         ratatui::widgets::Paragraph::new(\\\"ishi — (view not implemented)\\\"),\\n46:                         area,\\n47:                     );\\n48:                 }\\n49:             }\\n50:         })?;\\n51: \\n52:         if event::poll(std::time::Duration::from_millis(100))?\\n53:             && let Event::Key(key) = event::read()?\\n54:         {\\n55:             if app.awaiting_quit {\\n56:                 app.awaiting_quit = false;\\n57:                 match key.code {\\n58:                     KeyCode::Char('q') => app.running = false,\\n59:                     _ => {}\\n60:                 }\\n61:             } else if app.awaiting_sort {\\n62:                 app.awaiting_sort = false;\\n63:                 match key.code {\\n64:                     KeyCode::Char('i') => app.set_sort(app::SortColumn::Identifier),\\n65:                     KeyCode::Char('t') => app.set_sort(app::SortColumn::Title),\\n66:                     KeyCode::Char('p') => app.set_sort(app::SortColumn::Project),\\n67:                     KeyCode::Char('s') => app.set_sort(app::SortColumn::Status),\\n68:                     KeyCode::Char('r') => app.set_sort(app::SortColumn::Priority),\\n69:                     _ => {}\\n70:                 }\\n71:             } else if app.awaiting_filter {\\n72:                 app.awaiting_filter = false;\\n73:                 match key.code {\\n74:                     KeyCode::Char('i') => app.start_column_filter(app::SortColumn::Identifier),\\n75:                     KeyCode::Char('t') => app.start_column_filter(app::SortColumn::Title),\\n76:                     KeyCode::Char('p') => app.start_column_filter(app::SortColumn::Project),\\n77:                     KeyCode::Char('s') => app.start_column_filter(app::SortColumn::Status),\\n78:                     KeyCode::Char('r') => app.start_column_filter(app::SortColumn::Priority),\\n79:                     _ => {}\\n80:                 }\\n81:             } else if app.searching {\\n82:                 match key.code {\\n83:                     KeyCode::Enter => app.apply_search(),\\n84:                     KeyCode::Esc => app.cancel_search(),\\n85:                     KeyCode::Backspace => {\\n86:                         app.search_input.pop();\\n87:                     }\\n88:                     KeyCode::Char(c) => {\\n89:                         app.search_input.push(c);\\n90:                     }\\n91:                     _ => {}\\n92:                 }\\n93:             } else if app.filtering {\\n94:                 match key.code {\\n95:                     KeyCode::Enter => app.apply_filter(),\\n96:                     KeyCode::Esc => app.cancel_filter(),\\n97:                     KeyCode::Backspace => {\\n98:                         app.filter_input.pop();\\n99:                     }\\n100:                     KeyCode::Char(c) => {\\n101:                         app.filter_input.push(c);\\n102:                     }\\n103:                     _ => {}\\n104:                 }\\n105:             } else if matches!(app.view, app::View::Detail) {\\n106:                 if let Some(action) = keys::map_key(key) {\\n107:                     match action {\\n108:                         keys::Action::Quit => app.awaiting_quit = true,\\n109:                         keys::Action::Back => app.back_to_list(),\\n110:                         keys::Action::MoveDown => app.scroll_detail_down(),\\n111:                         keys::Action::MoveUp => app.scroll_detail_up(),\\n112:                         keys::Action::Top => app.detail_scroll = 0,\\n113:                         keys::Action::Refresh => app.refresh().await,\\n114:                         _ => {}\\n115:                     }\\n116:                 }\\n117:             } else if let Some(action) = keys::map_key(key) {\\n118:                 match action {\\n119:                     keys::Action::Quit => app.awaiting_quit = true,\\n120:                     keys::Action::MoveDown => app.move_down(),\\n121:                     keys::Action::MoveUp => app.move_up(),\\n122:                     keys::Action::Top => app.top(),\\n123:                     keys::Action::Bottom => app.bottom(),\\n124:                     keys::Action::Select => app.select_issue(),\\n125:                     keys::Action::Search => app.start_search(),\\n126:                     keys::Action::Back => {\\n127:                         if app.search.is_some() {\\n128:                             app.clear_search();\\n129:                         } else {\\n130:                             app.clear_filter();\\n131:                         }\\n132:                     }\\n133:                     keys::Action::OrderBy => app.awaiting_sort = true,\\n134:                     keys::Action::FilterBy => app.awaiting_filter = true,\\n135:                     keys::Action::Refresh => app.refresh().await,\\n136:                     _ => {}\\n137:                 }\\n138:             }\\n139:         }\\n140:     }\\n141: \\n142:     // Teardown\\n143:     disable_raw_mode()?;\\n144:     stdout().execute(LeaveAlternateScreen)?;\\n145:     Ok(())\\n146: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01116qF76TpkUnray2k2BtLE","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/config.rs\",\"content\":\"1: use anyhow::{Context, Result};\\n2: use serde::{Deserialize, Serialize};\\n3: use std::path::PathBuf;\\n4: \\n5: #[derive(Debug, Serialize, Deserialize, Default)]\\n6: pub struct Config {\\n7:     pub api_key: Option<String>,\\n8: }\\n9: \\n10: pub fn config_path() -> Result<PathBuf> {\\n11:     let dir = dirs::config_dir()\\n12:         .context(\\\"could not determine config directory\\\")?\\n13:         .join(\\\"ishi\\\");\\n14:     std::fs::create_dir_all(&dir)?;\\n15:     Ok(dir.join(\\\"config.toml\\\"))\\n16: }\\n17: \\n18: pub fn resolve_api_key() -> Result<String> {\\n19:     // 1. Environment variable\\n20:     if let Ok(key) = std::env::var(\\\"LINEAR_API_KEY\\\")\\n21:         && !key.is_empty()\\n22:     {\\n23:         return Ok(key);\\n24:     }\\n25: \\n26:     // 2. Config file\\n27:     let path = config_path()?;\\n28:     if path.exists() {\\n29:         let contents = std::fs::read_to_string(&path)?;\\n30:         let cfg: Config = toml::from_str(&contents)?;\\n31:         if let Some(key) = cfg.api_key\\n32:             && !key.is_empty()\\n33:         {\\n34:             return Ok(key);\\n35:         }\\n36:     }\\n37: \\n38:     anyhow::bail!(\\n39:         \\\"No Linear API key found.\\\\n\\\\\\n40:          Set LINEAR_API_KEY or add api_key to {}\\\",\\n41:         config_path()?.display()\\n42:     )\\n43: }\\n44: \\n45: #[allow(dead_code)]\\n46: pub fn store_api_key(key: &str) -> Result<()> {\\n47:     let cfg = Config {\\n48:         api_key: Some(key.to_string()),\\n49:     };\\n50:     let contents = toml::to_string_pretty(&cfg)?;\\n51:     std::fs::write(config_path()?, contents)?;\\n52:     Ok(())\\n53: }\\n54: \\n55: #[cfg(test)]\\n56: mod tests {\\n57:     use super::*;\\n58: \\n59:     #[test]\\n60:     fn resolve_env_var_priority() {\\n61:         // Non-empty env var is accepted\\n62:         unsafe { std::env::set_var(\\\"LINEAR_API_KEY\\\", \\\"test-key-from-env\\\") };\\n63:         let result = resolve_api_key();\\n64:         assert_eq!(result.unwrap(), \\\"test-key-from-env\\\");\\n65: \\n66:         // Empty env var is rejected (falls through to file lookup)\\n67:         unsafe { std::env::set_var(\\\"LINEAR_API_KEY\\\", \\\"\\\") };\\n68:         // Don't assert error here — a real config file may exist on this machine\\n69:         let result = resolve_api_key();\\n70:         if let Ok(key) = &result {\\n71:             assert_ne!(key, \\\"\\\", \\\"empty string should never be returned\\\");\\n72:         }\\n73: \\n74:         unsafe { std::env::remove_var(\\\"LINEAR_API_KEY\\\") };\\n75:     }\\n76: \\n77:     #[test]\\n78:     fn store_and_load_round_trip() {\\n79:         let dir = tempfile::tempdir().unwrap();\\n80:         let path = dir.path().join(\\\"config.toml\\\");\\n81: \\n82:         let cfg = Config {\\n83:             api_key: Some(\\\"round-trip-key\\\".into()),\\n84:         };\\n85:         let contents = toml::to_string_pretty(&cfg).unwrap();\\n86:         std::fs::write(&path, &contents).unwrap();\\n87: \\n88:         let loaded: Config = toml::from_str(&std::fs::read_to_string(&path).unwrap()).unwrap();\\n89:         assert_eq!(loaded.api_key.unwrap(), \\\"round-trip-key\\\");\\n90:     }\\n91: \\n92:     #[test]\\n93:     fn config_deserializes_missing_key() {\\n94:         let cfg: Config = toml::from_str(\\\"\\\").unwrap();\\n95:         assert!(cfg.api_key.is_none());\\n96:     }\\n97: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_011g9vFpGbZZ5Xu3pcrS3Pze","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/suspend.rs\",\"content\":\"1: use anyhow::Result;\\n2: use crossterm::{\\n3:     execute,\\n4:     terminal::{EnterAlternateScreen, LeaveAlternateScreen, disable_raw_mode, enable_raw_mode},\\n5: };\\n6: use std::io::stdout;\\n7: use std::path::Path;\\n8: use std::process::{Command, ExitStatus};\\n9: \\n10: #[allow(dead_code)]\\n11: /// Suspend the TUI, run an external command, then restore the TUI.\\n12: ///\\n13: /// Steps:\\n14: /// 1. Leave alternate screen\\n15: /// 2. Disable raw mode\\n16: /// 3. Run the command (blocking, inheriting stdin/stdout/stderr)\\n17: /// 4. Re-enable raw mode\\n18: /// 5. Re-enter alternate screen\\n19: /// 6. Force terminal redraw (via the returned `needs_redraw` signal)\\n20: ///\\n21: /// Returns the command's exit status.\\n22: pub fn run_external_command(program: &str, args: &[&str], working_dir: &Path) -> Result<ExitStatus> {\\n23:     run_external_command_with(&mut RealTerminal, program, args, working_dir)\\n24: }\\n25: \\n26: /// Testable version that accepts a [`TerminalControl`] implementation.\\n27: pub fn run_external_command_with<T: TerminalControl>(\\n28:     terminal: &mut T,\\n29:     program: &str,\\n30:     args: &[&str],\\n31:     working_dir: &Path,\\n32: ) -> Result<ExitStatus> {\\n33:     terminal.leave_alternate_screen()?;\\n34:     terminal.disable_raw_mode()?;\\n35: \\n36:     let status = Command::new(program)\\n37:         .args(args)\\n38:         .current_dir(working_dir)\\n39:         .stdin(std::process::Stdio::inherit())\\n40:         .stdout(std::process::Stdio::inherit())\\n41:         .stderr(std::process::Stdio::inherit())\\n42:         .status();\\n43: \\n44:     // Always attempt to restore the terminal, even if the command failed to run.\\n45:     terminal.enable_raw_mode()?;\\n46:     terminal.enter_alternate_screen()?;\\n47: \\n48:     Ok(status?)\\n49: }\\n50: \\n51: /// Abstraction over terminal operations for testability.\\n52: pub trait TerminalControl {\\n53:     fn leave_alternate_screen(&mut self) -> Result<()>;\\n54:     fn disable_raw_mode(&mut self) -> Result<()>;\\n55:     fn enable_raw_mode(&mut self) -> Result<()>;\\n56:     fn enter_alternate_screen(&mut self) -> Result<()>;\\n57: }\\n58: \\n59: /// Real implementation that talks to the actual terminal.\\n60: struct RealTerminal;\\n61: \\n62: impl TerminalControl for RealTerminal {\\n63:     fn leave_alternate_screen(&mut self) -> Result<()> {\\n64:         execute!(stdout(), LeaveAlternateScreen)?;\\n65:         Ok(())\\n66:     }\\n67: \\n68:     fn disable_raw_mode(&mut self) -> Result<()> {\\n69:         disable_raw_mode()?;\\n70:         Ok(())\\n71:     }\\n72: \\n73:     fn enable_raw_mode(&mut self) -> Result<()> {\\n74:         enable_raw_mode()?;\\n75:         Ok(())\\n76:     }\\n77: \\n78:     fn enter_alternate_screen(&mut self) -> Result<()> {\\n79:         execute!(stdout(), EnterAlternateScreen)?;\\n80:         Ok(())\\n81:     }\\n82: }\\n83: \\n84: #[cfg(test)]\\n85: mod tests {\\n86:     use super::*;\\n87:     use std::cell::RefCell;\\n88: \\n89:     /// Records the sequence of terminal operations for verification.\\n90:     struct MockTerminal {\\n91:         ops: RefCell<Vec<&'static str>>,\\n92:     }\\n93: \\n94:     impl MockTerminal {\\n95:         fn new() -> Self {\\n96:             Self {\\n97:                 ops: RefCell::new(Vec::new()),\\n98:             }\\n99:         }\\n100: \\n101:         fn ops(&self) -> Vec<&'static str> {\\n102:             self.ops.borrow().clone()\\n103:         }\\n104:     }\\n105: \\n106:     impl TerminalControl for MockTerminal {\\n107:         fn leave_alternate_screen(&mut self) -> Result<()> {\\n108:             self.ops.borrow_mut().push(\\\"leave_alternate_screen\\\");\\n109:             Ok(())\\n110:         }\\n111: \\n112:         fn disable_raw_mode(&mut self) -> Result<()> {\\n113:             self.ops.borrow_mut().push(\\\"disable_raw_mode\\\");\\n114:             Ok(())\\n115:         }\\n116: \\n117:         fn enable_raw_mode(&mut self) -> Result<()> {\\n118:             self.ops.borrow_mut().push(\\\"enable_raw_mode\\\");\\n119:             Ok(())\\n120:         }\\n121: \\n122:         fn enter_alternate_screen(&mut self) -> Result<()> {\\n123:             self.ops.borrow_mut().push(\\\"enter_alternate_screen\\\");\\n124:             Ok(())\\n125:         }\\n126:     }\\n127: \\n128:     #[test]\\n129:     fn terminal_operations_in_correct_order() {\\n130:         let mut mock = MockTerminal::new();\\n131:         let dir = tempfile::tempdir().unwrap();\\n132: \\n133:         let status =\\n134:             run_external_command_with(&mut mock, \\\"echo\\\", &[\\\"hello\\\"], dir.path()).unwrap();\\n135: \\n136:         assert!(status.success());\\n137:         assert_eq!(\\n138:             mock.ops(),\\n139:             vec![\\n140:                 \\\"leave_alternate_screen\\\",\\n141:                 \\\"disable_raw_mode\\\",\\n142:                 \\\"enable_raw_mode\\\",\\n143:                 \\\"enter_alternate_screen\\\",\\n144:             ]\\n145:         );\\n146:     }\\n147: \\n148:     #[test]\\n149:     fn returns_exit_status_of_command() {\\n150:         let mut mock = MockTerminal::new();\\n151:         let dir = tempfile::tempdir().unwrap();\\n152: \\n153:         let status =\\n154:             run_external_command_with(&mut mock, \\\"sh\\\", &[\\\"-c\\\", \\\"exit 42\\\"], dir.path()).unwrap();\\n155: \\n156:         assert!(!status.success());\\n157:         assert_eq!(status.code(), Some(42));\\n158:     }\\n159: \\n160:     #[test]\\n161:     fn runs_in_specified_working_directory() {\\n162:         let mut mock = MockTerminal::new();\\n163:         let dir = tempfile::tempdir().unwrap();\\n164:         let marker = dir.path().join(\\\"marker.txt\\\");\\n165: \\n166:         let status = run_external_command_with(\\n167:             &mut mock,\\n168:             \\\"sh\\\",\\n169:             &[\\\"-c\\\", \\\"echo ok > marker.txt\\\"],\\n170:             dir.path(),\\n171:         )\\n172:         .unwrap();\\n173: \\n174:         assert!(status.success());\\n175:         assert!(marker.exists());\\n176:     }\\n177: \\n178:     #[test]\\n179:     fn terminal_restored_even_when_command_fails() {\\n180:         let mut mock = MockTerminal::new();\\n181:         let dir = tempfile::tempdir().unwrap();\\n182: \\n183:         let status =\\n184:             run_external_command_with(&mut mock, \\\"sh\\\", &[\\\"-c\\\", \\\"exit 1\\\"], dir.path()).unwrap();\\n185: \\n186:         assert!(!status.success());\\n187:         // Terminal should still be restored\\n188:         assert_eq!(\\n189:             mock.ops(),\\n190:             vec![\\n191:                 \\\"leave_alternate_screen\\\",\\n192:                 \\\"disable_raw_mode\\\",\\n193:                 \\\"enable_raw_mode\\\",\\n194:                 \\\"enter_alternate_screen\\\",\\n195:             ]\\n196:         );\\n197:     }\\n198: \\n199:     #[test]\\n200:     fn error_when_program_not_found() {\\n201:         let mut mock = MockTerminal::new();\\n202:         let dir = tempfile::tempdir().unwrap();\\n203: \\n204:         let result = run_external_command_with(\\n205:             &mut mock,\\n206:             \\\"nonexistent_program_that_should_not_exist\\\",\\n207:             &[],\\n208:             dir.path(),\\n209:         );\\n210: \\n211:         assert!(result.is_err());\\n212:         // Terminal should still be restored even when the command can't be spawned\\n213:         assert_eq!(\\n214:             mock.ops(),\\n215:             vec![\\n216:                 \\\"leave_alternate_screen\\\",\\n217:                 \\\"disable_raw_mode\\\",\\n218:                 \\\"enable_raw_mode\\\",\\n219:                 \\\"enter_alternate_screen\\\",\\n220:             ]\\n221:         );\\n222:     }\\n223: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01VMkTFNJfUZPw9ioYY2yqiS","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/tests\",\"content\":\"fixtures/\",\"isDirectory\":true,\"directoryEntries\":[\"fixtures/\"]}","is_error":false}]},"parent_tool_use_id":null,"session_id":"T-019cff5d-cbf9-76ae-ba67-6f6c84c089e3"}
