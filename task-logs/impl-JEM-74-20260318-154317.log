ion) = keys::map_key(key) {\\n292:                     match app.detail_section {\\n293:                         app::DetailSection::Threads => match action {\\n294:                             keys::Action::Quit => app.awaiting_quit = true,\\n295:                             keys::Action::Back => app.focus_body(),\\n296:                             keys::Action::MoveDown => app.thread_move_down(),\\n297:                             keys::Action::MoveUp => app.thread_move_up(),\\n298:                             keys::Action::Select => {\\n299:                                 if let Some(thread) = app.selected_thread() {\\n300:                                     let thread_id = thread.id.clone();\\n301:                                     let _ = continue_thread(&thread_id);\\n302:                                 }\\n303:                             }\\n304:                             keys::Action::Tab => app.focus_body(),\\n305:                             keys::Action::Refresh => app.refresh().await,\\n306:                             keys::Action::NewThread => open_workspace_picker(&mut app),\\n307:                             keys::Action::OpenIn => app.awaiting_open = true,\\n308:                             _ => {}\\n309:                         },\\n310:                         app::DetailSection::Body => match action {\\n311:                             keys::Action::Quit => app.awaiting_quit = true,\\n312:                             keys::Action::Back => app.back_to_list(),\\n313:                             keys::Action::MoveDown => app.scroll_detail_down(),\\n314:                             keys::Action::MoveUp => app.scroll_detail_up(),\\n315:                             keys::Action::Top => app.detail_scroll = 0,\\n316:                             keys::Action::Refresh => app.refresh().await,\\n317:                             keys::Action::Tab => app.focus_threads(),\\n318:                             keys::Action::NewThread => open_workspace_picke