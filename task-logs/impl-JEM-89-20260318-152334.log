{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"toolu_vrtx_01Ni4YMeCEQnHRPfVKj6CjxF","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/amp/state.rs\",\"content\":\"1: use anyhow::Result;\\n2: use serde::{Deserialize, Serialize};\\n3: use std::collections::HashMap;\\n4: use std::path::{Path, PathBuf};\\n5: \\n6: /// Maps Linear issue identifiers (e.g. \\\"JEM-91\\\") to a list of Amp thread IDs,\\n7: /// and tracks workspace directories for each thread.\\n8: #[derive(Debug, Serialize, Deserialize, Default, Clone, PartialEq)]\\n9: pub struct State {\\n10:     /// issue identifier → list of thread IDs\\n11:     pub threads: HashMap<String, Vec<String>>,\\n12:     /// thread ID → workspace directory path\\n13:     #[serde(default)]\\n14:     pub workspaces: HashMap<String, String>,\\n15: }\\n16: \\n17: #[allow(dead_code)]\\n18: impl State {\\n19:     pub fn load(path: &Path) -> Result<Self> {\\n20:         if !path.exists() {\\n21:             return Ok(Self::default());\\n22:         }\\n23:         let contents = std::fs::read_to_string(path)?;\\n24:         let state: State = serde_json::from_str(&contents)?;\\n25:         Ok(state)\\n26:     }\\n27: \\n28:     pub fn save(&self, path: &Path) -> Result<()> {\\n29:         if let Some(parent) = path.parent() {\\n30:             std::fs::create_dir_all(parent)?;\\n31:         }\\n32:         let contents = serde_json::to_string_pretty(self)?;\\n33:         std::fs::write(path, contents)?;\\n34:         Ok(())\\n35:     }\\n36: \\n37:     pub fn thread_ids_for(&self, issue_identifier: &str) -> &[String] {\\n38:         self.threads\\n39:             .get(issue_identifier)\\n40:             .map(|v| v.as_slice())\\n41:             .unwrap_or(&[])\\n42:     }\\n43: \\n44:     pub fn link_thread(&mut self, issue_identifier: &str, thread_id: &str) {\\n45:         let ids = self\\n46:             .threads\\n47:             .entry(issue_identifier.to_string())\\n48:             .or_default();\\n49:         if !ids.contains(&thread_id.to_string()) {\\n50:             ids.push(thread_id.to_string());\\n51:         }\\n52:     }\\n53: \\n54:     pub fn set_workspace(&mut self, thread_id: &str, workspace: &str) {\\n55:         self.workspaces\\n56:             .insert(thread_id.to_string(), workspace.to_string());\\n57:     }\\n58: \\n59:     pub fn workspace_for(&self, thread_id: &str) -> Option<&str> {\\n60:         self.workspaces.get(thread_id).map(|s| s.as_str())\\n61:     }\\n62: }\\n63: \\n64: pub fn state_path() -> Result<PathBuf> {\\n65:     let dir = dirs::data_dir()\\n66:         .ok_or_else(|| anyhow::anyhow!(\\\"could not determine data directory\\\"))?\\n67:         .join(\\\"ishi\\\");\\n68:     std::fs::create_dir_all(&dir)?;\\n69:     Ok(dir.join(\\\"state.json\\\"))\\n70: }\\n71: \\n72: #[cfg(test)]\\n73: mod tests {\\n74:     use super::*;\\n75: \\n76:     #[test]\\n77:     fn load_missing_file_returns_default() {\\n78:         let dir = tempfile::tempdir().unwrap();\\n79:         let path = dir.path().join(\\\"nonexistent.json\\\");\\n80:         let state = State::load(&path).unwrap();\\n81:         assert!(state.threads.is_empty());\\n82:     }\\n83: \\n84:     #[test]\\n85:     fn save_and_load_round_trip() {\\n86:         let dir = tempfile::tempdir().unwrap();\\n87:         let path = dir.path().join(\\\"state.json\\\");\\n88: \\n89:         let mut state = State::default();\\n90:         state.link_thread(\\\"JEM-1\\\", \\\"T-abc-123\\\");\\n91:         state.link_thread(\\\"JEM-1\\\", \\\"T-def-456\\\");\\n92:         state.link_thread(\\\"JEM-2\\\", \\\"T-ghi-789\\\");\\n93: \\n94:         state.save(&path).unwrap();\\n95: \\n96:         let loaded = State::load(&path).unwrap();\\n97:         assert_eq!(loaded, state);\\n98:     }\\n99: \\n100:     #[test]\\n101:     fn thread_ids_for_unknown_issue_returns_empty() {\\n102:         let state = State::default();\\n103:         assert!(state.thread_ids_for(\\\"JEM-999\\\").is_empty());\\n104:     }\\n105: \\n106:     #[test]\\n107:     fn thread_ids_for_known_issue() {\\n108:         let mut state = State::default();\\n109:         state.link_thread(\\\"JEM-1\\\", \\\"T-abc\\\");\\n110:         state.link_thread(\\\"JEM-1\\\", \\\"T-def\\\");\\n111:         assert_eq!(state.thread_ids_for(\\\"JEM-1\\\"), &[\\\"T-abc\\\", \\\"T-def\\\"]);\\n112:     }\\n113: \\n114:     #[test]\\n115:     fn link_thread_prevents_duplicates() {\\n116:         let mut state = State::default();\\n117:         state.link_thread(\\\"JEM-1\\\", \\\"T-abc\\\");\\n118:         state.link_thread(\\\"JEM-1\\\", \\\"T-abc\\\");\\n119:         assert_eq!(state.thread_ids_for(\\\"JEM-1\\\").len(), 1);\\n120:     }\\n121: \\n122:     #[test]\\n123:     fn save_creates_parent_directories() {\\n124:         let dir = tempfile::tempdir().unwrap();\\n125:         let path = dir.path().join(\\\"nested\\\").join(\\\"dir\\\").join(\\\"state.json\\\");\\n126: \\n127:         let state = State::default();\\n128:         state.save(&path).unwrap();\\n129:         assert!(path.exists());\\n130:     }\\n131: \\n132:     #[test]\\n133:     fn workspace_for_unknown_thread_returns_none() {\\n134:         let state = State::default();\\n135:         assert!(state.workspace_for(\\\"T-unknown\\\").is_none());\\n136:     }\\n137: \\n138:     #[test]\\n139:     fn set_and_get_workspace() {\\n140:         let mut state = State::default();\\n141:         state.set_workspace(\\\"T-abc\\\", \\\"/home/user/project\\\");\\n142:         assert_eq!(state.workspace_for(\\\"T-abc\\\"), Some(\\\"/home/user/project\\\"));\\n143:     }\\n144: \\n145:     #[test]\\n146:     fn workspace_round_trips_through_save_load() {\\n147:         let dir = tempfile::tempdir().unwrap();\\n148:         let path = dir.path().join(\\\"state.json\\\");\\n149: \\n150:         let mut state = State::default();\\n151:         state.link_thread(\\\"JEM-1\\\", \\\"T-abc\\\");\\n152:         state.set_workspace(\\\"T-abc\\\", \\\"/workspace/dir\\\");\\n153:         state.save(&path).unwrap();\\n154: \\n155:         let loaded = State::load(&path).unwrap();\\n156:         assert_eq!(loaded.workspace_for(\\\"T-abc\\\"), Some(\\\"/workspace/dir\\\"));\\n157:         assert_eq!(loaded, state);\\n158:     }\\n159: \\n160:     #[test]\\n161:     fn set_workspace_overwrites_previous() {\\n162:         let mut state = State::default();\\n163:         state.set_workspace(\\\"T-abc\\\", \\\"/old/path\\\");\\n164:         state.set_workspace(\\\"T-abc\\\", \\\"/new/path\\\");\\n165:         assert_eq!(state.workspace_for(\\\"T-abc\\\"), Some(\\\"/new/path\\\"));\\n166:     }\\n167: \\n168:     #[test]\\n169:     fn load_legacy_state_without_workspaces() {\\n170:         let dir = tempfile::tempdir().unwrap();\\n171:         let path = dir.path().join(\\\"state.json\\\");\\n172:         // Simulate a state file from before workspaces were added\\n173:         let json = r#\\\"{\\\"threads\\\":{\\\"JEM-1\\\":[\\\"T-abc\\\"]}}\\\"#;\\n174:         std::fs::write(&path, json).unwrap();\\n175: \\n176:         let state = State::load(&path).unwrap();\\n177:         assert_eq!(state.thread_ids_for(\\\"JEM-1\\\"), &[\\\"T-abc\\\"]);\\n178:         assert!(state.workspaces.is_empty());\\n179:     }\\n180: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01CUHogx7o4QHGvRJEGL9TaP","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/amp/mod.rs\",\"content\":\"1: pub mod state;\\n2: pub mod thread;\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01Ak6X924YPeeP2FreddfAGX","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/amp/thread.rs\",\"content\":\"1: use anyhow::Result;\\n2: use serde::Deserialize;\\n3: use std::path::{Path, PathBuf};\\n4: \\n5: #[derive(Debug, Deserialize)]\\n6: struct RawThread {\\n7:     id: String,\\n8:     created: u64,\\n9:     title: Option<String>,\\n10:     #[serde(default)]\\n11:     messages: Vec<serde_json::Value>,\\n12:     #[serde(rename = \\\"usageLedger\\\")]\\n13:     usage_ledger: Option<UsageLedger>,\\n14: }\\n15: \\n16: #[derive(Debug, Deserialize)]\\n17: struct UsageLedger {\\n18:     #[serde(default)]\\n19:     events: Vec<LedgerEvent>,\\n20: }\\n21: \\n22: #[derive(Debug, Deserialize)]\\n23: struct LedgerEvent {\\n24:     timestamp: String,\\n25: }\\n26: \\n27: /// Summary of an Amp thread for display in the TUI.\\n28: #[derive(Debug, Clone, PartialEq)]\\n29: pub struct ThreadSummary {\\n30:     pub id: String,\\n31:     pub title: String,\\n32:     pub message_count: usize,\\n33:     /// Milliseconds since Unix epoch of last activity (or creation time).\\n34:     pub last_activity_ms: u64,\\n35: }\\n36: \\n37: impl ThreadSummary {\\n38:     pub fn relative_time(&self) -> String {\\n39:         let now_ms = std::time::SystemTime::now()\\n40:             .duration_since(std::time::UNIX_EPOCH)\\n41:             .map(|d| d.as_millis() as u64)\\n42:             .unwrap_or(0);\\n43:         format_relative_time(now_ms, self.last_activity_ms)\\n44:     }\\n45: }\\n46: \\n47: pub fn format_relative_time(now_ms: u64, then_ms: u64) -> String {\\n48:     let diff_secs = now_ms.saturating_sub(then_ms) / 1000;\\n49: \\n50:     if diff_secs < 60 {\\n51:         format!(\\\"{}s ago\\\", diff_secs)\\n52:     } else if diff_secs < 3600 {\\n53:         format!(\\\"{}m ago\\\", diff_secs / 60)\\n54:     } else if diff_secs < 86400 {\\n55:         format!(\\\"{}h ago\\\", diff_secs / 3600)\\n56:     } else {\\n57:         format!(\\\"{}d ago\\\", diff_secs / 86400)\\n58:     }\\n59: }\\n60: \\n61: /// Returns the default directory where Amp stores thread files.\\n62: pub fn amp_threads_dir() -> Option<PathBuf> {\\n63:     dirs::data_dir().map(|d| d.join(\\\"amp\\\").join(\\\"threads\\\"))\\n64: }\\n65: \\n66: /// Read a thread file and produce a summary.\\n67: pub fn read_thread_summary(path: &Path) -> Result<ThreadSummary> {\\n68:     let contents = std::fs::read_to_string(path)?;\\n69:     parse_thread_summary(&contents)\\n70: }\\n71: \\n72: /// Parse a thread JSON string into a summary.\\n73: pub fn parse_thread_summary(json: &str) -> Result<ThreadSummary> {\\n74:     let raw: RawThread = serde_json::from_str(json)?;\\n75: \\n76:     let title = raw\\n77:         .title\\n78:         .unwrap_or_else(|| \\\"Untitled thread\\\".to_string());\\n79: \\n80:     let message_count = raw.messages.len();\\n81: \\n82:     // Last activity: latest usage ledger event timestamp, or creation time.\\n83:     let last_activity_ms = raw\\n84:         .usage_ledger\\n85:         .and_then(|ledger| {\\n86:             ledger.events.last().and_then(|e| {\\n87:                 chrono_parse_to_ms(&e.timestamp)\\n88:             })\\n89:         })\\n90:         .unwrap_or(raw.created);\\n91: \\n92:     Ok(ThreadSummary {\\n93:         id: raw.id,\\n94:         title,\\n95:         message_count,\\n96:         last_activity_ms,\\n97:     })\\n98: }\\n99: \\n100: /// Parse an ISO-8601 timestamp string to milliseconds since epoch.\\n101: /// Uses manual parsing to avoid adding a chrono dependency.\\n102: fn chrono_parse_to_ms(s: &str) -> Option<u64> {\\n103:     // Expected format: \\\"2025-12-28T21:21:59.052Z\\\"\\n104:     // We'll use a simple parse approach\\n105:     let s = s.trim_end_matches('Z');\\n106:     let (date_part, time_part) = s.split_once('T')?;\\n107: \\n108:     let mut date_iter = date_part.split('-');\\n109:     let year: i64 = date_iter.next()?.parse().ok()?;\\n110:     let month: u32 = date_iter.next()?.parse().ok()?;\\n111:     let day: u32 = date_iter.next()?.parse().ok()?;\\n112: \\n113:     let (time_main, millis) = if let Some((t, ms)) = time_part.split_once('.') {\\n114:         let ms_val: u64 = ms.parse().ok()?;\\n115:         (t, ms_val)\\n116:     } else {\\n117:         (time_part, 0u64)\\n118:     };\\n119: \\n120:     let mut time_iter = time_main.split(':');\\n121:     let hour: u32 = time_iter.next()?.parse().ok()?;\\n122:     let min: u32 = time_iter.next()?.parse().ok()?;\\n123:     let sec: u32 = time_iter.next()?.parse().ok()?;\\n124: \\n125:     // Days from epoch (1970-01-01) using a simplified calculation\\n126:     let days = days_from_epoch(year, month, day)?;\\n127:     let total_secs = (days as u64) * 86400 + (hour as u64) * 3600 + (min as u64) * 60 + (sec as u64);\\n128:     Some(total_secs * 1000 + millis)\\n129: }\\n130: \\n131: fn days_from_epoch(year: i64, month: u32, day: u32) -> Option<i64> {\\n132:     // Adjust for months <= 2 (treat Jan/Feb as months 13/14 of previous year)\\n133:     let (y, m) = if month <= 2 {\\n134:         (year - 1, month + 12)\\n135:     } else {\\n136:         (year, month)\\n137:     };\\n138: \\n139:     let era = if y >= 0 { y } else { y - 399 } / 400;\\n140:     let yoe = (y - era * 400) as u32;\\n141:     let doy = (153 * (m - 3) + 2) / 5 + day - 1;\\n142:     let doe = yoe * 365 + yoe / 4 - yoe / 100 + doy;\\n143:     let days = era * 146097 + doe as i64 - 719468;\\n144:     Some(days)\\n145: }\\n146: \\n147: /// Load thread summaries for a list of thread IDs from the given threads directory.\\n148: pub fn load_thread_summaries(\\n149:     threads_dir: &Path,\\n150:     thread_ids: &[String],\\n151: ) -> Vec<ThreadSummary> {\\n152:     thread_ids\\n153:         .iter()\\n154:         .filter_map(|id| {\\n155:             let path = threads_dir.join(format!(\\\"{}.json\\\", id));\\n156:             read_thread_summary(&path).ok()\\n157:         })\\n158:         .collect()\\n159: }\\n160: \\n161: #[cfg(test)]\\n162: mod tests {\\n163:     use super::*;\\n164: \\n165:     #[test]\\n166:     fn parse_minimal_thread() {\\n167:         let json = r#\\\"{\\n168:             \\\"v\\\": 0,\\n169:             \\\"id\\\": \\\"T-abc-123\\\",\\n170:             \\\"created\\\": 1700000000000,\\n171:             \\\"messages\\\": []\\n172:         }\\\"#;\\n173:         let summary = parse_thread_summary(json).unwrap();\\n174:         assert_eq!(summary.id, \\\"T-abc-123\\\");\\n175:         assert_eq!(summary.title, \\\"Untitled thread\\\");\\n176:         assert_eq!(summary.message_count, 0);\\n177:         assert_eq!(summary.last_activity_ms, 1700000000000);\\n178:     }\\n179: \\n180:     #[test]\\n181:     fn parse_thread_with_title_and_messages() {\\n182:         let json = r#\\\"{\\n183:             \\\"v\\\": 0,\\n184:             \\\"id\\\": \\\"T-def-456\\\",\\n185:             \\\"created\\\": 1700000000000,\\n186:             \\\"title\\\": \\\"Fix the bug\\\",\\n187:             \\\"messages\\\": [{\\\"role\\\": \\\"user\\\"}, {\\\"role\\\": \\\"assistant\\\"}, {\\\"role\\\": \\\"user\\\"}]\\n188:         }\\\"#;\\n189:         let summary = parse_thread_summary(json).unwrap();\\n190:         assert_eq!(summary.title, \\\"Fix the bug\\\");\\n191:         assert_eq!(summary.message_count, 3);\\n192:     }\\n193: \\n194:     #[test]\\n195:     fn parse_thread_with_usage_ledger() {\\n196:         let json = r#\\\"{\\n197:             \\\"v\\\": 0,\\n198:             \\\"id\\\": \\\"T-ghi-789\\\",\\n199:             \\\"created\\\": 1700000000000,\\n200:             \\\"messages\\\": [{\\\"role\\\": \\\"user\\\"}],\\n201:             \\\"usageLedger\\\": {\\n202:                 \\\"events\\\": [\\n203:                     {\\\"timestamp\\\": \\\"2025-12-28T21:17:52.900Z\\\"},\\n204:                     {\\\"timestamp\\\": \\\"2025-12-28T21:21:59.052Z\\\"}\\n205:                 ]\\n206:             }\\n207:         }\\\"#;\\n208:         let summary = parse_thread_summary(json).unwrap();\\n209:         assert!(summary.last_activity_ms > 1700000000000);\\n210:         // 2025-12-28T21:21:59.052Z\\n211:         assert_eq!(summary.last_activity_ms, 1766956919052);\\n212:     }\\n213: \\n214:     #[test]\\n215:     fn format_relative_time_seconds() {\\n216:         assert_eq!(format_relative_time(1000_000, 1000_000), \\\"0s ago\\\");\\n217:         assert_eq!(format_relative_time(1030_000, 1000_000), \\\"30s ago\\\");\\n218:     }\\n219: \\n220:     #[test]\\n221:     fn format_relative_time_minutes() {\\n222:         assert_eq!(format_relative_time(1000_000 + 120_000, 1000_000), \\\"2m ago\\\");\\n223:         assert_eq!(format_relative_time(1000_000 + 420_000, 1000_000), \\\"7m ago\\\");\\n224:     }\\n225: \\n226:     #[test]\\n227:     fn format_relative_time_hours() {\\n228:         let two_hours = 2 * 3600 * 1000;\\n229:         assert_eq!(format_relative_time(1000_000 + two_hours, 1000_000), \\\"2h ago\\\");\\n230:     }\\n231: \\n232:     #[test]\\n233:     fn format_relative_time_days() {\\n234:         let three_days = 3 * 86400 * 1000;\\n235:         assert_eq!(format_relative_time(1000_000 + three_days, 1000_000), \\\"3d ago\\\");\\n236:     }\\n237: \\n238:     #[test]\\n239:     fn chrono_parse_known_timestamp() {\\n240:         let ms = chrono_parse_to_ms(\\\"2025-12-28T21:21:59.052Z\\\").unwrap();\\n241:         assert_eq!(ms, 1766956919052);\\n242:     }\\n243: \\n244:     #[test]\\n245:     fn chrono_parse_no_millis() {\\n246:         let ms = chrono_parse_to_ms(\\\"2025-01-01T00:00:00Z\\\").unwrap();\\n247:         // 2025-01-01 = day 20089 from epoch\\n248:         assert_eq!(ms, 1735689600000);\\n249:     }\\n250: \\n251:     #[test]\\n252:     fn load_thread_summaries_from_dir() {\\n253:         let dir = tempfile::tempdir().unwrap();\\n254:         let thread_json = r#\\\"{\\n255:             \\\"v\\\": 0,\\n256:             \\\"id\\\": \\\"T-test-1\\\",\\n257:             \\\"created\\\": 1700000000000,\\n258:             \\\"title\\\": \\\"Test thread\\\",\\n259:             \\\"messages\\\": [{\\\"role\\\": \\\"user\\\"}]\\n260:         }\\\"#;\\n261:         std::fs::write(dir.path().join(\\\"T-test-1.json\\\"), thread_json).unwrap();\\n262: \\n263:         let summaries = load_thread_summaries(dir.path(), &[\\\"T-test-1\\\".to_string()]);\\n264:         assert_eq!(summaries.len(), 1);\\n265:         assert_eq!(summaries[0].title, \\\"Test thread\\\");\\n266:     }\\n267: \\n268:     #[test]\\n269:     fn load_thread_summaries_skips_missing_files() {\\n270:         let dir = tempfile::tempdir().unwrap();\\n271:         let summaries = load_thread_summaries(\\n272:             dir.path(),\\n273:             &[\\\"T-nonexistent\\\".to_string()],\\n274:         );\\n275:         assert!(summaries.is_empty());\\n276:     }\\n277: \\n278:     #[test]\\n279:     fn thread_summary_relative_time_is_nonempty() {\\n280:         let summary = ThreadSummary {\\n281:             id: \\\"T-test\\\".to_string(),\\n282:             title: \\\"Test\\\".to_string(),\\n283:             message_count: 1,\\n284:             last_activity_ms: 1700000000000,\\n285:         };\\n286:         let relative = summary.relative_time();\\n287:         assert!(!relative.is_empty());\\n288:         assert!(relative.ends_with(\\\" ago\\\"));\\n289:     }\\n290: }\"}","is_error":false}]},"parent_tool_use_id":null,"session_id":"T-019cff66-99a5-7158-9c1b-99d421c4bc06"}
{"type":"assistant","message":{"type":"message","role":"assistant","content":[{"type":"text","text":"Now I have a clear picture. The issue asks for a state file at `~/.config/ishi/state.toml` with thread links and workspace history. The existing `state.rs` already has thread links and per-thread workspaces using JSON at `~/.local/share/ishi/state.json`, but the issue specifies:\n\n1. **TOML format** at `~/.config/ishi/state.toml`\n2. **Thread links**: thread ID → issue identifier + workspace path (different structure)\n3. **Workspace history**: ordered list of directories (most recent first)\n4. Specific API: `load()`, `save()`, `add_thread_link()`, `threads_for_issue()`, `add_workspace()`, `workspaces()`\n\nThe existing code is used in `main.rs`. I need to refactor to match the issue's spec while keeping the existing callers working. Let me understand the current usage patterns more carefully.\n\nThe issue says:\n- Thread links: thread ID → issue identifier + workspace path. One issue can have many threads, each thread belongs to exactly one issue.\n- Workspace history: ordered list of previously used directory paths, most recent first.\n\nThis is a redesign of the state module. The current structure maps issue → threads and has separate workspace map. The new structure maps thread → (issue, workspace) and adds a workspace history list.\n\nLet me implement this. I need to update `state.rs` to match the spec, then update all callers in `main.rs`."},{"type":"tool_use","id":"toolu_vrtx_01CNioQHuNr5hgV7VJpAEMHV","name":"create_file","input":{"path":"/Users/jmawson/Development/sourcery/ishi/src/amp/state.rs","content":"use anyhow::Result;\nuse serde::{Deserialize, Serialize};\nuse std::collections::HashMap;\nuse std::path::{Path, PathBuf};\n\n/// A thread's link to a Linear issue and the workspace it was started in.\n#[derive(Debug, Serialize, Deserialize, Clone, PartialEq)]\npub struct ThreadLink {\n    pub issue: String,\n    pub workspace: String,\n}\n\n/// Persistent state for ishi, stored at `~/.config/ishi/state.toml`.\n///\n/// Two data structures:\n/// * **Thread links** — maps thread ID → issue identifier + workspace path.\n///   One issue can have many threads, but each thread belongs to exactly one issue.\n/// * **Workspace history** — ordered list of previously used directory paths,\n///   most recent first.\n#[derive(Debug, Serialize, Deserialize, Default, Clone, PartialEq)]\npub struct State {\n    /// thread ID → link (issue identifier + workspace path)\n    #[serde(default)]\n    pub thread_links: HashMap<String, ThreadLink>,\n\n    /// Ordered list of workspace directory paths, most recent first.\n    #[serde(default)]\n    pub workspace_history: Vec<String>,\n}\n\n#[allow(dead_code)]\nimpl State {\n    /// Load state from a TOML file, returning default if the file does not exist.\n    pub fn load(path: &Path) -> Result<Self> {\n        if !path.exists() {\n            return Ok(Self::default());\n        }\n        let contents = std::fs::read_to_string(path)?;\n        let state: State = toml::from_str(&contents)?;\n        Ok(state)\n    }\n\n    /// Save state to a TOML file, creating parent directories as needed.\n    pub fn save(&self, path: &Path) -> Result<()> {\n        if let Some(parent) = path.parent() {\n            std::fs::create_dir_all(parent)?;\n        }\n        let contents = toml::to_string_pretty(self)?;\n        std::fs::write(path, contents)?;\n        Ok(())\n    }\n\n    /// Record a thread link: thread ID → issue identifier + workspace path.\n    /// If the thread already exists, it is updated.\n    pub fn add_thread_link(&mut self, thread_id: &str, issue: &str, workspace: &str) {\n        self.thread_links.insert(\n            thread_id.to_string(),\n            ThreadLink {\n                issue: issue.to_string(),\n                workspace: workspace.to_string(),\n            },\n        );\n    }\n\n    /// Return all thread IDs linked to the given issue identifier.\n    pub fn threads_for_issue(&self, issue_identifier: &str) -> Vec<&str> {\n        let mut ids: Vec<&str> = self\n            .thread_links\n            .iter()\n            .filter(|(_, link)| link.issue == issue_identifier)\n            .map(|(id, _)| id.as_str())\n            .collect();\n        ids.sort();\n        ids\n    }\n\n    /// Look up the workspace directory for a given thread ID.\n    pub fn workspace_for(&self, thread_id: &str) -> Option<&str> {\n        self.thread_links\n            .get(thread_id)\n            .map(|link| link.workspace.as_str())\n    }\n\n    /// Add a workspace directory to the front of the history.\n    /// If it already appears, it is moved to the front.\n    pub fn add_workspace(&mut self, workspace: &str) {\n        self.workspace_history\n            .retain(|w| w != workspace);\n        self.workspace_history.insert(0, workspace.to_string());\n    }\n\n    /// Return the ordered workspace history (most recent first).\n    pub fn workspaces(&self) -> &[String] {\n        &self.workspace_history\n    }\n}\n\n/// Return the default state file path: `~/.config/ishi/state.toml`.\npub fn state_path() -> Result<PathBuf> {\n    let dir = dirs::config_dir()\n        .ok_or_else(|| anyhow::anyhow!(\"could not determine config directory\"))?\n        .join(\"ishi\");\n    std::fs::create_dir_all(&dir)?;\n    Ok(dir.join(\"state.toml\"))\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn load_missing_file_returns_default() {\n        let dir = tempfile::tempdir().unwrap();\n        let path = dir.path().join(\"nonexistent.toml\");\n        let state = State::load(&path).unwrap();\n        assert!(state.thread_links.is_empty());\n        assert!(state.workspace_history.is_empty());\n    }\n\n    #[test]\n    fn save_and_load_round_trip() {\n        let dir = tempfile::tempdir().unwrap();\n        let path = dir.path().join(\"state.toml\");\n\n        let mut state = State::default();\n        state.add_thread_link(\"T-abc-123\", \"JEM-1\", \"/home/user/project-a\");\n        state.add_thread_link(\"T-def-456\", \"JEM-1\", \"/home/user/project-a\");\n        state.add_thread_link(\"T-ghi-789\", \"JEM-2\", \"/home/user/project-b\");\n        state.add_workspace(\"/home/user/project-a\");\n        state.add_workspace(\"/home/user/project-b\");\n\n        state.save(&path).unwrap();\n\n        let loaded = State::load(&path).unwrap();\n        assert_eq!(loaded, state);\n    }\n\n    #[test]\n    fn threads_for_issue_unknown_returns_empty() {\n        let state = State::default();\n        assert!(state.threads_for_issue(\"JEM-999\").is_empty());\n    }\n\n    #[test]\n    fn threads_for_issue_returns_matching_threads() {\n        let mut state = State::default();\n        state.add_thread_link(\"T-abc\", \"JEM-1\", \"/ws\");\n        state.add_thread_link(\"T-def\", \"JEM-1\", \"/ws\");\n        state.add_thread_link(\"T-ghi\", \"JEM-2\", \"/ws\");\n\n        let threads = state.threads_for_issue(\"JEM-1\");\n        assert_eq!(threads.len(), 2);\n        assert!(threads.contains(&\"T-abc\"));\n        assert!(threads.contains(&\"T-def\"));\n    }\n\n    #[test]\n    fn add_thread_link_overwrites_existing() {\n        let mut state = State::default();\n        state.add_thread_link(\"T-abc\", \"JEM-1\", \"/old/path\");\n        state.add_thread_link(\"T-abc\", \"JEM-1\", \"/new/path\");\n\n        assert_eq!(state.thread_links.len(), 1);\n        assert_eq!(state.workspace_for(\"T-abc\"), Some(\"/new/path\"));\n    }\n\n    #[test]\n    fn workspace_for_unknown_thread_returns_none() {\n        let state = State::default();\n        assert!(state.workspace_for(\"T-unknown\").is_none());\n    }\n\n    #[test]\n    fn workspace_for_known_thread() {\n        let mut state = State::default();\n        state.add_thread_link(\"T-abc\", \"JEM-1\", \"/home/user/project\");\n        assert_eq!(state.workspace_for(\"T-abc\"), Some(\"/home/user/project\"));\n    }\n\n    #[test]\n    fn add_workspace_inserts_at_front() {\n        let mut state = State::default();\n        state.add_workspace(\"/first\");\n        state.add_workspace(\"/second\");\n        assert_eq!(state.workspaces(), &[\"/second\", \"/first\"]);\n    }\n\n    #[test]\n    fn add_workspace_deduplicates_and_moves_to_front() {\n        let mut state = State::default();\n        state.add_workspace(\"/a\");\n        state.add_workspace(\"/b\");\n        state.add_workspace(\"/a\");\n        assert_eq!(state.workspaces(), &[\"/a\", \"/b\"]);\n    }\n\n    #[test]\n    fn workspaces_empty_by_default() {\n        let state = State::default();\n        assert!(state.workspaces().is_empty());\n    }\n\n    #[test]\n    fn save_creates_parent_directories() {\n        let dir = tempfile::tempdir().unwrap();\n        let path = dir.path().join(\"nested\").join(\"dir\").join(\"state.toml\");\n\n        let state = State::default();\n        state.save(&path).unwrap();\n        assert!(path.exists());\n    }\n\n    #[test]\n    fn workspace_history_round_trips_through_save_load() {\n        let dir = tempfile::tempdir().unwrap();\n        let path = dir.path().join(\"state.toml\");\n\n        let mut state = State::default();\n        state.add_workspace(\"/project-a\");\n        state.add_workspace(\"/project-b\");\n        state.add_workspace(\"/project-c\");\n        state.save(&path).unwrap();\n\n        let loaded = State::load(&path).unwrap();\n        assert_eq!(loaded.workspaces(), &[\"/project-c\", \"/project-b\", \"/project-a\"]);\n    }\n\n    #[test]\n    fn thread_link_round_trips_through_save_load() {\n        let dir = tempfile::tempdir().unwrap();\n        let path = dir.path().join(\"state.toml\");\n\n        let mut state = State::default();\n        state.add_thread_link(\"T-abc\", \"JEM-1\", \"/workspace/dir\");\n        state.save(&path).unwrap();\n\n        let loaded = State::load(&path).unwrap();\n        assert_eq!(loaded.workspace_for(\"T-abc\"), Some(\"/workspace/dir\"));\n        let threads = loaded.threads_for_issue(\"JEM-1\");\n        assert_eq!(threads, vec![\"T-abc\"]);\n    }\n\n    #[test]\n    fn load_empty_toml_returns_default() {\n        let dir = tempfile::tempdir().unwrap();\n        let path = dir.path().join(\"state.toml\");\n        std::fs::write(&path, \"\").unwrap();\n\n        let state = State::load(&path).unwrap();\n        assert!(state.thread_links.is_empty());\n        assert!(state.workspace_history.is_empty());\n    }\n\n    #[test]\n    fn load_toml_without_workspace_history() {\n        let dir = tempfile::tempdir().unwrap();\n        let path = dir.path().join(\"state.toml\");\n        let toml = r#\"\n[thread_links.T-abc]\nissue = \"JEM-1\"\nworkspace = \"/ws\"\n\"#;\n        std::fs::write(&path, toml).unwrap();\n\n        let state = State::load(&path).unwrap();\n        assert_eq!(state.threads_for_issue(\"JEM-1\"), vec![\"T-abc\"]);\n        assert!(state.workspace_history.is_empty());\n    }\n\n    #[test]\n    fn load_toml_without_thread_links() {\n        let dir = tempfile::tempdir().unwrap();\n        let path = dir.path().join(\"state.toml\");\n        let toml = r#\"workspace_history = [\"/a\", \"/b\"]\"#;\n        std::fs::write(&path, toml).unwrap();\n\n        let state = State::load(&path).unwrap();\n        assert!(state.thread_links.is_empty());\n        assert_eq!(state.workspaces(), &[\"/a\", \"/b\"]);\n    }\n}\n"}}],"stop_reason":"tool_use","usage":{"input_tokens":1,"cache_creation_input_tokens":6465,"cache_read_input_tokens":46042,"output_tokens":3365,"max_tokens":168000,"service_tier":"standard"}},"parent_tool_use_id":null,"session_id":"T-019cff66-99a5-7158-9c1b-99d421c4bc06"}
