Desc,\\n45: }\\n46: \\n47: impl SortDirection {\\n48:     pub fn toggle(self) -> Self {\\n49:         match self {\\n50:             SortDirection::Asc => SortDirection::Desc,\\n51:             SortDirection::Desc => SortDirection::Asc,\\n52:         }\\n53:     }\\n54: }\\n55: \\n56: pub struct App<A: LinearApi> {\\n57:     pub running: bool,\\n58:     pub view: View,\\n59:     pub api: A,\\n60:     pub issues: Vec<Issue>,\\n61:     pub selected: usize,\\n62:     pub filter: Option<(SortColumn, String)>,\\n63:     pub filter_input: String,\\n64:     pub filter_column: Option<SortColumn>,\\n65:     pub filtering: bool,\\n66:     pub awaiting_quit: bool,\\n67:     pub awaiting_filter: bool,\\n68:     pub awaiting_sort: bool,\\n69:     pub sort: Option<(SortColumn, SortDirection)>,\\n70:     pub search: Option<String>,\\n71:     pub search_input: String,\\n72:     pub searching: bool,\\n73:     pub detail_scroll: u16,\\n74:     pub detail_scroll_max: u16,\\n75:     pub refreshing: bool,\\n76:     pub detail_section: DetailSection,\\n77:     pub detail_threads: Vec<ThreadSummary>,\\n78:     pub detail_thread_selected: usize,\\n79: }\\n80: \\n81: impl<A: LinearApi> App<A> {\\n82:     pub fn new(api: A) -> Self {\\n83:         Self {\\n84:             running: true,\\n85:             view: View::MyIssues,\\n86:             api,\\n87:             issues: Vec::new(),\\n88:             selected: 0,\\n89:             filter: None,\\n90:             filter_input: String::new(),\\n91:             filter_column: None,\\n92:             filtering: false,\\n93:             awaiting_quit: false,\\n94:             awaiting_filter: false,\\n95:             awaiting_sort: false,\\n96:             sort: None,\\n97:             search: None,\\n98:             search_input: String::new(),\\n99:             searching: false,\\n100:             detail_scroll: 0,\\n101:             detail_scroll_max: 0,\\n102:             refreshing: false,\\n103:             detail_section: DetailSection::Body,\\n104:             detail_threads: Vec::new(),\\n105:             detail_thread_selected: 0,\\n106:         }\\n107:     }\\n108: \\n109:     pub fn filtered_issues(&self) -> Vec<&Issue> {\\n110:         let mut issues: Vec<&Issue> = self.issues.iter().collect();\\n111:         if let Some((col, f)) = &self.filter {\\n112:             let lower = f.to_lowercase();\\n113:             issues.retain(|i| {\\n114:                 let value = match col {\\n115:                     SortColumn::Identifier => i.identifier.as_str(),\\n116:                     SortColumn::Title => i.title.as_str(),\\n117:                     SortColumn::Project => i.project_str(),\\n118:                     SortColumn::Status => i.status_str(),\\n119:                     SortColumn::Priority => i.priority_str(),\\n120:                 };\\n121:                 value.to_lowercase().contains(&lower)\\n122:             });\\n123:         }\\n124:         if let Some(q) = &self.search {\\n125:             let lower = q.to_lowercase();\\n126:             issues.retain(|i| i.matches_search(&lower));\\n127:         }\\n128:         if let Some((col, dir)) = &self.sort {\\n129:             issues.sort_by(|a, b| {\\n130:                 let ord = match col {\\n131:                     SortColumn::Identifier => a.identifier.cmp(&b.identifier),\\n132:                     SortColumn::Title => a.title.to_lowercase().cmp(&b.title.to_lowercase()),\\n133:                     SortColumn::Project => a.project_str().cmp(b.project_str()),\\n134:                     SortColumn::Status => a.status_str().cmp(b.status_str()),\\n135:                     SortColumn::Priority => a.priority.partial_cmp(&b.priority).unwrap_or(Ordering::Equal),\\n136:                 };\\n137:                 match dir {\\n138:                     SortDirection::Asc => ord,\\n139:                     SortDirection::Desc => ord.reverse(),\\n140:                 }\\n141:             });\\n142:         }\\n143:         issues\\n144:     }\\n145: \\n146:     pub fn set_sort(&mut self, col: SortColumn) {\\n147:         self.sort = Some(match self.sort {\\n148:             Some((c, dir)) if c == col => (col, dir.toggle()),\\n149:             _ => (col, SortDirection::Asc),\\n150:         });\\n151:         self.selected = 0;\\n152:     }\\n153: \\n154:     pub fn move_down(&mut self) {\\n155:         let len = self.filtered_issues().len();\\n156:         if len > 0 && self.selected < len - 1 {\\n157:             self.selected += 1;\\n158:         }\\n159:     }\\n160: \\n161:     pub fn move_up(&mut self) {\\n162:         if self.selected > 0 {\\n163:             self.selected -= 1;\\n164:         }\\n165:     }\\n166: \\n167:     pub fn top(&mut self) {\\n168:         self.selected = 0;\\n169:     }\\n170: \\n171:     pub fn bottom(&mut self) {\\n172:         let len = self.filtered_issues().len();\\n173:         if len > 0 {\\n174:             self.selected = len - 1;\\n175:         }\\n176:     }\\n177: \\n178:     pub fn start_search(&mut self) {\\n179:         self.searching = true;\\n180:         self.search_input.clear();\\n181:     }\\n182: \\n183:     pub fn apply_search(&mut self) {\\n184:         self.searching = false;\\n185:         if self.search_input.is_empty() {\\n186:             self.search = None;\\n187:         } else {\\n188:             self.search = Some(self.search_input.clone());\\n189:         }\\n190:         self.selected = 0;\\n191:     }\\n192: \\n193:     pub fn cancel_search(&mut self) {\\n194:         self.searching = false;\\n195:         self.search_input.clear();\\n196:     }\\n197: \\n198:     pub fn clear_search(&mut self) {\\n199:         self.search = None;\\n200:         self.search_input.clear();\\n201:         self.selected = 0;\\n202:     }\\n203: \\n204:     pub fn start_filter(&mut self) {\\n205:         self.start_column_filter(SortColumn::Title);\\n206:     }\\n207: \\n208:     pub fn start_column_filter(&mut self, col: SortColumn) {\\n209:         self.filter_column = Some(col);\\n210:         self.filtering = true;\\n211:         self.filter_input.clear();\\n212:     }\\n213: \\n214:     pub fn apply_filter(&mut self) {\\n215:         self.filtering = false;\\n216:         if self.filter_input.is_empty() {\\n217:             self.filter = None;\\n218:         } else if let Some(col) = self.filter_column {\\n219:             self.filter = Some((col, self.filter_input.clone()));\\n220:         }\\n221:         self.filter_column = None;\\n222:         self.selected = 0;\\n223:     }\\n224: \\n225:     pub fn cancel_filter(&mut self) {\\n226:         self.filtering = false;\\n227:         self.filter_input.clear();\\n228:     }\\n229: \\n230:     pub fn clear_filter(&mut self) {\\n231:         self.filter = None;\\n232:         self.filter_column = None;\\n233:         self.filter_input.clear();\\n234:         self.selected = 0;\\n235:     }\\n236: \\n237:     pub fn select_issue(&mut self) {\\n238:         let issues = self.filtered_issues();\\n239:         if self.selected < issues.len() {\\n240:             self.view = View::Detail;\\n241:             self.detail_scroll = 0;\\n242:             self.detail_section = DetailSection::Body;\\n243:             self.detail_thread_selected = 0;\\n244:         }\\n245:     }\\n246: \\n247:     pub fn back_to_list(&mut self) {\\n248:         self.view = View::MyIssues;\\n249:         self.detail_scroll = 0;\\n250:         self.detail_section = DetailSection::Body;\\n[... omitted lines 251 to 477 ...]\\n478:         app.select_issue();\\n479:         app.detail_scroll_max = 2;\\n480:         app.scroll_detail_down();\\n481:         app.scroll_detail_down();\\n482:         assert_eq!(app.detail_scroll, 2);\\n483:         app.scroll_detail_down(); // should not exceed max\\n484:         assert_eq!(app.detail_scroll, 2);\\n485:     }\\n486: \\n487:     #[test]\\n488:     fn detail_scroll_blocked_when_content_fits() {\\n489:         let mut app = app_with_issues();\\n490:         app.select_issue();\\n491:         app.detail_scroll_max = 0; // content fits in box\\n492:         app.scroll_detail_down();\\n493:         assert_eq!(app.detail_scroll, 0);\\n494:     }\\n495: \\n496:     #[test]\\n497:     fn search_filters_across_all_columns() {\\n498:         let mut app = app_with_issues();\\n499:         app.search = Some(\\\"jem-2\\\".into());\\n500:         let results = app.filtered_issues();\\n501:         assert_eq!(results.len(), 1);\\n502:         assert_eq!(results[0].identifier, \\\"JEM-2\\\");\\n503:     }\\n504: \\n505:     #[test]\\n506:     fn search_is_case_insensitive() {\\n507:         let mut app = app_with_issues();\\n508:         app.search = Some(\\\"ALPHA\\\".into());\\n509:         assert_eq!(app.filtered_issues().len(), 1);\\n510:     }\\n511: \\n512:     #[test]\\n513:     fn search_matches_priority() {\\n514:         let mut app = app_with_issues();\\n515:         app.search = Some(\\\"high\\\".into());\\n516:         let results = app.filtered_issues();\\n517:         assert_eq!(results.len(), 1);\\n518:         assert_eq!(results[0].identifier, \\\"JEM-1\\\");\\n519:     }\\n520: \\n521:     #[test]\\n522:     fn apply_empty_search_clears() {\\n523:         let mut app = app_with_issues();\\n524:         app.start_search();\\n525:         app.apply_search();\\n526:         assert!(app.search.is_none());\\n527:         assert!(!app.searching);\\n528:     }\\n529: \\n530:     #[test]\\n531:     fn apply_search_sets_and_resets_cursor() {\\n532:         let mut app = app_with_issues();\\n533:         app.selected = 2;\\n534:         app.start_search();\\n535:         app.search_input = \\\"beta\\\".into();\\n536:         app.apply_search();\\n537:         assert_eq!(app.search.as_deref(), Some(\\\"beta\\\"));\\n538:         assert_eq!(app.selected, 0);\\n539:     }\\n540: \\n541:     #[test]\\n542:     fn cancel_search_discards_input() {\\n543:         let mut app = app_with_issues();\\n544:         app.start_search();\\n545:         app.search_input = \\\"something\\\".into();\\n546:         app.cancel_search();\\n547:         assert!(!app.searching);\\n548:         assert!(app.search_input.is_empty());\\n549:     }\\n550: \\n551:     #[test]\\n552:     fn search_and_filter_combine() {\\n553:         let mut app = app_with_issues();\\n554:         app.search = Some(\\\"task\\\".into());\\n555:         assert_eq!(app.filtered_issues().len(), 3);\\n556:         app.filter = Some((SortColumn::Title, \\\"alpha\\\".into()));\\n557:         assert_eq!(app.filtered_issues().len(), 1);\\n558:         assert_eq!(app.filtered_issues()[0].identifier, \\\"JEM-1\\\");\\n559:     }\\n560: \\n561:     #[tokio::test]\\n562:     async fn refresh_reloads_issues() {\\n563:         let fake = FakeLinearApi::new();\\n564:         fake.push_response(serde_json::json!({\\n565:             \\\"data\\\": { \\\"issues\\\": { \\\"nodes\\\": [\\n566:                 { \\\"id\\\": \\\"1\\\", \\\"identifier\\\": \\\"JEM-10\\\", \\\"title\\\": \\\"New issue\\\" }\\n567:             ]}}\\n568:         }));\\n569:         let mut app = App::new(fake);\\n570:         app.issues = vec![Issue {\\n571:             id: \\\"old\\\".into(),\\n572:             identifier: \\\"JEM-1\\\".into(),\\n573:             title: \\\"Old issue\\\".into(),\\n574:             state: None,\\n575:             priority: None,\\n576:             project: None,\\n577:             description: None,\\n578:             assignee: None,\\n579:             labels: None,\\n580:             comments: None,\\n581:         }];\\n582:         assert_eq!(app.issues.len(), 1);\\n583:         assert_eq!(app.issues[0].identifier, \\\"JEM-1\\\");\\n584: \\n585:         app.refresh().await;\\n586: \\n587:         assert_eq!(app.issues.len(), 1);\\n588:         assert_eq!(app.issues[0].identifier, \\\"JEM-10\\\");\\n589:         assert!(!app.refreshing);\\n590:     }\\n591: \\n592:     #[tokio::test]\\n593:     async fn refresh_preserves_selection_when_issue_exists() {\\n594:         let fake = FakeLinearApi::new();\\n595:         fake.push_response(serde_json::json!({\\n596:             \\\"data\\\": { \\\"issues\\\": { \\\"nodes\\\": [\\n597:                 { \\\"id\\\": \\\"1\\\", \\\"identifier\\\": \\\"JEM-1\\\", \\\"title\\\": \\\"Alpha\\\" },\\n598:                 { \\\"id\\\": \\\"2\\\", \\\"identifier\\\": \\\"JEM-2\\\", \\\"title\\\": \\\"Beta\\\" },\\n599:                 { \\\"id\\\": \\\"3\\\", \\\"identifier\\\": \\\"JEM-3\\\", \\\"title\\\": \\\"Gamma\\\" }\\n600:             ]}}\\n601:         }));\\n602:         let mut app = App::new(fake);\\n603:         app.issues = vec![\\n604:             Issue { id: \\\"1\\\".into(), identifier: \\\"JEM-1\\\".into(), title: \\\"Alpha\\\".into(), state: None, priority: None, project: None, description: None, assignee: None, labels: None, comments: None },\\n605:             Issue { id: \\\"2\\\".into(), identifier: \\\"JEM-2\\\".into(), title: \\\"Beta\\\".into(), state: None, priority: None, project: None, description: None, assignee: None, labels: None, comments: None },\\n606:         ];\\n607:         app.selected = 1; // JEM-2 selected\\n608: \\n609:         app.refresh().await;\\n610: \\n611:         assert_eq!(app.selected, 1); // JEM-2 is still at index 1\\n612:         assert_eq!(app.issues[app.selected].identifier, \\\"JEM-2\\\");\\n613:     }\\n614: \\n615:     #[tokio::test]\\n616:     async fn refresh_resets_selection_when_issue_gone() {\\n617:         let fake = FakeLinearApi::new();\\n618:         fake.push_response(serde_json::json!({\\n619:             \\\"data\\\": { \\\"issues\\\": { \\\"nodes\\\": [\\n620:                 { \\\"id\\\": \\\"1\\\", \\\"identifier\\\": \\\"JEM-1\\\", \\\"title\\\": \\\"Alpha\\\" },\\n621:                 { \\\"id\\\": \\\"3\\\", \\\"identifier\\\": \\\"JEM-3\\\", \\\"title\\\": \\\"Gamma\\\" }\\n622:             ]}}\\n623:         }));\\n624:         let mut app = App::new(fake);\\n625:         app.issues = vec![\\n626:             Issue { id: \\\"1\\\".into(), identifier: \\\"JEM-1\\\".into(), title: \\\"Alpha\\\".into(), state: None, priority: None, project: None, description: None, assignee: None, labels: None, comments: None },\\n627:             Issue { id: \\\"2\\\".into(), identifier: \\\"JEM-2\\\".into(), title: \\\"Beta\\\".into(), state: None, priority: None, project: None, description: None, assignee: None, labels: None, comments: None },\\n628:         ];\\n629:         app.selected = 1; // JEM-2 selected\\n630: \\n631:         app.refresh().await;\\n632: \\n633:         assert_eq!(app.selected, 0); // JEM-2 gone, reset to 0\\n634:     }\\n635: \\n636:     #[tokio::test]\\n637:     async fn refresh_on_api_error_preserves_issues() {\\n638:         let fake = FakeLinearApi::new();\\n639:         // No response enqueued — FakeLinearApi returns null data which yields empty vec,\\n640:         // but let's test the error case by not pushing any response (returns empty)\\n641:         let mut app = App::new(fake);\\n642:         let original_issues = vec![\\n643:             Issue { id: \\\"1\\\".into(), identifier: \\\"JEM-1\\\".into(), title: \\\"Alpha\\\".into(), state: None, priority: None, project: None, description: None, assignee: None, labels: None, comments: None },\\n644:         ];\\n645:         app.issues = original_issues.clone();\\n646: \\n647:         app.refresh().await;\\n648: \\n649:         // FakeLinearApi with no response returns empty vec (not an error), so issues get replaced\\n650:         // This tests that refreshing flag is cleared\\n651:         assert!(!app.refreshing);\\n652:     }\\n653: \\n654:     #[test]\\n655:     fn select_issue_resets_thread_state() {\\n656:         let mut app = app_with_issues();\\n657:         app.detail_section = DetailSection::Threads;\\n658:         app.detail_thread_selected = 2;\\n659:         app.select_issue();\\n660:         assert!(matches!(app.detail_section, DetailSection::Body));\\n661:         assert_eq!(app.detail_thread_selected, 0);\\n662:     }\\n663: \\n664:     #[test]\\n665:     fn back_to_list_clears_threads() {\\n666:         let mut app = app_with_issues();\\n667:         app.select_issue();\\n668:         app.detail_threads = vec![ThreadSummary {\\n669:             id: \\\"T-1\\\".into(),\\n670:             title: \\\"Thread\\\".into(),\\n671:             message_count: 5,\\n672:             last_activity_ms: 1700000000000,\\n673:         }];\\n674:         app.detail_section = DetailSection::Threads;\\n675:         app.back_to_list();\\n676:         assert!(matches!(app.detail_section, DetailSection::Body));\\n677:         assert!(app.detail_threads.is_empty());\\n678:         assert_eq!(app.detail_thread_selected, 0);\\n679:     }\\n680: \\n681:     #[test]\\n682:     fn thread_move_down_and_up() {\\n683:         let mut app = app_with_issues();\\n684:         app.detail_threads = vec![\\n685:             ThreadSummary { id: \\\"T-1\\\".into(), title: \\\"A\\\".into(), message_count: 1, last_activity_ms: 0 },\\n686:             ThreadSummary { id: \\\"T-2\\\".into(), title: \\\"B\\\".into(), message_count: 2, last_activity_ms: 0 },\\n687:             ThreadSummary { id: \\\"T-3\\\".into(), title: \\\"C\\\".into(), message_count: 3, last_activity_ms: 0 },\\n688:         ];\\n689:         assert_eq!(app.detail_thread_selected, 0);\\n690:         app.thread_move_down();\\n691:         assert_eq!(app.detail_thread_selected, 1);\\n692:         app.thread_move_down();\\n693:         assert_eq!(app.detail_thread_selected, 2);\\n694:         app.thread_move_down(); // should not exceed\\n695:         assert_eq!(app.detail_thread_selected, 2);\\n696:         app.thread_move_up();\\n697:         assert_eq!(app.detail_thread_selected, 1);\\n698:         app.thread_move_up();\\n699:         assert_eq!(app.detail_thread_selected, 0);\\n700:         app.thread_move_up(); // should not underflow\\n701:         assert_eq!(app.detail_thread_selected, 0);\\n702:     }\\n703: \\n704:     #[test]\\n705:     fn focus_threads_requires_threads() {\\n706:         let mut app = app_with_issues();\\n707:         app.focus_threads();\\n708:         assert!(matches!(app.detail_section, DetailSection::Body));\\n709: \\n710:         app.detail_threads = vec![ThreadSummary {\\n711:             id: \\\"T-1\\\".into(),\\n712:             title: \\\"A\\\".into(),\\n713:             message_count: 1,\\n714:             last_activity_ms: 0,\\n715:         }];\\n716:         app.focus_threads();\\n717:         assert!(matches!(app.detail_section, DetailSection::Threads));\\n718:     }\\n719: \\n720:     #[test]\\n721:     fn focus_body_returns_to_body() {\\n722:         let mut app = app_with_issues();\\n723:         app.detail_section = DetailSection::Threads;\\n724:         app.focus_body();\\n725:         assert!(matches!(app.detail_section, DetailSection::Body));\\n726:     }\\n727: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01SJ3aDe7LbVRewBk4ByWKFu","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/suspend.rs\",\"content\":\"1: use anyhow::Result;\\n2: use crossterm::{\\n3:     execute,\\n4:     terminal::{EnterAlternateScreen, LeaveAlternateScreen, disable_raw_mode, enable_raw_mode},\\n5: };\\n6: use std::io::stdout;\\n7: use std::path::Path;\\n8: use std::process::{Command, ExitStatus};\\n9: \\n10: #[allow(dead_code)]\\n11: /// Suspend the TUI, run an external command, then restore the TUI.\\n12: ///\\n13: /// Steps:\\n14: /// 1. Leave alternate screen\\n15: /// 2. Disable raw mode\\n16: /// 3. Run the command (blocking, inheriting stdin/stdout/stderr)\\n17: /// 4. Re-enable raw mode\\n18: /// 5. Re-enter alternate screen\\n19: /// 6. Force terminal redraw (via the returned `needs_redraw` signal)\\n20: ///\\n21: /// Returns the command's exit status.\\n22: pub fn run_external_command(program: &str, args: &[&str], working_dir: &Path) -> Result<ExitStatus> {\\n23:     run_external_command_with(&mut RealTerminal, program, args, working_dir)\\n24: }\\n25: \\n26: /// Testable version that accepts a [`TerminalControl`] implementation.\\n27: pub fn run_external_command_with<T: TerminalControl>(\\n28:     terminal: &mut T,\\n29:     program: &str,\\n30:     args: &[&str],\\n31:     working_dir: &Path,\\n32: ) -> Result<ExitStatus> {\\n33:     terminal.leave_alternate_screen()?;\\n34:     terminal.disable_raw_mode()?;\\n35: \\n36:     let status = Command::new(program)\\n37:         .args(args)\\n38:         .current_dir(working_dir)\\n39:         .stdin(std::process::Stdio::inherit())\\n40:         .stdout(std::process::Stdio::inherit())\\n41:         .stderr(std::process::Stdio::inherit())\\n42:         .status();\\n43: \\n44:     // Always attempt to restore the terminal, even if the command failed to run.\\n45:     terminal.enable_raw_mode()?;\\n46:     terminal.enter_alternate_screen()?;\\n47: \\n48:     Ok(status?)\\n49: }\\n50: \\n51: /// Abstraction over terminal operations for testability.\\n52: pub trait TerminalControl {\\n53:     fn leave_alternate_screen(&mut self) -> Result<()>;\\n54:     fn disable_raw_mode(&mut self) -> Result<()>;\\n55:     fn enable_raw_mode(&mut self) -> Result<()>;\\n56:     fn enter_alternate_screen(&mut self) -> Result<()>;\\n57: }\\n58: \\n59: /// Real implementation that talks to the actual terminal.\\n60: struct RealTerminal;\\n61: \\n62: impl TerminalControl for RealTerminal {\\n63:     fn leave_alternate_screen(&mut self) -> Result<()> {\\n64:         execute!(stdout(), LeaveAlternateScreen)?;\\n65:         Ok(())\\n66:     }\\n67: \\n68:     fn disable_raw_mode(&mut self) -> Result<()> {\\n69:         disable_raw_mode()?;\\n70:         Ok(())\\n71:     }\\n72: \\n73:     fn enable_raw_mode(&mut self) -> Result<()> {\\n74:         enable_raw_mode()?;\\n75:         Ok(())\\n76:     }\\n77: \\n78:     fn enter_alternate_screen(&mut self) -> Result<()> {\\n79:         execute!(stdout(), EnterAlternateScreen)?;\\n80:         Ok(())\\n81:     }\\n82: }\\n83: \\n84: #[cfg(test)]\\n85: mod tests {\\n86:     use super::*;\\n87:     use std::cell::RefCell;\\n88: \\n89:     /// Records the sequence of terminal operations for verification.\\n90:     struct MockTerminal {\\n91:         ops: RefCell<Vec<&'static str>>,\\n92:     }\\n93: \\n94:     impl MockTerminal {\\n95:         fn new() -> Self {\\n96:             Self {\\n97:                 ops: RefCell::new(Vec::new()),\\n98:             }\\n99:         }\\n100: \\n101:         fn ops(&self) -> Vec<&'static str> {\\n102:             self.ops.borrow().clone()\\n103:         }\\n104:     }\\n105: \\n106:     impl TerminalControl for MockTerminal {\\n107:         fn leave_alternate_screen(&mut self) -> Result<()> {\\n108:             self.ops.borrow_mut().push(\\\"leave_alternate_screen\\\");\\n109:             Ok(())\\n110:         }\\n111: \\n112:         fn disable_raw_mode(&mut self) -> Result<()> {\\n113:             self.ops.borrow_mut().push(\\\"disable_raw_mode\\\");\\n114:             Ok(())\\n115:         }\\n116: \\n117:         fn enable_raw_mode(&mut self) -> Result<()> {\\n118:             self.ops.borrow_mut().push(\\\"enable_raw_mode\\\");\\n119:             Ok(())\\n120:         }\\n121: \\n122:         fn enter_alternate_screen(&mut self) -> Result<()> {\\n123:             self.ops.borrow_mut().push(\\\"enter_alternate_screen\\\");\\n124:             Ok(())\\n125:         }\\n126:     }\\n127: \\n128:     #[test]\\n129:     fn terminal_operations_in_correct_order() {\\n130:         let mut mock = MockTerminal::new();\\n131:         let dir = tempfile::tempdir().unwrap();\\n132: \\n133:         let status =\\n134:             run_external_command_with(&mut mock, \\\"echo\\\", &[\\\"hello\\\"], dir.path()).unwrap();\\n135: \\n136:         assert!(status.success());\\n137:         assert_eq!(\\n138:             mock.ops(),\\n139:             vec![\\n140:                 \\\"leave_alternate_screen\\\",\\n141:                 \\\"disable_raw_mode\\\",\\n142:                 \\\"enable_raw_mode\\\",\\n143:                 \\\"enter_alternate_screen\\\",\\n144:             ]\\n145:         );\\n146:     }\\n147: \\n148:     #[test]\\n149:     fn returns_exit_status_of_command() {\\n150:         let mut mock = MockTerminal::new();\\n151:         let dir = tempfile::tempdir().unwrap();\\n152: \\n153:         let status =\\n154:             run_external_command_with(&mut mock, \\\"sh\\\", &[\\\"-c\\\", \\\"exit 42\\\"], dir.path()).unwrap();\\n155: \\n156:         assert!(!status.success());\\n157:         assert_eq!(status.code(), Some(42));\\n158:     }\\n159: \\n160:     #[test]\\n161:     fn runs_in_specified_working_directory() {\\n162:         let mut mock = MockTerminal::new();\\n163:         let dir = tempfile::tempdir().unwrap();\\n164:         let marker = dir.path().join(\\\"marker.txt\\\");\\n165: \\n166:         let status = run_external_command_with(\\n167:             &mut mock,\\n168:             \\\"sh\\\",\\n169:             &[\\\"-c\\\", \\\"echo ok > marker.txt\\\"],\\n170:             dir.path(),\\n171:         )\\n172:         .unwrap();\\n173: \\n174:         assert!(status.success());\\n175:         assert!(marker.exists());\\n176:     }\\n177: \\n178:     #[test]\\n179:     fn terminal_restored_even_when_command_fails() {\\n180:         let mut mock = MockTerminal::new();\\n181:         let dir = tempfile::tempdir().unwrap();\\n182: \\n183:         let status =\\n184:             run_external_command_with(&mut mock, \\\"sh\\\", &[\\\"-c\\\", \\\"exit 1\\\"], dir.path()).unwrap();\\n185: \\n186:         assert!(!status.success());\\n187:         // Terminal should still be restored\\n188:         assert_eq!(\\n189:             mock.ops(),\\n190:             vec![\\n191:                 \\\"leave_alternate_screen\\\",\\n192:                 \\\"disable_raw_mode\\\",\\n193:                 \\\"enable_raw_mode\\\",\\n194:                 \\\"enter_alternate_screen\\\",\\n195:             ]\\n196:         );\\n197:     }\\n198: \\n199:     #[test]\\n200:     fn error_when_program_not_found() {\\n201:         let mut mock = MockTerminal::new();\\n202:         let dir = tempfile::tempdir().unwrap();\\n203: \\n204:         let result = run_external_command_with(\\n205:             &mut mock,\\n206:             \\\"nonexistent_program_that_should_not_exist\\\",\\n207:             &[],\\n208:             dir.path(),\\n209:         );\\n210: \\n211:         assert!(result.is_err());\\n212:         // Terminal should still be restored even when the command can't be spawned\\n213:         assert_eq!(\\n214:             mock.ops(),\\n215:             vec![\\n216:                 \\\"leave_alternate_screen\\\",\\n217:                 \\\"disable_raw_mode\\\",\\n218:                 \\\"enable_raw_mode\\\",\\n219:                 \\\"enter_alternate_screen\\\",\\n220:             ]\\n221:         );\\n222:     }\\n223: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01BqgjtfeumRFYocUVLTjmGr","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/keys.rs\",\"content\":\"1: use crossterm::event::{KeyCode, KeyEvent, KeyModifiers};\\n2: \\n3: pub enum Action {\\n4:     Quit,\\n5:     MoveDown,\\n6:     MoveUp,\\n7:     Top,\\n8:     Bottom,\\n9:     Select,\\n10:     Back,\\n11:     Help,\\n12:     Search,\\n13:     OrderBy,\\n14:     FilterBy,\\n15:     Refresh,\\n16:     Tab,\\n17:     NewThread,\\n18: }\\n19: \\n20: pub fn map_key(key: KeyEvent) -> Option<Action> {\\n21:     match (key.modifiers, key.code) {\\n22:         (KeyModifiers::CONTROL, KeyCode::Char('c')) => Some(Action::Quit),\\n23:         (KeyModifiers::NONE, KeyCode::Char('q')) => Some(Action::Quit),\\n24:         (_, KeyCode::Char('j')) | (_, KeyCode::Down) => Some(Action::MoveDown),\\n25:         (_, KeyCode::Char('k')) | (_, KeyCode::Up) => Some(Action::MoveUp),\\n26:         (_, KeyCode::Char('g')) => Some(Action::Top),\\n27:         (KeyModifiers::SHIFT, KeyCode::Char('G')) => Some(Action::Bottom),\\n28:         (_, KeyCode::Enter) => Some(Action::Select),\\n29:         (_, KeyCode::Esc) => Some(Action::Back),\\n30:         (_, KeyCode::Char('?')) => Some(Action::Help),\\n31:         (_, KeyCode::Char('/')) => Some(Action::Search),\\n32:         (_, KeyCode::Char('s')) => Some(Action::OrderBy),\\n33:         (_, KeyCode::Char('f')) => Some(Action::FilterBy),\\n34:         (_, KeyCode::Char('r')) => Some(Action::Refresh),\\n35:         (_, KeyCode::Tab) => Some(Action::Tab),\\n36:         (_, KeyCode::Char('a')) => Some(Action::NewThread),\\n37:         _ => None,\\n38:     }\\n39: }\\n40: \\n41: #[cfg(test)]\\n42: mod tests {\\n43:     use super::*;\\n44:     use crossterm::event::{KeyCode, KeyEvent, KeyEventKind, KeyEventState, KeyModifiers};\\n45: \\n46:     fn key(code: KeyCode) -> KeyEvent {\\n47:         KeyEvent {\\n48:             code,\\n49:             modifiers: KeyModifiers::NONE,\\n50:             kind: KeyEventKind::Press,\\n51:             state: KeyEventState::NONE,\\n52:         }\\n53:     }\\n54: \\n55:     fn key_with(code: KeyCode, modifiers: KeyModifiers) -> KeyEvent {\\n56:         KeyEvent {\\n57:             code,\\n58:             modifiers,\\n59:             kind: KeyEventKind::Press,\\n60:             state: KeyEventState::NONE,\\n61:         }\\n62:     }\\n63: \\n64:     #[test]\\n65:     fn quit_on_q() {\\n66:         assert!(matches!(map_key(key(KeyCode::Char('q'))), Some(Action::Quit)));\\n67:     }\\n68: \\n69:     #[test]\\n70:     fn quit_on_ctrl_c() {\\n71:         assert!(matches!(\\n72:             map_key(key_with(KeyCode::Char('c'), KeyModifiers::CONTROL)),\\n73:             Some(Action::Quit)\\n74:         ));\\n75:     }\\n76: \\n77:     #[test]\\n78:     fn navigation_keys() {\\n79:         assert!(matches!(map_key(key(KeyCode::Char('j'))), Some(Action::MoveDown)));\\n80:         assert!(matches!(map_key(key(KeyCode::Down)), Some(Action::MoveDown)));\\n81:         assert!(matches!(map_key(key(KeyCode::Char('k'))), Some(Action::MoveUp)));\\n82:         assert!(matches!(map_key(key(KeyCode::Up)), Some(Action::MoveUp)));\\n83:         assert!(matches!(map_key(key(KeyCode::Char('g'))), Some(Action::Top)));\\n84:         assert!(matches!(\\n85:             map_key(key_with(KeyCode::Char('G'), KeyModifiers::SHIFT)),\\n86:             Some(Action::Bottom)\\n87:         ));\\n88:     }\\n89: \\n90:     #[test]\\n91:     fn action_keys() {\\n92:         assert!(matches!(map_key(key(KeyCode::Enter)), Some(Action::Select)));\\n93:         assert!(matches!(map_key(key(KeyCode::Esc)), Some(Action::Back)));\\n94:         assert!(matches!(map_key(key(KeyCode::Char('?'))), Some(Action::Help)));\\n95:         assert!(matches!(map_key(key(KeyCode::Char('/'))), Some(Action::Search)));\\n96:     }\\n97: \\n98:     #[test]\\n99:     fn refresh_on_r() {\\n100:         assert!(matches!(map_key(key(KeyCode::Char('r'))), Some(Action::Refresh)));\\n101:     }\\n102: \\n103:     #[test]\\n104:     fn tab_maps_to_tab() {\\n105:         assert!(matches!(map_key(key(KeyCode::Tab)), Some(Action::Tab)));\\n106:     }\\n107: \\n108:     #[test]\\n109:     fn new_thread_on_a() {\\n110:         assert!(matches!(map_key(key(KeyCode::Char('a'))), Some(Action::NewThread)));\\n111:     }\\n112: \\n113:     #[test]\\n114:     fn unmapped_keys_return_none() {\\n115:         assert!(map_key(key(KeyCode::Char('x'))).is_none());\\n116:         assert!(map_key(key(KeyCode::F(1))).is_none());\\n117:     }\\n118: }\"}","is_error":false}]},"parent_tool_use_id":null,"session_id":"T-019cff63-d9ff-75b9-843d-87c3d499cbb8"}
