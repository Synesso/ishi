{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"toolu_vrtx_0191sRQ31WnqpqQZS7k7EbCP","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/api/client.rs\",\"content\":\"1: use anyhow::Result;\\n2: use reqwest::Client;\\n3: use serde_json::Value;\\n4: \\n5: use super::types::Issue;\\n6: \\n7: const LINEAR_API_URL: &str = \\\"https://api.linear.app/graphql\\\";\\n8: \\n9: const MY_ISSUES_QUERY: &str = r#\\\"\\n10: query {\\n11:   viewer {\\n12:     assignedIssues(\\n13:       first: 50\\n14:       filter: { state: { type: { nin: [\\\"completed\\\", \\\"canceled\\\"] } } }\\n15:       orderBy: updatedAt\\n16:     ) {\\n17:       nodes {\\n18:         id\\n19:         identifier\\n20:         title\\n21:         state { name }\\n22:         priority\\n23:         project { name }\\n24:         description\\n25:         assignee { name }\\n26:         labels { nodes { name } }\\n27:         comments { nodes { body user { name } createdAt } }\\n28:       }\\n29:     }\\n30:   }\\n31: }\\n32: \\\"#;\\n33: \\n34: pub trait LinearApi: Send + Sync {\\n35:     fn query(\\n36:         &self,\\n37:         query: &str,\\n38:         variables: Option<Value>,\\n39:     ) -> impl std::future::Future<Output = Result<Value>> + Send;\\n40: \\n41:     fn fetch_my_issues(\\n42:         &self,\\n43:     ) -> impl std::future::Future<Output = Result<Vec<Issue>>> + Send;\\n44: }\\n45: \\n46: pub struct LinearClient {\\n47:     client: Client,\\n48:     api_key: [REDACTED:api-key],\\n49: }\\n50: \\n51: impl LinearClient {\\n52:     pub fn new(api_key: [REDACTED:api-key]) -> Self {\\n53:         Self {\\n54:             client: Client::new(),\\n55:             api_key,\\n56:         }\\n57:     }\\n58: }\\n59: \\n60: impl LinearApi for LinearClient {\\n61:     async fn query(&self, query: &str, variables: Option<Value>) -> Result<Value> {\\n62:         let mut body = serde_json::json!({ \\\"query\\\": query });\\n63:         if let Some(vars) = variables {\\n64:             body[\\\"variables\\\"] = vars;\\n65:         }\\n66: \\n67:         let resp = self\\n68:             .client\\n69:             .post(LINEAR_API_URL)\\n70:             .header(\\\"Authorization\\\", &self.api_key)\\n71:             .json(&body)\\n72:             .send()\\n73:             .await?\\n74:             .error_for_status()?\\n75:             .json::<Value>()\\n76:             .await?;\\n77: \\n78:         Ok(resp)\\n79:     }\\n80: \\n81:     async fn fetch_my_issues(&self) -> Result<Vec<Issue>> {\\n82:         let resp = self.query(MY_ISSUES_QUERY, None).await?;\\n83:         let issues: Vec<Issue> = serde_json::from_value(\\n84:             resp[\\\"data\\\"][\\\"viewer\\\"][\\\"assignedIssues\\\"][\\\"nodes\\\"].clone(),\\n85:         )?;\\n86:         Ok(issues)\\n87:     }\\n88: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01UjBEnRNmD6ky4wLQCJ5c69","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/api/fake.rs\",\"content\":\"1: use anyhow::Result;\\n2: use serde_json::Value;\\n3: use std::collections::VecDeque;\\n4: use std::sync::Mutex;\\n5: \\n6: use super::client::LinearApi;\\n7: use super::types::Issue;\\n8: \\n9: /// A fake Linear API client for tests and offline development.\\n10: /// Enqueue responses with `push_response`, and they'll be returned in order by `query`.\\n11: pub struct FakeLinearApi {\\n12:     responses: Mutex<VecDeque<Value>>,\\n13: }\\n14: \\n15: impl FakeLinearApi {\\n16:     pub fn new() -> Self {\\n17:         Self {\\n18:             responses: Mutex::new(VecDeque::new()),\\n19:         }\\n20:     }\\n21: \\n22:     pub fn push_response(&self, response: Value) {\\n23:         self.responses.lock().unwrap().push_back(response);\\n24:     }\\n25: }\\n26: \\n27: impl LinearApi for FakeLinearApi {\\n28:     async fn query(&self, _query: &str, _variables: Option<Value>) -> Result<Value> {\\n29:         let response = self\\n30:             .responses\\n31:             .lock()\\n32:             .unwrap()\\n33:             .pop_front()\\n34:             .unwrap_or_else(|| serde_json::json!({\\\"data\\\": null}));\\n35:         Ok(response)\\n36:     }\\n37: \\n38:     async fn fetch_my_issues(&self) -> Result<Vec<Issue>> {\\n39:         let resp = self.query(\\\"\\\", None).await?;\\n40:         let nodes = &resp[\\\"data\\\"][\\\"issues\\\"][\\\"nodes\\\"];\\n41:         if nodes.is_null() {\\n42:             return Ok(vec![]);\\n43:         }\\n44:         let issues: Vec<Issue> = serde_json::from_value(nodes.clone())?;\\n45:         Ok(issues)\\n46:     }\\n47: }\\n48: \\n49: #[cfg(test)]\\n50: mod tests {\\n51:     use super::*;\\n52: \\n53:     #[tokio::test]\\n54:     async fn returns_enqueued_responses_in_order() {\\n55:         let fake = FakeLinearApi::new();\\n56:         fake.push_response(serde_json::json!({\\\"data\\\": {\\\"first\\\": true}}));\\n57:         fake.push_response(serde_json::json!({\\\"data\\\": {\\\"second\\\": true}}));\\n58: \\n59:         let r1 = fake.query(\\\"q1\\\", None).await.unwrap();\\n60:         let r2 = fake.query(\\\"q2\\\", None).await.unwrap();\\n61: \\n62:         assert_eq!(r1[\\\"data\\\"][\\\"first\\\"], true);\\n63:         assert_eq!(r2[\\\"data\\\"][\\\"second\\\"], true);\\n64:     }\\n65: \\n66:     #[tokio::test]\\n67:     async fn returns_null_data_when_exhausted() {\\n68:         let fake = FakeLinearApi::new();\\n69:         let r = fake.query(\\\"q\\\", None).await.unwrap();\\n70:         assert!(r[\\\"data\\\"].is_null());\\n71:     }\\n72: \\n73:     #[tokio::test]\\n74:     async fn fetch_my_issues_from_fixture() {\\n75:         let fake = FakeLinearApi::new();\\n76:         let fixture: Value =\\n77:             serde_json::from_str(include_str!(\\\"../../tests/fixtures/my_issues.json\\\")).unwrap();\\n78:         fake.push_response(fixture);\\n79: \\n80:         let issues = fake.fetch_my_issues().await.unwrap();\\n81:         