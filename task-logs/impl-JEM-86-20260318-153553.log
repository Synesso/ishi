ring>,\n    pub state: Option<IssueState>,"}}],"stop_reason":"tool_use","usage":{"input_tokens":1,"cache_creation_input_tokens":498,"cache_read_input_tokens":70858,"output_tokens":614,"max_tokens":168000,"service_tier":"standard"}},"parent_tool_use_id":null,"session_id":"T-019cff71-c993-74f3-bc85-44bb4a8742c5"}
