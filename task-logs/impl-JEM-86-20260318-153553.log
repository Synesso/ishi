{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"toolu_vrtx_01UMV9nb6n4aRae5qf6xoGR5","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/api/client.rs\",\"content\":\"1: use anyhow::Result;\\n2: use reqwest::Client;\\n3: use serde_json::Value;\\n4: \\n5: use super::types::Issue;\\n6: \\n7: const LINEAR_API_URL: &str = \\\"https://api.linear.app/graphql\\\";\\n8: \\n9: const MY_ISSUES_QUERY: &str = r#\\\"\\n10: query {\\n11:   viewer {\\n12:     assignedIssues(\\n13:       first: 50\\n14:       filter: { state: { type: { nin: [\\\"completed\\\", \\\"canceled\\\"] } } }\\n15:       orderBy: updatedAt\\n16:     ) {\\n17:       nodes {\\n18:         id\\n19:         identifier\\n20:         title\\n21:         state { name }\\n22:         priority\\n23:         project { name }\\n24:         description\\n25:         assignee { name }\\n26:         labels { nodes { name } }\\n27:         comments { nodes { body user { name } createdAt } }\\n28:       }\\n29:     }\\n30:   }\\n31: }\\n32: \\\"#;\\n33: \\n34: pub trait LinearApi: Send + Sync {\\n35:     fn query(\\n36:         &self,\\n37:         query: &str,\\n38:         variables: Option<Value>,\\n39:     ) -> impl std::future::Future<Output = Result<Value>> + Send;\\n40: \\n41:     fn fetch_my_issues(\\n42:         &self,\\n43:     ) -> impl std::future::Future<Output = Result<Vec<Issue>>> + Send;\\n44: }\\n45: \\n46: pub struct LinearClient {\\n47:     client: Client,\\n48:     api_key: [REDACTED:api-key],\\n49: }\\n50: \\n51: impl LinearClient {\\n52:     pub fn new(api_key: [REDACTED:api-key]) -> Self {\\n53:         Self {\\n54:             client: Client::new(),\\n55:             api_key,\\n56:         }\\n57:     }\\n58: }\\n59: \\n60: impl LinearApi for LinearClient {\\n61:     async fn query(&self, query: &str, variables: Option<Value>) -> Result<Value> {\\n62:         let mut body = serde_json::json!({ \\\"query\\\": query });\\n63:         if let Some(vars) = variables {\\n64:             body[\\\"variables\\\"] = vars;\\n65:         }\\n66: \\n67:         let resp = self\\n68:             .client\\n69:             .post(LINEAR_API_URL)\\n70:             .header(\\\"Authorization\\\", &self.api_key)\\n71:             .json(&body)\\n72:             .send()\\n73:             .await?\\n74:             .error_for_status()?\\n75:             .json::<Value>()\\n76:             .await?;\\n77: \\n78:         Ok(resp)\\n79:     }\\n80: \\n81:     async fn fetch_my_issues(&self) -> Result<Vec<Issue>> {\\n82:         let resp = self.query(MY_ISSUES_QUERY, None).await?;\\n83:         let issues: Vec<Issue> = serde_json::from_value(\\n84:             resp[\\\"data\\\"][\\\"viewer\\\"][\\\"assignedIssues\\\"][\\\"nodes\\\"].clone(),\\n85:         )?;\\n86:         Ok(issues)\\n87:     }\\n88: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01HtSUgdEzscc7Kk8CjrPPdR","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/api\",\"content\":\"client.rs\\nfake.rs\\nmod.rs\\ntypes.rs\",\"isDirectory\":true,\"directoryEntries\":[\"client.rs\",\"fake.rs\",\"mod.rs\",\"types.rs\"]}","is_error":false}]},"parent_tool_use_id":null,"session_id":"T-019cff71-c993-74f3-bc85-44bb4a8742c5"}
