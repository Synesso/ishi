1:             },\\n412:             Issue {\\n413:                 id: \\\"2\\\".into(),\\n414:                 identifier: \\\"JEM-2\\\".into(),\\n415:                 title: \\\"Beta task\\\".into(),\\n416:                 state: None,\\n417:                 priority: Some(3.0),\\n418:                 project: None,\\n419:                 description: None,\\n420:                 assignee: None,\\n421:                 labels: None,\\n422:                 comments: None,\\n423:             },\\n424:             Issue {\\n425:                 id: \\\"3\\\".into(),\\n426:                 identifier: \\\"JEM-3\\\".into(),\\n427:                 title: \\\"Gamma task\\\".into(),\\n428:                 state: None,\\n429:                 priority: None,\\n430:                 project: None,\\n431:                 description: None,\\n432:                 assignee: None,\\n433:                 labels: None,\\n434:                 comments: None,\\n435:             },\\n436:         ];\\n437:         app\\n438:     }\\n439: \\n440:     #[test]\\n441:     fn navigation_wraps_at_bounds() {\\n442:         let mut app = app_with_issues();\\n443:         assert_eq!(app.selected, 0);\\n444: \\n445:         app.move_down();\\n446:         assert_eq!(app.selected, 1);\\n447:         app.move_down();\\n448:         assert_eq!(app.selected, 2);\\n449:         app.move_down(); // at bottom, stays\\n450:         assert_eq!(app.selected, 2);\\n451: \\n452:         app.move_up();\\n453:         assert_eq!(app.selected, 1);\\n454:         app.top();\\n455:         assert_eq!(app.selected, 0);\\n456:         app.move_up(); // at top, stays\\n457:         assert_eq!(app.selected, 0);\\n458:     }\\n459: \\n460:     #[test]\\n461:     fn bottom_goes_to_last() {\\n462:         let mut app = app_with_issues();\\n463:         app.bottom();\\n464:         assert_eq!(app.selected, 2);\\n465:     }\\n466: \\n467:     #[test]\\n468:     fn filter_narrows_results() {\\n469:         let mut app = app_with_issues();\\n470:         app.filter = Some((SortColumn::Title, \\\"beta\\\".into()));\\n471:         let filtered = app.filtered_issues();\\n472:         assert_eq!(filtered.len(), 1);\\n473:         assert_eq!(filtered[0].identifier, \\\"JEM-2\\\");\\n474:     }\\n475: \\n476:     #[test]\\n477:     fn filter_is_case_insensitive() {\\n478:         let mut app = app_with_issues();\\n479:         app.filter = Some((SortColumn::Title, \\\"ALPHA\\\".into()));\\n480:         assert_eq!(app.filtered_issues().len(), 1);\\n481:     }\\n482: \\n483:     #[test]\\n484:     fn apply_empty_filter_clears() {\\n485:         let mut app = app_with_issues();\\n486:         app.start_filter();\\n487:         app.apply_filter();\\n488:         assert!(app.filter.is_none());\\n489:         assert!(!app.filtering);\\n490:     }\\n491: \\n492:     #[test]\\n493:     fn apply_filter_sets_and_resets_cursor() {\\n494:         let mut app = app_with_issues();\\n495:         app.selected = 2;\\n496:         app.start_filter();\\n497:         app.filter_input = \\\"gamma\\\".into();\\n498:         app.apply_filter();\\n499:         assert_eq!(app.filter.as_ref().map(|(_, f)| f.as_str()), Some(\\\"gamma\\\"));\\n500:         assert_eq!(app.selected, 0);\\n[... omitted lines 501 to 1012 ...]\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01SB2CirdtWZH5YyTXWuhW41","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/main.rs\",\"content\":\"1: mod amp;\\n2: mod api;\\n3: mod app;\\n4: mod config;\\n5: mod keys;\\n6: mod suspend;\\n7: mod views;\\n8: \\n9: use anyhow::Result;\\n10: use api::client::{LinearApi, LinearClient};\\n11: use app::App;\\n12: use crossterm::{\\n13:     event::{self, Event, KeyCode},\\n14:     terminal::{disable_raw_mode, enable_raw_mode, EnterAlternateScreen, LeaveAlternateScreen},\\n15:     ExecutableCommand,\\n16: };\\n17: use ratatui::{prelude::CrosstermBackend, Terminal};\\n18: use std::io::stdout;\\n19: use std::path::Path;\\n20: use std::collections::HashSet;\\n21: \\n22: /// Look up the workspace for a thread from the state file, then run\\n23: /// `amp threads continue <thread_id>` in that workspace directory,\\n24: /// suspending and restoring the TUI around the external process.\\n25: fn continue_thread(thread_id: &str) -> Result<()> {\\n26:     let state_path = amp::state::state_path()?;\\n27:     let state = amp::state::State::load(&state_path)?;\\n28:     let workspace = state\\n29:         .workspace_for(thread_id)\\n30:         .ok_or_else(|| anyhow::anyhow!(\\\"no workspace recorded for thread {}\\\", thread_id))?;\\n31:     let workspace_path = Path::new(workspace);\\n32:     suspend::run_external_command(\\\"amp\\\", &[\\\"threads\\\", \\\"continue\\\", thread_id], workspace_path)?;\\n33:     Ok(())\\n34: }\\n35: \\n36: fn load_threads_for_issue(app: &mut App<impl LinearApi>, identifier: &str) {\\n37:     let state_path = match amp::state::state_path() {\\n38:         Ok(p) => p,\\n39:         Err(_) => return,\\n40:     };\\n41:     let state = match amp::state::State::load(&state_path) {\\n42:         Ok(s) => s,\\n43:         Err(_) => return,\\n44:     };\\n45:     let thread_ids: Vec<String> = state\\n46:         .threads_for_issue(identifier)\\n47:         .into_iter()\\n48:         .map(|s| s.to_string())\\n49:         .collect();\\n50:     if thread_ids.is_empty() {\\n51:         app.detail_threads.clear();\\n52:         return;\\n53:     }\\n54:     let threads_dir = match amp::thread::amp_threads_dir() {\\n55:         Some(d) => d,\\n56:         None => return,\\n57:     };\\n58:     app.detail_threads = amp::thread::load_thread_summaries(&threads_dir, &thread_ids);\\n59:     app.detail_thread_selected = 0;\\n60: }\\n61: \\n62: /// Open the workspace picker for the current issue.\\n63: /// Loads workspace history from state and populates the picker.\\n64: fn open_workspace_picker(app: &mut App<impl LinearApi>) {\\n65:     let state_path = match amp::state::state_path() {\\n66:         Ok(p) => p,\\n67:         Err(_) => return,\\n68:     };\\n69:     let state = match amp::state::State::load(&state_path) {\\n70:         Ok(s) => s,\\n71:         Err(_) => return,\\n72:     };\\n73:     let workspaces: Vec<String> = state.workspaces().to_vec();\\n74:     app.show_workspace_picker(workspaces);\\n75: }\\n76: \\n77: /// Execute the new-thread flow:\\n78: /// 1. Snapshot thread IDs\\n79: /// 2. Suspend TUI and run `amp threads new` in the chosen workspace\\n80: /// 3. Diff thread IDs to detect the new thread\\n81: /// 4. If found, save thread link and update workspace history\\n82: fn start_new_thread(\\n83:     issue_identifier: &str,\\n84:     workspace: &str,\\n85:     before_ids: &HashSet<String>,\\n86: ) -> Result<()> {\\n87:     let workspace_path = Path::new(workspace);\\n88:     suspend::run_external_command(\\\"amp\\\", &[\\\"threads\\\", \\\"new\\\"], workspace_path)?;\\n89: \\n90:     // Diff thread IDs to find the newly created thread\\n91:     let threads_dir = match amp::thread::amp_threads_dir() {\\n92:         Some(d) => d,\\n93:         None => return Ok(()),\\n94:     };\\n95:     let after_ids = amp::thread::snapshot_thread_ids(&threads_dir);\\n96:     let new_ids: Vec<&String> = after_ids.difference(before_ids).collect();\\n97: \\n98:     if let Some(new_thread_id) = new_ids.first() {\\n99:         let state_path = amp::state::state_path()?;\\n100:         let mut state = amp::state::State::load(&state_path)?;\\n101:         state.add_thread_link(new_thread_id, issue_identifier, workspace);\\n102:         state.add_workspace(workspace);\\n103:         state.save(&state_path)?;\\n104:     }\\n105: \\n106:     Ok(())\\n107: }\\n108: \\n109: #[tokio::main]\\n110: async fn main() -> Result<()> {\\n111:     let api_key = config::resolve_api_key()?;\\n112:     let client = LinearClient::new(api_key);\\n113:     let mut app = App::new(client);\\n114: \\n115:     // Fetch issues before entering TUI\\n116:     match app.api.fetch_my_issues().await {\\n117:         Ok(issues) => app.issues = issues,\\n118:         Err(e) => eprintln!(\\\"Failed to fetch issues: {e}\\\"),\\n119:     }\\n120: \\n121:     // Terminal setup\\n122:     enable_raw_mode()?;\\n123:     stdout().execute(EnterAlternateScreen)?;\\n124:     let mut terminal = Terminal::new(CrosstermBackend::new(stdout()))?;\\n125: \\n126:     // Main loop\\n127:     while app.running {\\n128:         terminal.draw(|frame| {\\n129:             let area = frame.area();\\n130:             match app.view {\\n131:                 app::View::MyIssues => views::my_issues::render(frame, area, &app),\\n132:                 app::View::Detail => views::detail::render(frame, area, &mut app),\\n133:                 _ => {\\n134:                     frame.render_widget(\\n135:                         ratatui::widgets::Paragraph::new(\\\"ishi — (view not implemented)\\\"),\\n136:                         area,\\n137:                     );\\n138:                 }\\n139:             }\\n140:         })?;\\n141: \\n142:         if event::poll(std::time::Duration::from_millis(100))?\\n143:             && let Event::Key(key) = event::read()?\\n144:         {\\n145:             if app.workspace_picker.is_some() {\\n146:                 let is_typing = app.workspace_picker.as_ref().is_some_and(|p| p.typing);\\n147:                 if is_typing {\\n148:                     match key.code {\\n149:                         KeyCode::Enter => {\\n150:                             let typed_path = app\\n151:                                 .workspace_picker\\n152:                                 .as_mut()\\n153:                                 .and_then(|p| p.confirm_typed_path());\\n154:                             if let (Some(workspace), Some(issue)) =\\n155:                                 (typed_path, app.selected_issue())\\n156:                             {\\n157:                                 let issue_id = issue.identifier.clone();\\n158:                                 app.workspace_picker = None;\\n159:                                 let before_ids = amp::thread::amp_threads_dir()\\n160:                                     .map(|d| amp::thread::snapshot_thread_ids(&d))\\n161:                                     .unwrap_or_default();\\n162:                                 let _ = start_new_thread(&issue_id, &workspace, &before_ids);\\n163:                                 load_threads_for_issue(&mut app, &issue_id);\\n164:                             }\\n165:                         }\\n166:                         KeyCode::Esc => {\\n167:                             if let Some(ref mut picker) = app.workspace_picker {\\n168:                                 picker.cancel_typing();\\n169:                             }\\n170:                         }\\n171:                         KeyCode::Backspace => {\\n172:                             if let Some(ref mut picker) = app.workspace_picker {\\n173:                                 picker.input.pop();\\n174:                             }\\n175:                         }\\n176:                         KeyCode::Char(c) => {\\n177:                             if let Some(ref mut picker) = app.workspace_picker {\\n178:                                 picker.input.push(c);\\n179:                             }\\n180:                         }\\n181:                         _ => {}\\n182:                     }\\n183:                 } else {\\n184:                     match key.code {\\n185:                         KeyCode::Enter => {\\n186:                             let picker = app.workspace_picker.take();\\n187:                             if let (Some(picker), Some(issue)) = (picker, app.selected_issue())\\n188:                                 && let Some(workspace) = picker.options.get(picker.selected)\\n189:                             {\\n190:                                 let issue_id = issue.identifier.clone();\\n191:                                 let workspace = workspace.clone();\\n192:                                 let before_ids = amp::thread::amp_threads_dir()\\n193:                                     .map(|d| amp::thread::snapshot_thread_ids(&d))\\n194:                                     .unwrap_or_default();\\n195:                                 let _ = start_new_thread(&issue_id, &workspace, &before_ids);\\n196:                                 load_threads_for_issue(&mut app, &issue_id);\\n197:                             }\\n198:                         }\\n199:                         KeyCode::Esc => app.cancel_workspace_picker(),\\n200:                         KeyCode::Char('/') => {\\n201:                             if let Some(ref mut picker) = app.workspace_picker {\\n202:                                 picker.start_typing();\\n203:                             }\\n204:                         }\\n205:                         KeyCode::Char('j') | KeyCode::Down => {\\n206:                             if let Some(ref mut picker) = app.workspace_picker {\\n207:                                 picker.move_down();\\n208:                             }\\n209:                         }\\n210:                         KeyCode::Char('k') | KeyCode::Up => {\\n211:                             if let Some(ref mut picker) = app.workspace_picker {\\n212:                                 picker.move_up();\\n213:                             }\\n214:                         }\\n215:                         _ => {}\\n216:                     }\\n217:                 }\\n218:             } else if app.awaiting_quit {\\n219:                 app.awaiting_quit = false;\\n220:                 match key.code {\\n221:                     KeyCode::Char('q') => app.running = false,\\n222:                     _ => {}\\n223:                 }\\n224:             } else if app.awaiting_sort {\\n225:                 app.awaiting_sort = false;\\n226:                 match key.code {\\n227:                     KeyCode::Char('i') => app.set_sort(app::SortColumn::Identifier),\\n228:                     KeyCode::Char('t') => app.set_sort(app::SortColumn::Title),\\n229:                     KeyCode::Char('p') => app.set_sort(app::SortColumn::Project),\\n230:                     KeyCode::Char('s') => app.set_sort(app::SortColumn::Status),\\n231:                     KeyCode::Char('r') => app.set_sort(app::SortColumn::Priority),\\n232:                     _ => {}\\n233:                 }\\n234:             } else if app.awaiting_filter {\\n235:                 app.awaiting_filter = false;\\n236:                 match key.code {\\n237:                     KeyCode::Char('i') => app.start_column_filter(app::SortColumn::Identifier),\\n238:                     KeyCode::Char('t') => app.start_column_filter(app::SortColumn::Title),\\n239:                     KeyCode::Char('p') => app.start_column_filter(app::SortColumn::Project),\\n240:                     KeyCode::Char('s') => app.start_column_filter(app::SortColumn::Status),\\n241:                     KeyCode::Char('r') => app.start_column_filter(app::SortColumn::Priority),\\n242:                     _ => {}\\n243:                 }\\n244:             } else if app.searching {\\n245:                 match key.code {\\n246:                     KeyCode::Enter => app.apply_search(),\\n247:                     KeyCode::Esc => app.cancel_search(),\\n248:                     KeyCode::Backspace => {\\n249:                         app.search_input.pop();\\n250:                     }\\n251:                     KeyCode::Char(c) => {\\n252:                         app.search_input.push(c);\\n253:                     }\\n254:                     _ => {}\\n255:                 }\\n256:             } else if app.filtering {\\n257:                 match key.code {\\n258:                     KeyCode::Enter => app.apply_filter(),\\n259:                     KeyCode::Esc => app.cancel_filter(),\\n260:                     KeyCode::Backspace => {\\n261:                         app.filter_input.pop();\\n262:                     }\\n263:                     KeyCode::Char(c) => {\\n264:                         app.filter_input.push(c);\\n265:                     }\\n266:                     _ => {}\\n267:                 }\\n268:             } else if matches!(app.view, app::View::Detail) {\\n269:                 if let Some(action) = keys::map_key(key) {\\n270:                     match app.detail_section {\\n271:                         app::DetailSection::Threads => match action {\\n272:                             keys::Action::Quit => app.awaiting_quit = true,\\n273:                             keys::Action::Back => app.focus_body(),\\n274:                             keys::Action::MoveDown => app.thread_move_down(),\\n275:                             keys::Action::MoveUp => app.thread_move_up(),\\n276:                             keys::Action::Select => {\\n277:                                 if let Some(thread) = app.selected_thread() {\\n278:                                     let thread_id = thread.id.clone();\\n279:                                     let _ = continue_thread(&thread_id);\\n280:                                 }\\n281:                             }\\n282:                             keys::Action::Tab => app.focus_body(),\\n283:                             keys::Action::Refresh => app.refresh().await,\\n284:                             keys::Action::NewThread => open_workspace_picker(&mut app),\\n285:                             _ => {}\\n286:                         },\\n287:                         app::DetailSection::Body => match action {\\n288:                             keys::Action::Quit => app.awaiting_quit = true,\\n289:                             keys::Action::Back => app.back_to_list(),\\n290:                             keys::Action::MoveDown => app.scroll_detail_down(),\\n291:                             keys::Action::MoveUp => app.scroll_detail_up(),\\n292:                             keys::Action::Top => app.detail_scroll = 0,\\n293:                             keys::Action::Refresh => app.refresh().await,\\n294:                             keys::Action::Tab => app.focus_threads(),\\n295:                             keys::Action::NewThread => open_workspace_picker(&mut app),\\n296:                             _ => {}\\n297:                         },\\n298:                     }\\n299:                 }\\n300:             } else if let Some(action) = keys::map_key(key) {\\n301:                 match action {\\n302:                     keys::Action::Quit => app.awaiting_quit = true,\\n303:                     keys::Action::MoveDown => app.move_down(),\\n304:                     keys::Action::MoveUp => app.move_up(),\\n305:                     keys::Action::Top => app.top(),\\n306:                     keys::Action::Bottom => app.bottom(),\\n307:                     keys::Action::Select => {\\n308:                         let id = app.selected_issue().map(|i| i.identifier.clone());\\n309:                         app.select_issue();\\n310:                         if let Some(id) = id {\\n311:                             load_threads_for_issue(&mut app, &id);\\n312:                         }\\n313:                     }\\n314:                     keys::Action::Search => app.start_search(),\\n315:                     keys::Action::Back => {\\n316:                         if app.search.is_some() {\\n317:                             app.clear_search();\\n318:                         } else {\\n319:                             app.clear_filter();\\n320:                         }\\n321:                     }\\n322:                     keys::Action::OrderBy => app.awaiting_sort = true,\\n323:                     keys::Action::FilterBy => app.awaiting_filter = true,\\n324:                     keys::Action::Refresh => app.refresh().await,\\n325:                     _ => {}\\n326:                 }\\n327:             }\\n328:         }\\n329:     }\\n33