{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"toolu_vrtx_01FeornfU1KZ65pApeZZkdYz","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/api/fake.rs\",\"content\":\"1: use anyhow::Result;\\n2: use serde_json::Value;\\n3: use std::collections::VecDeque;\\n4: use std::sync::Mutex;\\n5: \\n6: use super::client::LinearApi;\\n7: use super::types::Issue;\\n8: \\n9: /// A fake Linear API client for tests and offline development.\\n10: /// Enqueue responses with `push_response`, and they'll be returned in order by `query`.\\n11: pub struct FakeLinearApi {\\n12:     responses: Mutex<VecDeque<Value>>,\\n13: }\\n14: \\n15: impl FakeLinearApi {\\n16:     pub fn new() -> Self {\\n17:         Self {\\n18:             responses: Mutex::new(VecDeque::new()),\\n19:         }\\n20:     }\\n21: \\n22:     pub fn push_response(&self, response: Value) {\\n23:         self.responses.lock().unwrap().push_back(response);\\n24:     }\\n25: }\\n26: \\n27: impl LinearApi for FakeLinearApi {\\n28:     async fn query(&self, _query: &str, _variables: Option<Value>) -> Result<Value> {\\n29:         let response = self\\n30:             .responses\\n31:             .lock()\\n32:             .unwrap()\\n33:             .pop_front()\\n34:             .unwrap_or_else(|| serde_json::json!({\\\"data\\\": null}));\\n35:         Ok(response)\\n36:     }\\n37: \\n38:     async fn fetch_my_issues(&self) -> Result<Vec<Issue>> {\\n39:         let resp = self.query(\\\"\\\", None).await?;\\n40:         let nodes = &resp[\\\"data\\\"][\\\"issues\\\"][\\\"nodes\\\"];\\n41:         if nodes.is_null() {\\n42:             return Ok(vec![]);\\n43:         }\\n44:         let issues: Vec<Issue> = serde_json::from_value(nodes.clone())?;\\n45:         Ok(issues)\\n46:     }\\n47: }\\n48: \\n49: #[cfg(test)]\\n50: mod tests {\\n51:     use super::*;\\n52: \\n53:     #[tokio::test]\\n54:     async fn returns_enqueued_responses_in_order() {\\n55:         let fake = FakeLinearApi::new();\\n56:         fake.push_response(serde_json::json!({\\\"data\\\": {\\\"first\\\": true}}));\\n57:         fake.push_response(serde_json::json!({\\\"data\\\": {\\\"second\\\": true}}));\\n58: \\n59:         let r1 = fake.query(\\\"q1\\\", None).await.unwrap();\\n60:         let r2 = fake.query(\\\"q2\\\", None).await.unwrap();\\n61: \\n62:         assert_eq!(r1[\\\"data\\\"][\\\"first\\\"], true);\\n63:         assert_eq!(r2[\\\"data\\\"][\\\"second\\\"], true);\\n64:     }\\n65: \\n66:     #[tokio::test]\\n67:     async fn returns_null_data_when_exhausted() {\\n68:         let fake = FakeLinearApi::new();\\n69:         let r = fake.query(\\\"q\\\", None).await.unwrap();\\n70:         assert!(r[\\\"data\\\"].is_null());\\n71:     }\\n72: \\n73:     #[tokio::test]\\n74:     async fn fetch_my_issues_from_fixture() {\\n75:         let fake = FakeLinearApi::new();\\n76:         let fixture: Value =\\n77:             serde_json::from_str(include_str!(\\\"../../tests/fixtures/my_issues.json\\\")).unwrap();\\n78:         fake.push_response(fixture);\\n79: \\n80:         let issues = fake.fetch_my_issues().await.unwrap();\\n81:         assert_eq!(issues.len(), 2);\\n82:         assert_eq!(issues[0].identifier, \\\"JEM-1\\\");\\n83:         assert_eq!(issues[1].identifier, \\\"JEM-2\\\");\\n84:     }\\n85: \\n86:     #[tokio::test]\\n87:     async fn fetch_my_issues_empty_when_no_data() {\\n88:         let fake = FakeLinearApi::new();\\n89:         let issues = fake.fetch_my_issues().await.unwrap();\\n90:         assert!(issues.is_empty());\\n91:     }\\n92: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01MrykDKBQ7X1SiX4mryf1hE","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/tests/fixtures\",\"content\":\"issue_detail.json\\nmy_issues.json\",\"isDirectory\":true,\"directoryEntries\":[\"issue_detail.json\",\"my_issues.json\"]}","is_error":false}]},"parent_tool_use_id":null,"session_id":"T-019cff71-c993-74f3-bc85-44bb4a8742c5"}
