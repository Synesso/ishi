{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"toolu_vrtx_01U7mFX61Q6T53cJqcR3kYcm","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/suspend.rs\",\"content\":\"1: use anyhow::Result;\\n2: use crossterm::{\\n3:     execute,\\n4:     terminal::{EnterAlternateScreen, LeaveAlternateScreen, disable_raw_mode, enable_raw_mode},\\n5: };\\n6: use std::io::stdout;\\n7: use std::path::Path;\\n8: use std::process::{Command, ExitStatus};\\n9: \\n10: #[allow(dead_code)]\\n11: /// Suspend the TUI, run an external command, then restore the TUI.\\n12: ///\\n13: /// Steps:\\n14: /// 1. Leave alternate screen\\n15: /// 2. Disable raw mode\\n16: /// 3. Run the command (blocking, inheriting stdin/stdout/stderr)\\n17: /// 4. Re-enable raw mode\\n18: /// 5. Re-enter alternate screen\\n19: /// 6. Force terminal redraw (via the returned `needs_redraw` signal)\\n20: ///\\n21: /// Returns the command's exit status.\\n22: pub fn run_external_command(program: &str, args: &[&str], working_dir: &Path) -> Result<ExitStatus> {\\n23:     run_external_command_with(&mut RealTerminal, program, args, working_dir)\\n24: }\\n25: \\n26: /// Testable version that accepts a [`TerminalControl`] implementation.\\n27: pub fn run_external_command_with<T: TerminalControl>(\\n28:     terminal: &mut T,\\n29:     program: &str,\\n30:     args: &[&str],\\n31:     working_dir: &Path,\\n32: ) -> Result<ExitStatus> {\\n33:     terminal.leave_alternate_screen()?;\\n34:     terminal.disable_raw_mode()?;\\n35: \\n36:     let status = Command::new(program)\\n37:         .args(args)\\n38:         .current_dir(working_dir)\\n39:         .stdin(std::process::Stdio::inherit())\\n40:         .stdout(std::process::Stdio::inherit())\\n41:         .stderr(std::process::Stdio::inherit())\\n42:         .status();\\n43: \\n44:     // Always attempt to restore the terminal, even if the command failed to run.\\n45:     terminal.enable_raw_mode()?;\\n46:     terminal.enter_alternate_screen()?;\\n47: \\n48:     Ok(status?)\\n49: }\\n50: \\n51: /// Abstraction over terminal operations for testability.\\n52: pub trait TerminalControl {\\n53:     fn leave_alternate_screen(&mut self) -> Result<()>;\\n54:     fn disable_raw_mode(&mut self) -> Result<()>;\\n55:     fn enable_raw_mode(&mut self) -> Result<()>;\\n56:     fn enter_alternate_screen(&mut self) -> Result<()>;\\n57: }\\n58: \\n59: /// Real implementation that talks to the actual terminal.\\n60: struct RealTerminal;\\n61: \\n62: impl TerminalControl for RealTerminal {\\n63:     fn leave_alternate_screen(&mut self) -> Result<()> {\\n64:         execute!(stdout(), LeaveAlternateScreen)?;\\n65:         Ok(())\\n66:     }\\n67: \\n68:     fn disable_raw_mode(&mut self) -> Result<()> {\\n69:         disable_raw_mode()?;\\n70:         Ok(())\\n71:     }\\n72: \\n73:     fn enable_raw_mode(&mut self) -> Result<()> {\\n74:         enable_raw_mode()?;\\n75:         Ok(())\\n76:     }\\n77: \\n78:     fn enter_alternate_screen(&mut self) -> Result<()> {\\n79:         execute!(stdout(), EnterAlternateScreen)?;\\n80:         Ok(())\\n81:     }\\n82: }\\n83: \\n84: #[cfg(test)]\\n85: mod tests {\\n86:     use super::*;\\n87:     use std::cell::RefCell;\\n88: \\n89:     /// Records the sequence of terminal operations for verification.\\n90:     struct MockTerminal {\\n91:         ops: RefCell<Vec<&'static str>>,\\n92:     }\\n93: \\n94:     impl MockTerminal {\\n95:         fn new() -> Self {\\n96:             Self {\\n97:                 ops: RefCell::new(Vec::new()),\\n98:             }\\n99:         }\\n100: \\n101:         fn ops(&self) -> Vec<&'static str> {\\n102:             self.ops.borrow().clone()\\n103:         }\\n104:     }\\n105: \\n106:     impl TerminalControl for MockTerminal {\\n107:         fn leave_alternate_screen(&mut self) -> Result<()> {\\n108:             self.ops.borrow_mut().push(\\\"leave_alternate_screen\\\");\\n109:             Ok(())\\n110:         }\\n111: \\n112:         fn disable_raw_mode(&mut self) -> Result<()> {\\n113:             self.ops.borrow_mut().push(\\\"disable_raw_mode\\\");\\n114:             Ok(())\\n115:         }\\n116: \\n117:         fn enable_raw_mode(&mut self) -> Result<()> {\\n118:             self.ops.borrow_mut().push(\\\"enable_raw_mode\\\");\\n119:             Ok(())\\n120:         }\\n121: \\n122:         fn enter_alternate_screen(&mut self) -> Result<()> {\\n123:             self.ops.borrow_mut().push(\\\"enter_alternate_screen\\\");\\n124:             Ok(())\\n125:         }\\n126:     }\\n127: \\n128:     #[test]\\n129:     fn terminal_operations_in_correct_order() {\\n130:         let mut mock = MockTerminal::new();\\n131:         let dir = tempfile::tempdir().unwrap();\\n132: \\n133:         let status =\\n134:             run_external_command_with(&mut mock, \\\"echo\\\", &[\\\"hello\\\"], dir.path()).unwrap();\\n135: \\n136:         assert!(status.success());\\n137:         assert_eq!(\\n138:             mock.ops(),\\n139:             vec![\\n140:                 \\\"leave_alternate_screen\\\",\\n141:                 \\\"disable_raw_mode\\\",\\n142:                 \\\"enable_raw_mode\\\",\\n143:                 \\\"enter_alternate_screen\\\",\\n144:             ]\\n145:         );\\n146:     }\\n147: \\n148:     #[test]\\n149:     fn returns_exit_status_of_command() {\\n150:         let mut mock = MockTerminal::new();\\n151:         let dir = tempfile::tempdir().unwrap();\\n152: \\n153:         let status =\\n154:             run_external_command_with(&mut mock, \\\"sh\\\", &[\\\"-c\\\", \\\"exit 42\\\"], dir.path()).unwrap();\\n155: \\n156:         assert!(!status.success());\\n157:         assert_eq!(status.code(), Some(42));\\n158:     }\\n159: \\n160:     #[test]\\n161:     fn runs_in_specified_working_directory() {\\n162:         let mut mock = MockTerminal::new();\\n163:         let dir = tempfile::tempdir().unwrap();\\n164:         let marker = dir.path().join(\\\"marker.txt\\\");\\n165: \\n166:         let status = run_external_command_with(\\n167:             &mut mock,\\n168:             \\\"sh\\\",\\n169:             &[\\\"-c\\\", \\\"echo ok > marker.txt\\\"],\\n170:             dir.path(),\\n171:         )\\n172:         .unwrap();\\n173: \\n174:         assert!(status.success());\\n175:         assert!(marker.exists());\\n176:     }\\n177: \\n178:     #[test]\\n179:     fn terminal_restored_even_when_command_fails() {\\n180:         let mut mock = MockTerminal::new();\\n181:         let dir = tempfile::tempdir().unwrap();\\n182: \\n183:         let status =\\n184:             run_external_command_with(&mut mock, \\\"sh\\\", &[\\\"-c\\\", \\\"exit 1\\\"], dir.path()).unwrap();\\n185: \\n186:         assert!(!status.success());\\n187:         // Terminal should still be restored\\n188:         assert_eq!(\\n189:             mock.ops(),\\n190:             vec![\\n191:                 \\\"leave_alternate_screen\\\",\\n192:                 \\\"disable_raw_mode\\\",\\n193:                 \\\"enable_raw_mode\\\",\\n194:                 \\\"enter_alternate_screen\\\",\\n195:             ]\\n196:         );\\n197:     }\\n198: \\n199:     #[test]\\n200:     fn error_when_program_not_found() {\\n201:         let mut mock = MockTerminal::new();\\n202:         let dir = tempfile::tempdir().unwrap();\\n203: \\n204:         let result = run_external_command_with(\\n205:             &mut mock,\\n206:             \\\"nonexistent_program_that_should_not_exist\\\",\\n207:             &[],\\n208:             dir.path(),\\n209:         );\\n210: \\n211:         assert!(result.is_err());\\n212:         // Terminal should still be restored even when the command can't be spawned\\n213:         assert_eq!(\\n214:             mock.ops(),\\n215:             vec![\\n216:                 \\\"leave_alternate_screen\\\",\\n217:                 \\\"disable_raw_mode\\\",\\n218:                 \\\"enable_raw_mode\\\",\\n219:                 \\\"enter_alternate_screen\\\",\\n220:             ]\\n221:         );\\n222:     }\\n223: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01DyEhiZzS4hxfP51WPGt5wb","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/views/my_issues.rs\",\"content\":\"1: use ratatui::{\\n2:     layout::{Constraint, Layout, Rect},\\n3:     style::{Color, Modifier, Style},\\n4:     text::{Line, Span},\\n5:     widgets::{Block, Borders, Cell, Paragraph, Row, Table, TableState},\\n6:     Frame,\\n7: };\\n8: \\n9: use crate::api::client::LinearApi;\\n10: use crate::app::{App, SortDirection};\\n11: \\n12: pub fn render<A: LinearApi>(frame: &mut Frame, area: Rect, app: &App<A>) {\\n13:     let issues = app.filtered_issues();\\n14: \\n15:     let show_bar = app.refreshing || app.awaiting_quit || app.filtering || app.filter.is_some()\\n16:         || app.awaiting_sort || app.awaiting_filter\\n17:         || app.searching || app.search.is_some();\\n18:     let chunks = if show_bar {\\n19:         Layout::vertical([Constraint::Min(0), Constraint::Length(1)]).split(area)\\n20:     } else {\\n21:         Layout::vertical([Constraint::Min(0)]).split(area)\\n22:     };\\n23: \\n24:     let header = Row::new(vec![\\n25:         Cell::from(\\\"ID\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n26:         Cell::from(\\\"Title\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n27:         Cell::from(\\\"Project\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n28:         Cell::from(\\\"Status\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n29:         Cell::from(\\\"Priority\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n30:     ]);\\n31: \\n32:     let search_query = app.search.as_deref();\\n33: \\n34:     let rows: Vec<Row> = issues\\n35:         .iter()\\n36:         .map(|issue| {\\n37:             Row::new(vec![\\n38:                 Cell::from(Line::from(highlight_match(issue.identifier.as_str(), search_query, Style::default()))),\\n39:                 Cell::from(Line::from(highlight_match(issue.title.as_str(), search_query, Style::default()))),\\n40:                 Cell::from(Line::from(highlight_match(issue.project_str(), search_query, Style::default()))),\\n41:                 Cell::from(Line::from(highlight_match(issue.status_str(), search_query, status_style(issue.status_str())))),\\n42:                 Cell::from(Line::from(highlight_match(issue.priority_str(), search_query, priority_style(issue.priority_str())))),\\n43:             ])\\n44:         })\\n45:         .collect();\\n46: \\n47:     let sort_indicator = match &app.sort {\\n48:         Some((col, dir)) => {\\n49:             let arrow = match dir {\\n50:                 SortDirection::Asc => \\\"↑\\\",\\n51:                 SortDirection::Desc => \\\"↓\\\",\\n52:             };\\n53:             format!(\\\" [sort: {} {}]\\\", col.label(), arrow)\\n54:         }\\n55:         None => String::new(),\\n56:     };\\n57: \\n58:     let search_indicator = match &app.search {\\n59:         Some(q) => format!(\\\" [search: {}]\\\", q),\\n60:         None => String::new(),\\n61:     };\\n62: \\n63:     let title = match &app.filter {\\n64:         Some((col, f)) => format!(\\\"My Issues ({} of {}){}{} [filter: {} = {}]\\\", issues.len(), app.issues.len(), sort_indicator, search_indicator, col.label(), f),\\n65:         None => format!(\\\"My Issues ({}){}{}\\\", issues.len(), sort_indicator, search_indicator),\\n66:     };\\n67: \\n68:     let table = Table::new(\\n69:         rows,\\n70:         [\\n71:             Constraint::Length(10),\\n72:             Constraint::Min(30),\\n73:             Constraint::Length(20),\\n74:             Constraint::Length(15),\\n75:             Constraint::Length(10),\\n76:         ],\\n77:     )\\n78:     .header(header)\\n79:     .block(Block::default().borders(Borders::ALL).title(title))\\n80:     .row_highlight_style(Style::default().add_modifier(Modifier::REVERSED));\\n81: \\n82:     let mut table_state = TableState::default();\\n83:     if !issues.is_empty() {\\n84:         table_state.select(Some(app.selected));\\n85:     }\\n86: \\n87:     frame.render_stateful_widget(table, chunks[0], &mut table_state);\\n88: \\n89:     let key_style = Style::default().fg(Color::Yellow).add_modifier(Modifier::BOLD);\\n90: \\n91:     let column_hints = vec![\\n92:         Span::styled(\\\"i\\\", key_style),\\n93:         Span::raw(\\\"d  \\\"),\\n94:         Span::styled(\\\"t\\\", key_style),\\n95:         Span::raw(\\\"itle  \\\"),\\n96:         Span::styled(\\\"p\\\", key_style),\\n97:         Span::raw(\\\"roject  \\\"),\\n98:         Span::styled(\\\"s\\\", key_style),\\n99:         Span::raw(\\\"tatus  p\\\"),\\n100:         Span::styled(\\\"r\\\", key_style),\\n101:         Span::raw(\\\"iority\\\"),\\n102:     ];\\n103: \\n104:     // Status bar\\n105:     if app.refreshing {\\n106:         let line = Line::from(Span::styled(\\n107:             \\\"Refreshing...\\\",\\n108:             Style::default().fg(Color::Yellow),\\n109:         ));\\n110:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n111:     } else if app.awaiting_quit {\\n112:         let line = Line::from(vec![\\n113:             Span::raw(\\\"Press \\\"),\\n114:             Span::styled(\\\"q\\\", key_style),\\n115:             Span::raw(\\\" again to quit\\\"),\\n116:         ]);\\n117:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n118:     } else if app.awaiting_sort {\\n119:         let mut spans = vec![Span::raw(\\\"sort by: \\\")];\\n120:         spans.extend(column_hints);\\n121:         frame.render_widget(Paragraph::new(Line::from(spans)), chunks[1]);\\n122:     } else if app.awaiting_filter {\\n123:         let mut spans = vec![Span::raw(\\\"filter by: \\\")];\\n124:         spans.extend(column_hints);\\n125:         frame.render_widget(Paragraph::new(Line::from(spans)), chunks[1]);\\n126:     } else if app.filtering {\\n127:         let prefix = match app.filter_column {\\n128:             Some(ref col) => format!(\\\"[{}] /\\\", col.label()),\\n129:             None => \\\"/\\\".into(),\\n130:         };\\n131:         let line = Line::from(vec![\\n132:             Span::raw(prefix),\\n133:             Span::styled(&app.filter_input, Style::default().add_modifier(Modifier::BOLD)),\\n134:             Span::raw(\\\"▏\\\"),\\n135:         ]);\\n136:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n137:     } else if app.searching {\\n138:         let line = Line::from(vec![\\n139:             Span::raw(\\\"/\\\"),\\n140:             Span::styled(&app.search_input, Style::default().add_modifier(Modifier::BOLD)),\\n141:             Span::raw(\\\"▏\\\"),\\n142:         ]);\\n143:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n144:     } else if app.search.is_some() || app.filter.is_some() {\\n145:         let line = Line::from(vec![\\n146:             Span::raw(\\\"Active — press Esc to clear\\\"),\\n147:         ]);\\n148:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n149:     }\\n150: }\\n151: \\n152: fn highlight_match<'a>(text: &'a str, query: Option<&str>, base_style: Style) -> Vec<Span<'a>> {\\n153:     let query = match query {\\n154:         Some(q) if !q.is_empty() => q,\\n155:         _ => return vec![Span::styled(text, base_style)],\\n156:     };\\n157:     let lower_text = text.to_lowercase();\\n158:     let lower_query = query.to_lowercase();\\n159:     let mut spans = Vec::new();\\n160:     let mut start = 0;\\n161:     while let Some(pos) = lower_text[start..].find(&lower_query) {\\n162:         let abs_pos = start + pos;\\n163:         if abs_pos > start {\\n164:             spans.push(Span::styled(&text[start..abs_pos], base_style));\\n165:         }\\n166:         spans.push(Span::styled(\\n167:             &text[abs_pos..abs_pos + query.len()],\\n168:             base_style.add_modifier(Modifier::BOLD),\\n169:         ));\\n170:         start = abs_pos + query.len();\\n171:     }\\n172:     if start < text.len() {\\n173:         spans.push(Span::styled(&text[start..], base_style));\\n174:     }\\n175:     if spans.is_empty() {\\n176:         spans.push(Span::styled(text, base_style));\\n177:     }\\n178:     spans\\n179: }\\n180: \\n181: fn status_style(status: &str) -> Style {\\n182:     match status {\\n183:         \\\"In Progress\\\" => Style::default().fg(Color::Yellow),\\n184:         \\\"Todo\\\" => Style::default().fg(Color::Cyan),\\n185:         \\\"Done\\\" => Style::default().fg(Color::Green),\\n186:         \\\"Canceled\\\" | \\\"Cancelled\\\" => Style::default().fg(Color::DarkGray),\\n187:         \\\"In Review\\\" => Style::default().fg(Color::Magenta),\\n188:         \\\"Backlog\\\" | \\\"Triage\\\" => Style::default().fg(Color::DarkGray),\\n189:         _ => Style::default(),\\n190:     }\\n191: }\\n192: \\n193: fn priority_style(priority: &str) -> Style {\\n194:     match priority {\\n195:         \\\"Urgent\\\" => Style::default().fg(Color::Red).add_modifier(Modifier::BOLD),\\n196:         \\\"High\\\" => Style::default().fg(Color::Red),\\n197:         \\\"Medium\\\" => Style::default().fg(Color::Yellow),\\n198:         \\\"Low\\\" => Style::default().fg(Color::DarkGray),\\n199:         _ => Style::default(),\\n200:     }\\n201: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_018u5hFBppcFyyJxUJMLSKvj","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/views/detail.rs\",\"content\":\"1: use ratatui::{\\n2:     layout::{Constraint, Layout, Rect},\\n3:     style::{Color, Modifier, Style},\\n4:     text::{Line, Span},\\n5:     widgets::{Block, Borders, Clear, Paragraph, Wrap},\\n6:     Frame,\\n7: };\\n8: \\n9: use crate::api::client::LinearApi;\\n10: use crate::app::{App, DetailSection};\\n11: \\n12: pub fn render<A: LinearApi>(frame: &mut Frame, area: Rect, app: &mut App<A>) {\\n13:     let issue = match app.selected_issue() {\\n14:         Some(i) => i,\\n15:         None => {\\n16:             frame.render_widget(Paragraph::new(\\\"No issue selected\\\"), area);\\n17:             return;\\n18:         }\\n19:     };\\n20: \\n21:     // Metadata fields\\n22:     let label_style = Style::default().fg(Color::DarkGray);\\n23: \\n24:     let mut meta_lines: Vec<Line> = Vec::new();\\n25: \\n26:     meta_lines.push(Line::from(vec![\\n27:         Span::styled(\\\"Status:   \\\", label_style),\\n28:         Span::styled(issue.status_str(), status_style(issue.status_str())),\\n29:     ]));\\n30: \\n31:     meta_lines.push(Line::from(vec![\\n32:         Span::styled(\\\"Priority: \\\", label_style),\\n33:         Span::styled(issue.priority_str(), priority_style(issue.priority_str())),\\n34:     ]));\\n35: \\n36:     meta_lines.push(Line::from(vec![\\n37:         Span::styled(\\\"Project:  \\\", label_style),\\n38:         Span::raw(issue.project_str()),\\n39:     ]));\\n40: \\n41:     let assignee = issue\\n42:         .assignee\\n43:         .as_ref()\\n44:         .map_or(\\\"—\\\", |a| a.name.as_str());\\n45:     meta_lines.push(Line::from(vec![\\n46:         Span::styled(\\\"Assignee: \\\", label_style),\\n47:         Span::raw(assignee),\\n48:     ]));\\n49: \\n50:     let labels_str = issue\\n51:         .labels\\n52:         .as_ref()\\n53:         .map(|l| {\\n54:             l.nodes\\n55:                 .iter()\\n56:                 .map(|l| l.name.as_str())\\n57:                 .collect::<Vec<_>>()\\n58:                 .join(\\\", \\\")\\n59:         })\\n60:         .unwrap_or_default();\\n61:     if !labels_str.is_empty() {\\n62:         meta_lines.push(Line::from(vec![\\n63:             Span::styled(\\\"Labels:   \\\", label_style),\\n64:             Span::raw(labels_str),\\n65:         ]));\\n66:     }\\n67: \\n68:     // +2 for the border top/bottom\\n69:     let meta_height = (meta_lines.len() as u16) + 2;\\n70: \\n71:     // Calculate thread section height\\n72:     let thread_count = app.detail_threads.len();\\n73:     let threads_height = if thread_count > 0 {\\n74:         // header border (1) + each thread line (1 each) + bottom border (1)\\n75:         (thread_count as u16) + 2\\n76:     } else {\\n77:         0\\n78:     };\\n79: \\n80:     let chunks = Layout::vertical([\\n81:         Constraint::Length(meta_height),\\n82:         Constraint::Min(0),\\n83:         Constraint::Length(threads_height),\\n84:         Constraint::Length(1),\\n85:     ])\\n86:     .split(area);\\n87: \\n88:     // Metadata box\\n89:     let title = Line::from(vec![\\n90:         Span::styled(\\n91:             issue.identifier.to_string(),\\n92:             Style::default().fg(Color::Green).add_modifier(Modifier::BOLD),\\n93:         ),\\n94:         Span::raw(format!(\\\" — {}\\\", issue.title)),\\n95:     ]);\\n96:     let meta = Paragraph::new(meta_lines)\\n97:         .block(Block::default().borders(Borders::ALL).title(title));\\n98:     frame.render_widget(meta, chunks[0]);\\n99: \\n100:     // Description / Comments\\n101:     let mut body_lines: Vec<Line> = Vec::new();\\n102: \\n103:     if let Some(desc) = &issue.description {\\n104:         for line in desc.lines() {\\n105:             body_lines.push(Line::raw(line.to_string()));\\n106:         }\\n107:     }\\n108: \\n109:     // Comments\\n110:     if let Some(comments) = &issue.comments\\n111:         && !comments.nodes.is_empty()\\n112:     {\\n113:         if !body_lines.is_empty() {\\n114:             body_lines.push(Line::raw(\\\"\\\"));\\n115:         }\\n116:         body_lines.push(Line::from(Span::styled(\\n117:             format!(\\\"Comments ({})\\\", comments.nodes.len()),\\n118:             Style::default().add_modifier(Modifier::BOLD | Modifier::UNDERLINED),\\n119:         )));\\n120:         body_lines.push(Line::raw(\\\"\\\"));\\n121: \\n122:         for comment in &comments.nodes {\\n123:             let author = comment\\n124:                 .user\\n125:                 .as_ref()\\n126:                 .map_or(\\\"Unknown\\\", |u| u.name.as_str());\\n127:             body_lines.push(Line::from(vec![\\n128:                 Span::styled(\\n129:                     author,\\n130:                     Style::default().fg(Color::Yellow).add_modifier(Modifier::BOLD),\\n131:                 ),\\n132:                 Span::styled(\\n133:                     format!(\\\"  {}\\\", &comment.created_at[..10]),\\n134:                     Style::default().fg(Color::DarkGray),\\n135:                 ),\\n136:             ]));\\n137:             for line in comment.body.lines() {\\n138:                 body_lines.push(Line::raw(format!(\\\"  {}\\\", line)));\\n139:             }\\n140:             body_lines.push(Line::raw(\\\"\\\"));\\n141:         }\\n142:     }\\n143: \\n144:     let content_lines = body_lines.len() as u16;\\n145:     let inner_height = chunks[1].height.saturating_sub(2); // borders\\n146:     let scroll = app.detail_scroll;\\n147: \\n148:     let body_focused = app.detail_section == DetailSection::Body;\\n149:     let body_border_style = if body_focused {\\n150:         Style::default().fg(Color::Cyan)\\n151:     } else {\\n152:         Style::default().fg(Color::DarkGray)\\n153:     };\\n154: \\n155:     let detail = Paragraph::new(body_lines)\\n156:         .block(\\n157:             Block::default()\\n158:                 .borders(Borders::ALL)\\n159:                 .title(\\\"Description\\\")\\n160:                 .border_style(body_border_style),\\n161:         )\\n162:         .wrap(Wrap { trim: false })\\n163:         .scroll((scroll, 0));\\n164: \\n165:     frame.render_widget(detail, chunks[1]);\\n166: \\n167:     app.detail_scroll_max = content_lines.saturating_sub(inner_height);\\n168: \\n169:     // Threads section\\n170:     if thread_count > 0 {\\n171:         let threads_focused = app.detail_section == DetailSection::Threads;\\n172:         let threads_border_style = if threads_focused {\\n173:             Style::default().fg(Color::Cyan)\\n174:         } else {\\n175:             Style::default().fg(Color::DarkGray)\\n176:         };\\n177: \\n178:         let thread_lines: Vec<Line> = app\\n179:             .detail_threads\\n180:             .iter()\\n181:             .enumerate()\\n182:             .map(|(i, t)| {\\n183:                 let is_selected = threads_focused && i == app.detail_thread_selected;\\n184:                 let style = if is_selected {\\n185:                     Style::default().add_modifier(Modifier::REVERSED)\\n186:                 } else {\\n187:                     Style::default()\\n188:                 };\\n189:                 let time_str = t.relative_time();\\n190:                 Line::from(vec![\\n191:                     Span::styled(\\n192:                         format!(\\\"  {} \\\", t.title),\\n193:                         style,\\n194:                     ),\\n195:                     Span::styled(\\n196:                         format!(\\\"({} msgs) \\\", t.message_count),\\n197:                         style.fg(Color::DarkGray),\\n198:                     ),\\n199:                     Span::styled(\\n200:                         time_str,\\n201:                         style.fg(Color::DarkGray),\\n202:                     ),\\n203:                 ])\\n204:             })\\n205:             .collect();\\n206: \\n207:         let threads_block = Paragraph::new(thread_lines).block(\\n208:             Block::default()\\n209:                 .borders(Borders::ALL)\\n210:                 .title(format!(\\\"Threads ({})\\\", thread_count))\\n211:                 .border_style(threads_border_style),\\n212:         );\\n213:         frame.render_widget(threads_block, chunks[2]);\\n214:     }\\n215: \\n216:     // Status bar\\n217:     let key_style = Style::default().fg(Color::Yellow).add_modifier(Modifier::BOLD);\\n218:     let bar = if app.awaiting_quit {\\n219:         Line::from(vec![\\n220:             Span::raw(\\\"Press \\\"),\\n221:             Span::styled(\\\"q\\\", key_style),\\n222:             Span::raw(\\\" again to quit\\\"),\\n223:         ])\\n224:     } else if app.detail_section == DetailSection::Threads {\\n225:         Line::from(vec![\\n226:             Span::styled(\\\"Esc\\\", key_style),\\n227:             Span::raw(\\\" back  \\\"),\\n228:             Span::styled(\\\"j\\\", key_style),\\n229:             Span::raw(\\\"/\\\"),\\n230:             Span::styled(\\\"k\\\", key_style),\\n231:             Span::raw(\\\" navigate  \\\"),\\n232:             Span::styled(\\\"Enter\\\", key_style),\\n233:             Span::raw(\\\" continue  \\\"),\\n234:             Span::styled(\\\"a\\\", key_style),\\n235:             Span::raw(\\\" new thread\\\"),\\n236:         ])\\n237:     } else {\\n238:         let mut spans = vec![\\n239:             Span::styled(\\\"Esc\\\", key_style),\\n240:             Span::raw(\\\" back  \\\"),\\n241:             Span::styled(\\\"j\\\", key_style),\\n242:             Span::raw(\\\"/\\\"),\\n243:             Span::styled(\\\"k\\\", key_style),\\n244:             Span::raw(\\\" scroll\\\"),\\n245:         ];\\n246:         if !app.detail_threads.is_empty() {\\n247:             spans.push(Span::raw(\\\"  \\\"));\\n248:             spans.push(Span::styled(\\\"Tab\\\", key_style));\\n249:             spans.push(Span::raw(\\\" threads\\\"));\\n250:         }\\n251:         spans.push(Span::raw(\\\"  \\\"));\\n252:         spans.push(Span::styled(\\\"a\\\", key_style));\\n253:         spans.push(Span::raw(\\\" new thread\\\"));\\n254:         Line::from(spans)\\n255:     };\\n256:     frame.render_widget(Paragraph::new(bar), chunks[3]);\\n257: \\n258:     // Workspace picker modal\\n259:     if let Some(ref picker) = app.workspace_picker {\\n260:         // Extra line for the input row when typing, or the hint row\\n261:         let extra_lines: u16 = 1;\\n262:         let content_lines = picker.options.len() as u16 + extra_lines;\\n263:         let picker_height = (content_lines + 2).min(area.height.saturating_sub(4));\\n264:         let picker_width = picker\\n265:             .options\\n266:             .iter()\\n267:             .map(|s| s.len() as u16)\\n268:             .max()\\n269:             .unwrap_or(20)\\n270:             .max(20)\\n271:             + 4;\\n272:         let picker_width = picker_width.min(area.width.saturating_sub(4));\\n273: \\n274:         let x = area.x + (area.width.saturating_sub(picker_width)) / 2;\\n275:         let y = area.y + (area.height.saturating_sub(picker_height)) / 2;\\n276:         let popup_area = Rect::new(x, y, picker_width, picker_height);\\n277: \\n278:         frame.render_widget(Clear, popup_area);\\n279: \\n280:         let mut lines: Vec<Line> = picker\\n281:             .options\\n282:             .iter()\\n283:             .enumerate()\\n284:             .map(|(i, ws)| {\\n285:                 let style = if !picker.typing && i == picker.selected {\\n286:                     Style::default().add_modifier(Modifier::REVERSED)\\n287:                 } else {\\n288:                     Style::default()\\n289:                 };\\n290:                 Line::from(Span::styled(format!(\\\" {} \\\", ws), style))\\n291:             })\\n292:             .collect();\\n293: \\n294:         if picker.typing {\\n295:             lines.push(Line::from(vec![\\n296:                 Span::raw(\\\" /\\\"),\\n297:                 Span::styled(&picker.input, Style::default().add_modifier(Modifier::BOLD)),\\n298:                 Span::raw(\\\"▏\\\"),\\n299:             ]));\\n300:         } else {\\n301:             let key_style = Style::default().fg(Color::DarkGray);\\n302:             lines.push(Line::from(Span::styled(\\\" / to type a path\\\", key_style)));\\n303:         }\\n304: \\n305:         let popup = Paragraph::new(lines).block(\\n306:             Block::default()\\n307:                 .borders(Borders::ALL)\\n308:                 .title(\\\"Select workspace\\\")\\n