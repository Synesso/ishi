i/src/views\",\"content\":\"detail.rs\\nhelp.rs\\nmod.rs\\nmy_issues.rs\\nproject.rs\",\"isDirectory\":true,\"directoryEntries\":[\"detail.rs\",\"help.rs\",\"mod.rs\",\"my_issues.rs\",\"project.rs\"]}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01Bg5tkZSWvjiv8h6NsEgTVS","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/keys.rs\",\"content\":\"1: use crossterm::event::{KeyCode, KeyEvent, KeyModifiers};\\n2: \\n3: pub enum Action {\\n4:     Quit,\\n5:     MoveDown,\\n6:     MoveUp,\\n7:     Top,\\n8:     Bottom,\\n9:     Select,\\n10:     Back,\\n11:     Help,\\n12:     Search,\\n13:     OrderBy,\\n14:     FilterBy,\\n15:     Refresh,\\n16:     Tab,\\n17:     NewThread,\\n18:     OpenIn,\\n19: }\\n20: \\n21: pub fn map_key(key: KeyEvent) -> Option<Action> {\\n22:     match (key.modifiers, key.code) {\\n23:         (KeyModifiers::CONTROL, KeyCode::Char('c')) => Some(Action::Quit),\\n24:         (KeyModifiers::NONE, KeyCode::Char('q')) => Some(Action::Quit),\\n25:         (_, KeyCode::Char('j')) | (_, KeyCode::Down) => Some(Action::MoveDown),\\n26:         (_, KeyCode::Char('k')) | (_, KeyCode::Up) => Some(Action::MoveUp),\\n27:         (_, KeyCode::Char('g')) => Some(Action::Top),\\n28:         (KeyModifiers::SHIFT, KeyCode::Char('G')) => Some(Action::Bottom),\\n29:         (_, KeyCode::Enter) => Some(Action::Select),\\n30:         (_, KeyCode::Esc) => Some(Action::Back),\\n31:         (_, KeyCode::Char('?')) => Some(Action::Help),\\n32:         (_, KeyCode::Char('/')) => Some(Action::Search),\\n33:         (_, KeyCode::Char('s')) => Some(Action::OrderBy),\\n34:         (_, KeyCode::Char('f')) => Some(Action::FilterBy),\\n35:         (_, KeyCode::Char('r')) => Some(Action::Refresh),\\n36:         (_, KeyCode::Tab) => Some(Action::Tab),\\n37:         (_, KeyCode::Char('a')) => Some(Action::NewThread),\\n38:         (_, KeyCode::Char('o')) => Some(Action::OpenIn),\\n39:         _ => None,\\n40:     }\\n41: }\\n42: \\n43: #[cfg(test)]\\n44: mod tests {\\n45:     use super::*;\\n46:     use crossterm::event::{KeyCode, KeyEvent, KeyEventKind, KeyEventState, KeyModifiers};\\n47: \\n48:     fn key(code: KeyCode) -> KeyEvent {\\n49:         KeyEvent {\\n50:             code,\\n51:             modifiers: KeyModifiers::NONE,\\n52:             kind: KeyEventKind::Press,\\n53:             state: KeyEventState::NONE,\\n54:         }\\n55:     }\\n56: \\n57:     fn key_with(code: KeyCode, modifiers: KeyModifiers) -> KeyEvent {\\n58:         KeyEvent {\\n59:             code,\\n60:             modifiers,\\n61:             kind: KeyEventKind::Press,\\n62:             state: KeyEventState::NONE,\\n63:         }\\n64:     }\\n65: \\n66:     #[test]\\n67:     fn quit_on_q() {\\n68:         assert!(matches!(map_key(key(KeyCode::Char('q'))), Some(Action::Quit)));\\n69:     }\\n70: \\n71:     #[test]\\n72:     fn quit_on_ctrl_c() {\\n73:         assert!(matches!(\\n74:             map_key(key_with(KeyCode::Char('c'), KeyModifiers::CONTROL)),\\n75:             Some(Action::Quit)\\n76:         ));\\n77:     }\\n78: \\n79:     #[test]\\n80:     fn navigation_keys() {\\n81:         assert!(matches!(map_key(key(KeyCode::Char('j'))), Some(Action::MoveDown)));\\n82:         assert!(matches!(map_key(key(KeyCode::Down)), Some(Action::MoveDown)));\\n83:         assert!(matches!(map_key(key(KeyCode::Char('k'))), Some(Action::MoveUp)));\\n84:         assert!(matches!(map_key(key(KeyCode::Up)), Some(Action::MoveUp)));\\n85:         assert!(matches!(map_key(key(KeyCode::Char('g'))), Some(Action::Top)));\\n86:         assert!(matches!(\\n87:             map_key(key_with(KeyCode::Char('G'), KeyModifiers::SHIFT)),\\n88:             Some(Action::Bottom)\\n89:         ));\\n90:     }\\n91: \\n92:     #[test]\\n93:     fn action_keys() {\\n94:         assert!(matches!(map_key(key(KeyCode::Enter)), Some(Action::Select)));\\n95:         assert!(matches!(map_key(key(KeyCode::Esc)), Some(Action::Back)));\\n96:         assert!(matches!(map_key(key(KeyCode::Char('?'))), Some(Action::Help)));\\n97:         assert!(matches!(map_key(key(KeyCode::Char('/'))), Some(Action::Search)));\\n98:     }\\n99: \\n100:     #[test]\\n101:     fn refresh_on_r() {\\n102:         assert!(matches!(map_key(key(KeyCode::Char('r'))), Some(Action::Refresh)));\\n103:     }\\n104: \\n105:     #[test]\\n106:     fn tab_maps_to_tab() {\\n107:         assert!(matches!(map_key(key(KeyCode::Tab)), Some(Action::Tab)));\\n108:     }\\n109: \\n110:     #[test]\\n111:     fn new_thread_on_a() {\\n112:         assert!(matches!(map_key(key(KeyCode::Char('a'))), Some(Action::NewThread)));\\n113:     }\\n114: \\n115:     #[test]\\n116:     fn open_in_on_o() {\\n117:         assert!(matches!(map_key(key(KeyCode::Char('o'))), Some(Action::OpenIn)));\\n118:     }\\n119: \\n120:     #[test]\\n121:     fn unmapped_keys_return_none() {\\n122:         assert!(map_key(key(KeyCode::Char('x'))).is_none());\\n123:         assert!(map_key(key(KeyCode::F(1))).is_none());\\n124:     }\\n125: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_013rrf2mRp4m51AguK4n233G","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/main.rs\",\"content\":\"1: mod amp;\\n2: mod api;\\n3: mod app;\\n4: mod config;\\n5: mod keys;\\n6: mod suspend;\\n7: mod views;\\n8: \\n9: use anyhow::Result;\\n10: use api::client::{LinearApi, LinearClient};\\n11: use app::App;\\n12: use crossterm::{\\n13:     event::{self, Event, KeyCode},\\n14:     terminal::{disable_raw_mode, enable_raw_mode, EnterAlternateScreen, LeaveAlternateScreen},\\n15:     ExecutableCommand,\\n16: };\\n17: use ratatui::{prelude::CrosstermBackend, Terminal};\\n18: use std::io::stdout;\\n19: use std::path::Path;\\n20: use std::collections::HashSet;\\n21: \\n22: /// Look up the workspace for a thread from the state file, then run\\n23: /// `amp threads continue <thread_id>` in that workspace directory,\\n24: /// suspending and restoring the TUI around the external process.\\n25: fn continue_thread(thread_id: &str) -> Result<()> {\\n26:     let state_path = amp::state::state_path()?;\\n27:     let state = amp::state::State::load(&state_path)?;\\n28:     let workspace = state\\n29:         .workspace_for(thread_id)\\n30:         .ok_or_else(|| anyhow::anyhow!(\\\"no workspace recorded for thread {}\\\", thread_id))?;\\n31:     let workspace_path = Path::new(workspace);\\n32:     suspend::run_external_command(\\\"amp\\\", &[\\\"threads\\\", \\\"continue\\\", thread_id], workspace_path)?;\\n33:     Ok(())\\n34: }\\n35: \\n36: fn load_threads_for_issue(app: &mut App<impl LinearApi>, identifier: &str) {\\n37:     let state_path = match amp::state::state_path() {\\n38:         Ok(p) => p,\\n39:         Err(_) => return,\\n40:     };\\n41:     let state = match amp::state::State::load(&state_path) {\\n42:         Ok(s) => s,\\n43:         Err(_) => return,\\n44:     };\\n45:     let thread_ids: Vec<String> = state\\n46:         .threads_for_issue(identifier)\\n47:         .into_iter()\\n48:         .map(|s| s.to_string())\\n49:         .collect();\\n50:     if thread_ids.is_empty() {\\n51:         app.detail_threads.clear();\\n52:         return;\\n53:     }\\n54:     let threads_dir = match amp::thread::amp_threads_dir() {\\n55:         Some(d) => d,\\n56:         None => return,\\n57:     };\\n58:     app.detail_threads = amp::thread::load_thread_summaries(&threads_dir, &thread_ids);\\n59:     app.detail_thread_selected = 0;\\n60: }\\n61: \\n62: /// Open the workspace picker for the current issue.\\n63: /// Loads workspace history from state and populates the picker.\\n64: fn open_workspace_picker(app: &mut App<impl LinearApi>) {\\n65:     let state_path = match amp::state::state_path() {\\n66:         Ok(p) => p,\\n67:         Err(_) => return,\\n68:     };\\n69:     let state = match amp::state::State::load(&state_path) {\\n70:         Ok(s) => s,\\n71:         Err(_) => return,\\n72:     };\\n73:     let workspaces: Vec<String> = state.workspaces().to_vec();\\n74:     app.show_workspace_picker(workspaces);\\n75: }\\n76: \\n77: /// Execute the new-thread flow:\\n78: /// 1. Snapshot thread IDs\\n79: /// 2. Suspend TUI and run `amp threads new` in the chosen workspace\\n80: /// 3. Diff thread IDs to detect the new thread\\n81: /// 4. If found, save thread link and update workspace history\\n82: fn start_new_thread(\\n83:     issue_identifier: &str,\\n84:     workspace: &str,\\n85:     before_ids: &HashSet<String>,\\n86: ) -> Result<()> {\\n87:     let workspace_path = Path::new(workspace);\\n88:     suspend::run_external_command(\\\"amp\\\", &[\\\"threads\\\", \\\"new\\\"], workspace_path)?;\\n89: \\n90:     // Diff thread IDs to find the newly created thread\\n91:     let threads_dir = match amp::thread::amp_threads_dir() {\\n92:         Some(d) => d,\\n93:         None => return Ok(()),\\n94:     };\\n95:     let after_ids = amp::thread::snapshot_thread_ids(&threads_dir);\\n96:     let new_ids: Vec<&String> = after_ids.difference(before_ids).collect();\\n97: \\n98:     if let Some(new_thread_id) = new_ids.first() {\\n99:         let state_path = amp::state::state_path()?;\\n100:         let mut state = amp::state::State::load(&state_path)?;\\n101:         state.add_thread_link(new_thread_id, issue_identifier, workspace);\\n102:         state.add_workspace(workspace);\\n103:         state.save(&state_path)?;\\n104:     }\\n105: \\n106:     Ok(())\\n107: }\\n108: \\n109: #[tokio::main]\\n110: async fn main() -> Result<()> {\\n111:     let api_key = config::resolve_api_key()?;\\n112:     let client = LinearClient::new(api_key);\\n113:     let mut app = App::new(client);\\n114: \\n115:     // Fetch issues before entering TUI\\n116:     match app.api.fetch_my_issues().await {\\n117:         Ok(issues) => app.issues = issues,\\n118:         Err(e) => eprintln!(\\\"Failed to fetch issues: {e}\\\"),\\n119:     }\\n120: \\n121:     // Terminal setup\\n122:     enable_raw_mode()?;\\n123:     stdout().execute(EnterAlternateScreen)?;\\n124:     let mut terminal = Terminal::new(CrosstermBackend::new(stdout()))?;\\n125: \\n126:     // Main loop\\n127:     while app.running {\\n128:         terminal.draw(|frame| {\\n129:             let area = frame.area();\\n130:             match app.view {\\n131:                 app::View::MyIssues => views::my_issues::render(frame, area, &app),\\n132:                 app::View::Detail => views::detail::render(frame, area, &mut app),\\n133:                 _ => {\\n134:                     frame.render_widget(\\n135:                         ratatui::widgets::Paragraph::new(\\\"ishi — (view not implemented)\\\"),\\n136:                         area,\\n137:                     );\\n138:                 }\\n139:             }\\n140:             if app.show_help {\\n141:                 views::help::render(frame, area);\\n142:             }\\n143:         })?;\\n144: \\n145:         if event::poll(std::time::Duration::from_millis(100))?\\n146:             && let Event::Key(key) = event::read()?\\n147:         {\\n148:             if app.show_help {\\n149:                 match key.code {\\n150:                     KeyCode::Esc | KeyCode::Char('?') => app.dismiss_help(),\\n151:                     _ => {}\\n152:                 }\\n153:             } else if app.workspace_picker.is_some() {\\n154:                 let is_typing = app.workspace_picker.as_ref().is_some_and(|p| p.typing);\\n155:                 if is_typing {\\n156:                     match key.code {\\n157:                         KeyCode::Enter => {\\n158:                             let typed_path = app\\n159:                                 .workspace_picker\\n160:                                 .as_mut()\\n161:                                 .and_then(|p| p.confirm_typed_path());\\n162:                             if let (Some(workspace), Some(issue)) =\\n163:                                 (typed_path, app.selected_issue())\\n164:                             {\\n165:                                 let issue_id = issue.identifier.clone();\\n166:                                 app.workspace_picker = None;\\n167:                                 let before_ids = amp::thread::amp_threads_dir()\\n168:                                     .map(|d| amp::thread::snapshot_thread_ids(&d))\\n169:                                     .unwrap_or_default();\\n170:                                 let _ = start_new_thread(&issue_id, &workspace, &before_ids);\\n171:                                 load_threads_for_issue(&mut app, &issue_id);\\n172:                             }\\n173:                         }\\n174:                         KeyCode::Esc => {\\n175:                             if let Some(ref mut picker) = app.workspace_picker {\\n176:                                 picker.cancel_typing();\\n177:                             }\\n178:                         }\\n179:                         KeyCode::Backspace => {\\n180:                             if let Some(ref mut picker) = app.workspace_picker {\\n181:                                 picker.input.pop();\\n182:                             }\\n183:                         }\\n184:                         KeyCode::Char(c) => {\\n185:                             if let Some(ref mut picker) = app.workspace_picker {\\n186:                                 picker.input.push(c);\\n187:                             }\\n188:                         }\\n189:                         _ => {}\\n190:                     }\\n191:                 } else {\\n192:                     match key.code {\\n193:                         KeyCode::Enter => {\\n194:                             let picker = app.workspace_picker.take();\\n195:                             if let (Some(picker), Some(issue)) = (picker, app.selected_issue())\\n196:                                 && let Some(workspace) = picker.options.get(picker.selected)\\n197:                             {\\n198:                                 let issue_id = issue.identifier.clone();\\n199:                                 let workspace = workspace.clone();\\n200:                                 let before_ids = amp::thread::amp_threads_dir()\\n201:                                     .map(|d| amp::thread::snapshot_thread_ids(&d))\\n202:                                     .unwrap_or_default();\\n203:                                 let _ = start_new_thread(&issue_id, &workspace, &before_ids);\\n204:                                 load_threads_for_issue(&mut app, &issue_id);\\n205:                             }\\n206:                         }\\n207:                         KeyCode::Esc => app.cancel_workspace_picker(),\\n208:                         KeyCode::Char('/') => {\\n209:                             if let Some(ref mut picker) = app.workspace_picker {\\n210:                                 picker.start_typing();\\n211:                             }\\n212:                         }\\n213:                         KeyCode::Char('j') | KeyCode::Down => {\\n214:                             if let Some(ref mut picker) = app.workspace_picker {\\n215:                                 picker.move_down();\\n216:                             }\\n217:                         }\\n218:                         KeyCode::Char('k') | KeyCode::Up => {\\n219:                             if let Some(ref mut picker) = app.workspace_picker {\\n220:                                 picker.move_up();\\n221:                             }\\n222:                         }\\n223:                         _ => {}\\n224:                     }\\n225:                 }\\n226:             } else if app.awaiting_quit {\\n227:                 app.awaiting_quit = false;\\n228:                 match key.code {\\n229:                     KeyCode::Char('q') => app.running = false,\\n230:                     _ => {}\\n231:                 }\\n232:             } else if app.awaiting_open {\\n233:                 app.awaiting_open = false;\\n234:                 match key.code {\\n235:                     KeyCode::Char('l') => {\\n236:                         if let Some(url) = app.selected_issue_url() {\\n237:                             let _ = std::process::Command::new(\\\"open\\\")\\n238:                                 .arg(&url)\\n239:                                 .spawn();\\n240:                         }\\n241:                     }\\n242:                     KeyCode::Char('g') => {\\n243:                         if let Some(issue) = app.selected_issue() {\\n244:                             let issue_id = issue.id.clone();\\n245:                             if let Ok(Some(url)) = app.api.fetch_pull_request_url(&issue_id).await {\\n246:                                 let _ = std::process::Command::new(\\\"open\\\")\\n247:                                     .arg(&url)\\n248:                                     .spawn();\\n249:                             }\\n250:                         }\\n251:                     }\\n252:                     _ => {}\\n253:                 }\\n254:             } else if app.awaiting_sort {\\n255:                 app.awaiting_sort = false;\\n256:                 match key.code {\\n257:                     KeyCode::Char('i') => app.set_sort(app::SortColumn::Identifier),\\n258:                     KeyCode::Char('t') => app.set_sort(app::SortColumn::Title),\\n259:                     KeyCode::Char('p') => app.set_sort(app::SortColumn::Project),\\n260:                     KeyCode::Char('s') => app.set_sort(app::SortColumn::Status),\\n261:                     KeyCode::Char('r') => app.set_sort(app::SortColumn::Priority),\\n262:                     _ => {}\\n263:                 }\\n264:             } else if app.awaiting_filter {\\n265:                 app.awaiting_filter = false;\\n266:                 match key.code {\\n267:                     KeyCode::Char('i') => app.start_column_filter(app::SortColumn::Identifier),\\n268:                     KeyCode::Char('t') => app.start_column_filter(app::SortColumn::Title),\\n269:                     KeyCode::Char('p') => app.start_column_filter(app::SortColumn::Project),\\n270:                     KeyCode::Char('s') => app.start_column_filter(app::SortColumn::Status),\\n271:                     KeyCode::Char('r') => app.start_column_filter(app::SortColumn::Priority),\\n272:                     _ => {}\\n273:                 }\\n274:             } else if app.searching {\\n275:                 match key.code {\\n276:                     KeyCode::Enter => app.apply_search(),\\n277:                     KeyCode::Esc => app.cancel_search(),\\n278:                     KeyCode::Backspace => {\\n279:                         app.search_input.pop();\\n280:                     }\\n281:                     KeyCode::Char(c) => {\\n282:                         app.search_input.push(c);\\n283:                     }\\n284:                     _ => {}\\n285:                 }\\n286:             } else if app.filtering {\\n287:                 match key.code {\\n288:                     KeyCode::Enter => app.apply_filter(),\\n289:                     KeyCode::Esc => app.cancel_filter(),\\n290:                     KeyCode::Backspace => {\\n291:                         app.filter_input.pop();\\n292:                     }\\n293:                     KeyCode::Char(c) => {\\n294:                         app.filter_input.push(c);\\n295:                     }\\n296:                     _ => {}\\n297:                 }\\n298:             } else if matches!(app.view, app::View::Detail) {\\n299:                 if let Some(action) = keys::map_key(key) {\\n300:                     match app.detail_section {\\n301:                         app::DetailSection::Threads => match action {\\n302:                             keys::Action::Quit => app.awaiting_quit = true,\\n303:                             keys::Action::Back => app.focus_body(),\\n304:                             keys::Action::MoveDown => app.thread_move_down(),\\n305:                             keys::Action::MoveUp => app.thread_move_up(),\\n306:                             keys::Action::Select => {\\n307:                                 if let Some(thread) = app.selected_thread() {\\n308:                                     let thread_id = thread.id.clone();\\n309:                                     let _ = continue_thread(&thread_id);\\n310:                                 }\\n311:                             }\\n312:                             keys::Action::Tab => app.focus_body(),\\n313:                             keys::Action::Refresh => app.refresh().await,\\n314:                             keys::Action::NewThread => open_workspace_picker(&mut app),\\n315:                             keys::Action::OpenIn => app.awaiting_open = true,\\n316:                             keys::Action::Help => app.toggle_help(),\\n317:                             _ => {}\\n318:                         },\\n319:                         app::DetailSection::Body => match action {\\n320:                             keys::Action::Quit => app.awaiting_quit = true,\\n321:                             keys::Action::Back => app.back_to_list(),\\n322:                             keys::Action::MoveDown => app.scroll_detail_down(),\\n323:                             keys::Action::MoveUp => app.scroll_detail_up(),\\n324:                             keys::Action::Top => app.detail_scroll = 0,\\n325:                             keys::Action::Refresh => app.refresh().await,\\n326:                             keys::Action::Tab => app.focus_threads(),\\n327:                             keys::Action::NewThread => open_workspace_picker(&mut app),\\n328:                             keys::Action::OpenIn => app.awaiting_open = true,\\n329:                             keys::Action::Help => app.toggle_help(),\\n330:                             _ => {}\\n331:                         },\\n332:                     }\\n333:                 }\\n334:             } else if let Some(action) = keys::map_key(key) {\\n335:                 match action {\\n336:                     keys::Action::Quit => app.awaiting_quit = true,\\n337:                     keys::Action::MoveDown => app.move_down(),\\n338:                     keys::Action::MoveUp => app.move_up(),\\n339:                     keys::Action::Top => app.top(),\\n340:                     keys::Action::Bottom => app.bottom(),\\n341:                     keys::Action::Select => {\\n342:                         let id = app.selected_issue().map(|i| i.identifier.clone());\\n343:                         app.select_issue();\\n344:                         if let Some(id) = id {\\n345:                             load_threads_for_issue(&mut app, &id);\\n346:                         }\\n347:                     }\\n348:                     keys::Action::Search => app.start_search(),\\n349:                     keys::Action::Back => {\\n350:                         if app.search.is_some() {\\n351:                             app.clear_search();\\n352:                         } else {\\n353:                             app.clear_filter();\\n354:                         }\\n355:                     }\\n356:                     keys::Action::OrderBy => app.awaiting_sort = true,\\n357:                     keys::Action::FilterBy => app.awaiting_filter = true,\\n358:                     keys::Action::Refresh => app.refresh().await,\\n359:                     keys::Action::OpenIn => app.awaiting_open = true,\\n360:                     keys::Action::Help => app.toggle_help(),\\n361:                     _ => {}\\n362:                 }\\n363:             }\\n364:         }\\n365:     }\\n366: \\n367:     // Teardown\\n368:     disable_raw_mode()?;\\n369:     stdout().execute(LeaveAlternateScreen)?;\\n370:     Ok(())\\n371: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_0139218xsZeNpQkjHV5yqCHp","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/config.rs\",\"content\":\"1: use anyhow::{Context, Result};\\n2: use serde::{Deserialize, Serialize};\\n3: use std::path::PathBuf;\\n4: \\n5: #[derive(Debug, Serialize, Deserialize, Default)]\\n6: pub struct Config {\\n7:     pub api_key: Option<String>,\\n8: }\\n9: \\n10: pub fn config_path() -> Result<PathBuf> {\\n11:     let dir = dirs::config_dir()\\n12:         .context(\\\"could not determine config directory\\\")?\\n13:         .join(\\\"ishi\\\");\\n14:     std::fs::create_dir_all(&dir)?;\\n15:     Ok(dir.join(\\\"config.toml\\\"))\\n16: }\\n17: \\n18: pub fn resolve_api_key() -> Result<String> {\\n19:     // 1. Environment variable\\n20:     if let Ok(key) = std::env::var(\\\"LINEAR_API_KEY\\\")\\n21:         && !key.is_empty()\\n22:     {\\n23:         return Ok(key);\\n24:     }\\n25: \\n26:     // 2. Config file\\n27:     let path = config_path()?;\\n28:     if path.exists() {\\n29:         let contents = std::fs::read_to_string(&path)?;\\n30:         let cfg: Config = toml::from_str(&contents)?;\\n31:         if let Some(key) = cfg.api_key\\n32:             && !key.is_empty()\\n33:         {\\n34:             return Ok(key);\\n35:         }\\n36:     }\\n37: \\n38:     anyhow::bail!(\\n39:         \\\"No Linear API key found.\\\\n\\\\\\n40:          Set LINEAR_API_KEY or add api_key to {}\\\",\\n41:         config_path()?.display()\\n42:     )\\n43: }\\n44: \\n45: #[allow(dead_code)]\\n46: pub fn store_api_key(key: &str) -> Result<()> {\\n47:     let cfg = Config {\\n48:         api_key: Some(key.to_string()),\\n49:     };\\n50:     let contents = toml::to_string_pretty(&cfg)?;\\n51:     std::fs::write(config_path()?, contents)?;\\n52:     Ok(())\\n53: }\\n54: \\n55: #[cfg(test)]\\n56: mod tests {\\n57:     use super::*;\\n58: \\n59:     #[test]\\n60:     fn resolve_env_var_priority() {\\n61:         // Non-empty env var is accepted\\n62:         unsafe { std::env::set_var(\\\"LINEAR_API_KEY\\\", \\\"test-key-from-env\\\") };\\n63:         let result = resolve_api_key();\\n64:         assert_eq!(result.unwrap(), \\\"test-key-from-env\\\");\\n65: \\n66:         // Empty env var is rejected (falls through to file lookup)\\n67:         unsafe { std::env::set_var(\\\"LINEAR_API_KEY\\\", \\\"\\\") };\\n68:         // Don't assert error here — a real config file may exist on this machine\\n69:         let result = resolve_api_key();\\n70:         if let Ok(key) = &result {\\n71:             assert_ne!(key, \\\"\\\", \\\"empty string should never be returned\\\");\\n72:         }\\n73: \\n74:         unsafe { std::env::remove_var(\\\"LINEAR_API_KEY\\\") };\\n75:     }\\n76: \\n77:     #[test]\\n78:     fn store_and_load_round_trip() {\\n79:         let dir = tempfile::tempdir().unwrap();\\n80:         let path = dir.path().join(\\\"config.toml\\\");\\n81: \\n82:         let cfg = Config {\\n83:             api_key: Some(\\\"round-trip-key\\\".into()),\\n84:         };\\n85:         let contents = toml::to_string_pretty(&cfg).unwrap();\\n86:         std::fs::write(&path, &contents).unwrap();\\n87: \\n88:         let loaded: Config = toml::from_str(&std::fs::read_to_string(&path).unwrap()).unwrap();\\n89:         assert_eq!(loaded.api_key.unwrap(), \\\"round-trip-key\\\");\\n90:     }\\n91: \\n92:     #[test]\\n93:     fn config_deserializes_missing_key() {\\n94:         let cfg: Config = toml::from_str(\\\"\\\").unwrap();\\n95:         assert!(cfg.api_key.is_none());\\n96:     }\\n97: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01FwfghDGbmmRZoZB6Yzsotr","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/suspend.rs\",\"content\":\"1: use anyhow::Result;\\n2: use crossterm::{\\n3:     execute,\\n4:     terminal::{EnterAlternateScreen, LeaveAlternateScreen, disable_raw_mode, enable_raw_mode},\\n5: };\\n6: use std::io::stdout;\\n7: use std::path::Path;\\n8: use std::process::{Command, ExitStatus};\\n9: \\n10: #[allow(dead_code)]\\n11: /// Suspend the TUI, run an external command, then restore the TUI.\\n12: ///\\n13: /// Steps:\\n14: /// 1. Leave alternate screen\\n15: /// 2. Disable raw mode\\n16: /// 3. Run the command (blocking, inheriting stdin/stdout/stderr)\\n17: /// 4. Re-enable raw mode\\n18: /// 5. Re-enter alternate screen\\n19: /// 6. Force terminal redraw (via the returned `needs_redraw` signal)\\n20: ///\\n21: /// Returns the command's exit status.\\n22: pub fn run_external_command(program: &str, args: &[&str], working_dir: &Path) -> Result<ExitStatus> {\\n23:     run_external_command_with(&mut RealTerminal, program, args, working_dir)\\n24: }\\n25: \\n26: /// Testable version that accepts a [`TerminalControl`] implementation.\\n27: pub fn run_external_command_with<T: TerminalControl>(\\n28:     terminal: &mut T,\\n29:     program: &str,\\n30:     args: &[&str],\\n31:     working_dir: &Path,\\n32: ) -> Result<ExitStatus> {\\n33:     terminal.leave_alternate_screen()?;\\n34:     terminal.disable_raw_mode()?;\\n35: \\n36:     let status = Command::new(program)\\n37:         .args(args)\\n38:         .current_dir(working_dir)\\n39:         .stdin(std::process::Stdio::inherit())\\n40:         .stdout(std::process::Stdio::inherit())\\n41:         .stderr(std::process::Stdio::inherit())\\n42:         .status();\\n43: \\n44:     // Always attempt to restore the terminal, even if the command failed to run.\\n45:     terminal.enable_raw_mode()?;\\n46:     terminal.enter_alternate_screen()?;\\n47: \\n48:     Ok(status?)\\n49: }\\n50: \\n51: /// Abstraction over terminal operations for testability.\\n52: pub trait TerminalControl {\\n53:     fn leave_alternate_screen(&mut self) -> Result<()>;\\n54:     fn disable_raw_mode(&mut self) -> Result<()>;\\n55:     fn enable_raw_mode(&mut self) -> Result<()>;\\n56:     fn enter_alternate_screen(&mut self) -> Result<()>;\\n57: }\\n58: \\n59: /// Real implementation that talks to the actual terminal.\\n60: struct RealTerminal;\\n61: \\n62: impl TerminalControl for RealTerminal {\\n63:     fn leave_alternate_screen(&mut self) -> Result<()> {\\n64:         execute!(stdout(), LeaveAlternateScreen)?;\\n65:         Ok(())\\n66:     }\\n67: \\n68:     fn disable_raw_mode(&mut self) -> Result<()> {\\n69:         disable_raw_mode()?;\\n70:         Ok(())\\n71:     }\\n72: \\n73:     fn enable_raw_mode(&mut self) -> Result<()> {\\n74:         enable_raw_mode()?;\\n75:         Ok(())\\n76:     }\\n77: \\n78:     fn enter_alternate_screen(&mut self) -> Result<()> {\\n79:         execute!(stdout(), EnterAlternateScreen)?;\\n80:         Ok(())\\n81:     }\\n82: }\\n83: \\n84: #[cfg(test)]\\n85: mod tests {\\n86:     use super::*;\\n87:     use std::cell::RefCell;\\n88: \\n89:     /// Records the sequence of terminal operations for verification.\\n90:     struct MockTerminal {\\n91:         ops: RefCell<Vec<&'static str>>,\\n92:     }\\n93: \\n94:     impl MockTerminal {\\n95:         fn new() -> Self {\\n96:             Self {\\n97:                 ops: RefCell::new(Vec::new()),\\n98:             }\\n99:         }\\n100: \\n101:         fn ops(&self) -> Vec<&'static str> {\\n102:             self.ops.borrow().clone()\\n103:         }\\n104:     }\\n105: \\n106:     impl TerminalControl for MockTerminal {\\n107:         fn leave_alternate_screen(&mut self) -> Result<()> {\\n108:             self.ops.borrow_mut().push(\\\"leave_alternate_screen\\\");\\n109:             Ok(())\\n110:         }\\n111: \\n112:         fn disable_raw_mode(&mut self) -> Result<()> {\\n113:             self.ops.borrow_mut().push(\\\"disable_raw_mode\\\");\\n114:             Ok(())\\n115:         }\\n116: \\n117:         fn enable_raw_mode(&mut self) -> Result<()> {\\n118:             self.ops.borrow_mut().push(\\\"enable_raw_mode\\\");\\n119:             Ok(())\\n120:         }\\n121: \\n122:         fn enter_alternate_screen(&mut self) -> Result<()> {\\n123:             self.ops.borrow_mut().push(\\\"enter_alternate_screen\\\");\\n124:             Ok(())\\n125:         }\\n126:     }\\n127: \\n128:     #[test]\\n129:     fn terminal_operations_in_correct_order() {\\n130:         let mut mock = MockTerminal::new();\\n131:         let dir = tempfile::tempdir().unwrap();\\n132: \\n133:         let status =\\n134:             run_external_command_with(&mut mock, \\\"echo\\\", &[\\\"hello\\\"], dir.path()).unwrap();\\n135: \\n136:         assert!(status.success());\\n137:         assert_eq!(\\n138:             mock.ops(),\\n139:             vec![\\n140:                 \\\"leave_alternate_screen\\\",\\n141:                 \\\"disable_raw_mode\\\",\\n142:                 \\\"enable_raw_mode\\\",\\n143:                 \\\"enter_alternate_screen\\\",\\n144:             ]\\n145:         );\\n146:     }\\n147: \\n148:     #[test]\\n149:     fn returns_exit_status_of_command() {\\n150:         let mut mock = MockTerminal::new();\\n151:         let dir = tempfile::tempdir().unwrap();\\n152: \\n153:         let status =\\n154:             run_external_command_with(&mut mock, \\\"sh\\\", &[\\\"-c\\\", \\\"exit 42\\\"], dir.path()).unwrap();\\n155: \\n156:         assert!(!status.success());\\n157:         assert_eq!(status.code(), Some(42));\\n158:     }\\n159: \\n160:     #[test]\\n161:     fn runs_in_specified_working_directory() {\\n162:         let mut mock = MockTerminal::new();\\n163:         let dir = tempfile::tempdir().unwrap();\\n164:         let marker = dir.path().join(\\\"marker.txt\\\");\\n165: \\n166:         let status = run_external_command_with(\\n167:             &mut mock,\\n168:             \\\"sh\\\",\\n169:             &[\\\"-c\\\", \\\"echo ok > marker.txt\\\"],\\n170:             dir.path(),\\n171:         )\\n172:         .unwrap();\\n173: \\n174:         assert!(status.success());\\n175:         assert!(marker.exists());\\n176:     }\\n177: \\n178:     #[test]\\n179:     fn terminal_restored_even_when_command_fails() {\\n180:         let mut mock = MockTerminal::new();\\n181:         let dir = tempfile::tempdir().unwrap();\\n182: \\n183:         let status =\\n184:             run_external_command_with(&mut mock, \\\"sh\\\", &[\\\"-c\\\", \\\"exit 1\\\"], dir.path()).unwrap();\\n185: \\n186:         assert!(!status.success());\\n187:         // Terminal should still be restored\\n188:         assert_eq!(\\n189:             mock.ops(),\\n190:             vec![\\n191:                 \\\"leave_alternate_screen\\\",\\n192:                 \\\"disable_raw_mode\\\",\\n193:                 \\\"enable_raw_mode\\\",\\n194:                 \\\"enter_alternate_screen\\\",\\n195:             ]\\n196:         );\\n197:     }\\n198: \\n199:     #[test]\\n200:     fn error_when_program_not_found() {\\n201:         let mut mock = MockTerminal::new();\\n202:         let dir = tempfile::tempdir().unwrap();\\n203: \\n204:         let result = run_external_command_with(\\n205:             &mut mock,\\n206:             \\\"nonexistent_program_that_should_not_exist\\\",\\n207:             &[],\\n208:             dir.path(),\\n209:         );\\n210: \\n211:         assert!(result.is_err());\\n212:         // Terminal should still be restored even when the command can't be spawned\\n213:         assert_eq!(\\n214:             mock.ops(),\\n215:             vec![\\n216:                 \\\"leave_alternate_screen\\\",\\n217:                 \\\"disable_raw_mode\\\",\\n218:                 \\\"enable_raw_mode\\\",\\n219:                 \\\"enter_alternate_screen\\\",\\n220:             ]\\n221:         );\\n222:     }\\n223: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01B6WygHbZCkYGMZHAi71UA9","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/tests\",\"content\":\"fixtures/\",\"isDirectory\":true,\"directoryEntries\":[\"fixtures/\"]}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_014L4NEgYs8y4eCXQM7J1Sx8","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/amp\",\"content\":\"mod.rs\\nstate.rs\\nthr