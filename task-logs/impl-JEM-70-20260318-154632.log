\n906:         assert_eq!(picker.selected, 0);\\n907:     }\\n908: \\n909:     #[test]\\n910:     fn show_workspace_picker_sets_state() {\\n911:         let mut app = app_with_issues();\\n912:         assert!(app.workspace_picker.is_none());\\n913: \\n914:         app.show_workspace_picker(vec![\\\"/ws1\\\".into(), \\\"/ws2\\\".into()]);\\n915:         assert!(app.workspace_picker.is_some());\\n916: \\n917:         let picker = app.workspace_picker.as_ref().unwrap();\\n918:         assert_eq!(picker.options.len(), 2);\\n919:         assert_eq!(picker.selected, 0);\\n920:     }\\n921: \\n922:     #[test]\\n923:     fn show_workspace_picker_with_empty_list_opens_picker() {\\n924:         let mut app = app_with_issues();\\n925:         app.show_workspace_picker(vec![]);\\n926:         assert!(app.workspace_picker.is_some());\\n927:         let picker = app.workspace_picker.as_ref().unwrap();\\n928:         assert!(picker.options.is_empty());\\n929:     }\\n930: \\n931:     #[test]\\n932:     fn cancel_workspace_picker_clears_state() {\\n933:         let mut app = app_with_issues();\\n934:         app.show_workspace_picker(vec![\\\"/ws\\\".into()]);\\n935:         assert!(app.workspace_picker.is_some());\\n936: \\n937:         app.cancel_workspace_picker();\\n938:         assert!(app.workspace_picker.is_none());\\n939:     }\\n940: \\n941:     #[test]\\n942:     fn workspace_picker_start_typing() {\\n943:         let mut picker = WorkspacePicker::new(vec![\\\"/a\\\".into()]);\\n944:         assert!(!picker.typing);\\n945: \\n946:         picker.start_typing();\\n947:         assert!(picker.typing);\\n948:         assert!(picker.input.is_empty());\\n949:     }\\n950: \\n951:     #[test]\\n952:     fn workspace_picker_cancel_typing() {\\n953:         let mut picker = WorkspacePicker::new(vec![\\\"/a\\\".into()]);\\n954:         picker.start_typing();\\n955:         picker.input.push_str(\\\"/some/path\\\");\\n956:         picker.cancel_typing();\\n957: \\n958:         ass