    pub fn thread_move_down(&mut self) {\\n338:         let len = self.detail_threads.len();\\n339:         if len > 0 && self.detail_thread_selected < len - 1 {\\n340:             self.detail_thread_selected += 1;\\n341:         }\\n342:     }\\n343: \\n344:     pub fn thread_move_up(&mut self) {\\n345:         if self.detail_thread_selected > 0 {\\n346:             self.detail_thread_selected -= 1;\\n347:         }\\n348:     }\\n349: \\n350:     pub fn selected_thread(&self) -> Option<&ThreadSummary> {\\n351:         if self.detail_section == DetailSection::Threads {\\n352:             self.detail_threads.get(self.detail_thread_selected)\\n353:         } else {\\n354:             None\\n355:         }\\n356:     }\\n357: \\n358:     pub fn focus_threads(&mut self) {\\n359:         if !self.detail_threads.is_empty() {\\n360:             self.detail_section = DetailSection::Threads;\\n361:         }\\n362:     }\\n363: \\n364:     pub fn focus_body(&mut self) {\\n365:         self.detail_section = DetailSection::Body;\\n366:     }\\n367: \\n368:     pub fn show_workspace_picker(&mut self, workspaces: Vec<String>) {\\n369:         self.workspace_picker = Some(WorkspacePicker::new(workspaces));\\n370:     }\\n371: \\n372:     pub fn cancel_workspace_picker(&mut self) {\\n373:         self.workspace_picker = None;\\n374:     }\\n375: \\n376:     pub fn toggle_help(&mut self) {\\n377:         self.show_help = !self.show_help;\\n378:     }\\n379: \\n380:     pub fn dismiss_help(&mut self) {\\n381:         self.show_help = false;\\n382:     }\\n383: \\n384:     pub fn selected_issue_url(&self) -> Option<String> {\\n385:         self.selected_issue().and_then(|i| i.url.clone())\\n386:     }\\n387: \\n388:     pub async fn refresh(&mut self) {\\n389:         self.refreshing = true;\\n390:         let selected_id = self.selected_issue().map(|i| i.identifier.clone());\\n391:         match self.api.fetch_my_issues().await {\\n392:             Ok(issues) => {\\n393:           