lected item is highlighted (tested by selected_workspace)\\n1009:         assert_eq!(picker.selected_workspace(), Some(\\\"/a\\\"));\\n1010: \\n1011:         picker.start_typing();\\n1012:         // selected_workspace still returns the same, but the UI won't highlight it\\n1013:         // (the typing flag tells the renderer to suppress highlight)\\n1014:         assert!(picker.typing);\\n1015:         assert_eq!(picker.selected, 0);\\n1016:     }\\n1017: \\n1018:     #[test]\\n1019:     fn workspace_picker_typing_input_accumulates() {\\n1020:         let mut picker = WorkspacePicker::new(vec![]);\\n1021:         picker.start_typing();\\n1022:         picker.input.push('/');\\n1023:         picker.input.push('h');\\n1024:         picker.input.push('o');\\n1025:         picker.input.push('m');\\n1026:         picker.input.push('e');\\n1027:         assert_eq!(picker.input, \\\"/home\\\");\\n1028: \\n1029:         picker.input.pop();\\n1030:         assert_eq!(picker.input, \\\"/hom\\\");\\n1031:     }\\n1032: \\n1033:     #[test]\\n1034:     fn selected_issue_url_returns_url() {\\n1035:         let app = app_with_issues();\\n1036:         assert_eq!(\\n1037:             app.selected_issue_url(),\\n1038:             Some(\\\"https://linear.app/test/issue/JEM-1\\\".into())\\n1039:         );\\n1040:     }\\n1041: \\n1042:     #[test]\\n1043:     fn selected_issue_url_returns_none_when_no_issues() {\\n1044:         let app = App::new(FakeLinearApi::new());\\n1045:         assert!(app.selected_issue_url().is_none());\\n1046:     }\\n1047: \\n1048:     #[test]\\n1049:     fn selected_issue_url_returns_none_when_url_missing() {\\n1050:         let mut app = App::new(FakeLinearApi::new());\\n1051:         app.issues = vec![Issue {\\n1052:             id: \\\"1\\\".into(),\\n1053:             identifier: \\\"JEM-1\\\".into(),\\n1054:             title: \\\"No URL\\\".into(),\\n1055:             url: None,\\n1056:             state: None,\\n1057:             priority: None,\