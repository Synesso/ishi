num View {\\n15:     MyIssues,\\n16:     Project,\\n17:     Detail,\\n18: }\\n19: \\n20: /// State for the workspace picker modal shown when starting a new Amp thread.\\n21: #[derive(Debug, Clone)]\\n22: pub struct WorkspacePicker {\\n23:     pub options: Vec<String>,\\n24:     pub selected: usize,\\n25:     /// When true, the user is typing a new workspace path via `/`.\\n26:     pub typing: bool,\\n27:     /// Buffer for the path being typed.\\n28:     pub input: String,\\n29: }\\n30: \\n31: #[allow(dead_code)]\\n32: impl WorkspacePicker {\\n33:     pub fn new(options: Vec<String>) -> Self {\\n34:         Self {\\n35:             options,\\n36:             selected: 0,\\n37:             typing: false,\\n38:             input: String::new(),\\n39:         }\\n40:     }\\n41: \\n42:     pub fn move_down(&mut self) {\\n43:         if !self.options.is_empty() && self.selected < self.options.len() - 1 {\\n44:             self.selected += 1;\\n45:         }\\n46:     }\\n47: \\n48:     pub fn move_up(&mut self) {\\n49:         if self.selected > 0 {\\n50:             self.selected -= 1;\\n51:         }\\n52:     }\\n53: \\n54:     pub fn selected_workspace(&self) -> Option<&str> {\\n55:         self.options.get(self.selected).map(|s| s.as_str())\\n56:     }\\n57: \\n58:     pub fn start_typing(&mut self) {\\n59:         self.typing = true;\\n60:         self.input.clear();\\n61:     }\\n62: \\n63:     pub fn cancel_typing(&mut self) {\\n64:         self.typing = false;\\n65:         self.input.clear();\\n66:     }\\n67: \\n68:     /// Confirm the typed path. Returns the entered path if non-empty.\\n69:     pub fn confirm_typed_path(&mut self) -> Option<String> {\\n70:         self.typing = false;\\n71:         let path = self.input.trim().to_string();\\n72:         self.input.clear();\\n73:         if path.is_empty() {\\n74:             None\\n75:         } else {\\n76:             Some(path)\\n77:         }\\n78:     }\\n79: }\\n80: \\n81: #[derive(Debug, Clone, Copy, 