444:                 identifier: \\\"JEM-3\\\".into(),\\n445:                 title: \\\"Gamma task\\\".into(),\\n446:                 url: Some(\\\"https://linear.app/test/issue/JEM-3\\\".into()),\\n447:                 state: None,\\n448:                 priority: None,\\n449:                 project: None,\\n450:                 description: None,\\n451:                 assignee: None,\\n452:                 labels: None,\\n453:                 comments: None,\\n454:             },\\n455:         ];\\n456:         app\\n457:     }\\n458: \\n459:     #[test]\\n460:     fn navigation_wraps_at_bounds() {\\n461:         let mut app = app_with_issues();\\n462:         assert_eq!(app.selected, 0);\\n463: \\n464:         app.move_down();\\n465:         assert_eq!(app.selected, 1);\\n466:         app.move_down();\\n467:         assert_eq!(app.selected, 2);\\n468:         app.move_down(); // at bottom, stays\\n469:         assert_eq!(app.selected, 2);\\n470: \\n471:         app.move_up();\\n472:         assert_eq!(app.selected, 1);\\n473:         app.top();\\n474:         assert_eq!(app.selected, 0);\\n475:         app.move_up(); // at top, stays\\n476:         assert_eq!(app.selected, 0);\\n477:     }\\n478: \\n479:     #[test]\\n480:     fn bottom_goes_to_last() {\\n481:         let mut app = app_with_issues();\\n482:         app.bottom();\\n483:         assert_eq!(app.selected, 2);\\n484:     }\\n485: \\n486:     #[test]\\n487:     fn filter_narrows_results() {\\n488:         let mut app = app_with_issues();\\n489:         app.filter = Some((SortColumn::Title, \\\"beta\\\".into()));\\n490:         let filtered = app.filtered_issues();\\n491:         assert_eq!(filtered.len(), 1);\\n492:         assert_eq!(filtered[0].identifier, \\\"JEM-2\\\");\\n493:     }\\n494: \\n495:     #[test]\\n496:     fn filter_is_case_insensitive() {\\n497:         let mut app = app_with_issues();\\n498:         app.filter = Some((SortColumn::Title, \\\"ALPHA\\\".into()));\\n499:         ass