 }\\n144: \\n145: impl<A: LinearApi> App<A> {\\n146:     pub fn new(api: A) -> Self {\\n147:         Self {\\n148:             running: true,\\n149:             view: View::MyIssues,\\n150:             api,\\n151:             issues: Vec::new(),\\n152:             selected: 0,\\n153:             filter: None,\\n154:             filter_input: String::new(),\\n155:             filter_column: None,\\n156:             filtering: false,\\n157:             awaiting_quit: false,\\n158:             awaiting_filter: false,\\n159:             awaiting_sort: false,\\n160:             awaiting_open: false,\\n161:             sort: None,\\n162:             search: None,\\n163:             search_input: String::new(),\\n164:             searching: false,\\n165:             detail_scroll: 0,\\n166:             detail_scroll_max: 0,\\n167:             refreshing: false,\\n168:             detail_section: DetailSection::Body,\\n169:             detail_threads: Vec::new(),\\n170:             detail_thread_selected: 0,\\n171:             workspace_picker: None,\\n172:             show_help: false,\\n173:         }\\n174:     }\\n175: \\n176:     pub fn filtered_issues(&self) -> Vec<&Issue> {\\n177:         let mut issues: Vec<&Issue> = self.issues.iter().collect();\\n178:         if let Some((col, f)) = &self.filter {\\n179:             let lower = f.to_lowercase();\\n180:             issues.retain(|i| {\\n181:                 let value = match col {\\n182:                     SortColumn::Identifier => i.identifier.as_str(),\\n183:                     SortColumn::Title => i.title.as_str(),\\n184:                     SortColumn::Project => i.project_str(),\\n185:                     SortColumn::Status => i.status_str(),\\n186:                     SortColumn::Priority => i.priority_str(),\\n187:                 };\\n188:                 value.to_lowercase().contains(&lower)\\n189:             });\\n190:         }\\n191:         if let Some(q) = &self.search {\\n192:             let lower = q.to_lowercase();\\n193:             issues.retain(|i| i.matches_search(&lower));\\n194:         }\\n195:         if let Some((col, dir)) = &self.sort {\\n196:             issues.sort_by(|a, b| {\\n197:                 let ord = match col {\\n198:                     SortColumn::Identifier => a.identifier.cmp(&b.identifier),\\n199:                     SortColumn::Title => a.title.to_lowercase().cmp(&b.title.to_lowercase()),\\n200:                     SortColumn::Project => a.project_str().cmp(b.project_str()),\\n201:                     SortColumn::Status => a.status_str().cmp(b.status_str()),\\n202:                     SortColumn::Priority => a.priority.partial_cmp(&b.priority).unwrap_or(Ordering::Equal),\\n203:                 };\\n204:                 match dir {\\n205:                     SortDirection::Asc => ord,\\n206:                     SortDirection::Desc => ord.reverse(),\\n207:                 }\\n208:             });\\n209:         }\\n210:         issues\\n211:     }\\n212: \\n213:     pub fn set_sort(&mut self, col: SortColumn) {\\n214:         self.sort = Some(match self.sort {\\n215:             Some((c, dir)) if c == col => (col, dir.toggle()),\\n216:             _ => (col, SortDirection::Asc),\\n217:         });\\n218:         self.selected = 0;\\n219:     }\\n220: \\n221:     pub fn move_down(&mut self) {\\n222:         let len = self.filtered_issues().len();\\n223:         if len > 0 && self.selected < len - 1 {\\n224:             self.selected += 1;\\n225:         }\\n226:     }\\n227: \\n228:     pub fn move_up(&mut self) {\\n229:         if self.selected > 0 {\\n230:             self.selected -= 1;\\n231:         }\\n232:     }\\n233: \\n234:     pub fn top(&mut self) {\\n235:         self.selected = 0;\\n236:     }\\n237: \\n238:     pub fn bottom(&mut self) {\\n239:         let len = self.filtered_issues().len();\\n240:         if len > 0 {\\n241:             self.selected = len - 1;\\n242:         }\\n243:     }\\n244: \\n245:     pub 