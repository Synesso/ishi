{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"toolu_vrtx_016NqeH1bWrgqVV4xT5W6vtF","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/amp/mod.rs\",\"content\":\"1: pub mod state;\\n2: pub mod thread;\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01DBbguCb7qcNVq8Whh1cfiM","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/amp/thread.rs\",\"content\":\"1: use anyhow::Result;\\n2: use serde::Deserialize;\\n3: use std::path::{Path, PathBuf};\\n4: \\n5: #[derive(Debug, Deserialize)]\\n6: struct RawThread {\\n7:     id: String,\\n8:     created: u64,\\n9:     title: Option<String>,\\n10:     #[serde(default)]\\n11:     messages: Vec<serde_json::Value>,\\n12:     #[serde(rename = \\\"usageLedger\\\")]\\n13:     usage_ledger: Option<UsageLedger>,\\n14: }\\n15: \\n16: #[derive(Debug, Deserialize)]\\n17: struct UsageLedger {\\n18:     #[serde(default)]\\n19:     events: Vec<LedgerEvent>,\\n20: }\\n21: \\n22: #[derive(Debug, Deserialize)]\\n23: struct LedgerEvent {\\n24:     timestamp: String,\\n25: }\\n26: \\n27: /// Summary of an Amp thread for display in the TUI.\\n28: #[derive(Debug, Clone, PartialEq)]\\n29: pub struct ThreadSummary {\\n30:     pub id: String,\\n31:     pub title: String,\\n32:     pub message_count: usize,\\n33:     /// Milliseconds since Unix epoch of last activity (or creation time).\\n34:     pub last_activity_ms: u64,\\n35: }\\n36: \\n37: impl ThreadSummary {\\n38:     pub fn relative_time(&self) -> String {\\n39:         let now_ms = std::time::SystemTime::now()\\n40:             .duration_since(std::time::UNIX_EPOCH)\\n41:             .map(|d| d.as_millis() as u64)\\n42:             .unwrap_or(0);\\n43:         format_relative_time(now_ms, self.last_activity_ms)\\n44:     }\\n45: }\\n46: \\n47: pub fn format_relative_time(now_ms: u64, then_ms: u64) -> String {\\n48:     let diff_secs = now_ms.saturating_sub(then_ms) / 1000;\\n49: \\n50:     if diff_secs < 60 {\\n51:         format!(\\\"{}s ago\\\", diff_secs)\\n52:     } else if diff_secs < 3600 {\\n53:         format!(\\\"{}m ago\\\", diff_secs / 60)\\n54:     } else if diff_secs < 86400 {\\n55:         format!(\\\"{}h ago\\\", diff_secs / 3600)\\n56:     } else {\\n57:         format!(\\\"{}d ago\\\", diff_secs / 86400)\\n58:     }\\n59: }\\n60: \\n61: /// Returns the default directory where Amp stores thread files.\\n62: pub fn amp_threads_dir() -> Option<PathBuf> {\\n63:     dirs::data_dir().map(|d| d.join(\\\"amp\\\").join(\\\"threads\\\"))\\n64: }\\n65: \\n66: /// Read a thread file and produce a summary.\\n67: pub fn read_thread_summary(path: &Path) -> Result<ThreadSummary> {\\n68:     let contents = std::fs::read_to_string(path)?;\\n69:     parse_thread_summary(&contents)\\n70: }\\n71: \\n72: /// Parse a thread JSON string into a summary.\\n73: pub fn parse_thread_summary(json: &str) -> Result<ThreadSummary> {\\n74:     let raw: RawThread = serde_json::from_str(json)?;\\n75: \\n76:     let title = raw\\n77:         .title\\n78:         .unwrap_or_else(|| \\\"Untitled thread\\\".to_string());\\n79: \\n80:     let message_count = raw.messages.len();\\n81: \\n82:     // Last activity: latest usage ledger event timestamp, or creation time.\\n83:     let last_activity_ms = raw\\n84:         .usage_ledger\\n85:         .and_then(|ledger| {\\n86:             ledger.events.last().and_then(|e| {\\n87:                 chrono_parse_to_ms(&e.timestamp)\\n88:             })\\n89:         })\\n90:         .unwrap_or(raw.created);\\n91: \\n92:     Ok(ThreadSummary {\\n93:         id: raw.id,\\n94:         title,\\n95:         message_count,\\n96:         last_activity_ms,\\n97:     })\\n98: }\\n99: \\n100: /// Parse an ISO-8601 timestamp string to milliseconds since epoch.\\n101: /// Uses manual parsing to avoid adding a chrono dependency.\\n102: fn chrono_parse_to_ms(s: &str) -> Option<u64> {\\n103:     // Expected format: \\\"2025-12-28T21:21:59.052Z\\\"\\n104:     // We'll use a simple parse approach\\n105:     let s = s.trim_end_matches('Z');\\n106:     let (date_part, time_part) = s.split_once('T')?;\\n107: \\n108:     let mut date_iter = date_part.split('-');\\n109:     let year: i64 = date_iter.next()?.parse().ok()?;\\n110:     let month: u32 = date_iter.next()?.parse().ok()?;\\n111:     let day: u32 = date_iter.next()?.parse().ok()?;\\n112: \\n113:     let (time_main, millis) = if let Some((t, ms)) = time_part.split_once('.') {\\n114:         let ms_val: u64 = ms.parse().ok()?;\\n115:         (t, ms_val)\\n116:     } else {\\n117:         (time_part, 0u64)\\n118:     };\\n119: \\n120:     let mut time_iter = time_main.split(':');\\n121:     let hour: u32 = time_iter.next()?.parse().ok()?;\\n122:     let min: u32 = time_iter.next()?.parse().ok()?;\\n123:     let sec: u32 = time_iter.next()?.parse().ok()?;\\n124: \\n125:     // Days from epoch (1970-01-01) using a simplified calculation\\n126:     let days = days_from_epoch(year, month, day)?;\\n127:     let total_secs = (days as u64) * 86400 + (hour as u64) * 3600 + (min as u64) * 60 + (sec as u64);\\n128:     Some(total_secs * 1000 + millis)\\n129: }\\n130: \\n131: fn days_from_epoch(year: i64, month: u32, day: u32) -> Option<i64> {\\n132:     // Adjust for months <= 2 (treat Jan/Feb as months 13/14 of previous year)\\n133:     let (y, m) = if month <= 2 {\\n134:         (year - 1, month + 12)\\n135:     } else {\\n136:         (year, month)\\n137:     };\\n138: \\n139:     let era = if y >= 0 { y } else { y - 399 } / 400;\\n140:     let yoe = (y - era * 400) as u32;\\n141:     let doy = (153 * (m - 3) + 2) / 5 + day - 1;\\n142:     let doe = yoe * 365 + yoe / 4 - yoe / 100 + doy;\\n143:     let days = era * 146097 + doe as i64 - 719468;\\n144:     Some(days)\\n145: }\\n146: \\n147: /// Load thread summaries for a list of thread IDs from the given threads directory.\\n148: pub fn load_thread_summaries(\\n149:     threads_dir: &Path,\\n150:     thread_ids: &[String],\\n151: ) -> Vec<ThreadSummary> {\\n152:     thread_ids\\n153:         .iter()\\n154:         .filter_map(|id| {\\n155:             let path = threads_dir.join(format!(\\\"{}.json\\\", id));\\n156:             read_thread_summary(&path).ok()\\n157:         })\\n158:         .collect()\\n159: }\\n160: \\n161: #[cfg(test)]\\n162: mod tests {\\n163:     use super::*;\\n164: \\n165:     #[test]\\n166:     fn parse_minimal_thread() {\\n167:         let json = r#\\\"{\\n168:             \\\"v\\\": 0,\\n169:             \\\"id\\\": \\\"T-abc-123\\\",\\n170:             \\\"created\\\": 1700000000000,\\n171:             \\\"messages\\\": []\\n172:         }\\\"#;\\n173:         let summary = parse_thread_summary(json).unwrap();\\n174:         assert_eq!(summary.id, \\\"T-abc-123\\\");\\n175:         assert_eq!(summary.title, \\\"Untitled thread\\\");\\n176:         assert_eq!(summary.message_count, 0);\\n177:         assert_eq!(summary.last_activity_ms, 1700000000000);\\n178:     }\\n179: \\n180:     #[test]\\n181:     fn parse_thread_with_title_and_messages() {\\n182:         let json = r#\\\"{\\n183:             \\\"v\\\": 0,\\n184:             \\\"id\\\": \\\"T-def-456\\\",\\n185:             \\\"created\\\": 1700000000000,\\n186:             \\\"title\\\": \\\"Fix the bug\\\",\\n187:             \\\"messages\\\": [{\\\"role\\\": \\\"user\\\"}, {\\\"role\\\": \\\"assistant\\\"}, {\\\"role\\\": \\\"user\\\"}]\\n188:         }\\\"#;\\n189:         let summary = parse_thread_summary(json).unwrap();\\n190:         assert_eq!(summary.title, \\\"Fix the bug\\\");\\n191:         assert_eq!(summary.message_count, 3);\\n192:     }\\n193: \\n194:     #[test]\\n195:     fn parse_thread_with_usage_ledger() {\\n196:         let json = r#\\\"{\\n197:             \\\"v\\\": 0,\\n198:             \\\"id\\\": \\\"T-ghi-789\\\",\\n199:             \\\"created\\\": 1700000000000,\\n200:             \\\"messages\\\": [{\\\"role\\\": \\\"user\\\"}],\\n201:             \\\"usageLedger\\\": {\\n202:                 \\\"events\\\": [\\n203:                     {\\\"timestamp\\\": \\\"2025-12-28T21:17:52.900Z\\\"},\\n204:                     {\\\"timestamp\\\": \\\"2025-12-28T21:21:59.052Z\\\"}\\n205:                 ]\\n206:             }\\n207:         }\\\"#;\\n208:         let summary = parse_thread_summary(json).unwrap();\\n209:         assert!(summary.last_activity_ms > 1700000000000);\\n210:         // 2025-12-28T21:21:59.052Z\\n211:         assert_eq!(summary.last_activity_ms, 1766956919052);\\n212:     }\\n213: \\n214:     #[test]\\n215:     fn format_relative_time_seconds() {\\n216:         assert_eq!(format_relative_time(1000_000, 1000_000), \\\"0s ago\\\");\\n217:         assert_eq!(format_relative_time(1030_000, 1000_000), \\\"30s ago\\\");\\n218:     }\\n219: \\n220:     #[test]\\n221:     fn format_relative_time_minutes() {\\n222:         assert_eq!(format_relative_time(1000_000 + 120_000, 1000_000), \\\"2m ago\\\");\\n223:         assert_eq!(format_relative_time(1000_000 + 420_000, 1000_000), \\\"7m ago\\\");\\n224:     }\\n225: \\n226:     #[test]\\n227:     fn format_relative_time_hours() {\\n228:         let two_hours = 2 * 3600 * 1000;\\n229:         assert_eq!(format_relative_time(1000_000 + two_hours, 1000_000), \\\"2h ago\\\");\\n230:     }\\n231: \\n232:     #[test]\\n233:     fn format_relative_time_days() {\\n234:         let three_days = 3 * 86400 * 1000;\\n235:         assert_eq!(format_relative_time(1000_000 + three_days, 1000_000), \\\"3d ago\\\");\\n236:     }\\n237: \\n238:     #[test]\\n239:     fn chrono_parse_known_timestamp() {\\n240:         let ms = chrono_parse_to_ms(\\\"2025-12-28T21:21:59.052Z\\\").unwrap();\\n241:         assert_eq!(ms, 1766956919052);\\n242:     }\\n243: \\n244:     #[test]\\n245:     fn chrono_parse_no_millis() {\\n246:         let ms = chrono_parse_to_ms(\\\"2025-01-01T00:00:00Z\\\").unwrap();\\n247:         // 2025-01-01 = day 20089 from epoch\\n248:         assert_eq!(ms, 1735689600000);\\n249:     }\\n250: \\n251:     #[test]\\n252:     fn load_thread_summaries_from_dir() {\\n253:         let dir = tempfile::tempdir().unwrap();\\n254:         let thread_json = r#\\\"{\\n255:             \\\"v\\\": 0,\\n256:             \\\"id\\\": \\\"T-test-1\\\",\\n257:             \\\"created\\\": 1700000000000,\\n258:             \\\"title\\\": \\\"Test thread\\\",\\n259:             \\\"messages\\\": [{\\\"role\\\": \\\"user\\\"}]\\n260:         }\\\"#;\\n261:         std::fs::write(dir.path().join(\\\"T-test-1.json\\\"), thread_json).unwrap();\\n262: \\n263:         let summaries = load_thread_summaries(dir.path(), &[\\\"T-test-1\\\".to_string()]);\\n264:         assert_eq!(summaries.len(), 1);\\n265:         assert_eq!(summaries[0].title, \\\"Test thread\\\");\\n266:     }\\n267: \\n268:     #[test]\\n269:     fn load_thread_summaries_skips_missing_files() {\\n270:         let dir = tempfile::tempdir().unwrap();\\n271:         let summaries = load_thread_summaries(\\n272:             dir.path(),\\n273:             &[\\\"T-nonexistent\\\".to_string()],\\n274:         );\\n275:         assert!(summaries.is_empty());\\n276:     }\\n277: \\n278:     #[test]\\n279:     fn thread_summary_relative_time_is_nonempty() {\\n280:         let summary = ThreadSummary {\\n281:             id: \\\"T-test\\\".to_string(),\\n282:             title: \\\"Test\\\".to_string(),\\n283:             message_count: 1,\\n284:             last_activity_ms: 1700000000000,\\n285:         };\\n286:         let relative = summary.relative_time();\\n287:         assert!(!relative.is_empty());\\n288:         assert!(relative.ends_with(\\\" ago\\\"));\\n289:     }\\n290: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01VhSA77YpVNXD7yinxcqPM9","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/amp/state.rs\",\"content\":\"1: use anyhow::Result;\\n2: use serde::{Deserialize, Serialize};\\n3: use std::collections::HashMap;\\n4: use std::path::{Path, PathBuf};\\n5: \\n6: /// A thread's link to a Linear issue and the workspace it was started in.\\n7: #[derive(Debug, Serialize, Deserialize, Clone, PartialEq)]\\n8: pub struct ThreadLink {\\n9:     pub issue: String,\\n10:     pub workspace: String,\\n11: }\\n12: \\n13: /// Persistent state for ishi, stored at `~/.config/ishi/state.toml`.\\n14: ///\\n15: /// Two data structures:\\n16: /// * **Thread links** — maps thread ID → issue identifier + workspace path.\\n17: ///   One issue can have many threads, but each thread belongs to exactly one issue.\\n18: /// * **Workspace history** — ordered list of previously used directory paths,\\n19: ///   most recent first.\\n20: #[derive(Debug, Serialize, Deserialize, Default, Clone, PartialEq)]\\n21: pub struct State {\\n22:     /// thread ID → link (issue identifier + workspace path)\\n23:     #[serde(default)]\\n24:     pub thread_links: HashMap<String, ThreadLink>,\\n25: \\n26:     /// Ordered list of workspace directory paths, most recent first.\\n27:     #[serde(default)]\\n28:     pub workspace_history: Vec<String>,\\n29: }\\n30: \\n31: #[allow(dead_code)]\\n32: impl State {\\n33:     /// Load state from a TOML file, returning default if the file does not exist.\\n34:     pub fn load(path: &Path) -> Result<Self> {\\n35:         if !path.exists() {\\n36:             return Ok(Self::default());\\n37:         }\\n38:         let contents = std::fs::read_to_string(path)?;\\n39:         let state: State = toml::from_str(&contents)?;\\n40:         Ok(state)\\n41:     }\\n42: \\n43:     /// Save state to a TOML file, creating parent directories as needed.\\n44:     pub fn save(&self, path: &Path) -> Result<()> {\\n45:         if let Some(parent) = path.parent() {\\n46:             std::fs::create_dir_all(parent)?;\\n47:         }\\n48:         let contents = toml::to_string_pretty(self)?;\\n49:         std::fs::write(path, contents)?;\\n50:         Ok(())\\n51:     }\\n52: \\n53:     /// Record a thread link: thread ID → issue identifier + workspace path.\\n54:     /// If the thread already exists, it is updated.\\n55:     pub fn add_thread_link(&mut self, thread_id: &str, issue: &str, workspace: &str) {\\n56:         self.thread_links.insert(\\n57:             thread_id.to_string(),\\n58:             ThreadLink {\\n59:                 issue: issue.to_string(),\\n60:                 workspace: workspace.to_string(),\\n61:             },\\n62:         );\\n63:     }\\n64: \\n65:     /// Return all thread IDs linked to the given issue identifier.\\n66:     pub fn threads_for_issue(&self, issue_identifier: &str) -> Vec<&str> {\\n67:         let mut ids: Vec<&str> = self\\n68:             .thread_links\\n69:             .iter()\\n70:             .filter(|(_, link)| link.issue == issue_identifier)\\n71:             .map(|(id, _)| id.as_str())\\n72:             .collect();\\n73:         ids.sort();\\n74:         ids\\n75:     }\\n76: \\n77:     /// Look up the workspace directory for a given thread ID.\\n78:     pub fn workspace_for(&self, thread_id: &str) -> Option<&str> {\\n79:         self.thread_links\\n80:             .get(thread_id)\\n81:             .map(|link| link.workspace.as_str())\\n82:     }\\n83: \\n84:     /// Add a workspace directory to the front of the history.\\n85:     /// If it already appears, it is moved to the front.\\n86:     pub fn add_workspace(&mut self, workspace: &str) {\\n87:         self.workspace_history\\n88:             .retain(|w| w != workspace);\\n89:         self.workspace_history.insert(0, workspace.to_string());\\n90:     }\\n91: \\n92:     /// Return the ordered workspace history (most recent first).\\n93:     pub fn workspaces(&self) -> &[String] {\\n94:         &self.workspace_history\\n95:     }\\n96: }\\n97: \\n98: /// Return the default state file path: `~/.config/ishi/state.toml`.\\n99: pub fn state_path() -> Result<PathBuf> {\\n100:     let dir = dirs::config_dir()\\n101:         .ok_or_else(|| anyhow::anyhow!(\\\"could not determine config directory\\\"))?\\n102:         .join(\\\"ishi\\\");\\n103:     std::fs::create_dir_all(&dir)?;\\n104:     Ok(dir.join(\\\"state.toml\\\"))\\n105: }\\n106: \\n107: #[cfg(test)]\\n108: mod tests {\\n109:     use super::*;\\n110: \\n111:     #[test]\\n112:     fn load_missing_file_returns_default() {\\n113:         let dir = tempfile::tempdir().unwrap();\\n114:         let path = dir.path().join(\\\"nonexistent.toml\\\");\\n115:         let state = State::load(&path).unwrap();\\n116:         assert!(state.thread_links.is_empty());\\n117:         assert!(state.workspace_history.is_empty());\\n118:     }\\n119: \\n120:     #[test]\\n121:     fn save_and_load_round_trip() {\\n122:         let dir = tempfile::tempdir().unwrap();\\n123:         let path = dir.path().join(\\\"state.toml\\\");\\n124: \\n125:         let mut state = State::default();\\n126:         state.add_thread_link(\\\"T-abc-123\\\", \\\"JEM-1\\\", \\\"/home/user/project-a\\\");\\n127:         state.add_thread_link(\\\"T-def-456\\\", \\\"JEM-1\\\", \\\"/home/user/project-a\\\");\\n128:         state.add_thread_link(\\\"T-ghi-789\\\", \\\"JEM-2\\\", \\\"/home/user/project-b\\\");\\n129:         state.add_workspace(\\\"/home/user/project-a\\\");\\n130:         state.add_workspace(\\\"/home/user/project-b\\\");\\n131: \\n132:         state.save(&path).unwrap();\\n133: \\n134:         let loaded = State::load(&path).unwrap();\\n135:         assert_eq!(loaded, state);\\n136:     }\\n137: \\n138:     #[test]\\n139:     fn threads_for_issue_unknown_returns_empty() {\\n140:         let state = State::default();\\n141:         assert!(state.threads_for_issue(\\\"JEM-999\\\").is_empty());\\n142:     }\\n143: \\n144:     #[test]\\n145:     fn threads_for_issue_returns_matching_threads() {\\n146:         let mut state = State::default();\\n147:         state.add_thread_link(\\\"T-abc\\\", \\\"JEM-1\\\", \\\"/ws\\\");\\n148:         state.add_thread_link(\\\"T-def\\\", \\\"JEM-1\\\", \\\"/ws\\\");\\n149:         state.add_thread_link(\\\"T-ghi\\\", \\\"JEM-2\\\", \\\"/ws\\\");\\n150: \\n151:         let threads = state.threads_for_issue(\\\"JEM-1\\\");\\n152:         assert_eq!(threads.len(), 2);\\n153:         assert!(threads.contains(&\\\"T-abc\\\"));\\n154:         assert!(threads.contains(&\\\"T-def\\\"));\\n155:     }\\n156: \\n157:     #[test]\\n158:     fn add_thread_link_overwrites_existing() {\\n159:         let mut state = State::default();\\n160:         state.add_thread_link(\\\"T-abc\\\", \\\"JEM-1\\\", \\\"/old/path\\\");\\n161:         state.add_thread_link(\\\"T-abc\\\", \\\"JEM-1\\\", \\\"/new/path\\\");\\n162: \\n163:         assert_eq!(state.thread_links.len(), 1);\\n164:         assert_eq!(state.workspace_for(\\\"T-abc\\\"), Some(\\\"/new/path\\\"));\\n165:     }\\n166: \\n167:     #[test]\\n168:     fn workspace_for_unknown_thread_returns_none() {\\n169:         let state = State::default();\\n170:         assert!(state.workspace_for(\\\"T-unknown\\\").is_none());\\n171:     }\\n172: \\n173:     #[test]\\n174:     fn workspace_for_known_thread() {\\n175:         let mut state = State::default();\\n176:         state.add_thread_link(\\\"T-abc\\\", \\\"JEM-1\\\", \\\"/home/user/project\\\");\\n177:         assert_eq!(state.workspace_for(\\\"T-abc\\\"), Some(\\\"/home/user/project\\\"));\\n178:     }\\n179: \\n180:     #[test]\\n181:     fn add_workspace_inserts_at_front() {\\n182:         let mut state = State::default();\\n183:         state.add_workspace(\\\"/first\\\");\\n184:         state.add_workspace(\\\"/second\\\");\\n185:         assert_eq!(state.workspaces(), &[\\\"/second\\\", \\\"/first\\\"]);\\n186:     }\\n187: \\n188:     #[test]\\n189:     fn add_workspace_deduplicates_and_moves_to_front() {\\n190:         let mut state = State::default();\\n191:         state.add_workspace(\\\"/a\\\");\\n192:         state.add_workspace(\\\"/b\\\");\\n193:         state.add_workspace(\\\"/a\\\");\\n194:         assert_eq!(state.workspaces(), &[\\\"/a\\