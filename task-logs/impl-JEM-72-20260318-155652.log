  let header = Row::new(vec![\\n25:         Cell::from(\\\"ID\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n26:         Cell::from(\\\"Title\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n27:         Cell::from(\\\"Project\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n28:         Cell::from(\\\"Status\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n29:         Cell::from(\\\"Priority\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n30:     ]);\\n31: \\n32:     let search_query = app.search.as_deref();\\n33: \\n34:     let rows: Vec<Row> = issues\\n35:         .iter()\\n36:         .map(|issue| {\\n37:             Row::new(vec![\\n38:                 Cell::from(Line::from(highlight_match(issue.identifier.as_str(), search_query, Style::default()))),\\n39:                 Cell::from(Line::from(highlight_match(issue.title.as_str(), search_query, Style::default()))),\\n40:                 Cell::from(Line::from(highlight_match(issue.project_str(), search_query, Style::default()))),\\n41:                 Cell::from(Line::from(highlight_match(issue.status_str(), search_query, status_style(issue.status_str())))),\\n42:                 Cell::from(Line::from(highlight_match(issue.priority_str(), search_query, priority_style(issue.priority_str())))),\\n43:             ])\\n44:         })\\n45:         .collect();\\n46: \\n47:     let sort_indicator = match &app.sort {\\n48:         Some((col, dir)) => {\\n49:             let arrow = match dir {\\n50:                 SortDirection::Asc => \\\"↑\\\",\\n51:                 SortDirection::Desc => \\\"↓\\\",\\n52:             };\\n53:             format!(\\\" [sort: {} {}]\\\", col.label(), arrow)\\n54:         }\\n55:         None => String::new(),\\n56:     };\\n57: \\n58:     let search_indicator = match &app.search {\\n59:         Some(q) => format!(\\\" [search: {}]\\\", q),\\n60:         None => String::new(),\\n61:     };\\n62: \\n63:     let title = match &app.filter {\\n64:         Some((col, f)) => format!(\\\"My Issues ({} of {}){}{} [filter: {} = {}]\\\", issues.len(), app.issues.len(), sort_indicator, search_indicator, col.label(), f),\\n65:         None => format!(\\\"My Issues ({}){}{}\\\", issues.len(), sort_indicator, search_indicator),\\n66:     };\\n67: \\n68:     let table = Table::new(\\n69:         rows,\\n70:         [\\n71:             Constraint::Length(10),\\n72:             Constraint::Min(30),\\n73:             Constraint::Length(20),\\n74:             Constraint::Length(15),\\n75:             Constraint::Length(10),\\n76:         ],\\n77:     )\\n78:     .header(header)\\n79:     .block(Block::default().borders(Borders::ALL).title(title))\\n80:     .row_highlight_style(Style::default().add_modifier(Modifier::REVERSED));\\n81: \\n82:     let mut table_state = TableState::default();\\n83:     if !issues.is_empty() {\\n84:         table_state.select(Some(app.selected));\\n85:     }\\n86: \\n87:     frame.render_stateful_widget(table, chunks[0], &mut table_state);\\n88: \\n89:     let key_style = Style::default().fg(Color::Yellow).add_modifier(Modifier::BOLD);\\n90: \\n91:     let column_hints = vec![\\n92:         Span::styled(\\\"i\\\", key_style),\\n93:         Span::raw(\\\"d  \\\"),\\n94:         Span::styled(\\\"t\\\", key_style),\\n95:         Span::raw(\\\"itle  \\\"),\\n96:         Span::styled(\\\"p\\\", key_style),\\n97:         Span::raw(\\\"roject  \\\"),\\n98:         Span::styled(\\\"s\\\", key_style),\\n99:         Span::raw(\\\"tatus  p\\\"),\\n100:         Span::styled(\\\"r\\\", key_style),\\n101:         Span::raw(\\\"iority\\\"),\\n102:     ];\\n103: \\n104:     // Status bar\\n105:     if app.refreshing {\\n106:         let line = Line::from(Span::styled(\\n107:             \\\"Refreshing...\\\",\\n108:             Style::default().fg(Color::Yellow),\\n109:         ));\\n110:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n111:     } else if app.awaiting_quit {\\n