\\n278:                 }\\n279:             } else if app.filtering {\\n280:                 match key.code {\\n281:                     KeyCode::Enter => app.apply_filter(),\\n282:                     KeyCode::Esc => app.cancel_filter(),\\n283:                     KeyCode::Backspace => {\\n284:                         app.filter_input.pop();\\n285:                     }\\n286:                     KeyCode::Char(c) => {\\n287:                         app.filter_input.push(c);\\n288:                     }\\n289:                     _ => {}\\n290:                 }\\n291:             } else if matches!(app.view, app::View::ProjectList) {\\n292:                 if let Some(action) = keys::map_key(key) {\\n293:                     match action {\\n294:                         keys::Action::Quit => app.awaiting_quit = true,\\n295:                         keys::Action::MoveDown => app.project_move_down(),\\n296:                         keys::Action::MoveUp => app.project_move_up(),\\n297:                         keys::Action::Top => app.project_top(),\\n298:                         keys::Action::Bottom => app.project_bottom(),\\n299:                         keys::Action::Select => {\\n300:                             app.select_project();\\n301:                             app.load_project_issues().await;\\n302:                         }\\n303:                         keys::Action::Back => app.switch_to_my_issues(),\\n304:                         keys::Action::Refresh => app.refresh_projects().await,\\n305:                         keys::Action::Help => app.toggle_help(),\\n306:                         keys::Action::OpenIn => {\\n307:                             if let Some(url) = app.selected_project_url() {\\n308:                                 let _ = std::process::Command::new(\\\"open\\\")\\n309:                                     .arg(&url)\\n310:                                     .spawn();\\n311:                             }\\n312:                         }\\n3