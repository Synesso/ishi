onstraint::Min(0), Constraint::Length(1)]).split(area)\\n21:     } else {\\n22:         Layout::vertical([Constraint::Min(0)]).split(area)\\n23:     };\\n24: \\n25:     let header = Row::new(vec![\\n26:         Cell::from(\\\"ID\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n27:         Cell::from(\\\"Title\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n28:         Cell::from(\\\"Status\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n29:         Cell::from(\\\"Priority\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n30:         Cell::from(\\\"Assignee\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n31:     ]);\\n32: \\n33:     let rows: Vec<Row> = app\\n34:         .project_issues\\n35:         .iter()\\n36:         .map(|issue| {\\n37:             Row::new(vec![\\n38:                 Cell::from(issue.identifier.as_str()),\\n39:                 Cell::from(issue.title.as_str()),\\n40:                 Cell::from(Span::styled(\\n41:                     issue.status_str(),\\n42:                     status_style(issue.status_str()),\\n43:                 )),\\n44:                 Cell::from(Span::styled(\\n45:                     issue.priority_str(),\\n46:                     priority_style(issue.priority_str()),\\n47:                 )),\\n48:                 Cell::from(\\n49:                     issue\\n50:                         .assignee\\n51:                         .as_ref()\\n52:                         .map_or(\\\"—\\\", |a| a.name.as_str()),\\n53:                 ),\\n54:             ])\\n55:         })\\n56:         .collect();\\n57: \\n58:     let title = format!(\\\"{} — Issues ({})\\\", project_name, app.project_issues.len());\\n59: \\n60:     let table = Table::new(\\n61:         rows,\\n62:         [\\n63:             Constraint::Length(10),\\n64:             Constraint::Min(30),\\n65:             Constraint::Length(15),\\n66:             Constraint::Length(10),\\n67:             Constraint::Length(20),\\n68:         ],\\n69:     )\\n70:     .header(header)\\n71:     .block(Block::default().borders(Borders::ALL).title(title))\\n72:     .row_highlight_style(Style::default().add_modifier(Modifier::REVERSED));\\n73: \\n74:     let mut table_state = TableState::default();\\n75:     if !app.project_issues.is_empty() {\\n76:         table_state.select(Some(app.project_issue_selected));\\n77:     }\\n78: \\n79:     frame.render_stateful_widget(table, chunks[0], &mut table_state);\\n80: \\n81:     let key_style = Style::default()\\n82:         .fg(Color::Yellow)\\n83:         .add_modifier(Modifier::BOLD);\\n84: \\n85:     if show_bar {\\n86:         if app.refreshing {\\n87:             let line = Line::from(Span::styled(\\n88:                 \\\"Refreshing...\\\",\\n89:                 Style::default().fg(Color::Yellow),\\n90:             ));\\n91:             frame.render_widget(Paragraph::new(line), chunks[1]);\\n92:         } else if app.awaiting_quit {\\n93:             let line = Line::from(vec![\\n94:                 Span::raw(\\\"Press \\\"),\\n95:                 Span::styled(\\\"q\\\", key_style),\\n96:                 Span::raw(\\\" again to quit\\\"),\\n97:             ]);\\n98:             frame.render_widget(Paragraph::new(line), chunks[1]);\\n99:         }\\n100:     }\\n101: }\\n102: \\n103: fn status_style(status: &str) -> Style {\\n104:     match status {\\n105:         \\\"In Progress\\\" => Style::default().fg(Color::Yellow),\\n106:         \\\"Todo\\\" => Style::default().fg(Color::Cyan),\\n107:         \\\"Done\\\" => Style::default().fg(Color::Green),\\n108:         \\\"Canceled\\\" | \\\"Cancelled\\\" => Style::default().fg(Color::DarkGray),\\n109:         \\\"In Review\\\" => Style::default().fg(Color::Magenta),\\n110:         \\\"Backlog\\\" | \\\"Triage\\\" => Style::default().fg(Color::DarkGray),\\n111:         _ => Style::default(),\\n112:     }\\n113: }\\n114: \\n115: fn priority_style(priority: &str) -> Style {\\n116:     match priority {\\n117:         \\\"Urgent\\\" => Style::default()\\n118:             .fg(Color::Red)\\n119:             .add_modifier(Modifier::BOLD),\\n120:         \\\"High\\\" => Style::default().fg(Color::Red),\\n121:         \\\"Medium\\\" => Style::default().fg(Color::Yellow),\\n122:         \\\"Low\\\" => Style::default().fg(Color::DarkGray),\\n123:         _ => Style::default(),\\n124:     }\\n125: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01XtWmDGZaHYPUd52koCtDyT","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/views/detail.rs\",\"content\":\"1: use ratatui::{\\n2:     layout::{Constraint, Layout, Rect},\\n3:     style::{Color, Modifier, Style},\\n4:     text::{Line, Span},\\n5:     widgets::{Block, Borders, Clear, Paragraph, Wrap},\\n6:     Frame,\\n7: };\\n8: \\n9: use crate::api::client::LinearApi;\\n10: use crate::app::{App, DetailSection};\\n11: \\n12: pub fn render<A: LinearApi>(frame: &mut Frame, area: Rect, app: &mut App<A>) {\\n13:     let issue = match app.selected_issue() {\\n14:         Some(i) => i,\\n15:         None => {\\n16:             frame.render_widget(Paragraph::new(\\\"No issue selected\\\"), area);\\n17:             return;\\n18:         }\\n19:     };\\n20: \\n21:     // Metadata fields\\n22:     let label_style = Style::default().fg(Color::DarkGray);\\n23: \\n24:     let mut meta_lines: Vec<Line> = Vec::new();\\n25: \\n26:     meta_lines.push(Line::from(vec![\\n27:         Span::styled(\\\"Status:   \\\", label_style),\\n28:         Span::styled(issue.status_str(), status_style(issue.status_str())),\\n29:     ]));\\n30: \\n31:     meta_lines.push(Line::from(vec![\\n32:         Span::styled(\\\"Priority: \\\", label_style),\\n33:         Span::styled(issue.priority_str(), priority_style(issue.priority_str())),\\n34:     ]));\\n35: \\n36:     meta_lines.push(Line::from(vec![\\n37:         Span::styled(\\\"Project:  \\\", label_style),\\n38:         Span::raw(issue.project_str()),\\n39:     ]));\\n40: \\n41:     let assignee = issue\\n42:         .assignee\\n43:         .as_ref()\\n44:         .map_or(\\\"—\\\", |a| a.name.as_str());\\n45:     meta_lines.push(Line::from(vec![\\n46:         Span::styled(\\\"Assignee: \\\", label_style),\\n47:         Span::raw(assignee),\\n48:     ]));\\n49: \\n50:     let labels_str = issue\\n51:         .labels\\n52:         .as_ref()\\n53:         .map(|l| {\\n54:             l.nodes\\n55:                 .iter()\\n56:                 .map(|l| l.name.as_str())\\n57:                 .collect::<Vec<_>>()\\n58:                 .join(\\\", \\\")\\n59:         })\\n60:         .unwrap_or_default();\\n61:     if !labels_str.is_empty() {\\n62:         meta_lines.push(Line::from(vec![\\n63:             Span::styled(\\\"Labels:   \\\", label_style),\\n64:             Span::raw(labels_str),\\n65:         ]));\\n66:     }\\n67: \\n68:     // +2 for the border top/bottom\\n69:     let meta_height = (meta_lines.len() as u16) + 2;\\n70: \\n71:     // Calculate thread section height\\n72:     let thread_count = app.detail_threads.len();\\n73:     let threads_height = if thread_count > 0 {\\n74:         // header border (1) + each thread line (1 each) + bottom border (1)\\n75:         (thread_count as u16) + 2\\n76:     } else {\\n77:         0\\n78:     };\\n79: \\n80:     let chunks = Layout::vertical([\\n81:         Constraint::Length(meta_height),\\n82:         Constraint::Min(0),\\n83:         Constraint::Length(threads_height),\\n84:         Constraint::Length(1),\\n85:     ])\\n86:     .split(area);\\n87: \\n88:     // Metadata box\\n89:     let title = Line::from(vec![\\n90:         Span::styled(\\n91:             issue.identifier.to_string(),\\n92:             Style::default().fg(Color::Green).add_modifier(Modifier::BOLD),\\n93:         ),\\n94:         Span::raw(format!(\\\" — {}\\\", issue.title)),\\n95:     ]);\\n96:     let meta = Paragraph::new(meta_lines)\\n97:         .block(Block::default().borders(Borders::ALL).title(title));\\n98:     frame.render_widget(meta, chunks[0]);\\n99: \\n100:     // Description / Comments\\n101:     let mut body_lines: Vec<Line> = Vec::new();\\n102: \\n103:     if let Some(desc) = &issue.description {\\n104:         for line in desc.lines() {\\n105:             body_lines.push(Line::raw(line.to_string()));\\n106:         }\\n107:     }\\n108: \\n109:     // Comments\\n110:     if let Some(comments) = &issue.comments\\n111:         && !comments.nodes.is_empty()\\n112:     {\\n113:         if !body_lines.is_empty() {\\n114:             body_lines.push(Line::raw(\\\"\\\"));\\n115:         }\\n116:         body_lines.push(Line::from(Span::styled(\\n117:             format!(\\\"Comments ({})\\\", comments.nodes.len()),\\n118:             Style::default().add_modifier(Modifier::BOLD | Modifier::UNDERLINED),\\n119:         )));\\n120:         body_lines.push(Line::raw(\\\"\\\"));\\n121: \\n122:         for comment in &comments.nodes {\\n123:             let author = comment\\n124:                 .user\\n125:                 .as_ref()\\n126:                 .map_or(\\\"Unknown\\\", |u| u.name.as_str());\\n127:             body_lines.push(Line::from(vec![\\n128:                 Span::styled(\\n129:                     author,\\n130:                     Style::default().fg(Color::Yellow).add_modifier(Modifier::BOLD),\\n131:                 ),\\n132:                 Span::styled(\\n133:                     format!(\\\"  {}\\\", &comment.created_at[..10]),\\n134:                     Style::default().fg(Color::DarkGray),\\n135:                 ),\\n136:             ]));\\n137:             for line in comment.body.lines() {\\n138:                 body_lines.push(Line::raw(format!(\\\"  {}\\\", line)));\\n139:             }\\n140:             body_lines.push(Line::raw(\\\"\\\"));\\n141:         }\\n142:     }\\n143: \\n144:     let content_lines = body_lines.len() as u16;\\n145:     let inner_height = chunks[1].height.saturating_sub(2); // borders\\n146:     let scroll = app.detail_scroll;\\n147: \\n148:     let body_focused = app.detail_section == DetailSection::Body;\\n149:     let body_border_style = if body_focused {\\n150:         Style::default().fg(Color::Cyan)\\n151:     } else {\\n152:         Style::default().fg(Color::DarkGray)\\n153:     };\\n154: \\n155:     let detail = Paragraph::new(body_lines)\\n156:         .block(\\n157:             Block::default()\\n158:                 .borders(Borders::ALL)\\n159:                 .title(\\\"Description\\\")\\n160:                 .border_style(body_border_style),\\n161:         )\\n162:         .wrap(Wrap { trim: false })\\n163:         .scroll((scroll, 0));\\n164: \\n165:     frame.render_widget(detail, chunks[1]);\\n166: \\n167:     app.detail_scroll_max = content_lines.saturating_sub(inner_height);\\n168: \\n169:     // Threads section\\n170:     if thread_count > 0 {\\n171:         let threads_focused = app.detail_section == DetailSection::Threads;\\n172:         let threads_border_style = if threads_focused {\\n173:             Style::default().fg(Color::Cyan)\\n174:         } else {\\n175:             Style::default().fg(Color::DarkGray)\\n176:         };\\n177: \\n178:         let thread_lines: Vec<Line> = app\\n179:             .detail_threads\\n180:             .iter()\\n181:             .enumerate()\\n182:             .map(|(i, t)| {\\n183:                 let is_selected = threads_focused && i == app.detail_thread_selected;\\n184:                 let style = if is_selected {\\n185:                     Style::default().add_modifier(Modifier::REVERSED)\\n186:                 } else {\\n187:                     Style::default()\\n188:                 };\\n189:                 let time_str = t.relative_time();\\n190:                 Line::from(vec![\\n191:                     Span::styled(\\n192:                         format!(\\\"  {} \\\", t.title),\\n193:                         style,\\n194:                     ),\\n195:                     Span::styled(\\n196:                         format!(\\\"({} msgs) \\\", t.message_count),\\n197:                         style.fg(Color::DarkGray),\\n198:                     ),\\n199:                     Span::styled(\\n200:                         time_str,\\n201:                         style.fg(Color::DarkGray),\\n202:                     ),\\n203:                 ])\\n204:             })\\n205:             .collect();\\n206: \\n207:         let threads_block = Paragraph::new(thread_lines).block(\\n208:             Block::default()\\n209:                 .borders(Borders::ALL)\\n210:                 .title(format!(\\\"Threads ({})\\\", thread_count))\\n211:                 .border_style(threads_border_style),\\n212:         );\\n213:         frame.render_widget(threads_block, chunks[2]);\\n214:     }\\n215: \\n216:     // Status bar\\n217:     let key_style = Style::default().fg(Color::Yellow).add_modifier(Modifier::BOLD);\\n218:     let bar = if app.awaiting_quit {\\n219:         Line::from(vec![\\n220:             Span::raw(\\\"Press \\\"),\\n221:             Span::styled(\\\"q\\\", key_style),\\n222:             Span::raw(\\\" again to quit\\\"),\\n223:         ])\\n224:     } else if app.awaiting_open {\\n225:         Line::from(vec![\\n226:             Span::raw(\\\"open in: \\\"),\\n227:             Span::styled(\\\"l\\\", key_style),\\n228:             Span::raw(\\\"inear  \\\"),\\n229:             Span::styled(\\\"g\\\", key_style),\\n230:             Span::raw(\\\"ithub PR\\\"),\\n231:         ])\\n232:     } else if app.detail_section == DetailSection::Threads {\\n233:         Line::from(vec![\\n234:             Span::styled(\\\"Esc\\\", key_style),\\n235:             Span::raw(\\\" back  \\\"),\\n236:             Span::styled(\\\"j\\\", key_style),\\n237:             Span::raw(\\\"/\\\"),\\n238:             Span::styled(\\\"k\\\", key_style),\\n239:             Span::raw(\\\" navigate  \\\"),\\n240:             Span::styled(\\\"Enter\\\", key_style),\\n241:             Span::raw(\\\" continue  \\\"),\\n242:             Span::styled(\\\"a\\\", key_style),\\n243:             Span::raw(\\\" new thread\\\"),\\n244:         ])\\n245:     } else {\\n246:         let mut spans = vec![\\n247:             Span::styled(\\\"Esc\\\", key_style),\\n248:             Span::raw(\\\" back  \\\"),\\n249:             Span::styled(\\\"j\\\", key_style),\\n250:             Span::raw(\\\"/\\\"),\\n251:             Span::styled(\\\"k\\\", key_style),\\n252:             Span::raw(\\\" scroll\\\"),\\n253:         ];\\n254:         if !app.detail_threads.is_empty() {\\n255:             spans.push(Span::raw(\\\"  \\\"));\\n256:             spans.push(Span::styled(\\\"Tab\\\", key_style));\\n257:             spans.push(Span::raw(\\\" threads\\\"));\\n258:         }\\n259:         spans.push(Span::raw(\\\"  \\\"));\\n260:         spans.push(Span::styled(\\\"a\\\", key_style));\\n261:         spans.push(Span::raw(\\\" new thread\\\"));\\n262:         Line::from(spans)\\n263:     };\\n264:     frame.render_widget(Paragraph::new(bar), chunks[3]);\\n265: \\n266:     // Workspace picker modal\\n267:     if let Some(ref picker) = app.workspace_picker {\\n268:         // Extra line for the input row when typing, or the hint row\\n269:         let extra_lines: u16 = 1;\\n270:         let content_lines = picker.options.len() as u16 + extra_lines;\\n271:         let picker_height = (content_lines + 2).min(area.height.saturating_sub(4));\\n272:         let picker_width = picker\\n273:             .options\\n274:             .iter()\\n275:             .map(|s| s.len() as u16)\\n276:             .max()\\n277:             .unwrap_or(20)\\n278:             .max(20)\\n279:             + 4;\\n280:         let picker_width = picker_width.min(area.width.saturating_sub(4));\\n281: \\n282:         let x = area.x + (area.width.saturating_sub(picker_width)) / 2;\\n283:         let y = area.y + (area.height.saturating_sub(picker_height)) / 2;\\n284:         let popup_area = Rect::new(x, y, picker_width, picker_height);\\n285: \\n286:         frame.render_widget(Clear, popup_area);\\n287: \\n288:         let mut lines: Vec<Line> = picker\\n289:             .options\\n290:             .iter()\\n291:             .enumerate()\\n292:             .map(|(i, ws)| {\\n293:                 let style = if !picker.typing && i == picker.selected {\\n294:                     Style::default().add_modifier(Modifier::REVERSED)\\n295:                 } else {\\n296:                     Style::default()\\n297:                 };\\n298:                 Line::from(Span::styled(format!(\\\" {} \\\", ws), style))\\n299:             })\\n300:             .collect();\\n301: \\n302:         if picker.typing {\\n303:             lines.push(Line::from(vec![\\n304:                 Span::raw(\\\" /\\\"),\\n305:                 Span::styled(&picker.input, Style::default().add_modifier(Modifier::BOLD)),\\n306:                 Span::raw(\\\"▏\\\"),\\n307:             ]));\\n308:         } else {\\n309:             let key_style = Style::default().fg(Color::DarkGray);\\n310:             lines.push(Line::from(Span::styled(\\\" / to type a path\\\", key_style)));\\n311:         }\\n312: \\n313:         let popup = Paragraph::new(lines).block(\\n314:             Block::default()\\n315:                 .borders(Borders::ALL)\\n316:                 .title(\\\"Select workspace\\\")\\n317:                 .border_style(Style::default().fg(Color::Cyan)),\\n318:         );\\n319:         frame.render_widget(popup, popup_area);\\n320:     }\\n321: }\\n322: \\n323: fn status_style(status: &str) -> Style {\\n324:     match status {\\n325:         \\\"In Progress\\\" => Style::default().fg(Color::Yellow),\\n326:         \\\"Todo\\\" => Style::default().fg(Color::Cyan),\\n327:         \\\"Done\\\" => Style::default().fg(Color::Green),\\n328:         \\\"Canceled\\\" | \\\"Cancelled\\\" => Style::default().fg(Color::DarkGray),\\n329:         \\\"In Review\\\" => Style::default().fg(Color::Magenta),\\n330:         \\\"Backlog\\\" | \\\"Triage\\\" => Style::default().fg(Color::DarkGray),\\n331:         _ => Style::default(),\\n332:     }\\n333: }\\n334: \\n335: fn priority_style(priority: &str) -> Style {\\n336:     match priority {\\n337:         \\\"Urgent\\\" => Style::default().fg(Color::Red).add_modifier(Modifier::BOLD),\\n338:         \\\"High\\\" => Style::default().fg(Color::Red),\\n339:         \\\"Medium\\\" => Style::default().fg(Color::Yellow),\\n340:         \\\"Low\\\" => Style::default().fg(Color::DarkGray),\\n341:         _ => Style::default(),\\n342:     }\\n343: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_019sJaxehX9W9rjpxHirJHxE","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/views/mod.rs\",\"content\":\"1: pub mod my_issues;\\n2: pub mod project;\\n3: pub mod project_list;\\n4: pub mod detail;\\n5: pub mod help;\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01NxRtDGhiy4jqr66tQq4JZi","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/api/types.rs\",\"content\":\"1: use serde::Deserialize;\\n2: \\n3: #[derive(Debug, Deserialize, Clone)]\\n4: pub struct Issue {\\n5:     #[allow(dead_code)]\\n6:     pub id: String,\\n7:     pub identifier: String,\\n8:     pub title: String,\\n9:     pub url: Option<String>,\\n10:     pub state: Option<IssueState>,\\n11:     pub priority: Option<f64>,\\n12:     pub project: Option<IssueProject>,\\n13:     pub description: Option<String>,\\n14:     pub assignee: Option<IssueUser>,\\n15:     pub labels: Option<IssueLabels>,\\n16:     pub comments: Option<IssueComments>,\\n17: }\\n18: \\n19: #[derive(Debug, Deserialize, Clone)]\\n20: pub struct IssueProject {\\n21:     pub name: String,\\n22: }\\n23: \\n24: #[derive(Debug, Deserialize, Clone)]\\n25: pub struct IssueUser {\\n26:     pub name: String,\\n27: }\\n28: \\n29: #[derive(Debug, Deserialize, Clone)]\\n30: pub struct IssueLabel {\\n31:     pub name: String,\\n32: }\\n33: \\n34: #[derive(Debug, Deserialize, Clone)]\\n35: pub struct IssueLabels {\\n36:     pub nodes: Vec<IssueLabel>,\\n37: }\\n38: \\n39: #[derive(Debug, Deserialize, Clone)]\\n40: pub struct IssueComment {\\n41:     pub body: String,\\n42:     pub user: Option<IssueUser>,\\n43:     #[serde(rename = \\\"createdAt\\\")]\\n44:     pub created_at: String,\\n45: }\\n46: \\n47: #[derive(Debug, Deserialize, Clone)]\\n48: pub struct IssueComments {\\n49:     pub nodes: Vec<IssueComment>,\\n50: }\\n51: \\n52: impl Issue {\\n53:     pub fn status_str(&self) -> &str {\\n54:         self.state.as_ref().map_or(\\\"—\\\", |s| s.name.as_str())\\n55:     }\\n56: \\n57:     pub fn project_str(&self) -> &str {\\n58:         self.project.as_ref().map_or(\\\"—\\\", |p| p.name.as_str())\\n59:     }\\n60: \\n61:     pub fn priority_str(&self) -> &str {\\n62:         match self.priority.map(|p| p as u8) {\\n63:             Some(1) => \\\"Urgent\\\",\\n64:             Some(2) => \\\"High\\\",\\n65:             Some(3) => \\\"Medium\\\",\\n66:             Some(4) => \\\"Low\\\",\\n67:             _ => \\\"—\\\",\\n68:         }\\n69:     }\\n70: \\n71:     pub fn matches_search(&self, query: &str) -> bool {\\n72:         self.identifier.to_lowercase().contains(query)\\n73:             || self.title.to_lowercase().contains(query)\\n74:             || self.project_str().to_lowercase().contains(query)\\n75:             || self.status_str().to_lowercase().contains(query)\\n76:             || self.priority_str().to_lowercase().contains(query)\\n77:     }\\n78: }\\n79: \\n80: #[derive(Debug, Deserialize, Clone)]\\n81: pub struct IssueState {\\n82:     pub name: String,\\n83: }\\n84: \\n85: #[allow(dead_code)]\\n86: #[derive(Debug, Deserialize)]\\n87: pub struct IssueConnection {\\n88:     pub nodes: Vec<Issue>,\\n89: }\\n90: \\n91: #[allow(dead_code)]\\n92: #[derive(Debug, Deserialize)]\\n93: pub struct IssuesData {\\n94:     pub issues: IssueConnection,\\n95: }\\n96: \\n97: #[allow(dead_code)]\\n98: #[derive(Debug, Deserialize)]\\n99: pub struct ViewerIssuesResponse {\\n100:     pub data: IssuesData,\\n101: }\\n102: \\n103: #[derive(Debug, Deserialize, Clone)]\\n104: pub struct Project {\\n105:     pub id: String,\\n106:     pub name: String,\\n107:     pub state: Option<String>,\\n108:     pub progress: Option<f64>,\\n109:     pub lead: Option<IssueUser>,\\n110:     pub url: Option<String>,\\n111: }\\n112: \\n113: impl Project {\\n114:     pub fn status_str(&self) -> &str {\\n115:         self.state.as_deref().unwrap_or(\\\"—\\\")\\n116:     }\\n117: \\n118:     pub fn lead_str(&self) -> &str {\\n119:         self.lead.as_ref().map_or(\\\"—\\\", |l| l.name.as_str())\\n120:     }\\n121: \\n122:     pub fn progress_percent(&self) -> String {\\n123:         match self.progress {\\n124:             Some(p) => format!(\\\"{:.0}%\\\", p * 100.0),\\n125:             None => \\\"—\\\".into(),\\n126:         }\\n127:     }\\n128: }\\n129: \\n130: #[cfg(test)]\\n131: mod tests {\\n132:     use super::*;\\n133: \\n134:     #[test]\\n135:     fn deserialize_issue_with_state() {\\n136:         let json = r#\\\"{\\n137:             \\\"id\\\": \\\"abc-123\\\",\\n138:             \\\"identifier\\\": \\\"JEM-1\\\",\\n139:             \\\"title\\\": \\\"Test issue\\\",\\n140:             \\\"state\\\": { \\\"name\\\": \\\"In Progress\\\" },\\n141:             \\\"priority\\\": 2.0\\n142:         }\\\"#;\\n143:         let issue: Issue = serde_json::from_str(json).unwrap();\\n144:         assert_eq!(issue.identifier, \\\"JEM-1\\\");\\n145:         assert_eq!(issue.title, \\\"Test issue\\\");\\n146:         assert_eq!(issue.state.unwrap().name, \\\"In Progress\\\");\\n147:         assert_eq!(issue.priority.unwrap(), 2.0);\\n148:     }\\n149: \\n150:     #[test]\\n151:     fn deserialize_issue_without_optional_fields() {\\n152:         let json = r#\\\"{\\n153:             \\\"id\\\": \\\"abc-456\\\",\\n154:             \\\"identifier\\\": \\\"JEM-2\\\",\\n155:             \\\"title\\\": \\\"Minimal issue\\\"\\n156:         }\\\"#;\\n157:         let issue: Issue = serde_json::from_str(json).unwrap();\\n158:         assert_eq!(issue.identifier, \\\"JEM-2\\\");\\n159:         assert!(issue.state.is_none());\\n160:         assert!(issue.priority.is_none());\\n161:     }\\n162: \\n163:     #[test]\\n164:     fn deserialize_project() {\\n165:         let json = r#\\\"{\\n166:             \\\"id\\\": \\\"proj-1\\\",\\n167:             \\\"name\\\": \\\"My Project\\\",\\n168:             \\\"state\\\": \\\"started\\\",\\n169:             \\\"progress\\\": 0.75,\\n170:             \\\"lead\\\": { \\\"name\\\": \\\"Alice\\\" },\\n171:             \\\"url\\\": \\\"https://linear.app/test/project/my-project\\\"\\n172:         }\\\"#;\\n173:         let project: Project = serde_json::from_str(json).unwrap();\\n174:         assert_eq!(project.name, \\\"My Project\\\");\\n175:         assert_eq!(project.status_str(), \\\"started\\\");\\n176:         assert_eq!(project.lead_str(), \\\"Alice\\\");\\n177:         assert_eq!(project.progress_percent(), \\\"75%\\\");\\n178:     }\\n179: \\n180:     #[test]\\n181:     fn deserialize_project_without_optional_fields() {\\n182:         let json = r#\\\"{\\n183:             \\\"id\\\": \\\"proj-2\\\",\\n184:             \\\"name\\\": \\\"Minimal Project\\\"\\n185:         }\\\"#;\\n186:         let project: Project = serde_json::from_str(json).unwrap();\\n187:         assert_eq!(project.name, \\\"Minimal Project\\\");\\n188:         assert_eq!(project.status_str(), \\\"—\\\");\\n189:         assert_eq!(project.lead_str(), \\\"—\\\");\\n190:         assert_eq!(project.progress_percent(), \\\"—\\\");\\n191:     }\\n192: \\n193:     #[test]\\n194:     fn project_progress_percent_rounds() {\\n195:         let project = Project {\\n196:             id: \\\"p\\\".into(),\\n197:             name: \\\"P\\\".into(),\\n198:             state: None,\\n199:             progress: Some(0.333),\\n200:             lead: None,\\n201:             url: None,\\n202:         };\\n203:         assert_eq!(project.progress_percent(), \\\"33%\\\");\\n204:     }\\n205: \\n206:     #[test]\\n207:     fn deserialize_projects_from_fixture() {\\n208:         let fixture = include_str!(\\\"../../tests/fixtures/projects.json\\\");\\n209:         let value: serde_json::Value = serde_json::from_str(fixture).unwrap();\\n210:         let nodes = &value[\\\"data\\\"][\\\"projects\\\"][\\\"nodes\\\"];\\n211:         let projects: Vec<Project> = serde_json::from_value(nodes.clone()).unwrap();\\n212:         assert_eq!(projects.len(), 2);\\n213:         assert_eq!(projects[0].name, \\\"Alpha Project\\\");\\n214:         assert_eq!(projects[1].name, \\\"Beta Project\\\");\\n215:     }\\n216: \\n217:     #[test]\\n218:     fn deserialize_issues_from_fixture() {\\n219:         let fixture = include_str!(\\\"../../tests/fixtures/my_issues.json\\\");\\n220:         let value: serde_json::Value = serde_json::from_str(fixture).unwrap();\\n221:         let nodes = &value[\\\"data\\\"][\\\"issues\\\"][\\\"nodes\\\"];\\n222:         let issues: Vec<Issue> = serde_json::from_value(nodes.clone()).unwrap();\\n223:         assert_eq!(issues.len(), 2);\\n224:         assert_eq!(issues[0].identifier, \\\"JEM-1\\\");\\n225:         assert_eq!(issues[1].identifier, \\\"JEM-2\\\");\\n226:     }\\n227: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01C15sMXPwBo9j12rxNwZy97","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/api/client.rs\",\"content\":\"1: use anyhow::Result;\\n2: use reqwest::Client;\\n3: use serde_json::Value;\\n4: \\n5: use super::types::{Issue, Project};\\n6: \\n7: const LINEAR_API_URL: &str = \\\"https://api.linear.app/graphql\\\";\\n8: \\n9: const ISSUE_PR_QUERY: &str = r#\\\"\\n10: query($issueId: String!) {\\n11:   issue(id: $issueId) {\\n12:     attachments {\\n13:       nodes {\\n14:         url\\n15:         sourceType\\n16:       }\\n17:     }\\n18:   }\\n19: }\\n20: \\\"#;\\n21: \\n22: const MY_ISSUES_QUERY: &str = r#\\\"\\n23: query {\\n24:   viewer {\\n25:     assignedIssues(\\n26:       first: 50\\n27:       filter: { state: { type: { nin: [\\\"completed\\\", \\\"canceled\\\"] } } }\\n28:       orderBy: updatedAt\\n29:     ) {\\n30:       nodes {\\n31:         id\\n32:         identifier\\n33:         title\\n34:         url\\n35:         state { name }\\n36:         priority\\n37:         project { name }\\n38:         description\\n39:         assignee { name }\\n40:         labels { nodes { name } }\\n41:         comments { nodes { body user { name } createdAt } }\\n42:       }\\n43:     }\\n44:   }\\n45: }\\n46: \\\"#;\\n47: \\n48: const MY_PROJECTS_QUERY: &str = r#\\\"\\n49: query {\\n50:   viewer {\\n51:     teamMemberships {\\n52:       nodes {\\n53:         team {\\n54:           projects(\\n55:             first: 50\\n56:             filter: { state: { type: { nin: [\\\"completed\\\", \\\"canceled\\\"] } } }\\n57:             orderBy: updatedAt\\n58:           ) {\\n59:             nodes {\\n60:               id\\n61:               name\\n62:               state\\n63:               progress\\n64:               lead { name }\\n65:               url\\n66:             }\\n67:           }\\n68:         }\\n69:       }\\n70:     }\\n71:   }\\n72: }\\n73: \\\"#;\\n74: \\n75: const PROJECT_ISSUES_QUERY: &str = r#\\\"\\n76: query($projectId: String!) {\\n77:   project(id: $projectId) {\\n78:     issues(\\n79:       first: 50\\n80:       filter: { state: { type: { nin: [\\\"completed\\\", \\\"canceled\\\"] } } }\\n81:       orderBy: updatedAt\\n82:     ) {\\n83:       nodes {\\n84:         id\\n85:         identifier\\n86:         title\\n87:         url\\n88:         state { name }\\n89:         priority\\n90:         project { name }\\n91:         description\\n92:         assignee { name }\\n93:         labels { nodes { name } }\\n94:         comments { nodes { body user { name } createdAt } }\\n95:       }\\n96:     }\\n97:   }\\n98: }\\n99: \\\"#;\\n100: \\n101: pub trait LinearApi: Send + Sync {\\n102:     fn query(\\n103:         &self,\\n104:         query: &str,\\n105:         variables: Option<Value>,\\n106:     ) -> impl std::future::Future<Output = Result<Value>> + Send;\\n107: \\n108:     fn fetch_my_issues(\\n109:         &self,\\n110:     ) -> impl std::future::Future<Output = Result<Vec<Issue>>> + Send;\\n111: \\n112:     fn fetch_pull_request_url(\\n113:         &self,\\n114:         issue_id: &str,\\n115:     ) -> impl std::future::Future<Output = Result<Option<String>>> + Send;\\n116: \\n117:     fn fetch_projects(\\n118:         &self,\\n119:     ) -> impl std::future::Future<Output = Result<Vec<Project>>> + Send;\\n120: \\n121:     fn fetch_project_issues(\\n122:         &self,\\n123:         project_id: &str,\\n124:     ) -> impl std::future::Future<Output = Result<Vec<Issue>>> + Send;\\n125: }\\n126: \\n127: pub struct LinearClient {\\n128:     client: Client,\\n129:     api_key: [REDACTED:api-key],\\n130: }\\n131: \\n132: impl LinearClient {\\n133:     pub fn new(api_key: [REDACTED:api-key]) -> Self {\\n134:         Self {\\n135:             client: Client::new(),\\n136:             api_key,\\n137:         }\\n138:     }\\n139: }\\n140: \\n141: impl LinearApi for LinearClient {\\n142:     async fn query(&self, query: &str, variables: Option<Value>) -> Result<Value> {\\n143:         let mut body = serde_json::json!({ \\\"query\\\": query });\\n144:         if let Some(vars) = variables {\\n145:             body[\\\"variables\\\"] = vars;\\n146:         }\\n147: \\n148:         let resp = self\\n149:             .client\\n150:             .post(LINEAR_API_URL)\\n151:             .header(\\\"Authorization\\\", &self.api_key)\\n152:             .json(&body)\\n153:             .send()\\n154:             .await?\\n155:             .error_for_status()?\\n156:             .json::<Value>()\\n157:             .await?;\\n158: \\n159:         Ok(resp)\\n160:     }\\n161: \\n162:     async fn fetch_my_issues(&self) -> Result<Vec<Issue>> {\\n163:         let resp = self.query(MY_ISSUES_QUERY, None).await?;\\n164:         let issues: Vec<Issue> = serde_json::from_value(\\n165:             resp[\\\"data\\\"][\\\"viewer\\\"][\\\"assignedIssues\\\"][\\\"nodes\\\"].clone(),\\n166:         )?;\\n167:         Ok(issues)\\n168:     }\\n169: \\n170:     async fn fetch_pull_request_url(&self, issue_id: &str) -> Result<Option<String>> {\\n171:         let vars = serde_json::json!({ \\\"issueId\\\": issue_id });\\n172:         let resp = self.query(ISSUE_PR_QUERY, Some(vars)).await?;\\n173:         let nodes = &resp[\\\"data\\\"][\\\"issue\\\"][\\\"attachments\\\"][\\\"nodes\\\"];\\n174:         if let Some(arr) = nodes.as_array() {\\n175:             for node in arr {\\n176:                 if let Some(url) = node[\\\"url\\\"].as_str()\\n177:                     && url.contains(\\\"github.com\\\") && url.contains(\\\"/pull/\\\")\\n178:                 {\\n179:                     return Ok(Some(url.to_string()));\\n180:                 }\\n181:             }\\n182:         }\\n183:         Ok(None)\\n184:     }\\n185: \\n186:     async fn fetch_projects(&self) -> Result<Vec<Project>> {\\n187:         let resp = self.query(MY_PROJECTS_QUERY, None).await?;\\n188:         let mut projects: Vec<Project> = Vec::new();\\n189:         let mut seen_ids = std::collections::HashSet::new();\\n190:         if let Some(memberships) = resp[\\\"data\\\"][\\\"viewer\\\"][\\\"teamMemberships\\\"][\\\"nodes\\\"].as_array() {\\n191:             for membership in memberships {\\n192:                 if let Some(nodes) = membership[\\\"team\\\"][\\\"projects\\\"][\\\"nodes\\\"].as_array() {\\n193:                     for node in nodes {\\n194:                         if let Ok(project) = serde_json::from_value::<Project>(node.clone())\\n195:                             && seen_ids.insert(project.id.clone())\\n196:                         {\\n197:                             projects.push(project);\\n198:                         }\\n199:                     }\\n200:                 }\\n201:             }\\n202:         }\\n203:         Ok(projects)\\n204:     }\\n205: \\n206:     async fn fetch_project_issues(&self, project_id: &str) -> Result<Vec<Issue>> {\\n207:         let vars = serde_json::json!({ \\\"projectId\\\": project_id });\\n208:         let resp = self.query(PROJECT_ISSUES_QUERY, Some(vars)).await?;\\n209:         let issues: Vec<Issue> =\\n210:             serde_json::from_value(resp[\\\"data\\\"][\\\"project\\\"][\\\"issues\\\"][\\\"nodes\\\"].clone())?;\\n211:         Ok(issues)\\n212:     }\\n213: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01CL47YnKtgoH1FRKDTYayHt","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/api/fake.rs\",\"content\":\"1: use anyhow::Result;\\n2: use serde_json::Value;\\n3: use std::collections::VecDeque;\\n4: use std::sync::Mutex;\\n5: \\n6: use super::client::LinearApi;\\n7: use super::types::{Issue, Project};\\n8: \\n9: /// A fake Linear API client for tests and offline development.\\n10: /// Enqueue responses with `push_response`, and they'll be returned in order by `query`.\\n11: /// PR URL responses are enqueued separately with `push_pr_url`.\\n12: pub struct FakeLinearApi {\\n13:     responses: Mutex<VecDeque<Value>>,\\n14:     pr_urls: Mutex<VecDeque<Option<String>>>,\\n15: }\\n16: \\n17: impl FakeLinearApi {\\n18:     pub fn new() -> Self {\\n19:         Self {\\n20:             responses: Mutex::new(VecDeque::new()),\\n21:             pr_urls: Mutex::new(VecDeque::new()),\\n22:         }\\n23:     }\\n24: \\n25:     pub fn push_response(&self, response: Value) {\\n26:         self.responses.lock().unwrap().push_back(response);\\n27:     }\\n28: \\n29:     #[allow(dead_code)]\\n30:     pub fn push_pr_url(&self, url: Option<String>) {\\n31:         self.pr_urls.lock().unwrap().push_back(url);\\n32:     }\\n33: }\\n34: \\n35: impl LinearApi for FakeLinearApi {\\n36:     async fn query(&self, _query: &str, _variables: Option<Value>) -> Result<Value> {\\n37:         let response = self\\n38:             .responses\\n39:             .lock()\\n40:             .unwrap()\\n41:             .pop_front()\\n42:             .unwrap_or_else(|| serde_json::json!({\\\"data\\\": null}));\\n43:         Ok(response)\\n44:     }\\n45: \\n46:     async fn fetch_my_issues(&self) -> Result<Vec<Issue>> {\\n47:         let resp = self.query(\\\"\\\", None).await?;\\n48:         let nodes = &resp[\\\"data\\\"][\\\"issues\\\"][\\\"nodes\\\"];\\n49:         if nodes.is_null() {\\n50:             return Ok(vec![]);\\n51:         }\\n52:         let issues: Vec<Issue> = serde_json::from_value(nodes.clone())?;\\n53:         Ok(issues)\\n54:     }\\n55: \\n56:     async fn fetch_pull_request_url(&self, _issue_id: &str) -> Result<Option<String>> {\\n57:         Ok(self.pr_urls.lock().unwrap().pop_front().flatten())\\n58:     }\\n59: \\n60:     async fn fetch_projects(&self) -> Result<Vec<Project>> {\\n61:         let resp = self.query(\\\"\\\", None).await?;\\n62:         let nodes = &resp[\\\"data\\\"][\\\"projects\\\"][\\\"nodes\\\"];\\n63:         if nodes.is_null() {\\n64:             return Ok(vec![]);\\n65:         }\\n66:         let projects: Vec<Project> = serde_json::from_value(nodes.clone())?;\\n67:         Ok(projects)\\n68:     }\\n69: \\n70:     async fn fetch_project_issues(&self, _project_id: &str) -> Result<Vec<Issue>> {\\n71:         let resp = self.query(\\\"\\\", None).await?;\\n72:         let nodes = &resp[\\\"data\\\"][\\\"project\\\"][\\\"issues\\\"][\\\"nodes\\\"];\\n73:         if nodes.is_null() {\\n74:             return Ok(vec![]);\\n75:         }\\n76:         let issues: Vec<Issue> = serde_json::from_value(nodes.clone())?;\\n77:         Ok(issues)\\n78:     }\\n79: }\\n80: \\n81: #[cfg(test)]\\n82: mod tests {\\n83:     use super::*;\\n84: \\n85:     #[tokio::test]\\n86:     async fn returns_enqueued_responses_in_order() {\\n87:         let fake = FakeLinearApi::new();\\n88:         fake.push_response(serde_json::json!({\\\"data\\\": {\\\"first\\\": true}}));\\n89:         fake.push_response(serde_json::json!({\\\"data\\\": {\\\"second\\\": true}}));\\n90: \\n91:         let r1 = fake.query(\\\"q1\\\", None).await.unwrap();\\n92:         let r2 = fake.query(\\\"q2\\\", None).await.unwrap();\\n93: \\n94:         assert_eq!(r1[\\\"data\\\"][\\\"first\\\"], true);\\n95:         assert_eq!(r2[\\\"data\\\"][\\\"second\\\"], true);\\n96:     }\\n97: \\n98:     #[tokio::test]\\n99:     async fn returns_null_data_when_exhausted() {\\n100:         let fake = FakeLinearApi::new();\\n101:         let r = fake.query(\\\"q\\\", None).await.unwrap();\\n102:         assert!(r[\\\"data\\\"].is_null());\\n103:     }\\n104: \\n105:     #[tokio::test]\\n106:     async fn fetch_my_issues_from_fixture() {\\n107:         let fake = FakeLinearApi::new();\\n108:         let fixture: Value =\\n109:             serde_json::from_str(include_str!(\\\"../../tests/fixtures/my_issues.json\\\")).unwrap();\\n110:         fake.push_response(fixture);\\n111: \\n112:         let issues = fake.fetch_my_issues().await.unwrap();\\n113:         assert_eq!(issues.len(), 2);\\n114:         assert_eq!(issues[0].identifier, \\\"JEM-1\\\");\\n115:         assert_eq!(issues[1].identifier, \\\"JEM-2\\\");\\n116:     }\\n117: \\n118:     #[tokio::test]\\n119:     async fn fetch_my_issues_empty_when_no_data() {\\n120:         let fake = FakeLinearApi::new();\\n121:         let issues = fake.fetch_my_issues().await.unwrap();\\n122:         assert!(issues.is_empty());\\n123:     }\\n124: \\n125:     #[tokio::test]\\n126:     async fn fetch_pull_request_url_returns_enqueued_url() {\\n127:         let fake = FakeLinearApi::new();\\n128:         fake.push_pr_url(Some(\\\"https://github.com/org/repo/pull/42\\\".into()));\\n129: \\n130:         let url = fake.fetch_pull_request_url(\\\"issue-1\\\").await.unwrap();\\n131:         assert_eq!(url, Some(\\\"https://github.com/org/repo/pull/42\\\".into()));\\n132:     }\\n133: \\n134:     #[tokio::test]\\n135:     async fn fetch_pull_request_url_returns_none_when_empty() {\\n136:         let fake = FakeLinearApi::new();\\n137:         let url = fake.fetch_pull_request_url(\\\"issue-1\\\").await.unwrap();\\n138:         assert!(url.is_none());\\n139:     }\\n140: \\n141:     #[tokio::test]\\n142:     async fn fetch_projects_from_fixture() {\\n143:         let fake = FakeLinearApi::new();\\n144:         let fixture: Value =\\n145:             serde_json::from_str(include_str!(\\\"../../tests/fixtures/projects.json\\\")).unwrap();\\n146:         fake.push_response(fixture);\\n147: \\n148:         let projects = fake.fetch_projects().await.unwrap();\\n149:         assert_eq!(projects.len(), 2);\\n150:         assert_eq!(projects[0].name, \\\"Alpha Project\\\");\\n151:         assert_eq!(projects[1].name, \\\"Beta Project\\\");\\n152:     }\\n153: \\n154:     #[tokio::test]\\n155:     async fn fetch_projects_empty_when_no_data() {\\n156:         let fake = FakeLinearApi::new();\\n157:         let projects = fake.fetch_projects().await.unwrap();\\n158:         assert!(projects.is_empty());\\n159:     }\\n160: \\n161:     #[tokio::test]\\n162:     async fn fetch_project_issues_from_fixture() {\\n163:         let fake = FakeLinearApi::new();\\n164:         let fixture: Value =\\n165:             serde_json::from_str(include_str!(\\\"../../tests/fixtures/project_issues.json\\\")).unwrap();\\n166:         fake.push_response(fixture);\\n167: \\n168:         let issues = fake.fetch_project_issues(\\\"proj-1\\\").await.unwrap();\\n169:         assert_eq!(issues.len(), 2);\\n170:         assert_eq!(issues[0].identifier, \\\"JEM-10\\\");\\n171:     }\\n172: \\n173:     #[tokio::test]\\n174:     async fn fetch_project_issues_empty_when_no_data() {\\n175:         let fake = FakeLinearApi::new();\\n176:         let issues = fake.fetch_project_issues(\\\"proj-1\\\").await.unwrap();\\n177:         assert!(issues.is_empty());\\n178:     }\\n179: \\n180:     #[tokio::test]\\n181:     async fn fetch_pull_request_url_returns_none_explicitly() {\\n182:         let fake = FakeLinearApi::new();\\n183:         fake.push_pr_url(None);\\n184: \\n185:         let url = fake.fetch_pull_request_url(\\\"issue-1\\\").await.unwrap();\\n186:         assert!(url.is_none());\\n187:     }\\n188: }\"}","is_error":false}]},"parent_tool_use_id":null,"session_id":"T-019cff84-fd1e-7738-a45c-2a0f8dd421b5"}
