  if let Ok(issues) = self.api.fetch_my_issues().await {\\n542:             self.cache.insert(CACHE_KEY_MY_ISSUES, issues.clone());\\n543:             self.issues = issues;\\n544:             if let Some(id) = selected_id {\\n545:                 let new_index = self\\n546:                     .filtered_issues()\\n547:                     .iter()\\n548:                     .position(|i| i.identifier == id);\\n549:                 self.selected = new_index.unwrap_or(0);\\n550:             }\\n551:         }\\n552:     }\\n553: }\\n554: \\n555: #[cfg(test)]\\n556: mod tests {\\n557:     use super::*;\\n558:     use crate::api::fake::FakeLinearApi;\\n559: \\n560:     fn app_with_issues() -> App<FakeLinearApi> {\\n561:         let mut app = App::new(FakeLinearApi::new());\\n562:         app.issues = vec![\\n563:             Issue {\\n564:                 id: \\\"1\\\".into(),\\n565:                 identifier: \\\"JEM-1\\\".into(),\\n566:                 title: \\\"Alpha task\\\".into(),\\n567:                 url: Some(\\\"https://linear.app/test/issue/JEM-1\\\".into()),\\n568:                 state: None,\\n569:                 priority: Some(2.0),\\n570:                 project: None,\\n571:                 description: None,\\n572:                 assignee: None,\\n573:                 labels: None,\\n574:                 comments: None,\\n575:             },\\n576:             Issue {\\n577:                 id: \\\"2\\\".into(),\\n578:                 identifier: \\\"JEM-2\\\".into(),\\n579:                 title: \\\"Beta task\\\".into(),\\n580:                 url: Some(\\\"https://linear.app/test/issue/JEM-2\\\".into()),\\n581:                 state: None,\\n582:                 priority: Some(3.0),\\n583:                 project: None,\\n584:                 description: None,\\n585:                 assignee: None,\\n586:                 labels: None,\\n587:                 comments: None,\\n588:             },\\n589:             Issue {\\n590:                 id: \\\"3\\\".into(),\\n591:                 identifier: \\\"JEM-3\\\".into(),\\n592:                 title: \\\"Gamma task\\\".into(),\\n593:                 url: Some(\\\"https://linear.app/test/issue/JEM-3\\\".into()),\\n594:                 state: None,\\n595:                 priority: None,\\n596:                 project: None,\\n597:                 description: None,\\n598:                 assignee: None,\\n599:                 labels: None,\\n600:                 comments: None,\\n601:             },\\n602:         ];\\n603:         app\\n604:     }\\n605: \\n606:     #[test]\\n607:     fn navigation_wraps_at_bounds() {\\n608:         let mut app = app_with_issues();\\n609:         assert_eq!(app.selected, 0);\\n610: \\n611:         app.move_down();\\n612:         assert_eq!(app.selected, 1);\\n613:         app.move_down();\\n614:         assert_eq!(app.selected, 2);\\n615:         app.move_down(); // at bottom, stays\\n616:         assert_eq!(app.selected, 2);\\n617: \\n618:         app.move_up();\\n619:         assert_eq!(app.selected, 1);\\n620:         app.top();\\n621:         assert_eq!(app.selected, 0);\\n622:         app.move_up(); // at top, stays\\n623:         assert_eq!(app.selected, 0);\\n624:     }\\n625: \\n626:     #[test]\\n627:     fn bottom_goes_to_last() {\\n628:         let mut app = app_with_issues();\\n629:         app.bottom();\\n630:         assert_eq!(app.selected, 2);\\n631:     }\\n632: \\n633:     #[test]\\n634:     fn filter_narrows_results() {\\n635:         let mut app = app_with_issues();\\n636:         app.filter = Some((SortColumn::Title, \\\"beta\\\".into()));\\n637:         let filtered = app.filtered_issues();\\n638:         assert_eq!(filtered.len(), 1);\\n639:         assert_eq!(filtered[0].identifier, \\\"JEM-2\\\");\\n640:     }\\n641: \\n642:     #[test]\\n643:     fn filter_is_case_insensitive() {\\n644:         let mut app = app_with_issues();\\n645:         app.filter = Some((SortColumn::Title, \\\"ALPHA\\\".into()));\\n646:         assert_eq!(app.filtered_issues().len(), 1);\\n647:     }\\n648: \\n649:     #[test]\\n650:     fn apply_empty_filter_clears() {\\n651:         let mut app = app_with_issues();\\n652:         app.start_filter();\\n653:         app.apply_filter();\\n654:         assert!(app.filter.is_none());\\n655:         assert!(!app.filtering);\\n656:     }\\n657: \\n658:     #[test]\\n659:     fn apply_filter_sets_and_resets_cursor() {\\n660:         let mut app = app_with_issues();\\n661:         app.selected = 2;\\n662:         app.start_filter();\\n663:         app.filter_input = \\\"gamma\\\".into();\\n664:         app.apply_filter();\\n665:         assert_eq!(app.filter.as_ref().map(|(_, f)| f.as_str()), Some(\\\"gamma\\\"));\\n666:         assert_eq!(app.selected, 0);\\n667:     }\\n668: \\n669:     #[test]\\n670:     fn cancel_filter_discards_input() {\\n671:         let mut app = app_with_issues();\\n672:         app.start_filter();\\n673:         app.filter_input = \\\"something\\\".into();\\n674:         app.cancel_filter();\\n675:         assert!(!app.filtering);\\n676:         assert!(app.filter_input.is_empty());\\n677:     }\\n678: \\n679:     #[test]\\n680:     fn select_issue_enters_detail_view() {\\n681:         let mut app = app_with_issues();\\n682:         app.selected = 1;\\n683:         app.select_issue();\\n684:         assert!(matches!(app.view, View::Detail));\\n685:         assert_eq!(app.detail_scroll, 0);\\n686:     }\\n687: \\n688:     #[test]\\n689:     fn back_to_list_returns_to_my_issues() {\\n690:         let mut app = app_with_issues();\\n691:         app.select_issue();\\n692:         app.back_to_list();\\n693:         assert!(matches!(app.view, View::MyIssues));\\n694:     }\\n695: \\n696:     #[test]\\n697:     fn selected_issue_returns_correct_issue() {\\n698:         let mut app = app_with_issues();\\n699:         app.selected = 1;\\n700:         let issue = app.selected_issue().unwrap();\\n[... omitted lines 701 to 1602