52:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n153:     } else if app.search.is_some() || app.filter.is_some() {\\n154:         let line = Line::from(vec![\\n155:             Span::raw(\\\"Active — press Esc to clear\\\"),\\n156:         ]);\\n157:         frame.render_widget(Paragraph::new(line), chunks[1]);\\n158:     }\\n159: }\\n160: \\n161: fn highlight_match<'a>(text: &'a str, query: Option<&str>, base_style: Style) -> Vec<Span<'a>> {\\n162:     let query = match query {\\n163:         Some(q) if !q.is_empty() => q,\\n164:         _ => return vec![Span::styled(text, base_style)],\\n165:     };\\n166:     let lower_text = text.to_lowercase();\\n167:     let lower_query = query.to_lowercase();\\n168:     let mut spans = Vec::new();\\n169:     let mut start = 0;\\n170:     while let Some(pos) = lower_text[start..].find(&lower_query) {\\n171:         let abs_pos = start + pos;\\n172:         if abs_pos > start {\\n173:             spans.push(Span::styled(&text[start..abs_pos], base_style));\\n174:         }\\n175:         spans.push(Span::styled(\\n176:             &text[abs_pos..abs_pos + query.len()],\\n177:             base_style.add_modifier(Modifier::BOLD),\\n178:         ));\\n179:         start = abs_pos + query.len();\\n180:     }\\n181:     if start < text.len() {\\n182:         spans.push(Span::styled(&text[start..], base_style));\\n183:     }\\n184:     if spans.is_empty() {\\n185:         spans.push(Span::styled(text, base_style));\\n186:     }\\n187:     spans\\n188: }\\n189: \\n190: fn status_style(status: &str) -> Style {\\n191:     match status {\\n192:         \\\"In Progress\\\" => Style::default().fg(Color::Yellow),\\n193:         \\\"Todo\\\" => Style::default().fg(Color::Cyan),\\n194:         \\\"Done\\\" => Style::default().fg(Color::Green),\\n195:         \\\"Canceled\\\" | \\\"Cancelled\\\" => Style::default().fg(Color::DarkGray),\\n196:         \\\"In Review\\\" => Style::default().fg(Color::Magenta),\\n197:         \\\"Backlog\\\" | \\\"Triage\\\" => Style::default().fg(Color::DarkGray),\\n198:         _ => Style::default(),\\n199:     }\\n200: }\\n201: \\n202: fn priority_style(priority: &str) -> Style {\\n203:     match priority {\\n204:         \\\"Urgent\\\" => Style::default().fg(Color::Red).add_modifier(Modifier::BOLD),\\n205:         \\\"High\\\" => Style::default().fg(Color::Red),\\n206:         \\\"Medium\\\" => Style::default().fg(Color::Yellow),\\n207:         \\\"Low\\\" => Style::default().fg(Color::DarkGray),\\n208:         _ => Style::default(),\\n209:     }\\n210: }\"}","is_error":false},{"type":"tool_result","tool_use_id":"toolu_vrtx_01Y2aL1PpW84zyqWVz73zpm4","content":"{\"absolutePath\":\"/Users/jmawson/Development/sourcery/ishi/src/views/project_list.rs\",\"content\":\"1: use ratatui::{\\n2:     layout::{Constraint, Layout, Rect},\\n3:     style::{Color, Modifier, Style},\\n4:     text::{Line, Span},\\n5:     widgets::{Block, Borders, Cell, Paragraph, Row, Table, TableState},\\n6:     Frame,\\n7: };\\n8: \\n9: use crate::api::client::LinearApi;\\n10: use crate::app::App;\\n11: \\n12: pub fn render<A: LinearApi>(frame: &mut Frame, area: Rect, app: &App<A>) {\\n13:     let show_bar = app.refreshing || app.awaiting_quit;\\n14:     let chunks = if show_bar {\\n15:         Layout::vertical([Constraint::Min(0), Constraint::Length(1)]).split(area)\\n16:     } else {\\n17:         Layout::vertical([Constraint::Min(0)]).split(area)\\n18:     };\\n19: \\n20:     let header = Row::new(vec![\\n21:         Cell::from(\\\"Name\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n22:         Cell::from(\\\"Status\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n23:         Cell::from(\\\"Lead\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n24:         Cell::from(\\\"Progress\\\").style(Style::default().add_modifier(Modifier::BOLD)),\\n25:     ]);\\n26: \\n27:     let rows: Vec<Row> = app\\n28:         .projects\\n29:         .iter()\\n30:    