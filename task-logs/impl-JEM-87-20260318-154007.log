 }\\n23:         priority\\n24:         project { name }\\n25:         description\\n26:         assignee { name }\\n27:         labels { nodes { name } }\\n28:         comments { nodes { body user { name } createdAt } }\\n29:       }\\n30:     }\\n31:   }\\n32: }\\n33: \\\"#;\\n34: \\n35: pub trait LinearApi: Send + Sync {\\n36:     fn query(\\n37:         &self,\\n38:         query: &str,\\n39:         variables: Option<Value>,\\n40:     ) -> impl std::future::Future<Output = Result<Value>> + Send;\\n41: \\n42:     fn fetch_my_issues(\\n43:         &self,\\n44:     ) -> impl std::future::Future<Output = Result<Vec<Issue>>> + Send;\\n45: }\\n46: \\n47: pub struct LinearClient {\\n48:     client: Client,\\n49:     api_key: [REDACTED:api-key],\\n50: }\\n51: \\n52: impl LinearClient {\\n53:     pub fn new(api_key: [REDACTED:api-key]) -> Self {\\n54:         Self {\\n55:             client: Client::new(),\\n56:             api_key,\\n57:         }\\n58:     }\\n59: }\\n60: \\n61: impl LinearApi for LinearClient {\\n62:     async fn query(&self, query: &str, variables: Option<Value>) -> Result<Value> {\\n63:         let mut body = serde_json::json!({ \\\"query\\\": query });\\n64:         if let Some(vars) = variables {\\n65:             body[\\\"variables\\\"] = vars;\\n66:         }\\n67: \\n68:         let resp = self\\n69:             .client\\n70:             .post(LINEAR_API_URL)\\n71:             .header(\\\"Authorization\\\", &self.api_key)\\n72:             .json(&body)\\n73:             .send()\\n74:             .await?\\n75:             .error_for_status()?\\n76:             .json::<Value>()\\n77:             .await?;\\n78: \\n79:         Ok(resp)\\n80:     }\\n81: \\n82:     async fn fetch_my_issues(&self) -> Result<Vec<Issue>> {\\n83:         let resp = self.query(MY_ISSUES_QUERY, None).await?;\\n84:         let issues: Vec<Issue> = serde_json::from_value(\\n85:             resp[\\\"data\\\"][\\\"viewer\\\"][\\\"assignedIssues\\\"][\\\"nodes\\\"].clone(),\\